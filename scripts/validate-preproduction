markdown_files = (required_files.select { |path| path.end_with?(".md") } + ["README.md"]).uniq
markdown_files.each do |relative|
  text = read(relative)
  lines = text.lines
  in_fence = false
  table_pipe_count = nil

  lines.each_with_index do |line, index|
    line_number = index + 1
    error("#{relative}:#{line_number}: trailing whitespace") if line.match?(/[ \t]+\r?\n\z/)

    if line.match?(/^\s*```/)
      in_fence = !in_fence
      table_pipe_count = nil
      next
    end
    next if in_fence

    if line.start_with?("|")
      pipe_count = line.scan(/(?<!\\)\|/).length
      table_pipe_count ||= pipe_count
      if pipe_count != table_pipe_count
        error("#{relative}:#{line_number}: Markdown table has #{pipe_count} pipes; expected #{table_pipe_count}")
      end
    else
      table_pipe_count = nil
    end
  end
  error("#{relative}: unclosed fenced code block") if in_fence

  text.scan(/!?\[[^\]]*\]\(([^)]+)\)/).flatten.each do |raw_target|
    target = raw_target.strip
    target = target[1...-1] if target.start_with?("<") && target.end_with?(">")
    target = target.split(/\s+["']/).first
    next if target.empty? || target.start_with?("#")
    next if target.match?(/\A[a-z][a-z0-9+.-]*:/i)

    relative_target = URI::DEFAULT_PARSER.unescape(target.split("#", 2).first)
    resolved = ROOT.join(relative).dirname.join(relative_target).cleanpath
    error("#{relative}: broken internal link: #{target}") unless resolved.exist?
  end
end

