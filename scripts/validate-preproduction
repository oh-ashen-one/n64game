#!/usr/bin/env ruby
# frozen_string_literal: true

require "pathname"
require "uri"
require "open3"
require "date"
require "fileutils"
require "tmpdir"

ROOT = Pathname.new(__dir__).join("..").expand_path
ERRORS = []

def error(message)
  ERRORS << message
end

def read(relative)
  path = ROOT.join(relative)
  unless path.file?
    error("missing required file: #{relative}")
    return ""
  end
  path.read
end

GATE2_APPROVAL_TRANSITION_PATHS = %w[
  README.md
  docs/PRODUCTION_CHECKLIST.md
  docs/PREPRODUCTION_TRACEABILITY.md
].freeze

# These are the Gate 2 contract bytes audited by the two independent reviewers.
# They are immutable only across the reviewed-content -> approval transition.
# Later gates may legitimately revise them while the two historical commits keep
# the exact reviewed snapshot and its approval evidence permanently inspectable.
GATE2_REVIEWED_SNAPSHOT_PATHS = %w[
  LICENSE
  ASSET_LICENSE.md
  THIRD_PARTY_NOTICES.md
  docs/N64GAME_MASTER_SPEC.md
  docs/N64GAME_GOAL_PROMPT.md
  docs/reference-study.md
  docs/STORY_AND_TIMING.md
  docs/DIALOGUE_GRAPH.md
  docs/CONDITION_REGISTRY.md
  docs/TECHNICAL_ARCHITECTURE.md
  docs/DATA_SCHEMAS.md
  docs/ART_BIBLE.md
  docs/ASSET_INVENTORY.md
  docs/ASSET_REVIEW_TEMPLATES.md
  docs/ASSET_LEDGER.md
  docs/NAMING_AND_ORIGINALITY_AUDIT.md
  docs/VISUAL_BENCHMARK_APPROVAL.md
  data/ids/dialogue_once_bits.lock
  data/ids/examine_once_bits.lock
  data/ids/npc_once_bits.lock
  data/ids/spawn_ids.lock
  data/ids/cutscene_ids.lock
  data/ids/serialized_ids.lock
  scripts/validate-data-c
  scripts/validate-dialogue-graph
  scripts/validate-condition-registry
  scripts/validate-id-locks
  scripts/validate-asset-contract
  scripts/validate-public-hygiene
  scripts/validate-preproduction
].freeze

GATE2_APPROVAL_EVIDENCE_COMMANDS = [
  "scripts/validate-data-c",
  "scripts/validate-dialogue-graph",
  "scripts/validate-condition-registry",
  "scripts/validate-id-locks",
  "scripts/validate-asset-contract",
  "scripts/validate-public-hygiene",
  "scripts/validate-preproduction --reviewed-content"
].freeze

GENERIC_REVIEWER_COMPONENTS = %w[
  agent anonymous audit bot codex example generic identity name pending person
  reviewer root sample someone test testing tbd todo unknown user
].freeze

GATE2_REVIEWED_CONTENT_PLACEHOLDER_ERRORS = [
  "Gate 2 exit audit still has 37 unchecked item(s)",
  "Gate 2 approval record lacks exactly one full reviewed content commit",
  "Gate 2 approval record must contain exactly one reviewer-1 row and one reviewer-2 row",
  "Gate 2 approval record lacks exactly one ISO review date",
  "Gate 2 approval record must contain the exact ordered reviewed-SHA/command/result=PASS evidence rows",
  "Gate 2 approval record omits one exact Gate 3/Gate 4 deferred-measurement-risk row",
  "Gate 2 approval decision is not exactly one APPROVED row"
].freeze

def git_capture(root, *arguments)
  stdout, stderr, status = Open3.capture3(
    { "GIT_NO_REPLACE_OBJECTS" => "1" },
    "git", *arguments,
    chdir: root.to_s
  )
  [stdout, stderr, status.success?]
end

def committed_file(root, commit, relative)
  stdout, _stderr, success = git_capture(root, "show", "#{commit}:#{relative}")
  success ? stdout : nil
end

def committed_mode(root, commit, relative)
  stdout, _stderr, success = git_capture(root, "ls-tree", commit, "--", relative)
  return nil unless success

  match = stdout.match(/\A([0-9]{6})\s+blob\s+[0-9a-f]+\t/)
  match && match[1]
end

def heading_section(text, heading)
  match = text.match(/^#{Regexp.escape(heading)}[ \t]*\r?\n?/)
  return nil unless match

  body_start = match.end(0)
  next_heading = text.match(/^##\s+/, body_start)
  body_end = next_heading ? next_heading.begin(0) : text.length
  {
    heading_start: match.begin(0),
    body_start: body_start,
    body_end: body_end,
    body: text[body_start...body_end]
  }
end

def heading_count(text, heading)
  text.scan(/^#{Regexp.escape(heading)}[ \t]*\r?$/).length
end

def gate2_checkbox_marks(traceability)
  section = heading_section(traceability, "## Gate 2 exit audit")
  section ? section[:body].scan(/^- \[([ xX])\] /).flatten : []
end

def gate2_approval_record(traceability)
  section = heading_section(traceability, "## Gate 2 approval record")
  section && section[:body]
end

def normalized_gate2_traceability(traceability)
  audit = heading_section(traceability, "## Gate 2 exit audit")
  approval = heading_section(traceability, "## Gate 2 approval record")
  return nil unless audit && approval

  normalized = traceability.dup
  replacements = [
    [audit[:body_start], audit[:body_end], audit[:body].gsub(/^- \[[ xX]\] /, "- [?] ")],
    [approval[:body_start], approval[:body_end], "<GATE2_APPROVAL_RECORD>\n"]
  ]
  replacements.sort_by(&:first).reverse_each do |start_index, end_index, replacement|
    normalized[start_index...end_index] = replacement
  end
  normalized
end

def gate2_readme_status_line(readme)
  matches = readme.lines.select { |line| line.match?(/^\*\*Preproduction — Gate 2: .*\*\*[ \t]*\r?\n?$/) }
  matches.length == 1 ? matches.first.sub(/\r?\n\z/, "") : nil
end

def normalized_gate2_readme(readme)
  status_line = gate2_readme_status_line(readme)
  return nil unless status_line

  readme.sub(status_line, "**<GATE2_STATUS>**")
end

def gate2_checklist_row(checklist)
  matches = checklist.lines.select { |line| line.match?(/^\| 2\. Preproduction \|/) }
  matches.length == 1 ? matches.first.sub(/\r?\n\z/, "") : nil
end

def normalized_gate2_checklist(checklist)
  row = gate2_checklist_row(checklist)
  return nil unless row

  checklist.sub(row, "| <GATE2_CHECKLIST_ROW> |")
end

def canonical_reviewer_identity?(identity)
  suffix = if (match = identity.match(/\Agithub:([A-Za-z0-9](?:[A-Za-z0-9-]{0,38}))\z/))
             match[1]
           elsif (match = identity.match(%r{\Aagent:(/[a-z0-9][a-z0-9._/-]{2,127})\z}))
             match[1]
           end
  return false unless suffix

  components = suffix.downcase.split(/[^a-z0-9]+/).reject(&:empty?).map { |component| component.sub(/\d+\z/, "") }
  components.any? { |component| !component.empty? && !GENERIC_REVIEWER_COMPONENTS.include?(component) }
end

def commit_calendar_date(root, commit)
  stdout, _stderr, success = git_capture(root, "show", "-s", "--format=%cs", commit)
  return nil unless success && stdout.strip.match?(/\A\d{4}-\d{2}-\d{2}\z/)

  Date.iso8601(stdout.strip)
rescue Date::Error
  nil
end

def validate_gate2_record_fields(record, expected_reviewed_commit, errors, root: nil, approval_commit: nil,
                                 reviewed_date_override: nil, approval_date_override: nil)
  unless record
    errors << "Gate 2 approval record section is missing"
    return nil
  end

  reviewed_rows = record.scan(/^\| Reviewed content commit \| `([0-9a-f]{40})` \|$/).flatten
  errors << "Gate 2 approval record lacks exactly one full reviewed content commit" unless reviewed_rows.length == 1
  reviewed_commit = reviewed_rows.first
  if expected_reviewed_commit && reviewed_commit != expected_reviewed_commit
    errors << "Gate 2 approval record names #{reviewed_commit || 'no commit'}, expected #{expected_reviewed_commit}"
  end

  reviewer_1_rows = record.scan(/^\| Independent reviewer 1 \| `([^`]+)` \|$/).flatten
  reviewer_2_rows = record.scan(/^\| Independent reviewer 2 \| `([^`]+)` \|$/).flatten
  unless reviewer_1_rows.length == 1 && reviewer_2_rows.length == 1
    errors << "Gate 2 approval record must contain exactly one reviewer-1 row and one reviewer-2 row"
  end
  reviewers = [reviewer_1_rows.first, reviewer_2_rows.first].compact
  if reviewers.length == 2
    normalized_reviewers = reviewers.map(&:downcase)
    errors << "Gate 2 independent reviewer identities are not distinct" unless normalized_reviewers.uniq.length == 2
    reviewers.each do |reviewer|
      errors << "Gate 2 reviewer identity is not canonical or is placeholder-only: #{reviewer.inspect}" unless
        canonical_reviewer_identity?(reviewer)
    end
  end

  date_rows = record.scan(/^\| Review date \| `(\d{4}-\d{2}-\d{2})` \|$/).flatten
  if date_rows.length != 1
    errors << "Gate 2 approval record lacks exactly one ISO review date"
  else
    begin
      review_date = Date.iso8601(date_rows.first)
      errors << "Gate 2 approval review date is in the future" if review_date > Date.today
      reviewed_commit_date = reviewed_date_override || (root && reviewed_commit && commit_calendar_date(root, reviewed_commit))
      approval_commit_date = approval_date_override || (root && approval_commit && commit_calendar_date(root, approval_commit))
      if reviewed_commit && root && reviewed_commit_date.nil?
        errors << "Gate 2 cannot read the reviewed content commit date"
      elsif reviewed_commit_date && review_date < reviewed_commit_date
        errors << "Gate 2 review date predates the reviewed content commit"
      end
      if approval_commit && root && approval_commit_date.nil?
        errors << "Gate 2 cannot read the approval commit date"
      elsif approval_commit_date && review_date > approval_commit_date
        errors << "Gate 2 review date is later than the approval commit"
      end
    rescue Date::Error
      errors << "Gate 2 approval record contains an invalid calendar date"
    end
  end

  evidence_rows = record.scan(
    /^\| Validation evidence \| `reviewed=([0-9a-f]{40}); command=(scripts\/[a-z0-9-]+(?: --[a-z0-9-]+)?); result=PASS` \|$/
  )
  evidence_lines = record.lines.count { |line| line.start_with?("| Validation evidence ") }
  expected_evidence = GATE2_APPROVAL_EVIDENCE_COMMANDS.map { |command| [reviewed_commit, command] }
  actual_evidence = evidence_rows.map { |sha, command| [sha, command] }
  unless reviewed_commit && evidence_lines == GATE2_APPROVAL_EVIDENCE_COMMANDS.length &&
         actual_evidence == expected_evidence
    errors << "Gate 2 approval record must contain the exact ordered reviewed-SHA/command/result=PASS evidence rows"
  end
  risk_rows = record.scan(/^\| Deferred measurement risks \| `([^`]+)` \|$/).flatten
  unless risk_rows.length == 1 && risk_rows.first.include?("Gate 3") && risk_rows.first.include?("Gate 4")
    errors << "Gate 2 approval record omits one exact Gate 3/Gate 4 deferred-measurement-risk row"
  end
  decisions = record.scan(/^\| Decision \| `([^`]+)` \|$/).flatten
  errors << "Gate 2 approval decision is not exactly one APPROVED row" unless decisions == ["APPROVED"]
  reviewed_commit
end

def validate_gate2_approval_history(root, current_readme, current_traceability, current_checklist)
  errors = []
  ["## Gate 2 exit audit", "## Gate 2 approval record"].each do |heading|
    count = heading_count(current_traceability, heading)
    errors << "current PREPRODUCTION_TRACEABILITY must contain exactly one #{heading}; found #{count}" unless count == 1
  end
  current_marks = gate2_checkbox_marks(current_traceability)
  errors << "Gate 2 exit-audit checkboxes: expected 37, got #{current_marks.length}" unless current_marks.length == 37
  unchecked = current_marks.count { |mark| mark == " " }
  errors << "Gate 2 exit audit still has #{unchecked} unchecked item(s)" unless current_marks.length == 37 && unchecked.zero?

  current_record = gate2_approval_record(current_traceability)
  reviewed_commit = validate_gate2_record_fields(current_record, nil, errors, root: root)
  return errors unless reviewed_commit

  _object_out, _object_err, commit_exists = git_capture(root, "cat-file", "-e", "#{reviewed_commit}^{commit}")
  unless commit_exists
    errors << "Gate 2 reviewed content commit is not available locally: #{reviewed_commit}"
    return errors
  end

  _ancestor_out, _ancestor_err, ancestor = git_capture(
    root, "merge-base", "--is-ancestor", reviewed_commit, "HEAD"
  )
  unless ancestor
    errors << "Gate 2 reviewed content commit is not an ancestor of HEAD"
    return errors
  end

  history, _history_err, history_ok = git_capture(root, "rev-list", "--parents", "HEAD")
  unless history_ok
    errors << "cannot inspect Git history for the Gate 2 approval transition"
    return errors
  end

  reachable_children = []
  direct_single_parent_children = history.lines.each_with_object([]) do |line, children|
    fields = line.split
    commit = fields.first
    parents = fields.drop(1)
    next unless parents.include?(reviewed_commit)

    reachable_children << commit
    children << commit if parents == [reviewed_commit]
  end
  approval_candidates = direct_single_parent_children.select do |commit|
    trace = committed_file(root, commit, "docs/PREPRODUCTION_TRACEABILITY.md")
    record = trace && gate2_approval_record(trace)
    record &&
      record.match?(/^\| Reviewed content commit \| `#{Regexp.escape(reviewed_commit)}` \|$/) &&
      record.match?(/^\| Decision \| `APPROVED` \|$/)
  end

  if approval_candidates.empty?
    errors << "no committed Gate 2 approval transition is a direct single-parent child of reviewed content commit #{reviewed_commit}"
    return errors
  end
  if approval_candidates.length > 1
    errors << "multiple Gate 2 approval transitions descend directly from reviewed content commit #{reviewed_commit}"
    return errors
  end
  approval_commit = approval_candidates.first
  unless reachable_children.uniq == [approval_commit]
    errors << "every reviewed-content -> HEAD history path must pass through the sole Gate 2 approval commit"
  end

  changed_out, _changed_err, changed_ok = git_capture(
    root, "diff-tree", "--no-commit-id", "--name-only", "-r", reviewed_commit, approval_commit
  )
  unless changed_ok
    errors << "cannot inspect the reviewed-content -> approval transition diff"
  else
    changed_paths = changed_out.lines.map(&:strip).reject(&:empty?).sort
    expected_paths = GATE2_APPROVAL_TRANSITION_PATHS.sort
    unless changed_paths == expected_paths
      errors << "Gate 2 approval transition must change exactly #{expected_paths.join(', ')}; changed #{changed_paths.join(', ')}"
    end
  end

  GATE2_REVIEWED_SNAPSHOT_PATHS.each do |relative|
    reviewed_bytes = committed_file(root, reviewed_commit, relative)
    approved_bytes = committed_file(root, approval_commit, relative)
    reviewed_mode = committed_mode(root, reviewed_commit, relative)
    approved_mode = committed_mode(root, approval_commit, relative)
    if reviewed_bytes.nil? || approved_bytes.nil?
      errors << "Gate 2 snapshot file is missing from reviewed or approval commit: #{relative}"
    elsif reviewed_bytes != approved_bytes
      errors << "Gate 2 snapshot file changed during approval transition: #{relative}"
    end
    unless reviewed_mode && reviewed_mode == approved_mode
      errors << "Gate 2 snapshot file changed type or mode during approval transition: #{relative}"
    end
  end

  GATE2_APPROVAL_TRANSITION_PATHS.each do |relative|
    reviewed_mode = committed_mode(root, reviewed_commit, relative)
    approved_mode = committed_mode(root, approval_commit, relative)
    unless reviewed_mode && reviewed_mode == approved_mode
      errors << "Gate 2 controlled approval file changed type or mode during approval: #{relative}"
    end
  end

  reviewed_readme = committed_file(root, reviewed_commit, "README.md")
  approved_readme = committed_file(root, approval_commit, "README.md")
  reviewed_checklist = committed_file(root, reviewed_commit, "docs/PRODUCTION_CHECKLIST.md")
  approved_checklist = committed_file(root, approval_commit, "docs/PRODUCTION_CHECKLIST.md")
  reviewed_traceability = committed_file(root, reviewed_commit, "docs/PREPRODUCTION_TRACEABILITY.md")
  approved_traceability = committed_file(root, approval_commit, "docs/PREPRODUCTION_TRACEABILITY.md")

  if [reviewed_readme, approved_readme, reviewed_checklist, approved_checklist,
      reviewed_traceability, approved_traceability].any?(&:nil?)
    errors << "Gate 2 approval transition is missing one or more controlled approval files"
    return errors
  end

  [reviewed_traceability, approved_traceability].each_with_index do |trace, index|
    label = index.zero? ? "reviewed content commit" : "approval commit"
    ["## Gate 2 exit audit", "## Gate 2 approval record"].each do |heading|
      count = heading_count(trace, heading)
      errors << "#{label} must contain exactly one #{heading}; found #{count}" unless count == 1
    end
  end

  reviewed_status = gate2_readme_status_line(reviewed_readme)
  approved_status = gate2_readme_status_line(approved_readme)
  unless reviewed_status&.match?(/\bin progress\b/i) && !reviewed_status.match?(/\bcomplete\b/i)
    errors << "reviewed content commit must report Gate 2 in progress in README"
  end
  unless approved_status&.match?(/\A\*\*Preproduction — Gate 2: complete\.?\*\*\z/)
    errors << "approval commit must report Gate 2 complete in README"
  end
  unless normalized_gate2_readme(reviewed_readme) == normalized_gate2_readme(approved_readme)
    errors << "README changed beyond its Gate 2 status line during approval"
  end

  reviewed_row = gate2_checklist_row(reviewed_checklist)
  approved_row = gate2_checklist_row(approved_checklist)
  unless reviewed_row&.match?(/^\| 2\. Preproduction \| In progress \|/)
    errors << "reviewed content commit must report Gate 2 In progress in PRODUCTION_CHECKLIST"
  end
  unless approved_row&.match?(/^\| 2\. Preproduction \| Complete \|/)
    errors << "approval commit must report Gate 2 Complete in PRODUCTION_CHECKLIST"
  end
  unless normalized_gate2_checklist(reviewed_checklist) == normalized_gate2_checklist(approved_checklist)
    errors << "PRODUCTION_CHECKLIST changed beyond its Gate 2 row during approval"
  end

  reviewed_marks = gate2_checkbox_marks(reviewed_traceability)
  approved_marks = gate2_checkbox_marks(approved_traceability)
  unless reviewed_marks.length == 37 && reviewed_marks.all? { |mark| mark == " " }
    errors << "reviewed content commit must contain exactly 37 unchecked Gate 2 audit items"
  end
  unless approved_marks.length == 37 && approved_marks.none? { |mark| mark == " " }
    errors << "approval commit must contain exactly 37 checked Gate 2 audit items"
  end
  reviewed_record = gate2_approval_record(reviewed_traceability)
  unless reviewed_record&.match?(/\bin progress\b/i) &&
         !reviewed_record.match?(/^\| Reviewed content commit \| `[0-9a-f]{40}` \|$/) &&
         !reviewed_record.match?(/^\| Decision \| `APPROVED` \|$/)
    errors << "reviewed content commit must retain an unapproved in-progress Gate 2 approval record"
  end
  unless normalized_gate2_traceability(reviewed_traceability) == normalized_gate2_traceability(approved_traceability)
    errors << "PREPRODUCTION_TRACEABILITY changed beyond Gate 2 checkbox marks and approval record during approval"
  end

  approved_record = gate2_approval_record(approved_traceability)
  validate_gate2_record_fields(approved_record, reviewed_commit, errors, root: root, approval_commit: approval_commit)
  approved_audit = heading_section(approved_traceability, "## Gate 2 exit audit")
  current_audit = heading_section(current_traceability, "## Gate 2 exit audit")
  unless approved_record == current_record
    errors << "current Gate 2 approval record differs from the committed approval transition"
  end
  unless approved_audit && current_audit && approved_audit[:body] == current_audit[:body]
    errors << "current Gate 2 exit audit differs from the committed approval transition"
  end


  head_traceability = committed_file(root, "HEAD", "docs/PREPRODUCTION_TRACEABILITY.md")
  if head_traceability
    ["## Gate 2 exit audit", "## Gate 2 approval record"].each do |heading|
      count = heading_count(head_traceability, heading)
      errors << "HEAD PREPRODUCTION_TRACEABILITY must contain exactly one #{heading}; found #{count}" unless count == 1
    end
  end
  head_record = head_traceability && gate2_approval_record(head_traceability)
  head_audit = head_traceability && heading_section(head_traceability, "## Gate 2 exit audit")
  unless head_record == approved_record
    errors << "HEAD does not preserve the committed Gate 2 approval record"
  end
  unless head_audit && approved_audit && head_audit[:body] == approved_audit[:body]
    errors << "HEAD does not preserve the committed Gate 2 exit audit"
  end

  current_row = gate2_checklist_row(current_checklist)
  unless current_row&.match?(/^\| 2\. Preproduction \| Complete \|/)
    errors << "current PRODUCTION_CHECKLIST does not preserve Gate 2 Complete"
  end
  head_checklist = committed_file(root, "HEAD", "docs/PRODUCTION_CHECKLIST.md")
  head_row = head_checklist && gate2_checklist_row(head_checklist)
  unless head_row&.match?(/^\| 2\. Preproduction \| Complete \|/)
    errors << "HEAD does not preserve Gate 2 Complete in PRODUCTION_CHECKLIST"
  end
  current_status = gate2_readme_status_line(current_readme)
  if current_status && !current_status.match?(/\A\*\*Preproduction — Gate 2: complete\.?\*\*\z/)
    errors << "current README still has a non-complete Gate 2 status"
  end

  head_out, _head_err, head_ok = git_capture(root, "rev-parse", "HEAD")
  if head_ok && head_out.strip == approval_commit
    errors << "uncommitted README differs from the approval commit" unless current_readme == approved_readme
    errors << "uncommitted PRODUCTION_CHECKLIST differs from the approval commit" unless current_checklist == approved_checklist
    errors << "uncommitted PREPRODUCTION_TRACEABILITY differs from the approval commit" unless current_traceability == approved_traceability
  end

  errors
end

def between(text, start_marker, end_marker = nil)
  start_index = text.index(start_marker)
  unless start_index
    error("missing section marker: #{start_marker}")
    return ""
  end

  body_start = start_index + start_marker.length
  end_index = end_marker ? text.index(end_marker, body_start) : text.length
  unless end_index
    error("missing section end marker after #{start_marker}: #{end_marker}")
    return ""
  end
  text[body_start...end_index]
end

def table_id_count(text, start_marker, end_marker)
  between(text, start_marker, end_marker).lines.count do |line|
    line.match?(/^\|\s*`[^`]+`\s*\|/)
  end
end

def expect_count(label, actual, expected)
  error("#{label}: expected #{expected}, got #{actual}") unless actual == expected
end

def enum_count(text, enum_name, prefix, excluded = [])
  match = text.match(/typedef enum #{Regexp.escape(enum_name)}\s*\{(?<body>.*?)\}\s*#{Regexp.escape(enum_name)}\s*;/m)
  unless match
    error("missing enum: #{enum_name}")
    return 0
  end

  match[:body].lines.count do |line|
    symbol = line[/^\s*(#{Regexp.escape(prefix)}[A-Z0-9_]+)\s*=/, 1]
    symbol && !excluded.include?(symbol)
  end
end

def validate_offset_table(label, text, start_marker, end_marker, expected_total)
  body = between(text, start_marker, end_marker)
  rows = body.scan(/^\|\s*`0x([0-9A-Fa-f]+)`\s*\|\s*(\d+)\s*\|/)
  if rows.empty?
    error("#{label}: no offset rows found")
    return
  end

  cursor = 0
  rows.each do |hex_offset, byte_count|
    offset = hex_offset.to_i(16)
    bytes = byte_count.to_i
    error("#{label}: expected next offset 0x#{cursor.to_s(16).upcase}, got 0x#{hex_offset.upcase}") unless offset == cursor
    cursor = offset + bytes
  end
  error("#{label}: expected #{expected_total} bytes, rows cover #{cursor}") unless cursor == expected_total
end

def gate2_history_test_git!(root, *arguments)
  stdout, stderr, success = git_capture(root, *arguments)
  return stdout if success

  raise "git #{arguments.join(' ')} failed in Gate 2 history self-test: #{stderr}"
end

def gate2_history_test_write(root, relative, body)
  path = Pathname.new(root).join(relative)
  FileUtils.mkdir_p(path.dirname)
  path.write(body)
end

def gate2_history_test_trace(reviewed_commit = nil, checked: false, review_date: nil)
  mark = checked ? "x" : " "
  audit = (1..37).map { |index| "- [#{mark}] synthetic audited criterion #{index}" }.join("\n")
  record = if reviewed_commit
             raise "Gate 2 history fixture requires a review date" unless review_date

             evidence = GATE2_APPROVAL_EVIDENCE_COMMANDS.map do |command|
               "| Validation evidence | `reviewed=#{reviewed_commit}; command=#{command}; result=PASS` |"
             end
             [
               "| Field | Value |",
               "|---|---|",
               "| Reviewed content commit | `#{reviewed_commit}` |",
               "| Independent reviewer 1 | `github:alice-audit` |",
               "| Independent reviewer 2 | `github:bob-audit` |",
               "| Review date | `#{review_date}` |",
               *evidence,
               "| Deferred measurement risks | `Gate 3 toolchain proof and Gate 4 native-resolution benchmark proof remain required` |",
               "| Decision | `APPROVED` |",
               ""
             ].join("\n")
           else
             "Gate 2 remains **in progress** pending independent review.\n"
           end
  <<~TRACE
    # Synthetic Gate 2 traceability fixture

    ## Gate 2 exit audit

    #{audit}

    ## Gate 2 approval record

    #{record}
  TRACE
end


def gate2_history_test_readme(complete: false)
  status = if complete
             "**Preproduction — Gate 2: complete.**"
           else
             "**Preproduction — Gate 2: specification and production-contract reconciliation in progress.**"
           end
  "# Synthetic repository\n\n#{status}\n\nStable README content.\n"
end

def gate2_history_test_checklist(complete: false)
  status = complete ? "Complete" : "In progress"
  <<~CHECKLIST
    # Synthetic production checklist

    | Gate | Status | Evidence | Note |
    |---|---|---|---|
    | 1. Audit | Complete | fixture | fixture |
    | 2. Preproduction | #{status} | fixture | fixture |
    | 3. Toolchain | Not started | fixture | fixture |
  CHECKLIST
end

def with_gate2_history_fixture
  Dir.mktmpdir("n64game-gate2-history-") do |directory|
    root = Pathname.new(directory)
    gate2_history_test_git!(root, "init", "-q")
    gate2_history_test_git!(root, "config", "user.name", "Gate 2 Self Test")
    gate2_history_test_git!(root, "config", "user.email", "gate2-self-test@example.invalid")

    GATE2_REVIEWED_SNAPSHOT_PATHS.each do |relative|
      gate2_history_test_write(root, relative, "reviewed fixture bytes for #{relative}\n")
    end
    gate2_history_test_write(root, "README.md", gate2_history_test_readme)
    gate2_history_test_write(root, "docs/PRODUCTION_CHECKLIST.md", gate2_history_test_checklist)
    gate2_history_test_write(root, "docs/PREPRODUCTION_TRACEABILITY.md", gate2_history_test_trace)
    gate2_history_test_git!(root, "add", "--all")
    gate2_history_test_git!(root, "commit", "-q", "-m", "Reviewed Gate 2 content snapshot")
    reviewed_commit = gate2_history_test_git!(root, "rev-parse", "HEAD").strip
    yield root, reviewed_commit
  end
end

def gate2_history_test_stage_approval(root, reviewed_commit, collateral_path: nil, collateral_body: nil,
                                      readme_suffix: "")
  review_date = gate2_history_test_git!(root, "show", "-s", "--format=%cs", reviewed_commit).strip
  gate2_history_test_write(
    root,
    "README.md",
    gate2_history_test_readme(complete: true) + readme_suffix
  )
  gate2_history_test_write(
    root,
    "docs/PRODUCTION_CHECKLIST.md",
    gate2_history_test_checklist(complete: true)
  )
  gate2_history_test_write(
    root,
    "docs/PREPRODUCTION_TRACEABILITY.md",
    gate2_history_test_trace(reviewed_commit, checked: true, review_date: review_date)
  )
  gate2_history_test_write(root, collateral_path, collateral_body) if collateral_path
  gate2_history_test_git!(root, "add", "--all")
end

def gate2_history_test_current(root)
  [
    root.join("README.md").read,
    root.join("docs/PREPRODUCTION_TRACEABILITY.md").read,
    root.join("docs/PRODUCTION_CHECKLIST.md").read
  ]
end

def run_gate2_approval_metadata_self_tests
  reviewed_commit = "a" * 40
  reviewed_date = Date.today - 2
  review_date = Date.today - 1
  approval_date = Date.today
  valid_record = gate2_approval_record(
    gate2_history_test_trace(reviewed_commit, checked: true, review_date: review_date.iso8601)
  )
  validate = lambda do |record, reviewed: reviewed_date, approved: approval_date|
    errors = []
    validate_gate2_record_fields(
      record,
      reviewed_commit,
      errors,
      reviewed_date_override: reviewed,
      approval_date_override: approved
    )
    errors
  end
  assertions = {
    "keeps reviewed snapshot path separate from reviewed-content command" =>
      GATE2_REVIEWED_SNAPSHOT_PATHS.include?("scripts/validate-preproduction") &&
      GATE2_REVIEWED_SNAPSHOT_PATHS.none? { |path| path.start_with?("--") || path.include?(" ") } &&
      GATE2_APPROVAL_EVIDENCE_COMMANDS.last == "scripts/validate-preproduction --reviewed-content" &&
      valid_record.include?("command=scripts/validate-preproduction --reviewed-content; result=PASS"),
    "accepts exact canonical approval metadata" => validate.call(valid_record).empty?,
    "rejects duplicate reviewer labels" => validate.call(
      valid_record.sub("Independent reviewer 2", "Independent reviewer 1")
    ).any? { |message| message.include?("exactly one reviewer-1 row and one reviewer-2 row") },
    "rejects generic placeholder identities with numeric suffixes" => validate.call(
      valid_record.sub("github:alice-audit", "github:reviewer1")
    ).any? { |message| message.include?("not canonical or is placeholder-only") },
    "rejects evidence without explicit PASS" => validate.call(
      valid_record.sub("result=PASS", "result=FAIL")
    ).any? { |message| message.include?("exact ordered reviewed-SHA") },
    "rejects evidence bound to another SHA" => validate.call(
      valid_record.sub(
        "| Validation evidence | `reviewed=#{reviewed_commit};",
        "| Validation evidence | `reviewed=#{'b' * 40};"
      )
    ).any? { |message| message.include?("exact ordered reviewed-SHA") },
    "rejects a review date before the reviewed commit" => validate.call(
      valid_record.sub(review_date.iso8601, (reviewed_date - 1).iso8601)
    ).any? { |message| message.include?("predates the reviewed content commit") },
    "rejects a review date after the approval commit" => validate.call(
      valid_record.sub(review_date.iso8601, (approval_date + 1).iso8601)
    ).any? { |message| message.include?("later than the approval commit") }
  }
  failures = assertions.reject { |_label, passed| passed }.keys
  raise "Gate 2 approval-metadata self-test failed: #{failures.join(', ')}" unless failures.empty?

  puts "Gate 2 approval-metadata self-test passed: #{assertions.length} isolated exact-field fixtures."
end

def run_gate2_history_self_tests
  run_gate2_approval_metadata_self_tests
  assertions = []
  assert = lambda do |condition, label, detail = nil|
    raise "Gate 2 history self-test failed: #{label}#{detail ? ": #{detail}" : ''}" unless condition

    assertions << label
  end

  with_gate2_history_fixture do |root, reviewed_commit|
    gate2_history_test_stage_approval(root, reviewed_commit)
    gate2_history_test_git!(root, "commit", "-q", "-m", "Approve Gate 2 reviewed snapshot")

    # A later gate may evolve formerly frozen production contracts and advance
    # the README banner; the historical reviewed/approval pair remains proof.
    gate2_history_test_write(root, "docs/ASSET_LEDGER.md", "legitimate Gate 4 ledger evolution\n")
    gate2_history_test_write(root, "THIRD_PARTY_NOTICES.md", "legitimate later notice evolution\n")
    future_readme = root.join("README.md").read.sub(
      /^\*\*Preproduction — Gate 2: complete\.\*\*$/,
      "**Toolchain — Gate 3: implementation in progress.**"
    )
    gate2_history_test_write(root, "README.md", future_readme)
    gate2_history_test_git!(root, "add", "--all")
    gate2_history_test_git!(root, "commit", "-q", "-m", "Begin legitimate post-Gate-2 production")
    errors = validate_gate2_approval_history(root, *gate2_history_test_current(root))
    assert.call(errors.empty?, "accepts an exact approval transition plus later production evolution", errors.join("; "))
  end

  with_gate2_history_fixture do |root, reviewed_commit|
    gate2_history_test_git!(root, "switch", "-q", "-c", "approval-path")
    gate2_history_test_stage_approval(root, reviewed_commit)
    gate2_history_test_git!(root, "commit", "-q", "-m", "Approve Gate 2 reviewed snapshot")

    # A second child of the reviewed commit cannot be merged after approval:
    # that would create a reviewed-content -> HEAD path which bypasses the
    # approval transition even though the approval commit remains an ancestor.
    gate2_history_test_git!(root, "switch", "-q", "-c", "parallel-preapproval-path", reviewed_commit)
    gate2_history_test_write(root, "docs/ASSET_LEDGER.md", "parallel preapproval ledger rewrite\n")
    gate2_history_test_git!(root, "add", "--all")
    gate2_history_test_git!(root, "commit", "-q", "-m", "Parallel preapproval content")
    gate2_history_test_git!(root, "switch", "-q", "approval-path")
    gate2_history_test_git!(
      root, "merge", "-q", "--no-ff", "parallel-preapproval-path", "-m", "Merge parallel preapproval path"
    )
    errors = validate_gate2_approval_history(root, *gate2_history_test_current(root))
    assert.call(
      errors.any? { |message| message.include?("every reviewed-content -> HEAD history path") },
      "rejects a merged history path that bypasses the approval commit",
      errors.join("; ")
    )
  end

  with_gate2_history_fixture do |root, reviewed_commit|
    gate2_history_test_stage_approval(root, reviewed_commit)
    errors = validate_gate2_approval_history(root, *gate2_history_test_current(root))
    assert.call(
      errors.any? { |message| message.include?("no committed Gate 2 approval transition") },
      "rejects a forged uncommitted approval",
      errors.join("; ")
    )
  end


  with_gate2_history_fixture do |root, reviewed_commit|
    gate2_history_test_stage_approval(root, reviewed_commit)
    gate2_history_test_git!(root, "commit", "-q", "-m", "Approve Gate 2 reviewed snapshot")
    approved_trace = root.join("docs/PREPRODUCTION_TRACEABILITY.md").read
    approved_checklist = root.join("docs/PRODUCTION_CHECKLIST.md").read
    gate2_history_test_write(
      root,
      "docs/PREPRODUCTION_TRACEABILITY.md",
      approved_trace.sub("`github:alice-audit`", "`github:erased-current-head`")
    )
    gate2_history_test_write(
      root,
      "docs/PRODUCTION_CHECKLIST.md",
      approved_checklist.sub("| 2. Preproduction | Complete |", "| 2. Preproduction | Reopened |")
    )
    gate2_history_test_git!(root, "add", "--all")
    gate2_history_test_git!(root, "commit", "-q", "-m", "Erase Gate 2 evidence from current HEAD")

    # Restoring the evidence only in the working tree must not conceal that the
    # current committed tree erased it.
    gate2_history_test_write(root, "docs/PREPRODUCTION_TRACEABILITY.md", approved_trace)
    gate2_history_test_write(root, "docs/PRODUCTION_CHECKLIST.md", approved_checklist)
    errors = validate_gate2_approval_history(root, *gate2_history_test_current(root))
    assert.call(
      errors.any? { |message| message.include?("HEAD does not preserve the committed Gate 2 approval record") } &&
        errors.any? { |message| message.include?("HEAD does not preserve Gate 2 Complete") },
      "rejects evidence restored only as uncommitted working-tree bytes",
      errors.join("; ")
    )
  end

  with_gate2_history_fixture do |root, reviewed_commit|
    gate2_history_test_stage_approval(
      root,
      reviewed_commit,
      collateral_path: "docs/ASSET_LEDGER.md",
      collateral_body: "unaudited approval-time mutation\n"
    )
    gate2_history_test_git!(root, "commit", "-q", "-m", "Approval with forbidden collateral mutation")
    errors = validate_gate2_approval_history(root, *gate2_history_test_current(root))
    assert.call(
      errors.any? { |message| message.include?("approval transition must change exactly") } &&
        errors.any? { |message| message.include?("snapshot file changed during approval transition") },
      "rejects a contract mutation hidden in the approval commit",
      errors.join("; ")
    )
  end

  with_gate2_history_fixture do |root, reviewed_commit|
    gate2_history_test_stage_approval(root, reviewed_commit)
    gate2_history_test_git!(root, "update-index", "--chmod=+x", "docs/ART_BIBLE.md")
    gate2_history_test_git!(root, "commit", "-q", "-m", "Approval with frozen snapshot mode mutation")
    errors = validate_gate2_approval_history(root, *gate2_history_test_current(root))
    assert.call(
      errors.any? do |message|
        message.include?("snapshot file changed type or mode during approval transition: docs/ART_BIBLE.md")
      end,
      "rejects a mode-only mutation of a frozen snapshot file in the approval commit",
      errors.join("; ")
    )
  end

  with_gate2_history_fixture do |root, reviewed_commit|
    # Preserve a valid approval commit as the replacement object, then make the
    # real HEAD an invalid approval whose parent and frozen snapshot both differ.
    gate2_history_test_stage_approval(root, reviewed_commit)
    gate2_history_test_git!(root, "commit", "-q", "-m", "Valid approval replacement object")
    replacement_commit = gate2_history_test_git!(root, "rev-parse", "HEAD").strip

    gate2_history_test_git!(root, "switch", "-q", "--detach", reviewed_commit)
    gate2_history_test_write(root, "docs/ART_BIBLE.md", "replacement-hidden frozen snapshot mutation\n")
    gate2_history_test_git!(root, "add", "--all")
    gate2_history_test_git!(root, "commit", "-q", "-m", "Intervening real content mutation")
    intervening_commit = gate2_history_test_git!(root, "rev-parse", "HEAD").strip
    gate2_history_test_stage_approval(root, reviewed_commit)
    gate2_history_test_git!(root, "commit", "-q", "-m", "Invalid real approval history")
    forged_commit = gate2_history_test_git!(root, "rev-parse", "HEAD").strip
    gate2_history_test_git!(
      root,
      "update-ref",
      "refs/replace/#{forged_commit}",
      replacement_commit
    )

    replaced_history, replaced_history_error, replaced_history_status = Open3.capture3(
      { "GIT_NO_REPLACE_OBJECTS" => nil },
      "git", "rev-list", "--parents", "--max-count=1", "HEAD",
      chdir: root.to_s
    )
    replaced_bytes, replaced_bytes_error, replaced_bytes_status = Open3.capture3(
      { "GIT_NO_REPLACE_OBJECTS" => nil },
      "git", "show", "HEAD:docs/ART_BIBLE.md",
      chdir: root.to_s
    )
    real_history, _real_history_error, real_history_ok = git_capture(
      root, "rev-list", "--parents", "--max-count=1", "HEAD"
    )
    real_bytes, _real_bytes_error, real_bytes_ok = git_capture(
      root, "show", "HEAD:docs/ART_BIBLE.md"
    )
    errors = validate_gate2_approval_history(root, *gate2_history_test_current(root))
    replaced_fields = replaced_history.split
    real_fields = real_history.split
    assert.call(
      replaced_history_status.success? &&
        replaced_bytes_status.success? &&
        replaced_fields == [forged_commit, reviewed_commit] &&
        replaced_bytes == "reviewed fixture bytes for docs/ART_BIBLE.md\n" &&
        real_history_ok &&
        real_bytes_ok &&
        real_fields == [forged_commit, intervening_commit] &&
        real_bytes == "replacement-hidden frozen snapshot mutation\n" &&
        errors.any? { |message| message.include?("no committed Gate 2 approval transition") },
      "rejects a replacement ref that would conceal real ancestry and frozen content",
      [
        "replacement history error=#{replaced_history_error.strip}",
        "replacement content error=#{replaced_bytes_error.strip}",
        "replacement history=#{replaced_history.strip}",
        "real history=#{real_history.strip}",
        "errors=#{errors.join('; ')}"
      ].join("; ")
    )
  end

  with_gate2_history_fixture do |root, reviewed_commit|
    gate2_history_test_write(root, "INTERMEDIATE.md", "intervening commit\n")
    gate2_history_test_git!(root, "add", "--all")
    gate2_history_test_git!(root, "commit", "-q", "-m", "Intervening unaudited commit")
    gate2_history_test_stage_approval(root, reviewed_commit)
    gate2_history_test_git!(root, "commit", "-q", "-m", "Approval too late in history")
    errors = validate_gate2_approval_history(root, *gate2_history_test_current(root))
    assert.call(
      errors.any? { |message| message.include?("direct single-parent child") },
      "rejects an approval whose exact parent is not the reviewed commit",
      errors.join("; ")
    )
  end

  with_gate2_history_fixture do |root, reviewed_commit|
    gate2_history_test_stage_approval(root, reviewed_commit)
    gate2_history_test_git!(root, "commit", "-q", "-m", "Approve Gate 2 reviewed snapshot")
    tampered = root.join("docs/PREPRODUCTION_TRACEABILITY.md").read.sub("`github:alice-audit`", "`github:forged-reviewer`")
    gate2_history_test_write(root, "docs/PREPRODUCTION_TRACEABILITY.md", tampered)
    errors = validate_gate2_approval_history(root, *gate2_history_test_current(root))
    assert.call(
      errors.any? { |message| message.include?("current Gate 2 approval record differs") } &&
        errors.any? { |message| message.include?("uncommitted PREPRODUCTION_TRACEABILITY differs") },
      "rejects current evidence tampering after approval",
      errors.join("; ")
    )
  end

  with_gate2_history_fixture do |root, reviewed_commit|
    gate2_history_test_stage_approval(
      root,
      reviewed_commit,
      readme_suffix: "unaudited README rewrite in approval commit\n"
    )
    gate2_history_test_git!(root, "commit", "-q", "-m", "Approval with uncontrolled README rewrite")
    errors = validate_gate2_approval_history(root, *gate2_history_test_current(root))
    assert.call(
      errors.any? { |message| message.include?("README changed beyond its Gate 2 status line") },
      "rejects uncontrolled edits inside an allowed approval file",
      errors.join("; ")
    )
  end


  with_gate2_history_fixture do |root, reviewed_commit|
    gate2_history_test_stage_approval(root, reviewed_commit)
    gate2_history_test_git!(root, "commit", "-q", "-m", "Approve Gate 2 reviewed snapshot")
    duplicate = root.join("docs/PREPRODUCTION_TRACEABILITY.md").read + <<~DUPLICATE

      ## Gate 2 approval record

      | Decision | `REBUILD` |
    DUPLICATE
    gate2_history_test_write(root, "docs/PREPRODUCTION_TRACEABILITY.md", duplicate)
    gate2_history_test_git!(root, "add", "--all")
    gate2_history_test_git!(root, "commit", "-q", "-m", "Append contradictory Gate 2 approval record")
    errors = validate_gate2_approval_history(root, *gate2_history_test_current(root))
    assert.call(
      errors.any? { |message| message.include?("must contain exactly one ## Gate 2 approval record") },
      "rejects duplicate or contradictory current approval sections",
      errors.join("; ")
    )
  end

  puts "Gate 2 approval-history self-test passed: #{assertions.length} isolated positive/negative histories."
end

if ARGV == ["--self-test-gate2-history"]
  run_gate2_history_self_tests
  exit 0
end
