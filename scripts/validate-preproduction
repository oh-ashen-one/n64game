inventory_character_rows = inventory.scan(
  /^\| `(chr\.[a-z0-9_.]+)` \|.*?\|\s*([^|]+)\|\s*[^|]*?(\d+) mats;[^|]*\|\s*(\d+) joints;/
).each_with_object({}) do |(asset, count_text, materials, joints), rows|
  symbol = character_symbol_by_asset[asset]
  next unless symbol

  rows[symbol] = [joints.to_i, materials.to_i, count_text.include?("distance mesh") ? 2 : 1]
end
