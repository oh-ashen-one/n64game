string_id_rows = data.scan(/^\s*(STR_[A-Z0-9_]+)\s*=\s*(0x[0-9A-Fa-f]+|\d+)/)
string_id_rows.group_by { |_name, value| Integer(value) }.each do |value, rows|
  next if rows.length == 1

  error("duplicate global StringId 0x#{value.to_s(16).upcase}: #{rows.map(&:first).join(', ')}")
end

all_numeric_symbols = data.scan(/^\s*([A-Z][A-Z0-9_]+)\s*=\s*(0x[0-9A-Fa-f]+|\d+)\b/)

declared_condition_symbols = all_numeric_symbols.map(&:first).grep(/\ACOND_/).uniq
condition_language_opcodes = %w[COND_AND COND_EQ COND_GE COND_NOT COND_OR]
undefined_condition_symbols = data.scan(/\bCOND_[A-Z0-9_]+\b/).uniq - declared_condition_symbols - condition_language_opcodes
unless undefined_condition_symbols.empty?
  error("data schemas reference undefined condition symbols: #{undefined_condition_symbols.sort.join(', ')}")
end

generated_move_id_ranges = [
  ["StringId", /^STR_/, "STR_MOVE_GENERATED_BASE", 0x8001..0x8022],
  ["AssetId", /^ASSET_/, "ASSET_VFX_MOVE_GENERATED_BASE", 0x8301..0x8322],
  ["AudioCueId", /^AUDIO_/, "AUDIO_SFX_MOVE_GENERATED_BASE", 0x8401..0x8422],
  ["CameraCueId", /^CAMERA_/, "CAMERA_CUE_MOVE_GENERATED_BASE", 0x8501..0x8522]
]
generated_move_id_ranges.each do |domain, prefix, base_symbol, range|
  explicit_rows = all_numeric_symbols.select do |symbol, _value|
    symbol.match?(prefix) && symbol != base_symbol
  end
  explicit_rows.each do |symbol, value_text|
    value = Integer(value_text)
    next unless range.cover?(value)

    error("generated move #{domain} range #{range.begin.to_s(16)}..#{range.end.to_s(16)} collides with #{symbol}=0x#{value.to_s(16).upcase}")
  end
end

numeric_enum_rows = {}
data.scan(/typedef enum\s+([A-Za-z0-9_]+)\s*\{(.*?)\}\s*[A-Za-z0-9_]+\s*;/m).each do |name, body|
  numeric_enum_rows[name] = body.scan(/^\s*([A-Z][A-Z0-9_]+)\s*=\s*(0x[0-9A-Fa-f]+|\d+)\b/)
end
data.scan(/^enum\s+([A-Za-z0-9_]+)\s*\{(.*?)^\};/m).each do |name, body|
  numeric_enum_rows[name] ||= body.scan(/^\s*([A-Z][A-Z0-9_]+)\s*=\s*(0x[0-9A-Fa-f]+|\d+)\b/)
end

