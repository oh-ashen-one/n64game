  error("StoryActionListId #{symbol} has #{rows.length} trigger owners; expected exactly 1") unless rows.length == 1
end

(live_story_action_list_symbols - trigger_owned_action_lists).uniq.sort.each do |symbol|
  error("live StoryActionListId lacks a sole-dispatch StoryTrigger owner: #{symbol}")
end
(trigger_owned_action_lists - live_story_action_list_symbols).uniq.sort.each do |symbol|
  error("StoryTrigger owns undefined StoryActionListId: #{symbol}")
end

if reviewed_content_mode
  expected = GATE2_REVIEWED_CONTENT_PLACEHOLDER_ERRORS.sort
  actual = ERRORS.sort
  if actual == expected
    puts "Gate 2 reviewed-content validation passed: all substantive checks pass and exactly seven approval-only placeholders remain."
    puts "This mode is valid only on the reviewed-content commit before its direct approval child."
    exit 0
  end

  missing = expected - actual
  unexpected = actual - expected
  warn "Gate 2 reviewed-content validation failed: the remaining error set is not the exact seven approval-only placeholders."
  missing.each { |message| warn "- missing expected placeholder: #{message}" }
  unexpected.each { |message| warn "- unexpected substantive error: #{message}" }
  exit 1
end

if ERRORS.empty?
  puts "Gate 2 preproduction validation passed."
  puts "Goal prompt: #{goal_chars} characters (<4000)."
  puts "Story: 10 scenes, 4 objectives, 23 flags, 11 checkpoints, 22:30 target / 15:35 active."
  puts "Inventory: 9 humans, 8 Echoforms, 16 environment sources, 63 props, 32 regular move events, 20 common VFX, 42 animation banks."
  puts "Data: 10 scenes, 9 characters, 8 Echoforms, 34 moves, 4 objectives, 23 flags, 11 checkpoints."
  exit 0
end

warn "Gate 2 preproduction validation failed with #{ERRORS.length} error(s):"
ERRORS.each { |message| warn "- #{message}" }
exit 1
