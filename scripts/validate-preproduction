live_story_action_list_symbols = data.scan(
  /static const StoryActionListDef\s+\w+\[\d+\]\s*=\s*\{(.*?)\n\};/m
).flat_map do |body|
  body.first.scan(/^\s*\{\s*([A-Z][A-Z0-9_]+)\s*,/).flatten
end

live_story_action_list_values = live_story_action_list_symbols.each_with_object([]) do |symbol, rows|
  assignments = all_numeric_symbols.select { |candidate, _value| candidate == symbol }
  if assignments.length != 1
    error("live StoryActionListId #{symbol} has #{assignments.length} numeric declarations; expected exactly 1")
    next
  end
  rows << [symbol, Integer(assignments.first.last)]
end
live_story_action_list_values.group_by(&:last).each do |value, rows|
  next if rows.length == 1

  error("duplicate live StoryActionListId 0x#{value.to_s(16).upcase}: #{rows.map(&:first).join(', ')}")
end

trigger_owned_action_lists = trigger_contract.scan(
  /^\|\s*`[^`]+`\s*\|\s*`[^`]+`\s*\|\s*`(ACTION_[A-Z0-9_]+)`\s*\|/
).flatten

trigger_owner_phase_keys = trigger_contract.scan(
  /^\|\s*`([^`]+)`\s*\|\s*`([^`]+)`\s*\|\s*`[^`]+`\s*\|/
).map { |owner, phase| [owner, phase] }
trigger_owner_phase_keys.group_by(&:itself).each do |(owner, phase), rows|
  next if rows.length == 1

  error("duplicate StoryTrigger owner/phase key #{owner} / #{phase}: #{rows.length} rows")
