trigger_contract.scan(
  /^\|\s*`(DIALOGUE\s*\/\s*[^`]+)`\s*\|\s*`[^`]+`\s*\|\s*`[^`]+`\s*\|\s*`(COND_TRANS_[A-Z0-9_]+)`\s*\|/
