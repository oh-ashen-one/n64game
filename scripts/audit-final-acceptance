#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
exec /usr/bin/python3 -I -B "$ROOT/tools/n64game_final_acceptance_audit.py" \
    --json-out "$ROOT/build/reports/final-acceptance-audit.json" \
    --md-out "$ROOT/build/reports/final-acceptance-audit.md" \
    "$@"
