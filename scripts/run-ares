#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ROM="$ROOT/build/game/n64game-gate3.z64"
EXPECTED_ROM_SHA=""
CHECK_ONLY=0
CAPTURE_SESSION=0

for argument in "$@"; do
    case "$argument" in
        --homebrew-mode) ;;
        --check-only) CHECK_ONLY=1 ;;
        --capture-session) CAPTURE_SESSION=1 ;;
        --expected-rom-sha256=*) EXPECTED_ROM_SHA="${argument#*=}" ;;
        --*) printf 'unsupported argument: %s\n' "$argument" >&2; exit 64 ;;
        *) ROM="$argument" ;;
    esac
done

if [[ "$ROM" != /* ]]; then
    ROM="$ROOT/$ROM"
fi
test -f "$ROM"
test ! -L "$ROM"

ACTUAL_ROM_SHA="$(shasum -a 256 "$ROM" | awk '{print $1}')"
if [[ -n "$EXPECTED_ROM_SHA" && "$ACTUAL_ROM_SHA" != "$EXPECTED_ROM_SHA" ]]; then
    printf 'ROM SHA-256 mismatch: got %s expected %s\n' "$ACTUAL_ROM_SHA" "$EXPECTED_ROM_SHA" >&2
    exit 1
fi

ARES="${N64GAME_ARES_BINARY:-$HOME/Applications/Emulators/ares-v148/ares.app/Contents/MacOS/ares}"
EXPECTED_ARES_SHA="7a49f00f96a691458461d7c9cf453d95c0f5c054389bbd87c253987b8b6fa345"
test -f "$ARES"
test -x "$ARES"
test ! -L "$ARES"
ACTUAL_ARES_SHA="$(shasum -a 256 "$ARES" | awk '{print $1}')"
if [[ "$ACTUAL_ARES_SHA" != "$EXPECTED_ARES_SHA" ]]; then
    printf 'Ares executable SHA-256 mismatch: got %s expected %s\n' "$ACTUAL_ARES_SHA" "$EXPECTED_ARES_SHA" >&2
    exit 1
fi

STATE_ROOT="${N64GAME_ARES_STATE:-$HOME/Library/Application Support/ares-v148-n64game}"
mkdir -p "$STATE_ROOT/Systems" "$STATE_ROOT/Saves/Nintendo 64" "$STATE_ROOT/Screenshots" "$STATE_ROOT/Debugging"
SETTINGS_FILE="$STATE_ROOT/settings.bml"
if [[ ! -f "$SETTINGS_FILE" ]]; then
    "$ARES" --settings-file "$SETTINGS_FILE" --version >/dev/null
fi
repair_ares_settings() {
    perl -0pi -e '
    s/(\n  Defocus: )[^\n]*/${1}Allow/;
    s/(\n  ExpansionPak: )[^\n]*/${1}false/;
    s/(\n        L-Up: )[^\n]*/${1};;/;
    s/(\n        L-Down: )[^\n]*/${1};;/;
    s/(\n        L-Left: )[^\n]*/${1};;/;
    s/(\n        L-Right: )[^\n]*/${1};;/;
    s/(\n        Up: )[^\n]*/${1}0x1\/0\/82;0x1\/0\/26;;/;
    s/(\n        Down: )[^\n]*/${1}0x1\/0\/81;0x1\/0\/22;;/;
    s/(\n        Left: )[^\n]*/${1}0x1\/0\/80;0x1\/0\/4;;/;
    s/(\n        Right: )[^\n]*/${1}0x1\/0\/79;0x1\/0\/7;;/;
    s/(\n        B: )[^\n]*/${1}0x1\/0\/29;;/;
    s/(\n        A: )[^\n]*/${1}0x1\/0\/27;;/;
    s/(\n        C-Down: )[^\n]*/${1}0x1\/0\/44;;/;
    s/(\n        Z: )[^\n]*/${1}0x1\/0\/225;;/;
    s/(\n        Start: )[^\n]*/${1}0x1\/0\/40;;/;
    s/(\n  CaptureScreenshot: )[^\n]*/${1}0x1\/0\/19;;/;
    s/(\n        X-Axis\n          Lo: )[^\n]*/${1}0x1\/0\/80;0x1\/0\/4;;/;
    s/(\n        X-Axis\n          Lo: [^\n]*\n          Hi: )[^\n]*/${1}0x1\/0\/79;0x1\/0\/7;;/;
    s/(\n        Y-Axis\n          Lo: )[^\n]*/${1}0x1\/0\/81;0x1\/0\/22;;/;
    s/(\n        Y-Axis\n          Lo: [^\n]*\n          Hi: )[^\n]*/${1}0x1\/0\/82;0x1\/0\/26;;/;
' "$SETTINGS_FILE"
}
repair_ares_settings
VERSION="$($ARES --settings-file "$SETTINGS_FILE" --version)"
if [[ "$VERSION" != *"v148"* ]]; then
    printf 'unexpected Ares version: %s\n' "$VERSION" >&2
    exit 1
fi
repair_ares_settings

printf 'ares_version=%s\nares_sha256=%s\nrom_sha256=%s\nhomebrew_mode=true\nexpansion_pak=false\ndefocus=allow\n' \
    "$VERSION" "$ACTUAL_ARES_SHA" "$ACTUAL_ROM_SHA"

if [[ "$CHECK_ONLY" -eq 1 ]]; then
    exit 0
fi

AUDIT_JSON="$(mktemp -t n64game-ares-input-audit.XXXXXX.json)"
if ! "$ROOT/scripts/audit-ares-input" --strict >"$AUDIT_JSON"; then
    printf 'Ares input launch blocked: stale or invalid keyboard binding state detected.\n' >&2
    printf 'Run scripts/fix-ares-input, then launch again through scripts/run-ares.\n' >&2
    cat "$AUDIT_JSON" >&2
    rm -f "$AUDIT_JSON"
    exit 1
fi
rm -f "$AUDIT_JSON"

ARES_ARGS=(
    --settings-file "$STATE_ROOT/settings.bml"
    --setting General/HomebrewMode=true
    --setting Nintendo64/ExpansionPak=false
    --setting Input/Driver=SDL
    --setting Input/Defocus=Allow
    --setting 'Nintendo64/Input/Controller.Port.1/Gamepad/L-Up=;;'
    --setting 'Nintendo64/Input/Controller.Port.1/Gamepad/L-Down=;;'
    --setting 'Nintendo64/Input/Controller.Port.1/Gamepad/L-Left=;;'
    --setting 'Nintendo64/Input/Controller.Port.1/Gamepad/L-Right=;;'
    --setting 'Nintendo64/Input/Controller.Port.1/Gamepad/Up=0x1/0/82;0x1/0/26;'
    --setting 'Nintendo64/Input/Controller.Port.1/Gamepad/Down=0x1/0/81;0x1/0/22;'
    --setting 'Nintendo64/Input/Controller.Port.1/Gamepad/Left=0x1/0/80;0x1/0/4;'
    --setting 'Nintendo64/Input/Controller.Port.1/Gamepad/Right=0x1/0/79;0x1/0/7;'
    --setting 'Nintendo64/Input/Controller.Port.1/Gamepad/X-Axis/Lo=0x1/0/80;0x1/0/4;'
    --setting 'Nintendo64/Input/Controller.Port.1/Gamepad/X-Axis/Hi=0x1/0/79;0x1/0/7;'
    --setting 'Nintendo64/Input/Controller.Port.1/Gamepad/Y-Axis/Lo=0x1/0/81;0x1/0/22;'
    --setting 'Nintendo64/Input/Controller.Port.1/Gamepad/Y-Axis/Hi=0x1/0/82;0x1/0/26;'
    --setting 'Nintendo64/Input/Controller.Port.1/Gamepad/B=0x1/0/29;;'
    --setting 'Nintendo64/Input/Controller.Port.1/Gamepad/A=0x1/0/27;;'
    --setting 'Nintendo64/Input/Controller.Port.1/Gamepad/C-Down=0x1/0/44;;'
    --setting 'Nintendo64/Input/Controller.Port.1/Gamepad/Z=0x1/0/225;;'
    --setting 'Nintendo64/Input/Controller.Port.1/Gamepad/Start=0x1/0/40;;'
    --setting "Paths/Home=$STATE_ROOT/Systems/"
    --setting "Paths/Saves=$STATE_ROOT/Saves/"
    --setting "Paths/Screenshots=$STATE_ROOT/Screenshots/"
    --setting "Paths/Debugging=$STATE_ROOT/Debugging/"
    --setting 'Hotkey/CaptureScreenshot=0x1/0/19;;'
    --system "Nintendo 64"
)
if [[ "$CAPTURE_SESSION" -eq 0 ]]; then
    ARES_ARGS+=(--kiosk)
fi
ARES_ARGS+=("$ROM")
exec "$ARES" "${ARES_ARGS[@]}"
