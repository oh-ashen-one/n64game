#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ROM="$ROOT/build/game/n64game-gate3.z64"
EXPECTED_ROM_SHA=""
EXPECTED_ROM_SHA_SET=0
EXPECTED_EEPROM_SHA=""
EXPECTED_EEPROM_SHA_SET=0
CHECK_ONLY=0
ROM_SET=0

for argument in "$@"; do
    case "$argument" in
        --homebrew-mode) ;;
        --check-only) CHECK_ONLY=1 ;;
        --expected-rom-sha256=*)
            if [[ "$EXPECTED_ROM_SHA_SET" -eq 1 ]]; then
                printf 'duplicate --expected-rom-sha256 argument\n' >&2
                exit 64
            fi
            EXPECTED_ROM_SHA_SET=1
            EXPECTED_ROM_SHA="${argument#*=}"
            ;;
        --expected-eeprom-sha256=*)
            if [[ "$EXPECTED_EEPROM_SHA_SET" -eq 1 ]]; then
                printf 'duplicate --expected-eeprom-sha256 argument\n' >&2
                exit 64
            fi
            EXPECTED_EEPROM_SHA_SET=1
            EXPECTED_EEPROM_SHA="${argument#*=}"
            ;;
        --*) printf 'unsupported argument: %s\n' "$argument" >&2; exit 64 ;;
        *)
            if [[ "$ROM_SET" -eq 1 ]]; then
                printf 'multiple ROM paths are not supported\n' >&2
                exit 64
            fi
            ROM_SET=1
            ROM="$argument"
            ;;
    esac
done

if [[ "$EXPECTED_ROM_SHA_SET" -eq 1 && ! "$EXPECTED_ROM_SHA" =~ ^[0-9a-f]{64}$ ]]; then
    printf 'expected ROM SHA-256 must be 64 lowercase hexadecimal characters\n' >&2
    exit 64
fi
if [[ "$EXPECTED_EEPROM_SHA_SET" -eq 1 && ! "$EXPECTED_EEPROM_SHA" =~ ^[0-9a-f]{64}$ ]]; then
    printf 'expected EEPROM SHA-256 must be 64 lowercase hexadecimal characters\n' >&2
    exit 64
fi

if [[ "$ROM" != /* ]]; then
    ROM="$ROOT/$ROM"
fi
if [[ ! -f "$ROM" || -L "$ROM" ]]; then
    printf 'ROM must be a non-symlink regular file: %s\n' "$ROM" >&2
    exit 1
fi

ACTUAL_ROM_SHA="$(shasum -a 256 "$ROM" | awk '{print $1}')"
if [[ "$EXPECTED_ROM_SHA_SET" -eq 1 && "$ACTUAL_ROM_SHA" != "$EXPECTED_ROM_SHA" ]]; then
    printf 'ROM SHA-256 mismatch: got %s expected %s\n' "$ACTUAL_ROM_SHA" "$EXPECTED_ROM_SHA" >&2
    exit 1
fi

ARES="${N64GAME_ARES_BINARY:-$HOME/Applications/Emulators/ares-v148/ares.app/Contents/MacOS/ares}"
EXPECTED_ARES_SHA="7a49f00f96a691458461d7c9cf453d95c0f5c054389bbd87c253987b8b6fa345"
test -f "$ARES"
test -x "$ARES"
test ! -L "$ARES"
ACTUAL_ARES_SHA="$(shasum -a 256 "$ARES" | awk '{print $1}')"
if [[ "$ACTUAL_ARES_SHA" != "$EXPECTED_ARES_SHA" ]]; then
    printf 'Ares executable SHA-256 mismatch: got %s expected %s\n' "$ACTUAL_ARES_SHA" "$EXPECTED_ARES_SHA" >&2
    exit 1
fi

STATE_ROOT="${N64GAME_ARES_STATE:-$HOME/Library/Application Support/ares-v148-n64game}"
mkdir -p "$STATE_ROOT/Systems" "$STATE_ROOT/Saves/Nintendo 64" "$STATE_ROOT/Screenshots" "$STATE_ROOT/Debugging"
VERSION_RAW="$($ARES --settings-file "$STATE_ROOT/settings.bml" --version)"
if [[ ! "$VERSION_RAW" =~ ^[[:space:]]*v148[[:space:]]*$ ]]; then
    printf 'unexpected Ares version output: %q\n' "$VERSION_RAW" >&2
    exit 1
fi
VERSION_CANONICAL="ares version v148"

printf 'ares_version=%s\nares_sha256=%s\nrom_sha256=%s\nhomebrew_mode=true\nexpansion_pak=false\ndefocus=allow\n' \
    "$VERSION_CANONICAL" "$ACTUAL_ARES_SHA" "$ACTUAL_ROM_SHA"

if [[ "$EXPECTED_EEPROM_SHA_SET" -eq 1 ]]; then
    ROM_FILENAME="$(basename "$ROM")"
    EEPROM_PATH="$STATE_ROOT/Saves/Nintendo 64/${ROM_FILENAME%.*}.eeprom"
    if [[ ! -f "$EEPROM_PATH" || -L "$EEPROM_PATH" ]]; then
        printf 'active Ares EEPROM must be a non-symlink regular file: %s\n' "$EEPROM_PATH" >&2
        exit 1
    fi
    EEPROM_BYTES="$(stat -f '%z' "$EEPROM_PATH")"
    if [[ "$EEPROM_BYTES" != "512" ]]; then
        printf 'active Ares EEPROM must be exactly 512 bytes: got %s\n' "$EEPROM_BYTES" >&2
        exit 1
    fi
    ACTUAL_EEPROM_SHA="$(shasum -a 256 "$EEPROM_PATH" | awk '{print $1}')"
    if [[ "$ACTUAL_EEPROM_SHA" != "$EXPECTED_EEPROM_SHA" ]]; then
        printf 'EEPROM SHA-256 mismatch: got %s expected %s\n' "$ACTUAL_EEPROM_SHA" "$EXPECTED_EEPROM_SHA" >&2
        exit 1
    fi
    printf 'eeprom_sha256=%s\n' "$ACTUAL_EEPROM_SHA"
fi

if [[ "$CHECK_ONLY" -eq 1 ]]; then
    exit 0
fi

exec "$ARES" \
    --settings-file "$STATE_ROOT/settings.bml" \
    --setting General/HomebrewMode=true \
    --setting Nintendo64/ExpansionPak=false \
    --setting Input/Driver=SDL \
    --setting Input/Defocus=Allow \
    --setting 'Nintendo64/Input/Controller.Port.1/Gamepad/Up=0x1/0/92;;' \
    --setting 'Nintendo64/Input/Controller.Port.1/Gamepad/Down=0x1/0/93;;' \
    --setting 'Nintendo64/Input/Controller.Port.1/Gamepad/Left=0x1/0/94;;' \
    --setting 'Nintendo64/Input/Controller.Port.1/Gamepad/Right=0x1/0/95;;' \
    --setting 'Nintendo64/Input/Controller.Port.1/Gamepad/B=0x1/0/63;;' \
    --setting 'Nintendo64/Input/Controller.Port.1/Gamepad/A=0x1/0/65;;' \
    --setting 'Nintendo64/Input/Controller.Port.1/Gamepad/C-Down=0x1/0/42;;' \
    --setting 'Nintendo64/Input/Controller.Port.1/Gamepad/Z=0x1/0/98;;' \
    --setting 'Nintendo64/Input/Controller.Port.1/Gamepad/Start=0x1/0/97;;' \
    --setting "Paths/Home=$STATE_ROOT/Systems/" \
    --setting "Paths/Saves=$STATE_ROOT/Saves/" \
    --setting "Paths/Screenshots=$STATE_ROOT/Screenshots/" \
    --setting "Paths/Debugging=$STATE_ROOT/Debugging/" \
    --system "Nintendo 64" \
    --kiosk \
    "$ROM"
