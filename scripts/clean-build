#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
TARGET="$ROOT/build"
ROOT_ROM="$ROOT/n64game-gate3.z64"
FILESYSTEM_TARGET="$ROOT/filesystem"
test "$TARGET" = "$ROOT/build"
test "$ROOT_ROM" = "$ROOT/n64game-gate3.z64"
test "$FILESYSTEM_TARGET" = "$ROOT/filesystem"
rm -rf "$TARGET"
rm -rf "$FILESYSTEM_TARGET"
rm -f "$ROOT_ROM"
