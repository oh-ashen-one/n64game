TEMP_DIRS = []
at_exit do
  TEMP_DIRS.each { |path| FileUtils.remove_entry_secure(path) if File.directory?(path) }
end

def strip_code(value)
  value.to_s.strip.sub(/\A`/, "").sub(/`\z/, "")
end

def table_cells(line)
  line.split("|", -1)[1...-1].map(&:strip)
end

def canonical_inventory_production_ids(body)
  sections = [
    ["## 3. Humanoid characters", "## 4. Echoforms", [0]],
    ["## 4. Echoforms and battle-slot resolution", "## 5. Authored environment", [0]],
    ["## 5. Authored environment", "## 6. Landmark assets", [0]],
    ["## 6. Landmark assets", "## 7. Purposeful prop inventory", [0]],
    ["## 7. Purposeful prop inventory", "## 8. Collision", [0]],
    ["## 8. Collision", "### 8.2 Zone-to-bundle", [0, 3, 5]],
    ["## 9. UI", "## 10. Battle move", [0]],
    ["## 10. Battle move", "## 11. Common", [0, 1]],
    ["## 11. Common", "## 12. Animation", [0]],
    ["## 12. Animation", "## 13. Music", [0]],
    ["## 13. Music", "## 14. Boot", [0]],
    ["## 15. Opening storyboard", "## 16. Evidence", [0]]
  ]
  sections.flat_map do |start_marker, end_marker, owner_columns|
    between(body, start_marker, end_marker).lines.each_with_object([]) do |line, ids|
      next unless line.start_with?("| `")
      cells = table_cells(line)
      ids.concat(owner_columns.flat_map do |column|
        cells.fetch(column, "").scan(/`([a-z][a-z0-9_]*(?:\.[a-z0-9_]+)+)`/).flatten
      end)
    end
  end
end

def parse_ledger_entries(body, label)
  ledger_table = between(body, "## Ledger", "### Required provenance record")
  entries = ledger_table.lines.each_with_object([]) do |line, rows|
    next unless line.start_with?("| `")

    cells = table_cells(line).map { |cell| strip_code(cell) }
    unless cells.length == 15
      error("#{label}: explicit ledger row must have exactly 15 columns")
      next
    end
    entry = {
      id: cells[0], relation: cells[1], profile_tier: cells[2], purpose: cells[3], status: cells[4],
      creator: cells[5], provenance: cells[6], rights: cells[7], transforms: cells[8], source: cells[9],
      output: cells[10], license: cells[11], gates: cells[12], evidence: cells[13], notes: cells[14]
    }
    error("#{label} #{entry[:id]}: invalid case-sensitive ledger status #{entry[:status].inspect}") unless STATUS_VALUES.include?(entry[:status])
    rows << entry
  end
  exact_set("#{label} explicit production ledger IDs", entries.map { |entry| entry[:id] }, entries.map { |entry| entry[:id] }.uniq)
  entries
end

def validate_ledger_scaffold(entries, inventory_body, label)
  entries.each do |entry|
    inventory_row = inventory_body.lines.any? { |line| line.start_with?("| `#{entry[:id]}` |") }
    error("#{label} #{entry[:id]}: ID does not resolve to an exact inventory table row") unless inventory_row
    expected = expected_profile_tier(entry[:id])
    error("#{label} #{entry[:id]}: no deterministic profile/tier mapping") unless expected
    error("#{label} #{entry[:id]}: profile/tier differs from canonical mapping") unless
      expected && entry[:profile_tier] == expected.join(" / ")
    next unless entry[:status] == "planned"

    error("#{label} #{entry[:id]}: planned source/output/evidence must be literal PENDING") unless
      entry[:source] == "PENDING" && entry[:output] == "PENDING" && entry[:evidence] == "PENDING"
    error("#{label} #{entry[:id]}: planned row must retain exact G1..G7=PENDING shorthand") unless
      entry[:gates].start_with?("G1..G7=PENDING") &&
      !entry[:gates].match?(/(?:^|[; ])G[1-7]=(?!PENDING)/)
    [entry[:provenance], entry[:rights], entry[:transforms]].each do |cell|
      error("#{label} #{entry[:id]}: planned row cannot claim a hashed production binding") if
        cell.match?(/[A-Za-z0-9._\/-]+@[0-9a-f]{64}/)
    end
  end
end

def safe_repo_path?(relative)
  return false unless relative.is_a?(String)
  portable = relative.match?(/\A[A-Za-z0-9][A-Za-z0-9._\/-]*\z/) || relative.match?(WORKFLOW_PATH)
  return false unless portable
  return false if relative.start_with?("/", "./") || relative.end_with?("/") || relative.include?("//") || relative.include?("\\")

  relative.split("/").none? { |component| component.empty? || component == "." || component == ".." }
end

def validate_sole_payload_workflow(context, selected_path, label)
  workflow_members = context[:closure].select { |path| path.start_with?(".github/workflows/") }.sort
  workflow_members.each do |path|
    error("#{label}: payload workflow path is noncanonical or not .yml: #{path}") unless path.match?(WORKFLOW_PATH)
  end
  expected = selected_path == "PENDING" ? [] : [selected_path]
  error("#{label}: payload must contain exactly its selected sole public workflow") unless workflow_members == expected
end

def regular_without_symlink?(relative, root: ROOT)
  return false unless safe_repo_path?(relative)

  cursor = Pathname.new(root)
  relative.split("/").each do |component|
    cursor = cursor.join(component)
    return false unless cursor.exist? || cursor.symlink?
    return false if cursor.symlink?
  end
  cursor.file?
end

def git_capture(*args, root: ROOT, env: {}, unsetenv_others: false, stdin_data: nil)
  isolated = unsetenv_others || Pathname.new(root).expand_path != ROOT.expand_path
  effective_env = isolated ? public_clone_env.merge(env) : env
  git_binary = isolated ? PUBLIC_GIT_BINARY : "git"
  Open3.capture3(
    effective_env, git_binary, *args, chdir: root.to_s, unsetenv_others: isolated,
    stdin_data: stdin_data
  )
end

def canonical_lfs_pointer(bytes)
  match = bytes.match(/\Aversion https:\/\/git-lfs\.github\.com\/spec\/v1\noid sha256:([0-9a-f]{64})\nsize (0|[1-9][0-9]*)\n\z/)
  match && { oid: match[1], size: match[2].to_i }
end

def materialized_commit_file(relative, commit, label, fresh_clone: nil, allow_lfs: true)
  unless safe_repo_path?(relative)
    error("#{label} path is unsafe: #{relative}")
    return nil
  end
  unless commit
    unless regular_without_symlink?(relative)
      error("#{label} path is missing, non-regular, or traverses a symlink: #{relative}")
      return nil
    end
    local_bytes = File.binread(ROOT.join(relative))
    return {
      bytes: local_bytes, kind: :working, mode: nil,
      digest: Digest::SHA256.hexdigest(local_bytes), size: local_bytes.bytesize
    }
  end

  commit_root = fresh_clone || ROOT
  tree_out, _tree_err, tree_status = git_capture("ls-tree", commit, "--", relative, root: commit_root)
  tree_mode = tree_out[/\A(\d{6})\s+blob\s+[0-9a-f]+\t/, 1]
  unless tree_status.success? && %w[100644 100755].include?(tree_mode)
    error("#{label} reviewed tree entry is missing, symlinked, non-blob, or submodule: #{relative}")
    return nil
  end
  blob, _blob_err, blob_status = git_capture("show", "#{commit}:#{relative}", root: commit_root)
  unless blob_status.success?
    error("#{label} is absent from reviewed payload commit: #{relative}")
    return nil
  end
  pointer = canonical_lfs_pointer(blob.b)
  attr_out, _attr_err, attr_status = git_capture(
    "check-attr", "--source=#{commit}", "filter", "--", relative, root: commit_root
  )
  lfs_attribute = attr_status.success? && attr_out.to_s.split(":", 3).last.to_s.strip == "lfs"
  if pointer
    unless allow_lfs
      error("#{label} uses Git LFS where ordinary Git text is required: #{relative}")
      return nil
    end
    error("#{label} canonical LFS pointer lacks filter=lfs at reviewed commit: #{relative}") unless lfs_attribute
    object_bytes = nil
    if fresh_clone
      git_dir_out, _git_dir_err, git_dir_status = git_capture("rev-parse", "--git-dir", root: fresh_clone)
      if git_dir_status.success?
        git_dir = Pathname.new(git_dir_out.strip)
        git_dir = Pathname.new(fresh_clone).join(git_dir) unless git_dir.absolute?
        object = git_dir.join("lfs", "objects", pointer[:oid][0, 2], pointer[:oid][2, 2], pointer[:oid])
        if object.file?
          object_bytes = File.binread(object)
        end
        unless object_bytes && Digest::SHA256.hexdigest(object_bytes) == pointer[:oid] && object_bytes.bytesize == pointer[:size]
          error("#{label} LFS object is not retrievable/valid in fresh public clone: #{relative}")
        end
      else
        error("#{label} cannot resolve fresh-clone Git directory for LFS verification")
      end
    else
      error("#{label} commit-bound LFS verification requires a fresh public clone: #{relative}")
    end
    object_bytes ||= "".b
    return {
      bytes: object_bytes, kind: :lfs, mode: tree_mode,
      digest: Digest::SHA256.hexdigest(object_bytes), size: object_bytes.bytesize, oid: pointer[:oid]
    }
  end

  if lfs_attribute
    error("#{label} has filter=lfs but reviewed blob is not a canonical LFS pointer: #{relative}")
    return nil
  end
  {
    bytes: blob.b, kind: :git, mode: tree_mode,
    digest: Digest::SHA256.hexdigest(blob.b), size: blob.bytesize
  }
end

def validate_path_hash(value, label, commit: nil, fresh_clone: nil, allow_lfs: true)
  path, digest = value.to_s.split("@", 2)
  unless path && digest && safe_repo_path?(path) && digest.match?(HEX64)
    error("#{label} must be safe repo-relative path@64-lowercase-hex")
    return nil
  end
  material = materialized_commit_file(path, commit, label, fresh_clone: fresh_clone, allow_lfs: allow_lfs)
  return nil unless material

  error("#{label} SHA-256 mismatch for #{path}") unless material[:digest] == digest
  material.merge(path: path, expected_digest: digest)
end

def new_manifest_context
  {
    manifests: {},
    manifest_digests: {},
    member_owner: {},
    casefold_owner: {},
    content_owner: {},
    capture_owner: {},
    closure: Set.new,
    entries: {}
  }
end

def validate_manifest(relative, expected_digest, label, stack = [], commit = nil, fresh_clone = nil, context = nil,
                      ancestor_digests = [])
  context ||= new_manifest_context
  if context[:manifests].key?(relative)
    error("#{label} cached manifest SHA-256 differs from caller binding") unless
      context[:manifest_digests][relative] == expected_digest
    return context[:manifests][relative]
  end
  manifest_casefold = relative.downcase
  prior_manifest_casefold = context[:casefold_owner][manifest_casefold]
  if prior_manifest_casefold && prior_manifest_casefold != relative
    error("#{label} manifest path case-collides across the graph: #{prior_manifest_casefold} / #{relative}")
  end
  context[:casefold_owner][manifest_casefold] ||= relative
  unless safe_repo_path?(relative) && (commit || regular_without_symlink?(relative))
    error("#{label} manifest path is unsafe, missing, non-regular, or symlinked: #{relative}")
    return []
  end
  if stack.include?(relative)
    error("#{label} manifest dependency cycle: #{(stack + [relative]).join(' -> ')}")
    return []
  end

  manifest_material = materialized_commit_file(relative, commit, label, fresh_clone: fresh_clone, allow_lfs: false)
  return [] unless manifest_material
  bytes = manifest_material[:bytes]
  actual_manifest_digest = Digest::SHA256.hexdigest(bytes)
  error("#{label} manifest SHA-256 mismatch") unless actual_manifest_digest == expected_digest
  utf8 = bytes.dup.force_encoding(Encoding::UTF_8)
  error("#{label} manifest is not valid UTF-8") unless utf8.valid_encoding?
  error("#{label} manifest has a BOM") if bytes.start_with?("\xEF\xBB\xBF".b)
  error("#{label} manifest must use LF only") if bytes.include?("\r")
  error("#{label} manifest must have exactly one final LF") unless bytes.end_with?("\n") && !bytes.end_with?("\n\n")
  lines = bytes.split("\n", -1)
  lines.pop if lines.last == ""
  error("#{label} manifest contains blank/comment lines") if lines.empty? || lines.any? { |line| line.empty? || line.start_with?("#") }

  member_paths = []
  entries = []
  lines.each_with_index do |line, index|
    fields = line.split("\t", -1)
    unless fields.length == 6
      error("#{label} manifest line #{index + 1} must have exactly six TAB fields")
      next
    end
    path, count, digest, build, capture, role = fields
    member_paths << path
    error("#{label} member path is unsafe: #{path}") unless safe_repo_path?(path)
    error("#{label} cannot list itself") if path == relative
    error("#{label} byte count is non-canonical for #{path}") unless count.match?(/\A(?:0|[1-9][0-9]*)\z/)
    error("#{label} member digest is malformed for #{path}") unless digest.match?(HEX64)
    error("#{label} build token is malformed for #{path}") unless build.match?(/\Abuild:(?:-|[A-Za-z0-9][A-Za-z0-9._-]{0,95})\z/)
    error("#{label} capture token is malformed for #{path}") unless capture.match?(/\Acapture:(?:-|[A-Za-z0-9][A-Za-z0-9._-]{0,95})\z/)
    error("#{label} role token is malformed for #{path}") unless role.match?(/\Arole:[a-z][a-z0-9._-]{0,63}\z/) && !%w[role:file role:misc].include?(role)
    error("#{label} forbids remote/release locator evidence role: #{path}") if role.match?(/(?:remote|locator|release_url|url_object)/)
    next unless safe_repo_path?(path) && (commit || regular_without_symlink?(path))

    member_material = materialized_commit_file(path, commit, "#{label} member", fresh_clone: fresh_clone, allow_lfs: true)
    next unless member_material
    member_bytes = member_material[:bytes]
    error("#{label} byte count mismatch for #{path}") unless member_bytes.bytesize.to_s == count
    member_digest = Digest::SHA256.hexdigest(member_bytes)
    error("#{label} member SHA-256 mismatch for #{path}") unless member_digest == digest
    (ancestor_digests + [actual_manifest_digest]).each do |ancestor_digest|
      if member_bytes.include?(ancestor_digest)
        error("#{label} member directly/transitively embeds an ancestor manifest digest: #{path}")
      end
    end
    if BINARY_LFS_EXTENSIONS.include?(File.extname(path).downcase) && commit
      error("#{label} binary art/evidence member must be canonical Git LFS: #{path}") unless member_material[:kind] == :lfs
    end
    prior_owner = context[:member_owner][path]
    error("#{label} member has multiple direct/nested manifest owners: #{path}") if prior_owner && prior_owner != relative
    context[:member_owner][path] ||= relative
    casefold_path = path.downcase
    prior_casefold_path = context[:casefold_owner][casefold_path]
    if prior_casefold_path && prior_casefold_path != path
      error("#{label} member case-collides across the manifest graph: #{prior_casefold_path} / #{path}")
    end
    context[:casefold_owner][casefold_path] ||= path
    prior_digest_path = context[:content_owner][member_digest]
    error("#{label} duplicate materialized content hash under different paths: #{prior_digest_path} / #{path}") if prior_digest_path && prior_digest_path != path
    context[:content_owner][member_digest] ||= path
    capture_id = capture.sub(/\Acapture:/, "")
    if capture_id != "-"
      prior_capture_path = context[:capture_owner][capture_id]
      error("#{label} capture ID is owned by multiple members: #{capture_id}") if prior_capture_path && prior_capture_path != path
      context[:capture_owner][capture_id] ||= path
    end
    entry = {
      path: path, count: count.to_i, digest: digest, build: build.sub(/\Abuild:/, ""),
      capture: capture_id, role: role.sub(/\Arole:/, ""), kind: member_material[:kind],
      mode: member_material[:mode]
    }
    entries << entry
    context[:closure] << path
    context[:entries][path] = entry
    if File.basename(path).end_with?("MANIFEST.sha256")
      validate_manifest(
        path, digest, "#{label}/#{path}", stack + [relative], commit, fresh_clone, context,
        ancestor_digests + [actual_manifest_digest]
      )
    end
  end
  error("#{label} members are not raw-byte path sorted") unless member_paths == member_paths.sort
  error("#{label} has duplicate member paths") unless member_paths.uniq.length == member_paths.length
  error("#{label} has case-colliding member paths") unless member_paths.map(&:downcase).uniq.length == member_paths.length
  context[:manifests][relative] = entries
  context[:manifest_digests][relative] = actual_manifest_digest
  context[:closure] << relative
  entries
end

def parse_tsv(path_hash, label, header, row_count, commit: nil, fresh_clone: nil, payload_context: nil)
  validated = validate_path_hash(path_hash, label, commit: commit, fresh_clone: fresh_clone, allow_lfs: false)
  return [] unless validated
  if payload_context && !payload_context[:closure].include?(validated[:path])
    error("#{label} is not owned by benchmark payload manifest: #{validated[:path]}")
  end
  bytes = validated[:bytes]
  utf8 = bytes.dup.force_encoding(Encoding::UTF_8)
  error("#{label} must be valid UTF-8") unless utf8.valid_encoding?
  error("#{label} must not have BOM") if bytes.start_with?("\xEF\xBB\xBF".b)
  error("#{label} must be LF-only") if bytes.include?("\r")
  error("#{label} must have exactly one final LF") unless bytes.end_with?("\n") && !bytes.end_with?("\n\n")
  lines = bytes.split("\n", -1)
  lines.pop if lines.last == ""
  error("#{label} contains blank/comment lines") if lines.any? { |line| line.empty? || line.start_with?("#") }
  actual_header = lines.shift.to_s.split("\t", -1)
  error("#{label} header mismatch") unless actual_header == header
  error("#{label} must contain exactly #{row_count} data rows; got #{lines.length}") unless lines.length == row_count
  rows = lines.map.with_index do |line, index|
    fields = line.split("\t", -1)
    error("#{label} row #{index + 1} must have exactly #{header.length} fields") unless fields.length == header.length
    fields
  end
  rows.select { |row| row.length == header.length }
end

def parse_variable_tsv(path_hash, label, header, minimum_rows:, commit:, fresh_clone:, payload_context: nil)
  material = validate_path_hash(path_hash, label, commit: commit, fresh_clone: fresh_clone, allow_lfs: false)
  return [] unless material
  row_count = [material[:bytes].split("\n", -1).length - 2, 0].max
  rows = parse_tsv(
    path_hash, label, header, row_count, commit: commit, fresh_clone: fresh_clone,
    payload_context: payload_context
  )
  error("#{label} must contain at least #{minimum_rows} data rows") if rows.length < minimum_rows
  rows
end

def same_repo_slug
  remote, _err, status = git_capture(
    "remote", "get-url", "origin", unsetenv_others: true
  )
  return nil unless status.success?
  url = remote.strip
  match = url.match(%r{\A(?:https://github\.com/|git@github\.com:)([A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+?)(?:\.git)?\z})
  match && match[1]
end

def public_clone_env
  {
    "PATH" => PUBLIC_CLONE_PATH,
    "LANG" => "C.UTF-8",
    "LC_ALL" => "C.UTF-8",
    "GIT_TERMINAL_PROMPT" => "0",
    "GCM_INTERACTIVE" => "never",
    "GIT_ASKPASS" => "/usr/bin/false",
    "GIT_ASKPASS_REQUIRE" => "force",
    "GIT_CONFIG_GLOBAL" => "/dev/null",
    "GIT_CONFIG_NOSYSTEM" => "1",
    "GIT_NO_REPLACE_OBJECTS" => "1",
    "GH_TOKEN" => nil,
    "GITHUB_TOKEN" => nil,
    "GITLAB_TOKEN" => nil
  }
end

def public_git_capture(slug, *args, root: ROOT)
  if args.first == "ls-remote"
    return Dir.mktmpdir("n64game-public-git-neutral-") do |neutral_root|
      git_capture(
        "-c", "credential.helper=", "-c", "http.extraHeader=", *args,
        root: neutral_root, env: public_clone_env, unsetenv_others: true
      )
    end
  end
  git_capture(
    "-c", "credential.helper=", "-c", "http.extraHeader=", *args,
    root: root, env: public_clone_env, unsetenv_others: true
  )
end

def prepare_fresh_public_clone(slug, payload_commit, tag_ref)
  root = Dir.mktmpdir("n64game-art-verify-")
  TEMP_DIRS << root
  clone = File.join(root, "repo")
  _out, err, status = Open3.capture3(
    public_clone_env,
    PUBLIC_GIT_BINARY, "-c", "credential.helper=", "-c", "http.extraHeader=", "clone", "--no-checkout", "--quiet",
    "https://github.com/#{slug}.git", clone, chdir: root, unsetenv_others: true
  )
  unless status.success?
    error("credential-free fresh public clone failed: #{err.lines.first.to_s.strip}")
    return nil
  end
  public_url = "https://github.com/#{slug}.git"
  _fetch_out, fetch_err, fetch_status = public_git_capture(slug, "fetch", "--force", public_url, "#{tag_ref}:#{tag_ref}", root: clone)
  error("fresh public clone cannot fetch exact approval tag: #{fetch_err.lines.first.to_s.strip}") unless fetch_status.success?
  _commit_out, _commit_err, commit_status = git_capture("cat-file", "-e", "#{payload_commit}^{commit}", root: clone)
  error("payload commit is not reachable in fresh public clone") unless commit_status.success?
  _lfs_out, lfs_err, lfs_status = public_git_capture(slug, "lfs", "fetch", public_url, payload_commit, tag_ref, root: clone)
  error("fresh public clone Git LFS fetch failed: #{lfs_err.lines.first.to_s.strip}") unless lfs_status.success?
  clone
end

def prepare_fresh_public_payload_clone(slug, payload_commit)
  root = Dir.mktmpdir("n64game-preapproval-verify-")
  TEMP_DIRS << root
  clone = File.join(root, "repo")
  _out, clone_error, clone_status = Open3.capture3(
    public_clone_env,
    PUBLIC_GIT_BINARY, "-c", "credential.helper=", "-c", "http.extraHeader=", "clone", "--no-checkout", "--quiet",
    "https://github.com/#{slug}.git", clone, chdir: root, unsetenv_others: true
  )
  unless clone_status.success?
    error("credential-free preapproval public clone failed: #{clone_error.lines.first.to_s.strip}")
    return nil
  end
  _commit_out, _commit_error, commit_status = git_capture("cat-file", "-e", "#{payload_commit}^{commit}", root: clone)
  unless commit_status.success?
    _fetch_out, fetch_error, fetch_status = public_git_capture(
      slug, "fetch", "--force", "https://github.com/#{slug}.git", payload_commit, root: clone
    )
    error("preapproval payload commit is not public/reachable: #{fetch_error.lines.first.to_s.strip}") unless fetch_status.success?
    _verify_out, _verify_error, commit_status = git_capture("cat-file", "-e", "#{payload_commit}^{commit}", root: clone)
  end
  return nil unless commit_status.success?
  _lfs_out, lfs_error, lfs_status = public_git_capture(
    slug, "lfs", "fetch", "https://github.com/#{slug}.git", payload_commit, root: clone
  )
  unless lfs_status.success?
    error("preapproval fresh public-clone Git LFS fetch failed: #{lfs_error.lines.first.to_s.strip}")
    return nil
  end
  clone
end

def prepare_fresh_advertised_public_head(slug, label)
  unless slug == N64Game::PublicCommitAuthority::REPOSITORY
    error("#{label} requires exact public repository #{N64Game::PublicCommitAuthority::REPOSITORY}")
    return nil
  end

  status_out, status_error, status_status = git_capture(
    "status", "--porcelain=v1", "-z", "--untracked-files=all", "--ignore-submodules=none",
    unsetenv_others: true
  )
  unless status_status.success?
    error("#{label} cannot inspect local worktree/index: #{status_error.lines.first.to_s.strip}")
    return nil
  end
  head_out, head_error, head_status = git_capture(
    "rev-parse", "HEAD^{commit}", unsetenv_others: true
  )
  local_head = head_out.strip
  unless head_status.success? && local_head.match?(HEX40)
    error("#{label} cannot resolve canonical local HEAD: #{head_error.lines.first.to_s.strip}")
    return nil
  end

  public_url = N64Game::PublicCommitAuthority::PUBLIC_URL
  advertised_out, advertised_error, advertised_status = public_git_capture(
    slug, "ls-remote", "--refs", public_url,
    "refs/heads/*", "refs/pull/*/head", "refs/pull/*/merge"
  )
  unless advertised_status.success?
    error("#{label} cannot discover credential-free advertised refs: #{advertised_error.lines.first.to_s.strip}")
    return nil
  end
  branch_ref_valid = lambda do |ref|
    _format_out, _format_error, format_status = public_git_capture(slug, "check-ref-format", ref)
    format_status.success?
  end
  begin
    authority = N64Game::PublicCommitAuthority.select_advertised_ref!(
      head: local_head, status_bytes: status_out, advertised_bytes: advertised_out,
      branch_ref_valid: branch_ref_valid
    )
  rescue N64Game::PublicCommitAuthority::Violation => violation
    violation.issues.each { |issue| error("#{label}: #{issue}") }
    return nil
  end

  root = Dir.mktmpdir("n64game-advertised-head-")
  TEMP_DIRS << root
  begin
    clone = N64Game::PublicCommitAuthority.clone_and_fetch!(
      remote_url: public_url, selected_ref: authority["ref"], expected_head: local_head,
      root: root, env: public_clone_env
    )
  rescue N64Game::PublicCommitAuthority::Violation => violation
    violation.issues.each { |issue| error("#{label}: #{issue}") }
    return nil
  end
  PUBLIC_AUTHORITY_EXECUTION_PATHS.each do |path|
    material = materialized_commit_file(
      path, local_head, "#{label} execution dependency #{path}",
      fresh_clone: clone, allow_lfs: false
    )
    local_bytes = regular_without_symlink?(path) ? File.binread(ROOT.join(path)) : nil
    error("#{label} local execution dependency differs from verified advertised revision: #{path}") unless
      material && local_bytes && material[:bytes].b == local_bytes.b
  end
  authority.merge("fresh_clone" => clone)
end

def validate_staged_control_transaction(authority, reviewed_payload_commit)
  return false unless authority && reviewed_payload_commit&.match?(HEX40)

  clone = authority["fresh_clone"]
  public_head = authority["commit"]
  control_path = "docs/VISUAL_BENCHMARK_APPROVAL.md"
  control_out, control_error, control_status = git_capture(
    "rev-list", "-1", public_head, "--", control_path, root: clone
  )
  control_commit = control_out.strip
  error("staged benchmark transaction cannot resolve its control commit: #{control_error.lines.first.to_s.strip}") unless
    control_status.success? && control_commit.match?(HEX40)

  parents = []
  if control_commit.match?(HEX40)
    parents_out, parents_error, parents_status = git_capture(
      "rev-list", "--parents", "-n", "1", control_commit, root: clone
    )
    if parents_status.success?
      parent_fields = parents_out.strip.split(" ")
      parents = parent_fields.first == control_commit ? parent_fields.drop(1) : []
    else
      error("staged benchmark transaction cannot resolve control parents: #{parents_error.lines.first.to_s.strip}")
    end
  end
  changed_paths = []
  if control_commit.match?(HEX40) && parents.length == 1
    diff_out, diff_error, diff_status = git_capture(
      "diff", "--name-only", "-z", parents.first, control_commit, "--", root: clone
    )
    if diff_status.success?
      changed_paths = diff_out.split("\0").reject(&:empty?)
    else
      error("staged benchmark transaction cannot enumerate payload/control diff: #{diff_error.lines.first.to_s.strip}")
    end
  end
  _lineage_out, _lineage_error, lineage_status = git_capture(
    "merge-base", "--is-ancestor", control_commit, public_head, root: clone
  )
  _public_out, _public_error, public_status = git_capture(
    "cat-file", "-e", "#{control_commit}^{commit}", root: clone
  )
  control_at_transaction, _transaction_error, transaction_status = git_capture(
    "show", "#{control_commit}:#{control_path}", root: clone
  )
  control_at_head, _head_error, head_status = git_capture(
    "show", "#{public_head}:#{control_path}", root: clone
  )
  control_tree_out, _control_tree_error, control_tree_status = git_capture(
    "rev-parse", "#{control_commit}^{tree}", root: clone
  )
  public_tree_out, _public_tree_error, public_tree_status = git_capture(
    "rev-parse", "#{public_head}^{tree}", root: clone
  )
  begin
    N64Game::PublicCommitAuthority.validate_control_transaction!(
      public_head: public_head, control_commit: control_commit, parents: parents,
      reviewed_payload_commit: reviewed_payload_commit, changed_paths: changed_paths,
      current_descends_from_control: lineage_status.success?, control_public: public_status.success?,
      control_bytes_equal: transaction_status.success? && head_status.success? &&
        control_at_transaction.b == control_at_head.b,
      public_tree_equal: control_tree_status.success? && public_tree_status.success? &&
        control_tree_out.strip.match?(HEX40) && control_tree_out.strip == public_tree_out.strip
    )
  rescue N64Game::PublicCommitAuthority::Violation => violation
    violation.issues.each { |issue| error("staged benchmark transaction: #{issue}") }
    return false
  end

  true
end

def production_root_paths(root: ROOT)
  %w[assets-src review].each_with_object(Set.new) do |root_name, paths|
    absolute_root = Pathname.new(root).join(root_name)
    next unless absolute_root.exist?
    Dir.glob(absolute_root.join("**", "*").to_s, File::FNM_DOTMATCH).each do |absolute|
      next if [".", ".."].include?(File.basename(absolute))
      paths << Pathname.new(absolute).relative_path_from(Pathname.new(root)).to_s if
        File.file?(absolute) || File.symlink?(absolute)
    end
  end
end

def verify_pinned_ssh_signature(signed_bytes, signature_bytes, report: true)
  Dir.mktmpdir("n64game-ssh-verify-") do |dir|
    allowed = File.join(dir, "allowed_signers")
    signature = File.join(dir, "signature")
    File.binwrite(allowed, "#{PINNED_SSH_PRINCIPAL} #{PINNED_SSH_PUBLIC_KEY}\n")
    File.binwrite(signature, signature_bytes)
    out, err, status = Open3.capture3(
      "ssh-keygen", "-Y", "verify", "-f", allowed, "-I", PINNED_SSH_PRINCIPAL,
      "-n", "git", "-s", signature, stdin_data: signed_bytes
    )
    error("approval SSH signature failed pinned-key verification: #{(out + err).lines.first.to_s.strip}") if report && !status.success?
    status.success?
  end
end

def http_get(uri, redirects: 5, &block)
  raise "too many redirects" if redirects.negative?
  raise "HTTPS required" unless uri.is_a?(URI::HTTPS)
  http = Net::HTTP.new(uri.host, uri.port)
  http.use_ssl = true
  http.open_timeout = 15
  http.read_timeout = 60
  request = Net::HTTP::Get.new(uri.request_uri, "User-Agent" => "n64game-asset-validator", "Accept" => "application/vnd.github+json")
  http.request(request) do |response|
    if response.is_a?(Net::HTTPRedirection)
      location = URI.join(uri, response.fetch("location"))
      allowed = location.host == "github.com" || location.host == "api.github.com" || location.host.end_with?(".githubusercontent.com") || location.host.end_with?(".github.com")
      raise "redirect host is not allowed: #{location.host}" unless allowed
      return http_get(location, redirects: redirects - 1, &block)
    end
    raise "HTTP #{response.code}" unless response.is_a?(Net::HTTPSuccess)
    return block.call(response)
  end
end

def http_json(url, label)
  body = http_get(URI(url)) { |response| response.body }
  JSON.parse(body)
rescue StandardError => e
  error("#{label} public verification failed: #{e.message}")
  nil
end

def download_identity(url, label)
  digest = Digest::SHA256.new
  count = 0
  header = +"".b
  http_get(URI(url)) do |response|
    response.read_body do |chunk|
      digest.update(chunk)
      count += chunk.bytesize
      header << chunk.byteslice(0, [64 - header.bytesize, chunk.bytesize].min) if header.bytesize < 64
    end
  end
  error("#{label} is not a big-endian .z64 image (missing 80 37 12 40 magic)") unless
    header.start_with?(N64_BIG_ENDIAN_MAGIC)
  { digest: digest.hexdigest, size: count, header_digest: Digest::SHA256.hexdigest(header) }
rescue StandardError => e
  error("#{label} public bytes verification failed: #{e.message}")
  nil
end

def rom_identity(bytes, label)
  error("#{label} is shorter than the 64-byte ROM header") if bytes.bytesize < 64
  error("#{label} is not a big-endian .z64 image (missing 80 37 12 40 magic)") unless
    bytes.start_with?(N64_BIG_ENDIAN_MAGIC)
  {
    digest: Digest::SHA256.hexdigest(bytes), size: bytes.bytesize,
    header_digest: Digest::SHA256.hexdigest(bytes.byteslice(0, 64).to_s)
  }
end

def pinned_tool_available?(command, version_args, expected_prefix, label)
  output, tool_error, status = Open3.capture3(command, *version_args)
  unless status.success? && output.start_with?(expected_prefix)
    error("#{label} is missing or not at pinned version #{expected_prefix.strip}: #{tool_error.lines.first.to_s.strip}")
    return false
  end
  true
rescue Errno::ENOENT => e
  error("#{label} is required and unavailable: #{e.message}")
  false
end

def probe_mp4(bytes, label)
  return nil unless pinned_tool_available?("ffprobe", ["-version"], PINNED_FFPROBE_VERSION, "ffprobe")
  Dir.mktmpdir("n64game-mp4-probe-") do |dir|
    media_path = File.join(dir, "evidence.mp4")
    File.binwrite(media_path, bytes)
    output, probe_error, status = Open3.capture3(
      "ffprobe", "-v", "error", "-count_frames",
      "-show_entries", "stream=codec_type,codec_name,width,height,duration,avg_frame_rate,nb_read_frames:format=duration",
      "-of", "json", "--", media_path
    )
    unless status.success?
      error("#{label} fails pinned ffprobe decode: #{probe_error.lines.first.to_s.strip}")
      return nil
    end
    parsed = JSON.parse(output)
    streams = Array(parsed["streams"])
    stream = streams.find { |candidate| candidate["codec_type"] == "video" }
    unless stream
      error("#{label} has no decodable video stream")
      return nil
    end
    codec = stream["codec_name"].to_s
    width = canonical_integer(stream["width"])
    height = canonical_integer(stream["height"])
    stream_duration = stream["duration"].to_s
    duration_text = stream_duration.empty? || stream_duration == "N/A" ? parsed.dig("format", "duration") : stream_duration
    duration = Float(duration_text)
    decoded_video_frames = canonical_integer(stream["nb_read_frames"])
    frame_rate_parts = stream["avg_frame_rate"].to_s.split("/", 2)
    frame_rate = if frame_rate_parts.length == 2 && frame_rate_parts[1] != "0"
                   Float(frame_rate_parts[0]) / Float(frame_rate_parts[1])
                 else
                   Float(stream["avg_frame_rate"])
                 end
    unless codec == "h264" && width&.positive? && height&.positive? && duration.finite? && duration.positive? &&
           frame_rate.finite? && frame_rate >= 30.0 && decoded_video_frames&.positive?
      error("#{label} must decode positive H.264 frames at >=30 fps with positive dimensions/duration")
      return nil
    end
    error("#{label} video dimensions must be exact 4:3") unless width * 3 == height * 4
    audio_stream = streams.find do |candidate|
      candidate["codec_type"] == "audio" && !candidate["codec_name"].to_s.empty? &&
        canonical_integer(candidate["nb_read_frames"])&.positive?
    end
    {
      codec: codec, width: width, height: height, duration_ms: (duration * 1000).round,
      frame_rate: frame_rate, frames: decoded_video_frames, audio: !audio_stream.nil?
    }
  end
rescue JSON::ParserError, ArgumentError, TypeError => e
  error("#{label} ffprobe output is invalid: #{e.message}")
  nil
end

def decode_video_framehash(bytes, label)
  return [] unless pinned_tool_available?("ffmpeg", ["-version"], PINNED_FFMPEG_VERSION, "ffmpeg")
  Dir.mktmpdir("n64game-framehash-") do |dir|
    media_path = File.join(dir, "capture.mp4")
    File.binwrite(media_path, bytes)
    output, decode_error, status = Open3.capture3(
      "ffmpeg", "-v", "error", "-i", media_path, "-map", "0:v:0", "-vsync", "0",
      "-pix_fmt", "rgb24", "-f", "framehash", "-hash", "sha256", "-"
    )
    unless status.success?
      error("#{label} fails pinned ffmpeg framehash decode: #{decode_error.lines.first.to_s.strip}")
      return []
    end
    timebase_match = output.match(/^#tb 0:\s*(\d+)\/(\d+)\s*$/)
    unless timebase_match && timebase_match[2] != "0"
      error("#{label} framehash lacks canonical stream-0 timebase")
      return []
    end
    numerator = timebase_match[1].to_i
    denominator = timebase_match[2].to_i
    frames = output.lines.reject { |line| line.start_with?("#") || line.strip.empty? }.map.with_index do |line, index|
      fields = line.split(",", -1).map(&:strip)
      unless fields.length == 6 && fields[0] == "0" && fields[1].match?(/\A-?\d+\z/) &&
             fields[2].match?(/\A-?\d+\z/) && fields[3].match?(/\A[1-9]\d*\z/) && fields[5].match?(HEX64)
        error("#{label} framehash row #{index + 1} is malformed")
        next
      end
      pts = fields[2].to_i
      duration = fields[3].to_i
      {
        index: index,
        start_us: (Rational(pts * numerator, denominator) * 1_000_000).round,
        frame_time_us: (Rational(duration * numerator, denominator) * 1_000_000).round,
        rgb_sha256: fields[5]
      }
    end.compact
    error("#{label} framehash rows must have positive ordered timing") unless
      frames.each_cons(2).all? { |left, right| right[:start_us] > left[:start_us] } &&
      frames.all? { |frame| frame[:frame_time_us].positive? }
    frames
  end
end

def derive_telemetry_metrics(rows)
  raise ArgumentError, "telemetry must contain at least 1800 frames" if rows.length < 1800
  parsed = rows.each_with_index.map do |row, index|
    integer_fields = %w[
      frame_index frame_start_us frame_time_us free_heap_bytes display_batches particles
      scene_textures_bytes scene_geometry_display_bytes scene_skeleton_animation_bytes
      scene_collision_nav_state_bytes scene_vfx_bytes resource_count converter_warning_count
    ]
    values = integer_fields.to_h { |field| [field, canonical_integer(row[field])] }
    raise ArgumentError, "telemetry integer malformed" if values.values.any?(&:nil?)
    raise ArgumentError, "telemetry frame index is not contiguous" unless values["frame_index"] == index
    raise ArgumentError, "telemetry frame timing is nonpositive" unless values["frame_time_us"].positive?
    raise ArgumentError, "telemetry RGB hash malformed" unless row["video_rgb_sha256"]&.match?(HEX64)
    raise ArgumentError, "telemetry placeholder mask malformed" unless row["placeholder_mask"]&.match?(/\A[0-9a-f]{8}\z/)
    raise ArgumentError, "telemetry event invalid" unless
      %w[NONE UNLOAD_BASELINE UNLOAD_COMPLETE RELOAD_COMPLETE].include?(row["event"])
    values.merge(
      "video_rgb_sha256" => row["video_rgb_sha256"], "placeholder_mask" => row["placeholder_mask"],
      "event" => row["event"], "run_id" => row["run_id"]
    )
  end
  raise ArgumentError, "telemetry run_id differs across frames" unless parsed.map { |row| row["run_id"] }.uniq.length == 1
  parsed.each_cons(2) do |left, right|
    raise ArgumentError, "telemetry frame timeline is discontinuous" unless
      right["frame_start_us"] == left["frame_start_us"] + left["frame_time_us"]
  end
  raise ArgumentError, "telemetry must begin at zero" unless parsed.first["frame_start_us"].zero?
  duration_us = parsed.last["frame_start_us"] + parsed.last["frame_time_us"]
  raise ArgumentError, "telemetry duration below 60 seconds" if duration_us < 60_000_000
  full_windows = duration_us / 1_000_000
  window_counts = (0...full_windows).map do |window|
    first = window * 1_000_000
    parsed.count { |row| row["frame_start_us"] >= first && row["frame_start_us"] < first + 1_000_000 }
  end
  raise ArgumentError, "telemetry has no complete one-second windows" if window_counts.empty?
  sorted_frame_times = parsed.map { |row| row["frame_time_us"] }.sort
  p95 = sorted_frame_times.fetch((0.95 * sorted_frame_times.length).ceil - 1)
  scene_fields = %w[
    scene_textures_bytes scene_geometry_display_bytes scene_skeleton_animation_bytes
    scene_collision_nav_state_bytes scene_vfx_bytes
  ]
  scene_peak = parsed.max_by do |row|
    [scene_fields.sum { |field| row[field] }, -row["frame_index"]]
  end
  event_rows = parsed.reject { |row| row["event"] == "NONE" }
  raise ArgumentError, "telemetry unload event sequence is not exact" unless
    event_rows.map { |row| row["event"] } == %w[UNLOAD_BASELINE UNLOAD_COMPLETE RELOAD_COMPLETE]
  baseline, unload_complete, reload_complete = event_rows
  metrics = {
    "run_id" => parsed.first["run_id"], "frame_first" => 0, "frame_last" => parsed.length - 1,
    "sample_count" => parsed.length, "duration_ms" => (duration_us / 1000.0).round,
    "fps_window_us" => 1_000_000, "full_window_count" => full_windows,
    "fps_min" => window_counts.min, "sustained_sub30_windows" => window_counts.count { |count| count < 30 },
    "placeholder_frames" => parsed.count { |row| row["placeholder_mask"] != "00000000" },
    "frame_time_p95_us" => p95, "free_heap_min_bytes" => parsed.map { |row| row["free_heap_bytes"] }.min,
    "display_batches_peak" => parsed.map { |row| row["display_batches"] }.max,
    "particles_peak" => parsed.map { |row| row["particles"] }.max,
    "scene_peak_frame" => scene_peak["frame_index"],
    "scene_working_set_bytes" => scene_fields.sum { |field| scene_peak[field] },
    "texture_working_set_bytes" => scene_peak["scene_textures_bytes"],
    "unexplained_converter_warnings" => parsed.sum { |row| row["converter_warning_count"] },
    "baseline_frame" => baseline["frame_index"], "unload_complete_frame" => unload_complete["frame_index"],
    "reload_complete_frame" => reload_complete["frame_index"],
    "baseline_heap_bytes" => baseline["free_heap_bytes"], "post_reload_heap_bytes" => reload_complete["free_heap_bytes"],
    "heap_delta_bytes" => reload_complete["free_heap_bytes"] - baseline["free_heap_bytes"],
    "baseline_resource_count" => baseline["resource_count"],
    "post_reload_resource_count" => reload_complete["resource_count"],
    "resource_delta_count" => reload_complete["resource_count"] - baseline["resource_count"]
  }
  metrics.merge(scene_fields.to_h { |field| [field, scene_peak[field]] })
end

def gate_attempt_row_sha256(fields)
  Digest::SHA256.hexdigest(fields.join("\t") + "\n")
end

def generic_machine_component?(value)
  compact = value.to_s.downcase.delete("._@+-")
  GENERIC_MACHINE_COMPONENTS.any? do |component|
    root = component.delete("._@+-")
    compact == root || compact.match?(/\A#{Regexp.escape(root)}0*[0-9]+\z/)
  end
end

def canonical_defect_token?(value)
  value.to_s.match?(/\A[A-Z][A-Z0-9_-]{2,63}\z/) &&
    value.split(/[_-]+/).none? { |component| generic_machine_component?(component) }
end

def canonical_defect_ids?(value)
  defects = value.to_s.split(",", -1)
  !defects.empty? && defects == defects.sort.uniq && defects.all? { |defect| canonical_defect_token?(defect) }
end

def canonical_return_token?(value)
  match = value.to_s.match(/\A(WB-\d{3}):(G[1-7]):([A-Z][A-Z0-9_-]{2,63})\z/)
  match && canonical_defect_token?(match[3])
end

def canonical_build_id?(value)
  return false unless value.to_s.match?(BUILD_ID)

  !generic_machine_component?(value)
end

def run_hardening_self_test(data_schemas, verbose: false)
  tests = []
  check = lambda do |name, &block|
    tests << [name, !!block.call]
  rescue StandardError
    tests << [name, false]
  end

  check.call("identity accepts substantive machine identity") { canonical_identity?("artist.alex-042") }
  %w[todo TBD t-b-d test test001 example-02 placeholder_3 unknown reviewer99 operator n-a].each do |identity|
    check.call("identity rejects #{identity}") { !canonical_identity?(identity) }
  end
  check.call("license accepts project original ARR") do
    output_license_compatible?("project-original", "project-all-rights-reserved")
  end
  check.call("license rejects CC-BY laundering to ARR") do
    !output_license_compatible?("licensed-cc-by-4.0", "project-all-rights-reserved")
  end
  check.call("license rejects provider output as project original") do
    !output_license_compatible?("generated-provider-terms", "project-all-rights-reserved")
  end
  check.call("source.generated accepts provider terms") do
    generated_source_basis_valid?("source.generated", "generated-provider-terms")
  end
  check.call("source.generated accepts explicit self-owned generator") do
    generated_source_basis_valid?("source.generated", "generated-self-owned")
  end
  check.call("source.generated rejects ordinary original basis") do
    !generated_source_basis_valid?("source.generated", "project-original")
  end

  telemetry_rows = Array.new(3600) do |index|
    event = case index
            when 600 then "UNLOAD_BASELINE"
            when 1200 then "UNLOAD_COMPLETE"
            when 1800 then "RELOAD_COMPLETE"
            else "NONE"
            end
    {
      "run_id" => "ares-selftest0001", "frame_index" => index.to_s,
      "frame_start_us" => (index * 16_667).to_s, "frame_time_us" => "16667",
      "video_rgb_sha256" => Digest::SHA256.hexdigest("frame-#{index}"),
      "placeholder_mask" => "00000000", "free_heap_bytes" => "600000",
      "display_batches" => "12", "particles" => "24", "scene_textures_bytes" => "100000",
      "scene_geometry_display_bytes" => "200000", "scene_skeleton_animation_bytes" => "100000",
      "scene_collision_nav_state_bytes" => "100000", "scene_vfx_bytes" => "100000",
      "resource_count" => "40", "converter_warning_count" => "0", "event" => event
    }
  end
  derived = derive_telemetry_metrics(telemetry_rows)
  check.call("telemetry derives exact duration/placeholder/unload values") do
    derived["duration_ms"] == 60_001 && derived["placeholder_frames"].zero? &&
      derived["heap_delta_bytes"].zero? && derived["resource_delta_count"].zero?
  end
  check.call("telemetry rejects one-frame timeline mutation") do
    mutated = telemetry_rows.map(&:dup)
    mutated[10]["frame_start_us"] = (mutated[10]["frame_start_us"].to_i + 1).to_s
    begin
      derive_telemetry_metrics(mutated)
      false
    rescue ArgumentError
      true
    end
  end
  check.call("telemetry rejects reordered unload lifecycle") do
    mutated = telemetry_rows.map(&:dup)
    mutated[600]["event"], mutated[1200]["event"] = mutated[1200]["event"], mutated[600]["event"]
    begin
      derive_telemetry_metrics(mutated)
      false
    rescue ArgumentError
      true
    end
  end
  report_claim = { "fps_min" => derived["fps_min"].to_s, "placeholder_frames" => "0" }
  check.call("report-byte mutation differs from recomputed telemetry") do
    report_claim.merge("fps_min" => (derived["fps_min"] + 1).to_s)["fps_min"] != derived["fps_min"].to_s
  end

  sample_attempt = GATE_ATTEMPT_HISTORY_HEADER.map { |field| "v-#{field}" }
  chained = gate_attempt_row_sha256(sample_attempt)
  check.call("Gate-1 attempt chain binds exact row bytes") do
    chained.match?(HEX64) && gate_attempt_row_sha256(sample_attempt.dup.tap { |row| row[1] = "2" }) != chained
  end
  attempt_one = [sample_attempt]
  attempt_two = [sample_attempt, sample_attempt.dup.tap { |row| row[1] = "2" }]
  check.call("Gate-1 attempt history permits only initial add and exact append") do
    gate_attempt_history_edge_append_only?(nil, attempt_one) &&
      gate_attempt_history_edge_append_only?(attempt_one, attempt_two)
  end
  check.call("Gate-1 attempt history rejects deletion after first publication") do
    !gate_attempt_history_edge_append_only?(attempt_one, nil)
  end
  check.call("Gate-1 attempt history rejects row removal, reorder, or rewrite") do
    rewritten = [sample_attempt.dup.tap { |row| row[1] = "9" }]
    !gate_attempt_history_edge_append_only?(attempt_two, attempt_one) &&
      !gate_attempt_history_edge_append_only?(attempt_one, rewritten)
  end
  check.call("Gate-1 attempt retention scans every public Git edge and rejects linear or merge deletion") do
    error_start = ERRORS.length
    linear_result = false
    merge_result = false
    begin
      Dir.mktmpdir("n64game-attempt-history-") do |fixture_root|
        fixture_git = lambda do |*arguments|
          _out, fixture_error, fixture_status = git_capture(*arguments, root: fixture_root)
          raise fixture_error unless fixture_status.success?
        end
        fixture_git.call("init", "-q")
        fixture_git.call("config", "user.name", "Attempt History Self Test")
        fixture_git.call("config", "user.email", "attempt-history@example.invalid")
        fixture_path = "review/fixture.asset/g1/attempts/ATTEMPT_HISTORY.tsv"
        absolute_path = Pathname.new(fixture_root).join(fixture_path)
        FileUtils.mkdir_p(absolute_path.dirname)
        header = GATE_ATTEMPT_HISTORY_HEADER.join("\t") + "\n"
        first_row = GATE_ATTEMPT_HISTORY_HEADER.each_index.map { |index| "v#{index}" }
        second_row = first_row.dup.tap { |row| row[1] = "2" }
        File.binwrite(absolute_path, header + first_row.join("\t") + "\n")
        fixture_git.call("add", "--", fixture_path)
        fixture_git.call("commit", "-q", "-m", "add immutable attempt")
        File.binwrite(absolute_path, header + first_row.join("\t") + "\n" + second_row.join("\t") + "\n")
        fixture_git.call("add", "--", fixture_path)
        fixture_git.call("commit", "-q", "-m", "append immutable attempt")
        append_commit, _append_error, append_status = git_capture("rev-parse", "HEAD", root: fixture_root)
        raise "cannot resolve append fixture" unless append_status.success?
        validate_gate1_attempt_history_retention(
          "fixture.asset", fixture_path, current_manifest_owns: true,
          commit: append_commit.strip, fresh_clone: fixture_root
        )
        append_errors = ERRORS.slice!(error_start, ERRORS.length - error_start) || []

        FileUtils.rm(absolute_path)
        fixture_git.call("add", "--all")
        fixture_git.call("commit", "-q", "-m", "delete immutable attempt")
        delete_commit, _delete_error, delete_status = git_capture("rev-parse", "HEAD", root: fixture_root)
        raise "cannot resolve deletion fixture" unless delete_status.success?
        validate_gate1_attempt_history_retention(
          "fixture.asset", fixture_path, current_manifest_owns: false,
          commit: delete_commit.strip, fresh_clone: fixture_root
        )
        deletion_errors = ERRORS.slice!(error_start, ERRORS.length - error_start) || []
        linear_result = append_errors.empty? &&
          deletion_errors.any? { |message| message.include?("current Gate-1 evidence manifest dropped") } &&
          deletion_errors.any? { |message| message.include?("canonical history was deleted") }
      end
      Dir.mktmpdir("n64game-attempt-history-merge-") do |fixture_root|
        fixture_git = lambda do |*arguments|
          _out, fixture_error, fixture_status = git_capture(*arguments, root: fixture_root)
          raise fixture_error unless fixture_status.success?
        end
        fixture_git.call("init", "-q", "-b", "main")
        fixture_git.call("config", "user.name", "Attempt History Merge Self Test")
        fixture_git.call("config", "user.email", "attempt-history-merge@example.invalid")
        safe_path = Pathname.new(fixture_root).join("safe.txt")
        File.binwrite(safe_path, "baseline\n")
        fixture_git.call("add", "--all")
        fixture_git.call("commit", "-q", "-m", "baseline without attempt history")
        fixture_git.call("switch", "-q", "-c", "attempt")
        fixture_path = "review/fixture.asset/g1/attempts/ATTEMPT_HISTORY.tsv"
        absolute_path = Pathname.new(fixture_root).join(fixture_path)
        FileUtils.mkdir_p(absolute_path.dirname)
        header = GATE_ATTEMPT_HISTORY_HEADER.join("\t") + "\n"
        first_row = GATE_ATTEMPT_HISTORY_HEADER.each_index.map { |index| "v#{index}" }
        File.binwrite(absolute_path, header + first_row.join("\t") + "\n")
        fixture_git.call("add", "--all")
        fixture_git.call("commit", "-q", "-m", "publish attempt on side branch")
        fixture_git.call("switch", "-q", "main")
        File.binwrite(safe_path, "mainline\n")
        fixture_git.call("add", "--all")
        fixture_git.call("commit", "-q", "-m", "advance mainline")
        fixture_git.call("merge", "-q", "-s", "ours", "-m", "merge while dropping attempt history", "attempt")
        merge_commit, _merge_error, merge_status = git_capture("rev-parse", "HEAD", root: fixture_root)
        raise "cannot resolve merge fixture" unless merge_status.success?
        validate_gate1_attempt_history_retention(
          "fixture.asset", fixture_path, current_manifest_owns: false,
          commit: merge_commit.strip, fresh_clone: fixture_root
        )
        merge_errors = ERRORS.slice!(error_start, ERRORS.length - error_start) || []
        merge_result =
          merge_errors.any? { |message| message.include?("current Gate-1 evidence manifest dropped") } &&
          merge_errors.any? { |message| message.include?("canonical history was deleted") }
      end
    ensure
      ERRORS.slice!(error_start, ERRORS.length - error_start) if ERRORS.length > error_start
    end
    linear_result && merge_result
  end
  check.call("Gate-1 promotion path cannot drop previously published attempt history") do
    error_start = ERRORS.length
    integration_result = false
    begin
      Dir.mktmpdir("n64game-attempt-history-promotion-") do |fixture_root|
        fixture_git = lambda do |*arguments|
          _out, fixture_error, fixture_status = git_capture(*arguments, root: fixture_root)
          raise fixture_error unless fixture_status.success?
        end
        fixture_git.call("init", "-q")
        fixture_git.call("config", "user.name", "Attempt Promotion Self Test")
        fixture_git.call("config", "user.email", "attempt-promotion@example.invalid")

        scope = "chr.fixture"
        profile = "RIGGED_MODEL"
        tier = "H2"
        source_digest = "a" * 64
        attempt_path = "review/#{scope}/g1/attempts/ATTEMPT_HISTORY.tsv"
        attempt_absolute = Pathname.new(fixture_root).join(attempt_path)
        FileUtils.mkdir_p(attempt_absolute.dirname)
        attempt_row = GATE_ATTEMPT_HISTORY_HEADER.each_index.map { |index| "v#{index}" }
        File.binwrite(
          attempt_absolute,
          GATE_ATTEMPT_HISTORY_HEADER.join("\t") + "\n" + attempt_row.join("\t") + "\n"
        )
        fixture_git.call("add", "--all")
        fixture_git.call("commit", "-q", "-m", "publish rejected attempt history")

        FileUtils.rm(attempt_absolute)
        observation_path = "review/#{scope}/g1/OBSERVATION.txt"
        observation_bytes = "substantive Gate-1 observation\n"
        observation_absolute = Pathname.new(fixture_root).join(observation_path)
        FileUtils.mkdir_p(observation_absolute.dirname)
        File.binwrite(observation_absolute, observation_bytes)
        evidence_path = "review/#{scope}/g1/EVIDENCE_MANIFEST.sha256"
        evidence_bytes = [
          observation_path, observation_bytes.bytesize,
          Digest::SHA256.hexdigest(observation_bytes), "build:-", "capture:-", "role:gate.observation"
        ].join("\t") + "\n"
        evidence_absolute = Pathname.new(fixture_root).join(evidence_path)
        File.binwrite(evidence_absolute, evidence_bytes)
        evidence_digest = Digest::SHA256.hexdigest(evidence_bytes)

        review_path = "review/#{scope}/g1/REVIEW.md"
        review_values = {
          "schema" => "n64game-gate-review-v1", "scope_id" => scope, "gate" => "G1",
          "decision" => "pass", "reviewer_id" => "artist.alex-042", "reviewer_non_owner" => "YES",
          "source_manifest_sha256" => source_digest, "output_manifest_sha256" => "NONE",
          "evidence_manifest" => "#{evidence_path}@#{evidence_digest}", "build_id" => "-",
          "decided_at" => "2026-07-18T12:00:00Z", "defect_ids" => "NONE",
          "disposition" => "NONE", "rationale" => "The promoted concept satisfies the Gate-1 review criteria."
        }
        review_bytes = GATE_REVIEW_RECORD_KEYS.map { |key| "#{key}: #{review_values.fetch(key)}" }.join("\n") + "\n"
        review_absolute = Pathname.new(fixture_root).join(review_path)
        File.binwrite(review_absolute, review_bytes)
        review_digest = Digest::SHA256.hexdigest(review_bytes)

        gate_path = "review/#{scope}/g1/GATE_RECORD.tsv"
        gate_one = [
          scope, profile, tier, "G1", "pass", "artist.alex-042", "YES", source_digest, "NONE",
          evidence_path, evidence_digest, review_path, review_digest, "-", "2026-07-18T12:00:00Z", "NONE"
        ]
        pending_rows = (2..7).map do |gate_number|
          [scope, profile, tier, "G#{gate_number}", "PENDING"] + Array.new(11, "PENDING")
        end
        gate_bytes = GATE_RECORD_HEADER.join("\t") + "\n" +
          ([gate_one] + pending_rows).map { |row| row.join("\t") }.join("\n") + "\n"
        gate_absolute = Pathname.new(fixture_root).join(gate_path)
        File.binwrite(gate_absolute, gate_bytes)
        fixture_git.call("add", "--all")
        fixture_git.call("commit", "-q", "-m", "promote while dropping rejected attempt history")
        current_commit, _current_error, current_status = git_capture("rev-parse", "HEAD", root: fixture_root)
        raise "cannot resolve promotion fixture" unless current_status.success?

        validate_gate_record(
          "#{gate_path}@#{Digest::SHA256.hexdigest(gate_bytes)}", "Gate-1 promotion integration fixture",
          scope: scope, profile: profile, tier: tier, source_digest: source_digest,
          output_digest: "NONE", build_id: "-", expected_vector: ["pass"] + Array.new(6, "PENDING"),
          commit: current_commit.strip, fresh_clone: fixture_root,
          owner_ids: %w[artist.owner-042 studio.n64game]
        )
        integration_errors = ERRORS.slice!(error_start, ERRORS.length - error_start) || []
        integration_result = integration_errors.any? do |message|
          message.include?("current Gate-1 evidence manifest dropped the canonical attempt-history member")
        end
      end
    ensure
      ERRORS.slice!(error_start, ERRORS.length - error_start) if ERRORS.length > error_start
    end
    integration_result
  end
  check.call("Gate-1 history universe rejects removal of the entire current owner") do
    error_start = ERRORS.length
    universe_result = false
    begin
      Dir.mktmpdir("n64game-attempt-history-owner-removal-") do |fixture_root|
        fixture_git = lambda do |*arguments|
          _out, fixture_error, fixture_status = git_capture(*arguments, root: fixture_root)
          raise fixture_error unless fixture_status.success?
        end
        fixture_git.call("init", "-q")
        fixture_git.call("config", "user.name", "Attempt Owner Removal Self Test")
        fixture_git.call("config", "user.email", "attempt-owner-removal@example.invalid")
        scope = "chr.abandoned"
        attempt_path = "review/#{scope}/g1/attempts/ATTEMPT_HISTORY.tsv"
        attempt_absolute = Pathname.new(fixture_root).join(attempt_path)
        FileUtils.mkdir_p(attempt_absolute.dirname)
        attempt_row = GATE_ATTEMPT_HISTORY_HEADER.each_index.map { |index| "v#{index}" }
        File.binwrite(
          attempt_absolute,
          GATE_ATTEMPT_HISTORY_HEADER.join("\t") + "\n" + attempt_row.join("\t") + "\n"
        )
        fixture_git.call("add", "--all")
        fixture_git.call("commit", "-q", "-m", "publish owner attempt history")

        FileUtils.rm_r(Pathname.new(fixture_root).join("review"))
        File.binwrite(Pathname.new(fixture_root).join("safe.txt"), "current tree without prior owner\n")
        fixture_git.call("add", "--all")
        fixture_git.call("commit", "-q", "-m", "remove current owner and history")
        current_commit, _current_error, current_status = git_capture("rev-parse", "HEAD", root: fixture_root)
        raise "cannot resolve owner-removal fixture" unless current_status.success?

        validate_gate1_attempt_history_universe(current_commit.strip, fixture_root, {})
        universe_errors = ERRORS.slice!(error_start, ERRORS.length - error_start) || []
        universe_result =
          universe_errors.any? { |message| message.include?("current Gate-1 evidence manifest dropped") } &&
          universe_errors.any? { |message| message.include?("canonical history was deleted") }
      end
    ensure
      ERRORS.slice!(error_start, ERRORS.length - error_start) if ERRORS.length > error_start
    end
    universe_result
  end
  check.call("Gate-1 history universe discovers merge-result-only publication and deletion") do
    error_start = ERRORS.length
    merge_universe_result = false
    begin
      Dir.mktmpdir("n64game-attempt-history-merge-universe-") do |fixture_root|
        fixture_git = lambda do |*arguments|
          _out, fixture_error, fixture_status = git_capture(*arguments, root: fixture_root)
          raise fixture_error unless fixture_status.success?
        end
        fixture_write = lambda do |relative, bytes|
          absolute = Pathname.new(fixture_root).join(relative)
          FileUtils.mkdir_p(absolute.dirname)
          File.binwrite(absolute, bytes)
        end
        fixture_git.call("init", "-q", "-b", "main")
        fixture_git.call("config", "user.name", "Attempt Merge Universe Self Test")
        fixture_git.call("config", "user.email", "attempt-merge-universe@example.invalid")
        fixture_write.call("baseline.txt", "baseline\n")
        fixture_git.call("add", "--all")
        fixture_git.call("commit", "-q", "-m", "merge universe baseline")

        fixture_git.call("switch", "-q", "-c", "add-side")
        fixture_write.call("add-side.txt", "side parent without attempt history\n")
        fixture_git.call("add", "--all")
        fixture_git.call("commit", "-q", "-m", "advance add side")
        fixture_git.call("switch", "-q", "main")
        fixture_write.call("add-main.txt", "main parent without attempt history\n")
        fixture_git.call("add", "--all")
        fixture_git.call("commit", "-q", "-m", "advance add main")
        fixture_git.call("merge", "-q", "--no-commit", "--no-ff", "add-side")
        scope = "chr.merge_only"
        attempt_path = "review/#{scope}/g1/attempts/ATTEMPT_HISTORY.tsv"
        attempt_row = GATE_ATTEMPT_HISTORY_HEADER.each_index.map { |index| "v#{index}" }
        fixture_write.call(
          attempt_path,
          GATE_ATTEMPT_HISTORY_HEADER.join("\t") + "\n" + attempt_row.join("\t") + "\n"
        )
        fixture_git.call("add", "--all")
        fixture_git.call("commit", "-q", "-m", "publish history only in merge result")

        fixture_git.call("switch", "-q", "-c", "delete-side")
        fixture_write.call("delete-side.txt", "side parent retaining attempt history\n")
        fixture_git.call("add", "--all")
        fixture_git.call("commit", "-q", "-m", "advance delete side")
        fixture_git.call("switch", "-q", "main")
        fixture_write.call("delete-main.txt", "main parent retaining attempt history\n")
        fixture_git.call("add", "--all")
        fixture_git.call("commit", "-q", "-m", "advance delete main")
        fixture_git.call("merge", "-q", "--no-commit", "--no-ff", "delete-side")
        FileUtils.rm_r(Pathname.new(fixture_root).join("review"))
        fixture_git.call("add", "--all")
        fixture_git.call("commit", "-q", "-m", "delete history only in merge result")
        current_commit, _current_error, current_status = git_capture("rev-parse", "HEAD", root: fixture_root)
        raise "cannot resolve merge-universe fixture" unless current_status.success?

        discovered_paths = gate1_attempt_history_paths_in_graph(current_commit.strip, fixture_root)
        validate_gate1_attempt_history_universe(current_commit.strip, fixture_root, {})
        universe_errors = ERRORS.slice!(error_start, ERRORS.length - error_start) || []
        merge_universe_result =
          discovered_paths.include?([scope, attempt_path]) &&
          universe_errors.any? { |message| message.include?("current Gate-1 evidence manifest dropped") } &&
          universe_errors.count { |message| message.include?("canonical history was deleted") } >= 2
      end
    ensure
      ERRORS.slice!(error_start, ERRORS.length - error_start) if ERRORS.length > error_start
    end
    merge_universe_result
  end
  check.call("Gate-1 defect IDs accept sorted canonical values") do
    canonical_defect_ids?("ART_LIGHTING_001,MODEL_TOPOLOGY_002")
  end
  check.call("Gate-1 defect IDs reject unanchored literal-z form") do
    !canonical_defect_ids?("xART_LIGHTING_001z")
  end
  check.call("Gate-1 defect IDs reject duplicate or unsorted values") do
    !canonical_defect_ids?("MODEL_TOPOLOGY_002,ART_LIGHTING_001") &&
      !canonical_defect_ids?("ART_LIGHTING_001,ART_LIGHTING_001")
  end
  check.call("defect IDs reject reserved and generic placeholders") do
    %w[NONE PENDING TODO TODO_001 TEST_DEFECT PLACEHOLDER-02].all? do |defect|
      !canonical_defect_ids?(defect)
    end
  end
  check.call("return tokens reject a reserved no-defect marker") do
    canonical_return_token?("WB-001:G1:ART_LIGHTING_001") &&
      !canonical_return_token?("WB-001:G1:NONE")
  end
  check.call("build IDs require a substantive nonplaceholder identity") do
    %w[n64game-g4-a1b2c3d4 build-001 release-2026 latest].all? { |build_id| canonical_build_id?(build_id) } &&
      %w[PENDING NONE TODO TBD test001].none? { |build_id| canonical_build_id?(build_id) }
  end
  check.call("remote protection rejects a generic operator identity") do
    remote_protection_fields("CONFIRMED:operator@2026-07-18T12:00:00Z@https://github.com/oh-ashen-one/n64game/settings/tags").nil?
  end
  check.call("benchmark header cannot fall through to a fenced approval example") do
    fallback_only = <<~MARKDOWN
      # N64GAME Visual Benchmark Approval

      ```text
      Status: Gate 4 approved control record
      Schema-Version: 4
      Production-Lock: UNLOCKED
      Decision: APPROVED
      ```
    MARKDOWN
    benchmark_control_header(fallback_only, "hardening benchmark header", report: false).nil?
  end

  camera_bytes = GENERATED_CAMERA_CHILDREN.keys.map do |child_id|
    expected_camera_output_bytes(data_schemas, child_id, "hardening self-test camera #{child_id}")
  end
  source_table = data_schemas[/The 15 resource payloads, in AssetId order, are exact:(.*?)(?=These 15 AssetIds are generated runtime children)/m, 1].to_s
  source_rows = source_table.lines.grep(/^\| `ASSET_CAMERA_SHOT_/)
  check.call("camera source rows equal frozen ordered 15-row seal") do
    source_rows.length == 15 && Digest::SHA256.hexdigest(source_rows.join) == GENERATED_CAMERA_SOURCE_ROWS_SHA256
  end
  check.call("camera tuple seal equals frozen 540-byte digest") do
    camera_bytes.none?(&:nil?) && camera_bytes.join.bytesize == 540 &&
      Digest::SHA256.hexdigest(camera_bytes.join) == GENERATED_CAMERA_PAYLOADS_SHA256
  end
  mutated_schema = data_schemas.sub(
    "| `ASSET_CAMERA_SHOT_UI_NONE` | `NONE / PRESERVE_ACTIVE` | `0,0,0` |",
    "| `ASSET_CAMERA_SHOT_UI_NONE` | `NONE / PRESERVE_ACTIVE` | `1,0,0` |"
  )
  mutated_camera_bytes = GENERATED_CAMERA_CHILDREN.keys.map do |child_id|
    expected_camera_output_bytes(mutated_schema, child_id, "hardening mutation camera #{child_id}")
  end
  check.call("camera eye mutation breaks frozen payload seal") do
    mutated_schema != data_schemas && mutated_camera_bytes.none?(&:nil?) &&
      Digest::SHA256.hexdigest(mutated_camera_bytes.join) != GENERATED_CAMERA_PAYLOADS_SHA256
  end
  check.call("Ares schema carries wrapper/capture/audit/execution causal bindings") do
    %w[wrapper_path wrapper_sha256 invocation capture_sha256 frame_audit_sha256 execution_log_sha256].all? do |field|
      ARES_RUN_HEADER.include?(field)
    end && ARES_EXECUTION_EVENTS.include?("BOOT_READY")
  end
  check.call("production lifecycle harness is independently pinned from semantic snapshots") do
    SEMANTIC_LIFECYCLE_SNAPSHOT_SHA256.match?(HEX64) &&
      PRODUCTION_LIFECYCLE_HARNESS_IMPLEMENTED &&
      PRODUCTION_LIFECYCLE_HARNESS_SHA256.match?(HEX64) &&
      PRODUCTION_LIFECYCLE_HARNESS_SHA256 != SEMANTIC_LIFECYCLE_SNAPSHOT_SHA256 &&
      regular_without_symlink?(PRODUCTION_LIFECYCLE_HARNESS_MANIFEST_PATH) &&
      Digest::SHA256.file(ROOT.join(PRODUCTION_LIFECYCLE_HARNESS_MANIFEST_PATH)).hexdigest ==
        PRODUCTION_LIFECYCLE_HARNESS_SHA256 &&
      approval_lifecycle_pins_ready?
  end
  check.call("generated camera review snapshots stay outside the ignored build tree") do
    GENERATED_CAMERA_CHILDREN.keys.all? do |child_id|
      generated_camera_review_snapshot_path(child_id) ==
        "review/generated/#{child_id}/g5/CAMERA_PAYLOAD.n64cam"
    end
  end

  failed = tests.reject(&:last).map(&:first)
  error("hardening self-test failures: #{failed.join(', ')}") unless failed.empty?
  puts "Hardening self-test passed #{tests.length}/#{tests.length}." if failed.empty? && verbose
end

def exact_nearest_neighbor_4x?(native_bytes, enlarged_bytes, label)
  return false unless pinned_tool_available?("magick", ["-version"], PINNED_MAGICK_VERSION, "ImageMagick")
  Dir.mktmpdir("n64game-pixel-compare-") do |dir|
    native_path = File.join(dir, "native.png")
    enlarged_path = File.join(dir, "enlarged.png")
    File.binwrite(native_path, native_bytes)
    File.binwrite(enlarged_path, enlarged_bytes)
    expected, expected_error, expected_status = Open3.capture3(
      "magick", native_path, "-alpha", "on", "-depth", "8", "-filter", "point", "-resize", "400%", "rgba:-"
    )
    actual, actual_error, actual_status = Open3.capture3(
      "magick", enlarged_path, "-alpha", "on", "-depth", "8", "rgba:-"
    )
    unless expected_status.success? && actual_status.success?
      error("#{label} fails pinned ImageMagick decode: #{(expected_error + actual_error).lines.first.to_s.strip}")
      return false
    end
    exact_size = 1280 * 960 * 4
    match = expected.bytesize == exact_size && actual.bytesize == exact_size && expected == actual
    error("#{label} is not the exact decoded-pixel 4x nearest-neighbor native capture") unless match
    match
  end
end

HERO_PROPS = Set.new(%w[
  prop.annex.field_relay prop.annex.relay_dock prop.annex.relay_side_reader
  prop.annex.calibration_locator_tag prop.annex.beacon_decoder prop.annex.solace_model
  prop.estate.rusk_wrench prop.estate.impossible_compass prop.estate.orrery_switch
  prop.estate.ivo_track_roll prop.estate.packet_recorder prop.estate.telescope_controls
]).freeze

def expected_profile_tier(production_id)
  case production_id
  when /\A(?:chr|echo)\./ then %w[RIGGED_MODEL H2]
  when /\A(?:env|lmk|veh)\./ then %w[STATIC_MODEL_ENV H2]
  when ->(id) { HERO_PROPS.include?(id) } then %w[STATIC_MODEL_ENV H2]
  when /\Aprop\./ then %w[STATIC_MODEL_ENV M7]
  when /\A(?:ui\.(?:screen|battle|panel))\./ then %w[UI_FONT_IMAGE H2]
  when /\A(?:ui|font)\./ then %w[UI_FONT_IMAGE M7]
  when /\A(?:vfx\.finisher\.|vfx\.story\.fracture_monitor\z|vfx\.transition\.)/ then %w[VFX H2]
  when /\Avfx\./ then %w[VFX M7]
  when /\A(?:sfx|mus|amb|vox)\./ then %w[AUDIO M7]
  when /\Aanm\./ then %w[ANIMATION M7]
  when /\A(?:col|nav|spn|int|bnd)\./ then %w[DATA_SPATIAL S7]
  when /\Asb\./ then %w[STORYBOARD D7]
  else nil
  end
end

def completion_decision_allowed?(decision, profile, gate)
  case decision
  when "pass"
    true
  when "STATIC_STATE_EQ"
    gate == "G4" && %w[STATIC_MODEL_ENV UI_FONT_IMAGE DATA_SPATIAL].include?(profile)
  when "NON_ROM_DELIVERY_EQ"
    profile == "STORYBOARD" && %w[G5 G6].include?(gate)
  when "INHERITED_CHILD_EQ"
    false
  else
    false
  end
end

def validate_ledger_gate_lifecycle(entry, gates, has_output, label)
  N64Game::AssetLifecycleContract.ledger_lifecycle_issues(entry[:status], gates, has_output).each do |issue|
    error("#{label}: #{issue}")
  end
end

def parse_machine_record(path_hash, label, expected_keys, commit: nil, fresh_clone: nil, payload_context: nil,
                         record_context: nil)
  material = validate_path_hash(
    path_hash, label, commit: commit, fresh_clone: fresh_clone, allow_lfs: false
  )
  return {} unless material
  if payload_context && !payload_context[:closure].include?(material[:path])
    error("#{label} is outside the reviewed payload graph")
  end
  bytes = material[:bytes]
  utf8 = bytes.dup.force_encoding(Encoding::UTF_8)
  error("#{label} must be valid UTF-8") unless utf8.valid_encoding?
  error("#{label} must be BOM-free LF-only with exactly one final LF") if
    bytes.start_with?("\xEF\xBB\xBF".b) || bytes.include?("\r") || !bytes.end_with?("\n") || bytes.end_with?("\n\n")
  lines = bytes.split("\n", -1)
  lines.pop if lines.last == ""
  error("#{label} must contain exactly #{expected_keys.length} canonical key lines") unless lines.length == expected_keys.length
  pairs = lines.map do |line|
    match = line.match(/\A([a-z][a-z0-9_]*)\: ([^\r\n]+)\z/)
    error("#{label} contains malformed key/value line") unless match
    match && [match[1], match[2]]
  end.compact
  error("#{label} key order/schema mismatch") unless pairs.map(&:first) == expected_keys
  record = pairs.to_h
  if record_context
    prior_path = record_context[:content_owner][material[:digest]]
    error("#{label} duplicates record content owned by #{prior_path}") if prior_path && prior_path != material[:path]
    record_context[:content_owner][material[:digest]] ||= material[:path]
  end
  record
end

def validate_rights_support_binding(locator, label, commit:, fresh_clone:, payload_context:, allowed_paths:,
                                    required_support_root:)
  material = validate_path_hash(
    locator, label, commit: commit, fresh_clone: fresh_clone, allow_lfs: false
  )
  return nil unless material

  path = material[:path]
  error("#{label} path must be inside dedicated rights-support root") unless path.start_with?(required_support_root)
  error("#{label} is outside the reviewed payload graph") if payload_context && !payload_context[:closure].include?(path)
  error("#{label} is not owned by the subject source graph") if allowed_paths && !allowed_paths.include?(path)
  error("#{label} must use exact manifest role rights.support") if
    payload_context && payload_context[:entries].dig(path, :role) != "rights.support"
  bytes = material[:bytes]
  error("#{label} bytes are not substantive") if
    bytes.bytesize < 64 || bytes.bytes.uniq.length < 8 || bytes.match?(/\A(?:PENDING|NONE|TBD|TODO)\s*\z/i)
  path
end

def validate_rights_evidence_record(binding, label, subject_id:, rights_basis:, rights_holder_id:, output_license:,
                                    owner_ids:, commit:, fresh_clone:, payload_context: nil, allowed_paths: nil,
                                    required_support_root:, expected_sources: nil)
  record = parse_machine_record(
    binding, label, RIGHTS_EVIDENCE_RECORD_KEYS,
    commit: commit, fresh_clone: fresh_clone, payload_context: payload_context
  )
  expected_kind = RIGHTS_BASIS_KINDS[rights_basis]
  expected = {
    "schema" => "n64game-rights-evidence-v1", "subject_id" => subject_id,
    "rights_basis" => rights_basis, "rights_holder_id" => rights_holder_id,
    "output_license" => output_license, "evidence_kind" => expected_kind
  }
  expected.each { |key, value| error("#{label} #{key} mismatch") unless record[key] == value }
  error("#{label} reviewer_id malformed/placeholder") unless canonical_identity?(record["reviewer_id"])
  error("#{label} reviewer must be independent of creator/rightsholder") if owner_ids.compact.include?(record["reviewer_id"])
  error("#{label} verified_at is not RFC 3339") unless valid_rfc3339?(record["verified_at"])

  source_bindings = if expected_sources
                      expected_sources
                    elsif allowed_paths && payload_context
                      allowed_paths.each_with_object({}) do |path, sources|
                        entry = payload_context[:entries][path]
                        sources[path] = entry[:digest] if entry && TRANSFORMABLE_SOURCE_ROLES.include?(entry[:role])
                      end
                    else
                      {}
                    end
  support_paths = Set.new
  input_records = record["input_records"].to_s
  parsed_sources = {}
  expected_aggregate_basis = "project-original"
  if source_bindings.empty?
    error("#{label} empty source set must use NO_EXTERNAL_INPUT") unless input_records == "NO_EXTERNAL_INPUT"
    error("#{label} NO_EXTERNAL_INPUT is legal only for project-original") unless rights_basis == "project-original"
  else
    fields_by_record = input_records.split(";", -1).map { |input_record| input_record.split("|", -1) }
    fields_by_record.each_with_index do |fields, index|
      unless fields.length == 9
        error("#{label} input record #{index + 1} must have exactly nine pipe-delimited fields")
        next
      end
      source_locator, acquired_at, purpose, input_basis, license_id, terms_version,
        permission_locator, attribution_locator, clean_room_locator = fields
      source_path, source_digest = source_locator.split("@", 2)
      error("#{label} input source locator is unsafe/malformed") unless
        safe_repo_path?(source_path) && source_digest&.match?(HEX64)
      error("#{label} input source path is duplicate") if parsed_sources.key?(source_path)
      parsed_sources[source_path] = source_digest
      error("#{label} input acquisition time is not RFC 3339") unless valid_rfc3339?(acquired_at)
      error("#{label} input purpose token is malformed") unless purpose.match?(/\A[a-z][a-z0-9-]{2,63}\z/)
      error("#{label} input rights basis is invalid or recursively mixed") unless
        INPUT_LICENSE_BY_BASIS.key?(input_basis)
      error("#{label} input license does not match its own rights basis") unless
        license_id == INPUT_LICENSE_BY_BASIS[input_basis]
      manifest_role = payload_context && payload_context[:entries].dig(source_path, :role)
      error("#{label} source.generated input must use generated-provider-terms or explicit generated-self-owned basis") unless
        generated_source_basis_valid?(manifest_role, input_basis)
      error("#{label} input terms version is malformed/placeholder") unless canonical_identity?(terms_version)
      if input_basis == "project-original"
        error("#{label} project-original input permission must be NONE") unless permission_locator == "NONE"
      else
        support_path = validate_rights_support_binding(
          permission_locator, "#{label} input permission evidence", commit: commit, fresh_clone: fresh_clone,
          payload_context: payload_context, allowed_paths: allowed_paths,
          required_support_root: required_support_root
        )
        support_paths << support_path if support_path
      end
      { "attribution" => attribution_locator, "clean-room" => clean_room_locator }.each do |kind, locator|
        next if locator == "NONE"
        support_path = validate_rights_support_binding(
          locator, "#{label} #{kind} evidence", commit: commit, fresh_clone: fresh_clone,
          payload_context: payload_context, allowed_paths: allowed_paths,
          required_support_root: required_support_root
        )
        support_paths << support_path if support_path
      end
      error("#{label} CC-BY input requires explicit attribution evidence") if
        input_basis == "licensed-cc-by-4.0" && attribution_locator == "NONE"
    end
    error("#{label} input records must be byte-sorted by source path") unless parsed_sources.keys == parsed_sources.keys.sort
    error("#{label} input records must exactly cover all transformable source members") unless parsed_sources == source_bindings
    input_bases = fields_by_record.select { |fields| fields.length == 9 }.map { |fields| fields[3] }.uniq
    expected_aggregate_basis = input_bases.length == 1 ? input_bases.first : "mixed-cleared-inputs"
    error("#{label} aggregate rights_basis does not match the per-input basis set") unless
      rights_basis == expected_aggregate_basis
  end
  error("#{label} output license is incompatible with the aggregate input rights basis") unless
    output_license_compatible?(expected_aggregate_basis, output_license)
  notices = record["third_party_notices"]
  if %w[project-original generated-self-owned].include?(rights_basis)
    error("#{label} owned-input third_party_notices must be NONE") unless notices == "NONE"
  else
    notices_path = validate_rights_support_binding(
      notices, "#{label} third-party notices", commit: commit, fresh_clone: fresh_clone,
      payload_context: payload_context, allowed_paths: allowed_paths,
      required_support_root: required_support_root
    )
    support_paths << notices_path if notices_path
  end
  { record: record, support_paths: support_paths }
end

def validate_transformation_record(binding, label, subject_id:, commit:, fresh_clone:, payload_context: nil,
                                   allowed_paths: nil, expected_input_digest: nil, allow_no_input: false)
  record = parse_machine_record(
    binding, label, TRANSFORMATION_RECORD_KEYS,
    commit: commit, fresh_clone: fresh_clone, payload_context: payload_context
  )
  error("#{label} schema mismatch") unless record["schema"] == "n64game-transformations-v1"
  error("#{label} subject_id mismatch") unless record["subject_id"] == subject_id
  input_digest = record["input_sha256"]
  if expected_input_digest
    error("#{label} input_sha256 does not bind the exact source revision") unless input_digest == expected_input_digest
  elsif input_digest == "NO_MEDIA_INPUT"
    error("#{label} may use NO_MEDIA_INPUT only for a project-original subject") unless allow_no_input
    if allowed_paths && payload_context
      transformable_members = allowed_paths.select do |path|
        TRANSFORMABLE_SOURCE_ROLES.include?(payload_context[:entries].dig(path, :role))
      end
      error("#{label} cannot use NO_MEDIA_INPUT while transformable source members exist") unless
        transformable_members.empty?
    end
  else
    error("#{label} input_sha256 malformed") unless input_digest&.match?(HEX64)
    if input_digest&.match?(HEX64) && allowed_paths && payload_context
      input_is_owned = allowed_paths.any? do |path|
        entry = payload_context[:entries][path]
        entry && entry[:digest] == input_digest && TRANSFORMABLE_SOURCE_ROLES.include?(entry[:role])
      end
      error("#{label} input_sha256 does not resolve to one transformable source-owned content member") unless input_is_owned
    end
  end
  operation_count = canonical_integer(record["operation_count"])
  operations = record["operations"].to_s.split(",", -1)
  operations_valid = operation_count && operation_count.between?(1, 64) &&
    operations.length == operation_count && operations.each_with_index.all? do |operation, index|
      token = operation[/\A#{index + 1}:([a-z][a-z0-9-]{1,63})\z/, 1]
      token && TRANSFORMATION_OPERATIONS.include?(token)
    end
  error("#{label} operations must be an exact ordered 1..N canonical sequence") unless operations_valid
  error("#{label} editor_id malformed/placeholder") unless canonical_identity?(record["editor_id"])
  error("#{label} recorded_at is not RFC 3339") unless valid_rfc3339?(record["recorded_at"])
  record
end

def validate_generation_prompt_record(binding, label, child_id:, tool:, version:, creator_id:, generated_at:,
                                      commit:, fresh_clone:)
  record = parse_machine_record(
    binding, label, GENERATION_PROMPT_RECORD_KEYS, commit: commit, fresh_clone: fresh_clone
  )
  expected = {
    "schema" => "n64game-generation-prompt-v1", "child_id" => child_id,
    "generation_tool" => tool, "generation_version" => version,
    "author_id" => creator_id, "created_at" => generated_at
  }
  expected.each { |key, value| error("#{label} #{key} mismatch") unless record[key] == value }
  prompt_text = record["prompt_text"].to_s
  error("#{label} prompt_text must be substantive canonical one-line instructions") unless
    prompt_text.length.between?(40, 1000) && prompt_text.bytes.uniq.length >= 12 &&
    !prompt_text.match?(/\A(?:PENDING|NONE|TBD|TODO)\s*\z/i)
  error("#{label} prompt_sha256 does not hash prompt_text bytes") unless
    record["prompt_sha256"] == Digest::SHA256.hexdigest(prompt_text)
  record
end

def validate_authorization_record(binding, row, basis, commit: nil, fresh_clone: nil, payload_context: nil,
                                  record_context: nil)
  record = parse_machine_record(
    binding, "#{basis} authorization record", AUTHORIZATION_RECORD_KEYS,
    commit: commit, fresh_clone: fresh_clone, payload_context: payload_context, record_context: record_context
  )
  expected_output = row["output_manifest_path"] == "NONE" ? "NONE" :
    "#{row['output_manifest_path']}@#{row['output_manifest_sha256']}"
  expected = {
    "schema" => "n64game-authorization-v1", "basis" => basis,
    "production_id" => row["production_id"], "subset_sha256" => row["subset_sha256"],
    "state" => row["state"], "repair_ids" => row["repair_ids"], "build_id" => row["build_id"],
    "source_manifest" => "#{row['source_manifest_path']}@#{row['source_manifest_sha256']}",
    "output_manifest" => expected_output,
    "gate_record" => "#{row['gate_record_path']}@#{row['gate_record_sha256']}"
  }
  expected.each { |key, value| error("#{basis} authorization #{key} mismatch") unless record[key] == value }
  expected_subset_path = "review/#{row['production_id']}/g1/SUBSET_EXPORT_ALLOWLIST.tsv"
  subset_path, subset_digest = record["subset_allowlist"].to_s.split("@", 2)
  error("#{basis} authorization subset_allowlist binding malformed/noncanonical") unless
    subset_path == expected_subset_path && subset_digest&.match?(HEX64)
  error("#{basis} authorization authorizer_id malformed/placeholder") unless canonical_identity?(record["authorizer_id"])
  error("#{basis} authorization authorized_at is not RFC 3339") unless valid_rfc3339?(record["authorized_at"])
  record
end

def validate_source_role_partition(payload_context, source_manifest_path, rights_record_path,
                                   transformations_path, support_root, generation_root, label)
  return unless payload_context

  manifest_owned_paths(payload_context, source_manifest_path).each do |path|
    entry = payload_context[:entries][path]
    next unless entry
    expected_role = if path == rights_record_path
                      "rights.record"
                    elsif path == transformations_path
                      "metadata.transformations"
                    elsif path.start_with?(support_root)
                      "rights.support"
                    elsif path.start_with?(generation_root)
                      "generation.record"
                    elsif payload_context[:manifests].key?(path)
                      "source.manifest"
                    end
    if expected_role
      error("#{label}: source metadata/manifest role mismatch for #{path}") unless entry[:role] == expected_role
    else
      error("#{label}: every nonmetadata source member must use a closed transformable source role: #{path}") unless
        TRANSFORMABLE_SOURCE_ROLES.include?(entry[:role])
    end
  end
end

def validate_ordinary_generation_records(payload_context, source_manifest_path, production_id, creator_id,
                                         commit:, fresh_clone:, label:)
  return unless payload_context

  prefix = production_id.split(".", 2).first
  generation_root = "assets-src/#{prefix}/#{production_id}/generation/"
  source_owned = manifest_owned_paths(payload_context, source_manifest_path)
  generated_sources = source_owned.select do |path|
    payload_context[:entries].dig(path, :role) == "source.generated"
  end.sort
  expected_record_paths = generated_sources.map do |source_path|
    "#{generation_root}#{Digest::SHA256.hexdigest(source_path)[0, 16]}.md"
  end
  actual_record_paths = source_owned.select { |path| path.start_with?(generation_root) }.sort
  error("#{label}: ordinary generation records must exactly cover every source.generated member") unless
    actual_record_paths == expected_record_paths
  generated_sources.zip(expected_record_paths).each do |source_path, record_path|
    source_entry = payload_context[:entries][source_path]
    record_entry = payload_context[:entries][record_path]
    unless source_entry && record_entry
      error("#{label}: generated source/record binding is missing for #{source_path}")
      next
    end
    record = parse_machine_record(
      "#{record_path}@#{record_entry[:digest]}", "#{label} generation record for #{source_path}",
      ORDINARY_GENERATION_RECORD_KEYS, commit: commit, fresh_clone: fresh_clone,
      payload_context: payload_context
    )
    expected = {
      "schema" => "n64game-generated-source-v1", "production_id" => production_id,
      "selected_output_path" => source_path, "selected_output_sha256" => source_entry[:digest],
      "author_id" => creator_id
    }
    expected.each do |key, value|
      error("#{label}: generated-source record #{key} mismatch") unless record[key] == value
    end
    error("#{label}: generated-source model product/version malformed") unless
      canonical_identity?(record["model_product"]) && canonical_identity?(record["model_version"])
    positive = record["positive_prompt"].to_s
    negative = record["negative_constraints"].to_s
    error("#{label}: generated-source positive prompt is not substantive") unless
      positive.length.between?(40, 8000) && positive.bytes.uniq.length >= 12
    error("#{label}: generated-source negative constraints are not substantive") unless
      negative.length.between?(20, 4000) && negative.bytes.uniq.length >= 8
    error("#{label}: generated-source seed/job token malformed") unless
      record["seed_or_job"] == "NOT_EXPOSED" || canonical_identity?(record["seed_or_job"])
    error("#{label}: generated-source time is not RFC 3339") unless valid_rfc3339?(record["generated_at"])
    edit_summary = record["human_edit_summary"].to_s
    error("#{label}: generated-source human edit summary is missing/placeholder") unless
      edit_summary == "NO_HUMAN_EDITS" ||
      (edit_summary.length.between?(20, 2000) && edit_summary.bytes.uniq.length >= 8)
  end
end

def validate_provenance_record(binding, row, basis, commit: nil, fresh_clone: nil, payload_context: nil,
                               record_context: nil, allow_none_subset: false)
  record = parse_machine_record(
    binding, "#{basis} provenance record", PROVENANCE_RECORD_KEYS,
    commit: commit, fresh_clone: fresh_clone, payload_context: payload_context, record_context: record_context
  )
  expected_output = row["output_manifest_path"] == "NONE" ? "NONE" :
    "#{row['output_manifest_path']}@#{row['output_manifest_sha256']}"
  expected = {
    "schema" => "n64game-provenance-v1", "production_id" => row["production_id"],
    "subset_sha256" => row["subset_sha256"],
    "source_manifest" => "#{row['source_manifest_path']}@#{row['source_manifest_sha256']}",
    "output_manifest" => expected_output
  }
  expected.each { |key, value| error("#{basis} provenance #{key} mismatch") unless record[key] == value }
  if allow_none_subset
    error("#{basis} provenance concept subset_allowlist must be NONE") unless record["subset_allowlist"] == "NONE"
  else
    expected_subset_path = "review/#{row['production_id']}/g1/SUBSET_EXPORT_ALLOWLIST.tsv"
    subset_path, subset_digest = record["subset_allowlist"].to_s.split("@", 2)
    error("#{basis} provenance subset_allowlist binding malformed/noncanonical") unless
      subset_path == expected_subset_path && subset_digest&.match?(HEX64)
  end
  %w[creator_id rights_holder_id].each do |key|
    error("#{basis} provenance #{key} malformed/placeholder") unless canonical_identity?(record[key])
  end
  error("#{basis} provenance rights_basis malformed/vague") unless canonical_rights_token?(record["rights_basis"])
  source_owned = payload_context ? manifest_owned_paths(payload_context, row["source_manifest_path"]) : nil
  prefix = row["production_id"].split(".", 2).first
  transformations_path = "assets-src/#{prefix}/#{row['production_id']}/TRANSFORMATIONS.md"
  rights_record_path = record["rights_evidence"].to_s.split("@", 2).first
  support_root = "assets-src/#{prefix}/#{row['production_id']}/rights-support/"
  generation_root = "assets-src/#{prefix}/#{row['production_id']}/generation/"
  validate_source_role_partition(
    payload_context, row["source_manifest_path"], rights_record_path,
    transformations_path, support_root, generation_root, basis
  )
  validate_ordinary_generation_records(
    payload_context, row["source_manifest_path"], row["production_id"], record["creator_id"],
    commit: commit, fresh_clone: fresh_clone, label: basis
  )
  rights_evidence = validate_path_hash(
    record["rights_evidence"], "#{basis} provenance rights evidence", commit: commit,
    fresh_clone: fresh_clone, allow_lfs: false
  )
  if payload_context && rights_evidence && !payload_context[:closure].include?(rights_evidence[:path])
    error("#{basis} provenance rights evidence is outside the reviewed payload graph")
  end
  error("#{basis} provenance output_license malformed") unless
    canonical_rights_token?(record["output_license"], allow_all_rights_reserved: true)
  validate_rights_evidence_record(
    record["rights_evidence"], "#{basis} rights evidence record",
    subject_id: row["production_id"], rights_basis: record["rights_basis"],
    rights_holder_id: record["rights_holder_id"], output_license: record["output_license"],
    owner_ids: [record["creator_id"], record["rights_holder_id"]],
    commit: commit, fresh_clone: fresh_clone, payload_context: payload_context,
    allowed_paths: source_owned,
    required_support_root: support_root
  )
  invalid_transformation_digests = [Digest::SHA256.hexdigest(""), Digest::SHA256.hexdigest("PENDING")]
  error("#{basis} provenance transformations_sha256 malformed/placeholder") unless
    record["transformations_sha256"]&.match?(HEX64) && !invalid_transformation_digests.include?(record["transformations_sha256"])
  transformations = validate_path_hash(
    "#{transformations_path}@#{record['transformations_sha256']}", "#{basis} provenance transformations",
    commit: commit, fresh_clone: fresh_clone, allow_lfs: false
  )
  validate_transformation_record(
    "#{transformations_path}@#{record['transformations_sha256']}", "#{basis} transformations record",
    subject_id: row["production_id"], commit: commit, fresh_clone: fresh_clone,
    payload_context: payload_context, allowed_paths: source_owned,
    allow_no_input: record["rights_basis"] == "project-original"
  )
  if payload_context
    error("#{basis} provenance rights evidence must be owned by its source manifest") if
      rights_evidence && !source_owned.include?(rights_evidence[:path])
    error("#{basis} provenance transformations record must be owned by its source manifest") if
      transformations && !source_owned.include?(transformations[:path])
  end
  record
end

def validate_h2_phase_evidence(manifest_path, digest, scope:, phase:, source_digest:, output_digest:, build_id:,
                               reviewer_id:, reviewer_non_owner:, observed_at:, commit:, fresh_clone:,
                               payload_context:, local_context:, owned_paths:, label:)
  entries = validate_manifest(manifest_path, digest, label, [], commit, fresh_clone, local_context)
  expected_root = "#{File.dirname(manifest_path)}/"
  validate_manifest_member_roots(local_context, manifest_path, [expected_root], label)
  error("#{label}: phase evidence must contain exact native-capture and phase-report roles") unless
    entries.map { |entry| entry[:role] }.sort == %w[polish.native_capture polish.phase_report]
  capture_path = "#{expected_root}NATIVE_CAPTURE.mp4"
  report_path = "#{expected_root}PHASE_REPORT.tsv"
  capture = entries.find { |entry| entry[:role] == "polish.native_capture" }
  report = entries.find { |entry| entry[:role] == "polish.phase_report" }
  capture_id = "polish.#{scope}.#{phase}"
  error("#{label}: native capture path/build/capture ID is noncanonical") unless
    capture && capture[:path] == capture_path && capture[:build] == build_id && capture[:capture] == capture_id
  error("#{label}: phase report path/build/capture is noncanonical") unless
    report && report[:path] == report_path && report[:build] == build_id && report[:capture] == "-"
  if capture
    capture_material = materialized_commit_file(capture_path, commit, "#{label} native capture", fresh_clone: fresh_clone)
    probe_mp4(capture_material[:bytes], "#{label} native capture") if capture_material
  end
  if report
    report_rows = parse_tsv(
      "#{report_path}@#{report[:digest]}", "#{label} phase report", H2_PHASE_REPORT_HEADER, 1,
      commit: commit, fresh_clone: fresh_clone, payload_context: payload_context
    )
    record = H2_PHASE_REPORT_HEADER.zip(report_rows.first || []).to_h
    expected = {
      "scope_id" => scope, "phase" => phase, "source_manifest_sha256" => source_digest,
      "output_manifest_sha256" => output_digest, "build_id" => build_id,
      "reviewer_id" => reviewer_id, "reviewer_non_owner" => reviewer_non_owner,
      "observed_at" => observed_at, "capture_path" => capture_path,
      "capture_sha256" => capture && capture[:digest]
    }
    expected.each { |field, value| error("#{label}: phase report #{field} mismatch") unless record[field] == value }
    error("#{label}: phase report timestamp is not RFC 3339") unless valid_rfc3339?(record["observed_at"])
  end
  owned_paths&.merge(manifest_owned_paths(local_context, manifest_path))
  owned_paths << manifest_path if owned_paths
end

def validate_h2_polish_passes(scope, gate7_manifest_path, source_path, output_path, source_digest, output_digest, gate6_row,
                              gate7_row,
                              commit:, fresh_clone:, payload_context:, local_context:, owner_ids:, owned_paths:,
                              rollup_slug: nil, label:)
  root = rollup_slug ? "review/benchmark/rollups/#{rollup_slug}/g7" : "review/#{scope}/g7"
  registry_path = "#{root}/POLISH_PASSES.tsv"
  gate7_entries = local_context[:manifests][gate7_manifest_path] || []
  registry_entry = gate7_entries.select { |entry| entry[:role] == "polish.pass_registry" }
  error("#{label}: H2 Gate 7 must own exactly one polish.pass_registry") unless
    registry_entry.length == 1 && registry_entry.first[:path] == registry_path && registry_entry.first[:capture] == "-"
  return unless registry_entry.length == 1 && registry_entry.first[:path] == registry_path

  first_in_engine_path = "#{root}/FIRST_IN_ENGINE.tsv"
  first_in_engine_entry = gate7_entries.select { |entry| entry[:role] == "polish.first_in_engine" }
  error("#{label}: H2 Gate 7 must own exactly one polish.first_in_engine baseline") unless
    first_in_engine_entry.length == 1 && first_in_engine_entry.first[:path] == first_in_engine_path &&
    first_in_engine_entry.first[:capture] == "-"
  first_in_engine_rows = if first_in_engine_entry.length == 1 && first_in_engine_entry.first[:path] == first_in_engine_path
                           parse_tsv(
                             "#{first_in_engine_path}@#{first_in_engine_entry.first[:digest]}",
                             "#{label} first-in-engine Gate-6 baseline", FIRST_IN_ENGINE_HEADER, 1,
                             commit: commit, fresh_clone: fresh_clone, payload_context: payload_context
                           )
                         else
                           []
                         end
  first_in_engine = FIRST_IN_ENGINE_HEADER.zip(first_in_engine_rows.first || []).to_h
  owned_paths << first_in_engine_path if owned_paths && first_in_engine_rows.length == 1

  rows = parse_tsv(
    "#{registry_path}@#{registry_entry.first[:digest]}", "#{label} H2 polish-pass registry",
    POLISH_PASS_HEADER, 2, commit: commit, fresh_clone: fresh_clone, payload_context: payload_context
  )
  owned_paths << registry_path if owned_paths
  return unless rows.length == 2

  records = rows.map { |fields| POLISH_PASS_HEADER.zip(fields).to_h }
  error("#{label}: H2 polish passes must be exact ordered pass 1 then 2") unless
    records.map { |record| record["pass_number"] } == %w[1 2]

  if first_in_engine_rows.length == 1
    error("#{label}: first-in-engine baseline scope/build/decision mismatch") unless
      first_in_engine["scope_id"] == scope && first_in_engine["build_id"] == gate6_row["build_id"] &&
      first_in_engine["decision"] == "PASS"
    error("#{label}: first-in-engine baseline commit/digests malformed") unless
      first_in_engine["commit"]&.match?(HEX40) && first_in_engine["source_manifest_sha256"]&.match?(HEX64) &&
      first_in_engine["output_manifest_sha256"]&.match?(HEX64) && first_in_engine["gate_record_sha256"]&.match?(HEX64)
    baseline_reviewer = first_in_engine["reviewer_id"]
    error("#{label}: first-in-engine baseline requires a canonical non-owner reviewer") unless
      canonical_identity?(baseline_reviewer) && first_in_engine["reviewer_non_owner"] == "YES" && !owner_ids.include?(baseline_reviewer)
    expected_baseline_evidence = "#{root}/polish/first_in_engine/EVIDENCE_MANIFEST.sha256"
    error("#{label}: first-in-engine evidence path/digest is noncanonical") unless
      first_in_engine["evidence_path"] == expected_baseline_evidence && first_in_engine["evidence_sha256"]&.match?(HEX64)
    if first_in_engine["evidence_sha256"]&.match?(HEX64)
      validate_h2_phase_evidence(
        expected_baseline_evidence, first_in_engine["evidence_sha256"], scope: scope,
        phase: "first_in_engine", source_digest: first_in_engine["source_manifest_sha256"],
        output_digest: first_in_engine["output_manifest_sha256"], build_id: first_in_engine["build_id"],
        reviewer_id: baseline_reviewer, reviewer_non_owner: first_in_engine["reviewer_non_owner"],
        observed_at: first_in_engine["decided_at"], commit: commit, fresh_clone: fresh_clone,
        payload_context: payload_context, local_context: local_context, owned_paths: owned_paths,
        label: "#{label} first-in-engine evidence"
      )
    end
    if first_in_engine["commit"]&.match?(HEX40)
      source_material = materialized_commit_file(
        source_path, first_in_engine["commit"], "#{label} first-in-engine source manifest",
        fresh_clone: fresh_clone, allow_lfs: false
      )
      output_material = materialized_commit_file(
        output_path, first_in_engine["commit"], "#{label} first-in-engine output manifest",
        fresh_clone: fresh_clone, allow_lfs: false
      )
      error("#{label}: first-in-engine source/output hashes are not committed manifest bytes") unless
        source_material && output_material && source_material[:digest] == first_in_engine["source_manifest_sha256"] &&
        output_material[:digest] == first_in_engine["output_manifest_sha256"]
      historical_asset_context = new_manifest_context
      validate_manifest(
        source_path, first_in_engine["source_manifest_sha256"], "#{label} first-in-engine source closure",
        [], first_in_engine["commit"], fresh_clone, historical_asset_context
      ) if !rollup_slug && first_in_engine["source_manifest_sha256"]&.match?(HEX64)
      validate_manifest(
        output_path, first_in_engine["output_manifest_sha256"], "#{label} first-in-engine output closure",
        [], first_in_engine["commit"], fresh_clone, historical_asset_context
      ) if !rollup_slug && first_in_engine["output_manifest_sha256"]&.match?(HEX64)
      expected_historical_gate_path = rollup_slug ?
        "review/benchmark/rollups/#{rollup_slug}/GATE_RECORD.tsv" : "review/#{scope}/g1/GATE_RECORD.tsv"
      error("#{label}: first-in-engine historical gate-record path/hash is noncanonical") unless
        first_in_engine["gate_record_path"] == expected_historical_gate_path &&
        first_in_engine["gate_record_sha256"]&.match?(HEX64)
      historical_gate_rows = if first_in_engine["gate_record_sha256"]&.match?(HEX64)
                               parse_tsv(
                                 "#{expected_historical_gate_path}@#{first_in_engine['gate_record_sha256']}",
                                 "#{label} first-in-engine historical gate record", GATE_RECORD_HEADER, 7,
                                 commit: first_in_engine["commit"], fresh_clone: fresh_clone
                               )
                             else
                               []
                             end
      historical_vector = historical_gate_rows.map { |fields| GATE_RECORD_HEADER.zip(fields).to_h["decision"] }
      error("#{label}: first-in-engine checkpoint must have Gates 1-6 complete and Gate 7 PENDING") unless
        historical_vector.length == 7 &&
        historical_vector.first(6).each_with_index.all? do |decision, index|
          completion_decision_allowed?(decision, gate6_row["profile"], "G#{index + 1}")
        end && historical_vector[6] == "PENDING"
      validate_gate_record(
        "#{expected_historical_gate_path}@#{first_in_engine['gate_record_sha256']}",
        "#{label} first-in-engine historical gate record", scope: scope,
        profile: gate6_row["profile"], tier: gate6_row["tier"],
        source_digest: first_in_engine["source_manifest_sha256"],
        output_digest: first_in_engine["output_manifest_sha256"], build_id: first_in_engine["build_id"],
        expected_vector: historical_vector, commit: first_in_engine["commit"], fresh_clone: fresh_clone,
        source_context: historical_asset_context, owner_ids: owner_ids
      ) if historical_vector.length == 7
    end
  end
  records.each_with_index do |record, index|
    pass_number = index + 1
    error("#{label}: polish pass #{pass_number} scope mismatch") unless record["scope_id"] == scope
    %w[before_commit after_commit].each do |field|
      error("#{label}: polish pass #{pass_number} #{field} malformed") unless record[field]&.match?(HEX40)
    end
    if record["before_commit"]&.match?(HEX40) && record["after_commit"]&.match?(HEX40)
      _before_out, _before_err, before_status = git_capture(
        "cat-file", "-e", "#{record['before_commit']}^{commit}", root: fresh_clone || ROOT
      )
      _after_out, _after_err, after_status = git_capture(
        "cat-file", "-e", "#{record['after_commit']}^{commit}", root: fresh_clone || ROOT
      )
      _chain_out, _chain_err, chain_status = git_capture(
        "merge-base", "--is-ancestor", record["before_commit"], record["after_commit"], root: fresh_clone || ROOT
      )
      error("#{label}: polish pass #{pass_number} commits are missing or not in forward ancestry") unless
        before_status.success? && after_status.success? && chain_status.success? && record["before_commit"] != record["after_commit"]
    end
    %w[before_source_sha256 after_source_sha256 before_output_sha256 after_output_sha256].each do |field|
      error("#{label}: polish pass #{pass_number} #{field} malformed") unless record[field]&.match?(HEX64)
    end
    changed = record["before_source_sha256"] != record["after_source_sha256"] ||
              record["before_output_sha256"] != record["after_output_sha256"]
    error("#{label}: polish pass #{pass_number} must record a real source/output revision") unless changed
    [["before", record["before_commit"]], ["after", record["after_commit"]]].each do |phase, revision_commit|
      next unless revision_commit&.match?(HEX40)
      source_material = materialized_commit_file(
        source_path, revision_commit, "#{label} polish pass #{pass_number} #{phase} source manifest",
        fresh_clone: fresh_clone, allow_lfs: false
      )
      output_material = materialized_commit_file(
        output_path, revision_commit, "#{label} polish pass #{pass_number} #{phase} output manifest",
        fresh_clone: fresh_clone, allow_lfs: false
      )
      error("#{label}: polish pass #{pass_number} #{phase} source digest is not the committed manifest bytes") unless
        source_material && source_material[:digest] == record["#{phase}_source_sha256"]
      error("#{label}: polish pass #{pass_number} #{phase} output digest is not the committed manifest bytes") unless
        output_material && output_material[:digest] == record["#{phase}_output_sha256"]
      validate_manifest(
        source_path, record["#{phase}_source_sha256"], "#{label} polish pass #{pass_number} #{phase} source closure",
        [], revision_commit, fresh_clone, new_manifest_context
      ) if record["#{phase}_source_sha256"]&.match?(HEX64)
      validate_manifest(
        output_path, record["#{phase}_output_sha256"], "#{label} polish pass #{pass_number} #{phase} output closure",
        [], revision_commit, fresh_clone, new_manifest_context
      ) if record["#{phase}_output_sha256"]&.match?(HEX64)
    end
    reviewer = record["reviewer_id"]
    error("#{label}: polish pass #{pass_number} reviewer malformed/placeholder") unless canonical_identity?(reviewer)
    error("#{label}: polish pass #{pass_number} requires a non-owner reviewer") unless record["reviewer_non_owner"] == "YES"
    error("#{label}: polish pass #{pass_number} reviewer matches an asset owner") if owner_ids.include?(reviewer)
    error("#{label}: polish pass #{pass_number} must be PASS with no open defects") unless
      record["decision"] == "PASS" && record["defect_ids"] == "NONE"
    error("#{label}: polish pass #{pass_number} rationale missing") unless
      record["rationale"] && record["rationale"].length.between?(12, 500)
    expected_before_path = "#{root}/polish/pass#{pass_number}/before/EVIDENCE_MANIFEST.sha256"
    expected_after_path = "#{root}/polish/pass#{pass_number}/after/EVIDENCE_MANIFEST.sha256"
    error("#{label}: polish pass #{pass_number} before/after evidence paths are noncanonical") unless
      record["before_evidence_path"] == expected_before_path && record["after_evidence_path"] == expected_after_path
    [["before", expected_before_path], ["after", expected_after_path]].each do |phase, expected_path|
      digest = record["#{phase}_evidence_sha256"]
      error("#{label}: polish pass #{pass_number} #{phase} evidence digest malformed") unless digest&.match?(HEX64)
      if digest&.match?(HEX64)
        validate_h2_phase_evidence(
          expected_path, digest, scope: scope, phase: "pass#{pass_number}.#{phase}",
          source_digest: record["#{phase}_source_sha256"], output_digest: record["#{phase}_output_sha256"],
          build_id: gate6_row["build_id"], reviewer_id: reviewer,
          reviewer_non_owner: record["reviewer_non_owner"], observed_at: record["decided_at"],
          commit: commit, fresh_clone: fresh_clone, payload_context: payload_context,
          local_context: local_context, owned_paths: owned_paths,
          label: "#{label} polish pass #{pass_number} #{phase}"
        )
      end
    end
  end
  error("#{label}: polish pass revision chain is discontinuous") unless
    records[1]["before_commit"] == records[0]["after_commit"] &&
    records[1]["before_source_sha256"] == records[0]["after_source_sha256"] &&
    records[1]["before_output_sha256"] == records[0]["after_output_sha256"]
  error("#{label}: polish pass 2 does not resolve to the reviewed final source/output") unless
    records[1]["after_source_sha256"] == source_digest && records[1]["after_output_sha256"] == output_digest
  if commit&.match?(HEX40) && records[1]["after_commit"]&.match?(HEX40)
    _payload_chain_out, _payload_chain_err, payload_chain_status = git_capture(
      "merge-base", "--is-ancestor", records[1]["after_commit"], commit, root: fresh_clone || ROOT
    )
    error("#{label}: final polish revision must be a strict ancestor of the reviewed payload commit") unless
      payload_chain_status.success? && records[1]["after_commit"] != commit
  end
  if first_in_engine_rows.length == 1
    error("#{label}: first-in-engine commit cannot be its owning reviewed payload commit") if
      first_in_engine["commit"] == commit
    error("#{label}: pass 1 must descend from the exact first-in-engine Gate-6 baseline") unless
      records[0]["before_commit"] == first_in_engine["commit"] &&
      records[0]["before_source_sha256"] == first_in_engine["source_manifest_sha256"] &&
      records[0]["before_output_sha256"] == first_in_engine["output_manifest_sha256"]
  end
  [first_in_engine["decided_at"], *records.map { |record| record["decided_at"] },
   gate6_row["decided_at"], gate7_row["decided_at"]].each do |timestamp|
    error("#{label}: H2 polish/Gate timestamp is not exact RFC 3339") unless valid_rfc3339?(timestamp)
  end
  begin
    baseline_time = Time.iso8601(first_in_engine["decided_at"])
    pass_times = records.map { |record| Time.iso8601(record["decided_at"]) }
    final_gate6_time = Time.iso8601(gate6_row["decided_at"])
    final_gate7_time = Time.iso8601(gate7_row["decided_at"])
    error("#{label}: both H2 polish passes must follow first-in-engine Gate 6, then final Gate 6 must revalidate them") unless
      pass_times[0] > baseline_time && pass_times[1] > pass_times[0] && final_gate6_time > pass_times[1]
    error("#{label}: Gate 7 must be strictly later than final Gate-6 revalidation") unless final_gate7_time > final_gate6_time
  rescue ArgumentError, TypeError
    error("#{label}: H2 polish/Gate-6 timestamps must be RFC 3339")
  end
  kernel_passes = records.map do |record|
    ancestry_valid = false
    if record["before_commit"]&.match?(HEX40) && record["after_commit"]&.match?(HEX40)
      _out, _err, ancestry_status = git_capture(
        "merge-base", "--is-ancestor", record["before_commit"], record["after_commit"],
        root: fresh_clone || ROOT
      )
      ancestry_valid = ancestry_status.success?
    end
    {
      "pass_number" => record["pass_number"],
      "before_commit" => record["before_commit"], "after_commit" => record["after_commit"],
      "before_source_sha256" => record["before_source_sha256"],
      "after_source_sha256" => record["after_source_sha256"],
      "before_output_sha256" => record["before_output_sha256"],
      "after_output_sha256" => record["after_output_sha256"],
      "decided_at" => record["decided_at"], "ancestry_valid" => ancestry_valid
    }
  end
  final_payload_ancestry_valid = false
  if commit&.match?(HEX40) && records[1]["after_commit"]&.match?(HEX40)
    _out, _err, ancestry_status = git_capture(
      "merge-base", "--is-ancestor", records[1]["after_commit"], commit,
      root: fresh_clone || ROOT
    )
    final_payload_ancestry_valid = ancestry_status.success? && records[1]["after_commit"] != commit
  end
  validate_shared_lifecycle_branch(
    "h2",
    {
      "first_in_engine" => {
        "commit" => first_in_engine["commit"],
        "source_sha256" => first_in_engine["source_manifest_sha256"],
        "output_sha256" => first_in_engine["output_manifest_sha256"],
        "decided_at" => first_in_engine["decided_at"]
      },
      "passes" => kernel_passes, "final_source_sha256" => source_digest,
      "final_output_sha256" => output_digest,
      "final_g6_decided_at" => gate6_row["decided_at"],
      "final_g7_decided_at" => gate7_row["decided_at"],
      "final_payload_ancestry_valid" => final_payload_ancestry_valid
    },
    "#{label} shared production H2 lifecycle"
  )
end

def authoring_receipt_revision_key(commit, fresh_clone)
  return nil unless commit&.match?(HEX40) && fresh_clone

  [commit, Pathname.new(fresh_clone).expand_path.to_s]
end

def validate_authoring_root_payload_binding(payload_context, commit, fresh_clone, label)
  return unless payload_context

  roots = AUTHORING_ROOT_PAYLOAD_PATHS.select { |path| payload_context[:manifests].key?(path) }
  error("#{label}: multiple authoring root payload manifests are active") if roots.length > 1
  return if roots.empty?

  root_path = roots.first
  unless commit&.match?(HEX40) && fresh_clone
    error("#{label}: authoring root payload binding requires one reviewed commit and fresh public clone")
    return
  end
  AUTHORING_ROOT_REQUIRED_MODES.each do |path, expected_mode|
    error("#{label}: #{path} must be a direct #{root_path} member") unless
      payload_context[:member_owner][path] == root_path
    material = materialized_commit_file(
      path, commit, "#{label} root-bound #{path}", fresh_clone: fresh_clone, allow_lfs: false
    )
    error("#{label}: #{path} must be an ordinary Git #{expected_mode} blob at the reviewed commit") unless
      material && material[:kind] == :git && material[:mode] == expected_mode
  end
end

def validate_authoring_gate_receipt(scope:, gate:, applicable:, evidence_path:, row:, source_digest:,
                                    output_digest:, commit:, fresh_clone:, local_context:, source_context:, label:)
  evidence_owned_paths = manifest_owned_paths(local_context, evidence_path)
  # macOS ships a Ruby version where Set does not implement Enumerable#filter_map.
  # Keep this production path compatible with that exact /usr/bin/ruby runtime.
  evidence_entries = evidence_owned_paths.map { |path| local_context[:entries][path] }.compact
  source_manifest_path = "assets-src/#{scope.split('.', 2).first}/#{scope}/SOURCE_MANIFEST.sha256"
  output_manifest_path = "review/#{scope}/g5/OUTPUT_MANIFEST.sha256"
  source_owned_paths = source_context ? manifest_owned_paths(source_context, source_manifest_path) : Set.new
  output_owned_paths = manifest_owned_paths(local_context, output_manifest_path)
  receipt_path = %w[G2 G5].include?(gate) ? N64Game::AuthoringStackReceipt.receipt_path(scope, gate) : nil
  placement_issues = N64Game::AuthoringStackReceipt.placement_issues(
    scope_id: scope, gate: gate, applicable: applicable,
    evidence_manifest_path: evidence_path, evidence_entries: evidence_entries,
    direct_owner: receipt_path && local_context[:member_owner][receipt_path],
    source_owned_paths: source_owned_paths, output_owned_paths: output_owned_paths,
    build_id: row["build_id"]
  )
  placement_issues.each { |issue| error("#{label} #{gate}: #{issue}") }
  return unless applicable && %w[G2 G5].include?(gate)

  revision_key = authoring_receipt_revision_key(commit, fresh_clone)
  unless revision_key
    error("#{label} #{gate}: authoring receipt requires one reviewed commit and fresh public clone")
    return
  end
  AUTHORING_RECEIPT_EXPECTED_BY_REVISION[revision_key] << receipt_path
  receipt_material = materialized_commit_file(
    receipt_path, commit, "#{label} #{gate} authoring receipt",
    fresh_clone: fresh_clone, allow_lfs: false
  )
  error("#{label} #{gate}: authoring receipt must be an ordinary 100644 Git blob") unless
    receipt_material && receipt_material[:kind] == :git && receipt_material[:mode] == "100644"

  required_materials = AUTHORING_ROOT_REQUIRED_MODES.each_with_object({}) do |(path, expected_mode), materials|
    next if path == "scripts/validate-asset-contract" || path == "lib/n64game/authoring_stack_receipt.rb"

    material = materialized_commit_file(
      path, commit, "#{label} #{gate} authoring dependency #{path}",
      fresh_clone: fresh_clone, allow_lfs: false
    )
    error("#{label} #{gate}: authoring dependency #{path} must be an ordinary Git #{expected_mode} blob") unless
      material && material[:kind] == :git && material[:mode] == expected_mode
    materials[path] = material if material && material[:kind] == :git && material[:mode] == expected_mode
  end
  lock_material = required_materials["config/toolchain.lock.json"]
  checker_members = N64Game::AuthoringStackReceipt::CHECKER_BUNDLE_PATHS.to_h do |path|
    [path, required_materials.dig(path, :bytes)]
  end
  return unless receipt_material && lock_material && checker_members.values.none?(&:nil?)

  expected_output = gate == "G2" ? "NONE" : output_digest
  expected_build = gate == "G2" ? "-" : row["build_id"]
  N64Game::AuthoringStackReceipt.validate(
    bytes: receipt_material[:bytes], scope_id: scope, gate: gate,
    source_manifest_sha256: source_digest, output_manifest_sha256: expected_output,
    build_id: expected_build, decided_at: row["decided_at"],
    toolchain_lock_bytes: lock_material[:bytes], checker_members: checker_members
  ).each { |issue| error("#{label} #{gate}: #{issue}") }
rescue StandardError => exception
  error("#{label} #{gate}: controlled authoring receipt validation failure: #{exception.class}: #{exception.message}")
end

def validate_authoring_receipt_universe(commit:, fresh_clone:, payload_context:, tree_entries:, label:,
                                         inherited_contexts: [])
  return unless commit&.match?(HEX40) && fresh_clone && payload_context

  validate_authoring_root_payload_binding(payload_context, commit, fresh_clone, label)
  revision_key = authoring_receipt_revision_key(commit, fresh_clone)
  expected_paths = AUTHORING_RECEIPT_EXPECTED_BY_REVISION.fetch(revision_key, Set.new).dup
  Array(inherited_contexts).each do |context|
    context[:entries].each_value do |entry|
      expected_paths << entry[:path] if entry[:role] == "authoring.stack_receipt"
    end
  end
  contexts = [payload_context, *Array(inherited_contexts)].compact
  manifest_entries = contexts.flat_map { |context| context[:entries].values }.uniq do |entry|
    [entry[:path], entry[:role], entry[:build], entry[:capture], entry[:kind]]
  end
  N64Game::AuthoringStackReceipt.universe_issues(
    expected_paths: expected_paths.to_a, tree_entries: tree_entries,
    manifest_entries: manifest_entries
  ).each { |issue| error("#{label}: #{issue}") }
  expected_paths.each do |path|
    material = materialized_commit_file(
      path, commit, "#{label} receipt universe member", fresh_clone: fresh_clone, allow_lfs: false
    )
    error("#{label}: receipt universe member must be ordinary Git mode 100644: #{path}") unless
      material && material[:kind] == :git && material[:mode] == "100644"
  end
end

def validate_gate_record(path_hash, label, scope:, profile:, tier:, source_digest:, output_digest:, build_id:,
                         expected_vector:, commit: nil, fresh_clone: nil, payload_context: nil, source_context: nil,
                         require_complete: false, owned_paths: nil, owner_ids: [])
  gate_record_path = path_hash.to_s.split("@", 2).first
  canonical_profile_tier = expected_profile_tier(scope)
  canonical_asset_scope = !canonical_profile_tier.nil?
  error("#{label}: caller profile/tier differs from the canonical scope mapping") if
    canonical_asset_scope && [profile, tier] != canonical_profile_tier
  generated_child_scope = GENERATED_CAMERA_CHILDREN.key?(scope)
  rollup_slug = {
    "rollup.player" => "player", "rollup.quarrune" => "quarrune",
    "rollup.sector" => "sector", "rollup.presentation" => "presentation"
  }[scope]
  if canonical_asset_scope
    error("#{label}: canonical gate-record path mismatch") unless gate_record_path == "review/#{scope}/g1/GATE_RECORD.tsv"
  elsif rollup_slug
    error("#{label}: canonical rollup gate-record path mismatch") unless
      gate_record_path == "review/benchmark/rollups/#{rollup_slug}/GATE_RECORD.tsv"
  elsif generated_child_scope
    error("#{label}: canonical generated-child gate-record path mismatch") unless
      gate_record_path == "review/generated/#{scope}/GATE_RECORD.tsv"
  end
  rows = parse_tsv(
    path_hash, label, GATE_RECORD_HEADER, 7, commit: commit, fresh_clone: fresh_clone,
    payload_context: payload_context
  )
  return [] unless rows.length == 7
  owned_paths << gate_record_path if owned_paths

  source_context ||= payload_context
  local_context = payload_context || source_context || new_manifest_context
  canonical_profile = canonical_profile_tier&.first
  canonical_source_path = canonical_asset_scope ?
    "assets-src/#{scope.split('.', 2).first}/#{scope}/SOURCE_MANIFEST.sha256" : nil
  source_graph_ready = canonical_source_path && source_context &&
    source_context[:manifest_digests][canonical_source_path] == source_digest
  source_owned_paths = source_graph_ready ? manifest_owned_paths(source_context, canonical_source_path).to_a : []
  receipt_relevant = [rows[1], rows[4]].any? { |fields| fields && fields[4] != "PENDING" }
  if canonical_asset_scope && receipt_relevant && !source_graph_ready
    error("#{label}: G2/G5 authoring applicability requires the exact transitive SOURCE manifest context")
  end
  authoring_applicable = N64Game::AuthoringStackReceipt.applicable?(
    canonical_asset_scope: canonical_asset_scope, profile: canonical_profile,
    source_paths: source_owned_paths
  )
  authoring_applicable = true if canonical_asset_scope && receipt_relevant && !source_graph_ready
  decisions = []
  previous_decided_at = nil
  rows.each_with_index do |fields, index|
    row = GATE_RECORD_HEADER.zip(fields).to_h
    gate = "G#{index + 1}"
    error("#{label} #{gate}: scope mismatch") unless row["scope_id"] == scope
    error("#{label} #{gate}: profile/tier mismatch") unless row["profile"] == profile && row["tier"] == tier
    error("#{label}: gate rows must be exactly G1..G7") unless row["gate"] == gate
    decision = row["decision"]
    decisions << decision
    error("#{label} #{gate}: invalid decision #{decision.inspect}") unless ALL_GATE_DECISIONS.include?(decision)
    error("#{label} #{gate}: registry decision projection mismatch") unless
      expected_vector.nil? || decision == expected_vector[index]
    if decision == "PENDING"
      error("#{label} #{gate}: PENDING decision must use PENDING in all bindings") unless fields[5..].all? { |value| value == "PENDING" }
      error("#{label} #{gate}: completed decision required") if require_complete
      next
    end

    unless decisions[0...-1].all? { |prior| COMPLETE_GATE_DECISIONS.include?(prior) }
      error("#{label} #{gate}: nonpending decision follows an incomplete earlier gate")
    end
    if COMPLETE_GATE_DECISIONS.include?(decision) && !completion_decision_allowed?(decision, profile, gate)
      error("#{label} #{gate}: completion equivalent is illegal for profile/gate")
    end
    error("#{label} #{gate}: completed decision required") if require_complete && !COMPLETE_GATE_DECISIONS.include?(decision)

    reviewer = row["reviewer_id"]
    error("#{label} #{gate}: reviewer ID is malformed/placeholder") unless canonical_identity?(reviewer)
    error("#{label} #{gate}: reviewer_non_owner must be YES or NO") unless %w[YES NO].include?(row["reviewer_non_owner"])
    independent_required = (tier == "H2" && %w[G1 G3 G6 G7].include?(gate)) || (%w[M7 S7 C7 D7].include?(tier) && gate == "G7")
    error("#{label} #{gate}: required non-owner reviewer missing") if independent_required && row["reviewer_non_owner"] != "YES"
    if row["reviewer_non_owner"] == "YES" && owner_ids.include?(reviewer)
      error("#{label} #{gate}: claimed non-owner reviewer matches an asset owner")
    end
    error("#{label} #{gate}: reviewed source hash is not current") unless row["source_manifest_sha256"] == source_digest
    expected_output = if rollup_slug
                        output_digest
                      elsif index < 4 || output_digest == "NONE"
                        "NONE"
                      else
                        output_digest
                      end
    error("#{label} #{gate}: reviewed output hash is not current") unless row["output_manifest_sha256"] == expected_output
    evidence_path = row["evidence_manifest_path"]
    evidence_digest = row["evidence_manifest_sha256"]
    if canonical_asset_scope
      error("#{label} #{gate}: canonical evidence-manifest path mismatch") unless
        evidence_path == "review/#{scope}/g#{index + 1}/EVIDENCE_MANIFEST.sha256"
      error("#{label} #{gate}: canonical review-record path mismatch") unless
        row["review_record_path"] == "review/#{scope}/g#{index + 1}/REVIEW.md"
    elsif rollup_slug
      error("#{label} #{gate}: canonical rollup evidence-manifest path mismatch") unless
        evidence_path == "review/benchmark/rollups/#{rollup_slug}/g#{index + 1}/EVIDENCE_MANIFEST.sha256"
      error("#{label} #{gate}: canonical rollup review-record path mismatch") unless
        row["review_record_path"] == "review/benchmark/rollups/#{rollup_slug}/g#{index + 1}/REVIEW.md"
    elsif generated_child_scope
      error("#{label} #{gate}: canonical generated-child evidence-manifest path mismatch") unless
        evidence_path == "review/generated/#{scope}/g#{index + 1}/EVIDENCE_MANIFEST.sha256"
      error("#{label} #{gate}: canonical generated-child review-record path mismatch") unless
        row["review_record_path"] == "review/generated/#{scope}/g#{index + 1}/REVIEW.md"
    end
    if safe_repo_path?(evidence_path) && evidence_digest.match?(HEX64)
      if payload_context && !payload_context[:closure].include?(evidence_path)
        error("#{label} #{gate}: evidence manifest is not payload-owned")
      end
      validate_manifest(evidence_path, evidence_digest, "#{label} #{gate} evidence", [], commit, fresh_clone, local_context)
      evidence_root = if canonical_asset_scope
                        "review/#{scope}/g#{index + 1}/"
                      elsif generated_child_scope
                        "review/generated/#{scope}/g#{index + 1}/"
                      else
                        "review/benchmark/rollups/#{rollup_slug}/g#{index + 1}/"
                      end
      validate_manifest_member_roots(local_context, evidence_path, [evidence_root], "#{label} #{gate} evidence")
      validate_authoring_gate_receipt(
        scope: scope, gate: gate, applicable: authoring_applicable, evidence_path: evidence_path,
        row: row, source_digest: source_digest, output_digest: output_digest,
        commit: commit, fresh_clone: fresh_clone, local_context: local_context,
        source_context: source_context, label: label
      )
      if canonical_asset_scope && index.zero?
        validate_gate1_attempt_history(
          scope, evidence_path, owner_ids, commit: commit, fresh_clone: fresh_clone,
          payload_context: local_context, owned_paths: owned_paths || Set.new
        )
      end
      owned_paths&.merge(manifest_owned_paths(local_context, evidence_path))
      owned_paths << evidence_path if owned_paths
    else
      error("#{label} #{gate}: evidence manifest path/hash malformed")
    end
    review_record = parse_machine_record(
      "#{row['review_record_path']}@#{row['review_record_sha256']}", "#{label} #{gate} review record",
      GATE_REVIEW_RECORD_KEYS, commit: commit, fresh_clone: fresh_clone,
      payload_context: payload_context, record_context: local_context
    )
    expected_review = {
      "schema" => "n64game-gate-review-v1", "scope_id" => scope, "gate" => gate,
      "decision" => decision, "reviewer_id" => reviewer,
      "reviewer_non_owner" => row["reviewer_non_owner"],
      "source_manifest_sha256" => row["source_manifest_sha256"],
      "output_manifest_sha256" => row["output_manifest_sha256"],
      "evidence_manifest" => "#{evidence_path}@#{evidence_digest}", "build_id" => row["build_id"],
      "decided_at" => row["decided_at"], "defect_ids" => row["defect_ids"]
    }
    expected_review.each do |key, value|
      error("#{label} #{gate}: review-record #{key} mismatch") unless review_record[key] == value
    end
    expected_dispositions = COMPLETE_GATE_DECISIONS.include?(decision) ? ["NONE"] : %w[revise rebuild]
    error("#{label} #{gate}: review disposition does not match machine decision") unless
      expected_dispositions.include?(review_record["disposition"])
    error("#{label} #{gate}: review rationale is missing") unless
      review_record["rationale"] && review_record["rationale"] != "PENDING" && review_record["rationale"].length.between?(12, 500)
    owned_paths << row["review_record_path"] if owned_paths
    if payload_context && !payload_context[:closure].include?(row["review_record_path"])
      error("#{label} #{gate}: review record is not payload-owned")
    end
    expected_build = index >= 4 ? build_id : row["build_id"]
    error("#{label} #{gate}: Gate 5-7 build ID mismatch") if index >= 4 && expected_build != row["build_id"]
    error("#{label} #{gate}: prebuild build ID malformed") if index < 4 && row["build_id"] != "-" && !canonical_build_id?(row["build_id"])
    error("#{label} #{gate}: decision timestamp is not RFC 3339") unless valid_rfc3339?(row["decided_at"])
    begin
      decided_at = Time.iso8601(row["decided_at"])
      error("#{label} #{gate}: gate decision timestamp precedes an earlier gate") if
        previous_decided_at && decided_at < previous_decided_at
      previous_decided_at = decided_at
    rescue ArgumentError
      # The canonical syntax error above is already reported.
    end
    if COMPLETE_GATE_DECISIONS.include?(decision)
      error("#{label} #{gate}: completion decision must have NONE defects") unless row["defect_ids"] == "NONE"
    else
      error("#{label} #{gate}: fail decision requires canonical defect IDs") unless canonical_defect_ids?(row["defect_ids"])
      defect_ids = row["defect_ids"].split(",")
      error("#{label} #{gate}: defect IDs must be sorted and unique") unless defect_ids == defect_ids.sort && defect_ids.uniq == defect_ids
    end
  end
  if tier == "H2" && COMPLETE_GATE_DECISIONS.include?(decisions[6])
    gate6_row = GATE_RECORD_HEADER.zip(rows[5]).to_h
    gate7_row = GATE_RECORD_HEADER.zip(rows[6]).to_h
    source_path = canonical_asset_scope ? "assets-src/#{scope.split('.', 2).first}/#{scope}/SOURCE_MANIFEST.sha256" :
      "review/benchmark/WHITELIST_GATE_REGISTRY.tsv"
    output_path = canonical_asset_scope ? "review/#{scope}/g5/OUTPUT_MANIFEST.sha256" :
      "review/benchmark/WHITELIST_GATE_REGISTRY.tsv"
    validate_h2_polish_passes(
      scope, gate7_row["evidence_manifest_path"], source_path, output_path, source_digest, output_digest, gate6_row,
      gate7_row,
      commit: commit, fresh_clone: fresh_clone, payload_context: payload_context,
      local_context: local_context, owner_ids: owner_ids, owned_paths: owned_paths,
      rollup_slug: rollup_slug, label: label
    )
  end
  decisions
end

def expected_camera_output_bytes(source_bytes, child_id, label)
  text = source_bytes.dup.force_encoding(Encoding::UTF_8)
  unless text.valid_encoding?
    error("#{label}: DATA_SCHEMAS revision is not valid UTF-8")
    return nil
  end
  payload_table = text[/The 15 resource payloads, in AssetId order, are exact:(.*?)(?=These 15 AssetIds are generated runtime children)/m, 1]
  unless payload_table
    error("#{label}: DATA_SCHEMAS revision lacks the canonical camera payload table")
    return nil
  end
  rows = payload_table.scan(
    /^\|\s*`(ASSET_CAMERA_SHOT_[A-Z0-9_]+)`\s*\|\s*`([A-Z_]+)\s*\/\s*([A-Z_]+)`\s*\|\s*`(-?\d+),(-?\d+),(-?\d+)`\s*\|\s*`(-?\d+),(-?\d+),(-?\d+)`\s*\|\s*`(\d+)\s*\/\s*(\d+)`\s*\|/
  )
  error("#{label}: DATA_SCHEMAS camera payload table must retain exact 15-child order") unless
    rows.map(&:first) == GENERATED_CAMERA_CHILDREN.keys
  index = GENERATED_CAMERA_CHILDREN.keys.index(child_id)
  row = rows[index] if index && rows.map(&:first) == GENERATED_CAMERA_CHILDREN.keys
  return nil unless row && row[0] == child_id

  target_modes = {
    "NONE" => 0, "SPEAKER" => 1, "GROUP_CENTROID" => 2,
    "INTERACTION_MARKER" => 3, "SCENE_MARKER" => 4, "MAP_UI" => 5
  }
  framing_modes = { "PRESERVE_ACTIVE" => 0, "LOCKED" => 1, "FOLLOW_TARGET" => 2, "SCREEN_SPACE" => 3 }
  target = target_modes[row[1]]
  framing = framing_modes[row[2]]
  numbers = row[3..].map { |value| Integer(value, 10) }
  signed_values = numbers.first(6)
  fov, blend = numbers.last(2)
  error("#{label}: camera target/framing token is outside the closed schema") unless target && framing
  error("#{label}: camera Q16 value is outside signed 32-bit range") unless
    signed_values.all? { |value| (-2_147_483_648..2_147_483_647).cover?(value) }
  error("#{label}: camera FOV/blend is outside unsigned 16-bit range") unless
    [fov, blend].all? { |value| (0..65_535).cover?(value) }
  return nil unless target && framing && signed_values.all? { |value| (-2_147_483_648..2_147_483_647).cover?(value) } &&
                    [fov, blend].all? { |value| (0..65_535).cover?(value) }

  asset_id = 0x7801 + index
  [asset_id, target, framing, *signed_values, fov, blend, 0, 0].pack("nCCl>l>l>l>l>l>nnnn")
rescue ArgumentError, TypeError
  error("#{label}: camera payload table contains a noncanonical integer")
  nil
end

def generated_camera_review_snapshot_path(child_id)
  "review/generated/#{child_id}/g5/CAMERA_PAYLOAD.n64cam"
end

def validate_generated_child_transition_registry(ledger_body, decision, camera_lines, current_ledger_by_id)
  result = {
    populated: false, commit: nil, registry_path: nil,
    child_owned_paths: Hash.new { |hash, key| hash[key] = Set.new }, control_paths: Set.new,
    source_paths: Set.new
  }
  transition_authority = ledger_body[/^Generated-Child-Transition-Commit:\s*(\S+)\s*$/, 1]
  transition_binding = ledger_body[/^Generated-Child-Transition-Registry:\s*(\S+)\s*$/, 1]
  error("generated-child transition identity fields are missing") unless transition_authority && transition_binding
  jointly_pending = transition_authority == "PENDING" && transition_binding == "PENDING"
  jointly_populated = transition_authority == "CURRENT_PUBLIC_HEAD" && transition_binding != "PENDING"
  error("generated-child transition commit/registry must be jointly PENDING or populated") unless jointly_pending || jointly_populated
  return result if jointly_pending

  error("generated-child transitions are forbidden before the global benchmark is APPROVED") unless decision == "APPROVED"
  slug = same_repo_slug
  unless slug
    error("generated-child transition requires canonical same-repository public identity")
    return result
  end
  remote_out, remote_error, remote_status = public_git_capture(
    slug, "ls-remote", "--symref", "https://github.com/#{slug}.git", "HEAD"
  )
  transition_commit = remote_out.lines.map do |line|
    oid, ref = line.strip.split("\t", 2)
    oid if ref == "HEAD" && oid&.match?(HEX40)
  end.compact.first
  unless remote_status.success? && transition_commit
    error("generated-child transition cannot resolve credential-free public default HEAD: #{remote_error.lines.first.to_s.strip}")
    return result
  end
  clone = prepare_fresh_public_payload_clone(slug, transition_commit)
  return result unless clone
  expected_path = "review/generated/GENERATED_CHILD_GATE_REGISTRY.tsv"
  registry_path, registry_digest = transition_binding.split("@", 2)
  error("generated-child transition registry path/hash is noncanonical") unless
    registry_path == expected_path && registry_digest&.match?(HEX64)
  return result unless registry_path == expected_path && registry_digest&.match?(HEX64)
  result[:populated] = true
  result[:commit] = transition_commit
  result[:registry_path] = registry_path
  result[:control_paths] << registry_path

  rows = parse_tsv(
    transition_binding, "generated-child transition registry", GENERATED_CHILD_TRANSITION_HEADER, 15,
    commit: transition_commit, fresh_clone: clone
  )
  advanced_count = 0
  kernel_rows = []
  rows.each_with_index do |fields, index|
    row = GENERATED_CHILD_TRANSITION_HEADER.zip(fields).to_h
    child_id, parent_id = GENERATED_CAMERA_CHILDREN.to_a[index]
    label = "generated child #{child_id}"
    error("#{label}: transition row ID/parent/order mismatch") unless
      row["child_id"] == child_id && row["parent_id"] == parent_id
    expected_initial_digest = Digest::SHA256.hexdigest(camera_lines[index].to_s)
    error("#{label}: transition does not bind immutable initial tuple bytes") unless
      row["initial_tuple_sha256"] == expected_initial_digest
    unless %w[concept source converted review approved].include?(row["state"])
      error("#{label}: invalid transition state #{row['state'].inspect}")
      next
    end
    if row["state"] == "concept"
      error("#{label}: untouched transition row must retain literal PENDING fields/gates") unless
        fields[4..].all? { |value| value == "PENDING" }
      kernel_rows << {
        "child_id" => child_id, "parent_id" => parent_id, "state" => row["state"],
        "lifecycle_fields_pending" => fields[4..].all? { |value| value == "PENDING" }
      }
      next
    end
    advanced_count += 1

    owner_ids = [row["creator_id"], row["rights_holder_id"]]
    error("#{label}: transition creator/rightsholder malformed/placeholder") unless owner_ids.all? { |id| canonical_identity?(id) }
    parent_entry = current_ledger_by_id[parent_id]
    error("#{label}: advanced child requires an explicit current parent ledger row at source or later") unless
      parent_entry && %w[source converted review approved].include?(parent_entry[:status])
    expected_parent_gate_path = "review/#{parent_id}/g1/GATE_RECORD.tsv"
    error("#{label}: parent gate-record binding is noncanonical") unless
      row["parent_gate_record_path"] == expected_parent_gate_path && row["parent_gate_record_sha256"]&.match?(HEX64)
    parent_gate_binding = "#{expected_parent_gate_path}@#{row['parent_gate_record_sha256']}"
    error("#{label}: parent gate record does not equal the current parent ledger locator") unless
      leading_locator(parent_entry && parent_entry[:evidence], "gate_record") == parent_gate_binding
    parent_rows = if row["parent_gate_record_sha256"]&.match?(HEX64)
                    parse_tsv(
                      parent_gate_binding, "#{label} parent gate record",
                      GATE_RECORD_HEADER, 7, commit: transition_commit, fresh_clone: clone
                    )
                  else
                    []
                  end
    parent_g1 = GATE_RECORD_HEADER.zip(parent_rows.first || []).to_h
    parent_profile, parent_tier = expected_profile_tier(parent_id)
    error("#{label}: parent Gate 1 is not a matching completed parent decision") unless
      parent_rows.length == 7 && parent_g1["scope_id"] == parent_id && parent_g1["profile"] == parent_profile &&
      parent_g1["tier"] == parent_tier && completion_decision_allowed?(parent_g1["decision"], parent_profile, "G1")
    if parent_entry && parent_profile && parent_tier
      parent_source_path, parent_source_digest = leading_locator(parent_entry[:source], "source").to_s.split("@", 2)
      parent_output_path, parent_output_digest = leading_locator(parent_entry[:output], "output").to_s.split("@", 2)
      parent_has_output = %w[converted review approved].include?(parent_entry[:status])
      expected_parent_source_path = "assets-src/#{parent_id.split('.', 2).first}/#{parent_id}/SOURCE_MANIFEST.sha256"
      expected_parent_output_path = "review/#{parent_id}/g5/OUTPUT_MANIFEST.sha256"
      error("#{label}: current parent source locator is malformed/noncanonical") unless
        parent_source_path == expected_parent_source_path && parent_source_digest&.match?(HEX64)
      if parent_has_output
        error("#{label}: current parent output locator is malformed/noncanonical") unless
          parent_output_path == expected_parent_output_path && parent_output_digest&.match?(HEX64)
      else
        error("#{label}: source-state parent must retain output:NONE") unless leading_locator(parent_entry[:output], "output") == "NONE"
        parent_output_digest = "NONE"
      end
      parent_gates = parse_ledger_gate_vector(parent_entry[:gates], "#{label} parent")
      parent_build = if parent_has_output
                       GATE_RECORD_HEADER.zip(parent_rows[4] || []).to_h["build_id"]
                     else
                       "-"
                     end
      parent_owners = canonical_ledger_owners(parent_entry[:creator])
      error("#{label}: current parent creator/rightsholder is malformed") unless parent_owners
      parent_asset_context = new_manifest_context
      validate_manifest(
        parent_source_path, parent_source_digest, "#{label} parent source", [], transition_commit, clone,
        parent_asset_context
      ) if parent_source_digest&.match?(HEX64)
      validate_manifest(
        parent_output_path, parent_output_digest, "#{label} parent output", [], transition_commit, clone,
        parent_asset_context
      ) if parent_has_output && parent_output_digest&.match?(HEX64)
      validate_gate_record(
        parent_gate_binding, "#{label} fully validated parent gate record",
        scope: parent_id, profile: parent_profile, tier: parent_tier,
        source_digest: parent_source_digest, output_digest: parent_output_digest,
        build_id: parent_build, expected_vector: parent_gates,
        commit: transition_commit, fresh_clone: clone, require_complete: false,
        source_context: parent_asset_context, owner_ids: parent_owners || []
      ) if row["parent_gate_record_sha256"]&.match?(HEX64) && parent_source_digest&.match?(HEX64)
      validate_ledger_gate_lifecycle(parent_entry, parent_gates, parent_has_output, "#{label} parent")
    end

    error("#{label}: source revision must be exact docs/DATA_SCHEMAS.md@hash") unless
      row["source_revision_path"] == "docs/DATA_SCHEMAS.md" && row["source_revision_sha256"]&.match?(HEX64)
    source_material = materialized_commit_file(
      "docs/DATA_SCHEMAS.md", transition_commit, "#{label} source revision", fresh_clone: clone, allow_lfs: false
    )
    error("#{label}: source revision digest differs from committed DATA_SCHEMAS bytes") unless
      source_material && source_material[:digest] == row["source_revision_sha256"]
    result[:source_paths] << "docs/DATA_SCHEMAS.md"

    has_output = %w[converted review approved].include?(row["state"])
    expected_output_path = generated_camera_review_snapshot_path(child_id)
    output_digest = "NONE"
    output_material = nil
    if has_output
      error("#{label}: generated output path/hash is noncanonical") unless
        row["output_path"] == expected_output_path && row["output_sha256"]&.match?(HEX64)
      output_material = materialized_commit_file(
        expected_output_path, transition_commit, "#{label} generated output", fresh_clone: clone, allow_lfs: true
      )
      error("#{label}: generated output digest differs from committed bytes") unless
        output_material && output_material[:digest] == row["output_sha256"]
      expected_output_bytes = source_material && expected_camera_output_bytes(source_material[:bytes], child_id, label)
      error("#{label}: generated output must be the exact deterministic 36-byte big-endian DATA_SCHEMAS tuple") unless
        output_material && expected_output_bytes && output_material[:bytes] == expected_output_bytes &&
        output_material[:bytes].bytesize == 36
      output_digest = row["output_sha256"]
      result[:child_owned_paths][child_id] << expected_output_path
    else
      error("#{label}: preconversion output fields must be PENDING") unless row["output_path"] == "PENDING" && row["output_sha256"] == "PENDING"
    end

    expected_provenance_path = "review/generated/#{child_id}/g1/PROVENANCE.md"
    error("#{label}: generated-child provenance path/hash is noncanonical") unless
      row["provenance_path"] == expected_provenance_path && row["provenance_sha256"]&.match?(HEX64)
    provenance = if row["provenance_sha256"]&.match?(HEX64)
                   parse_machine_record(
                     "#{expected_provenance_path}@#{row['provenance_sha256']}",
                     "#{label} generated-child provenance", GENERATED_CHILD_PROVENANCE_KEYS,
                     commit: transition_commit, fresh_clone: clone
                   )
                 else
                   {}
                 end
    expected_selected_output = has_output ? row["output_sha256"] : "PENDING"
    expected_provenance = {
      "schema" => "n64game-generated-child-provenance-v1", "child_id" => child_id,
      "parent_id" => parent_id, "initial_tuple_sha256" => row["initial_tuple_sha256"],
      "creator_id" => row["creator_id"], "rights_holder_id" => row["rights_holder_id"],
      "source_revision" => "docs/DATA_SCHEMAS.md@#{row['source_revision_sha256']}",
      "selected_output_sha256" => expected_selected_output
    }
    expected_provenance.each do |field, value|
      error("#{label}: generated-child provenance #{field} mismatch") unless provenance[field] == value
    end
    error("#{label}: generated-child provenance rights basis/output license is malformed") unless
      canonical_rights_token?(provenance["rights_basis"]) &&
      canonical_rights_token?(provenance["output_license"], allow_all_rights_reserved: true)
    error("#{label}: generated-child generator tool/version is malformed/placeholder") unless
      canonical_identity?(provenance["generation_tool"]) && canonical_identity?(provenance["generation_version"])
    error("#{label}: generated-child provenance timestamp is not RFC 3339") unless valid_rfc3339?(provenance["generated_at"])
    provenance_support = {
      "rights_evidence" => "review/generated/#{child_id}/g1/RIGHTS.md",
      "transformations" => "review/generated/#{child_id}/g1/TRANSFORMATIONS.md",
      "generation_prompt" => "review/generated/#{child_id}/g1/GENERATION_PROMPT.txt"
    }
    provenance_support.each do |field, expected_path|
      binding = provenance[field]
      path, digest = binding.to_s.split("@", 2)
      error("#{label}: generated-child provenance #{field} path/hash is noncanonical") unless
        path == expected_path && digest&.match?(HEX64)
      result[:control_paths] << expected_path
    end
    rights_result = validate_rights_evidence_record(
      provenance["rights_evidence"], "#{label} generated-child rights evidence",
      subject_id: child_id, rights_basis: provenance["rights_basis"],
      rights_holder_id: provenance["rights_holder_id"], output_license: provenance["output_license"],
      owner_ids: [provenance["creator_id"], provenance["rights_holder_id"]],
      commit: transition_commit, fresh_clone: clone,
      required_support_root: "review/generated/#{child_id}/g1/rights-support/",
      expected_sources: { "docs/DATA_SCHEMAS.md" => row["source_revision_sha256"] }
    )
    result[:control_paths].merge(rights_result[:support_paths])
    validate_transformation_record(
      provenance["transformations"], "#{label} generated-child transformations",
      subject_id: child_id, commit: transition_commit, fresh_clone: clone,
      expected_input_digest: row["source_revision_sha256"]
    )
    validate_generation_prompt_record(
      provenance["generation_prompt"], "#{label} generated-child generation prompt",
      child_id: child_id, tool: provenance["generation_tool"], version: provenance["generation_version"],
      creator_id: provenance["creator_id"], generated_at: provenance["generated_at"],
      commit: transition_commit, fresh_clone: clone
    )
    result[:control_paths] << expected_provenance_path

    expected_gate_path = "review/generated/#{child_id}/GATE_RECORD.tsv"
    error("#{label}: child gate-record path/hash is noncanonical") unless
      row["gate_record_path"] == expected_gate_path && row["gate_record_sha256"]&.match?(HEX64)
    expected_build = has_output ? row["build_id"] : "-"
    error("#{label}: build ID does not match lifecycle") unless
      (has_output && canonical_build_id?(row["build_id"])) || (!has_output && row["build_id"] == "-")
    gates = (1..7).map { |gate| row["g#{gate}"] }
    validate_ledger_gate_lifecycle({ status: row["state"] }, gates, has_output, label)
    child_gate_owned_paths = Set.new
    validate_gate_record(
      "#{expected_gate_path}@#{row['gate_record_sha256']}", "#{label} gate record",
      scope: child_id, profile: "GENERATED_CHILD", tier: "C7", source_digest: row["source_revision_sha256"],
      output_digest: output_digest, build_id: expected_build, expected_vector: gates,
      commit: transition_commit, fresh_clone: clone, owner_ids: owner_ids,
      owned_paths: child_gate_owned_paths
    ) if row["gate_record_sha256"]&.match?(HEX64)
    result[:child_owned_paths][child_id].merge(child_gate_owned_paths)
    result[:control_paths].merge(child_gate_owned_paths.select { |path| path.start_with?("review/generated/") })
    kernel_rows << {
      "child_id" => child_id, "parent_id" => parent_id, "state" => row["state"],
      "initial_tuple_sha256" => row["initial_tuple_sha256"],
      "parent_active" => parent_entry && %w[source converted review approved].include?(parent_entry[:status]),
      "source_revision_path" => row["source_revision_path"],
      "source_revision_sha256" => row["source_revision_sha256"],
      "output_path" => row["output_path"], "output_sha256" => row["output_sha256"],
      "output_bytesize" => output_material && output_material[:bytes].bytesize,
      "output_bytes_hex" => output_material && output_material[:bytes].unpack1("H*"),
      "gates" => gates, "lifecycle_fields_pending" => false
    }
  end
  error("generated-child populated transition registry must advance at least one child") if advanced_count.zero?
  validate_shared_lifecycle_branch(
    "generated_child",
    { "transition_commit_matches_public_head" => remote_status.success? && !transition_commit.nil?, "rows" => kernel_rows },
    "shared production generated-child lifecycle"
  )
  result
end

def validate_move_pair_atomicity(entries, pair_keys, commit:, fresh_clone:, payload_context:, payload_path:,
                                 control_owned: nil)
  by_id = entries.each_with_object({}) { |entry, index| index[entry[:id]] = entry }
  move_entries = entries.select { |entry| entry[:id].match?(/\A(?:vfx|sfx)\.move\./) }
  return unless move_entries.any? { |entry| entry[:status] == "approved" }
  pair_keys.each do |pair_key|
    vfx_id = "vfx.move.#{pair_key}"
    sfx_id = "sfx.move.#{pair_key}"
    vfx_entry = by_id[vfx_id]
    sfx_entry = by_id[sfx_id]
    label = "move pair #{pair_key}"
    next unless [vfx_entry, sfx_entry].compact.any? { |entry| entry[:status] == "approved" }
    unless vfx_entry && sfx_entry
      error("#{label}: both VFX and audio child ledger rows are required")
      next
    end
    error("#{label}: Gate 7 is atomic; both children must be approved") unless
      vfx_entry[:status] == "approved" && sfx_entry[:status] == "approved"
    next unless vfx_entry[:status] == "approved" && sfx_entry[:status] == "approved"

    vfx_evidence = exact_locator_tokens(vfx_entry[:evidence])
    sfx_evidence = exact_locator_tokens(sfx_entry[:evidence])
    error("#{label}: each child evidence cell must contain exactly gate_record and shared pair_proof locators") unless
      vfx_evidence.keys.sort == %w[gate_record pair_proof] && sfx_evidence.keys.sort == %w[gate_record pair_proof]
    proof_binding = vfx_evidence["pair_proof"]
    error("#{label}: both children must bind the same synchronized pair proof") unless
      proof_binding && proof_binding == sfx_evidence["pair_proof"]
    next unless proof_binding
    expected_proof_path = "review/pairs/#{pair_key}/PAIR_SYNC_PROOF.tsv"
    proof_path, proof_digest = proof_binding.split("@", 2)
    error("#{label}: synchronized proof path/hash is noncanonical") unless
      proof_path == expected_proof_path && proof_digest&.match?(HEX64)
    next unless proof_path == expected_proof_path && proof_digest&.match?(HEX64)
    error("#{label}: pair proof must be a direct authoritative root PAYLOAD_MANIFEST member") unless
      payload_context[:member_owner][proof_path] == payload_path
    control_owned << proof_path if control_owned
    proof_rows = parse_tsv(
      proof_binding, "#{label} synchronized proof", PAIR_SYNC_HEADER, 1,
      commit: commit, fresh_clone: fresh_clone, payload_context: payload_context
    )
    next unless proof_rows.length == 1
    proof = PAIR_SYNC_HEADER.zip(proof_rows.first).to_h
    vfx_gate_path, vfx_gate_digest = vfx_evidence["gate_record"].to_s.split("@", 2)
    sfx_gate_path, sfx_gate_digest = sfx_evidence["gate_record"].to_s.split("@", 2)
    vfx_output_path, vfx_output_digest = leading_locator(vfx_entry[:output], "output").to_s.split("@", 2)
    sfx_output_path, sfx_output_digest = leading_locator(sfx_entry[:output], "output").to_s.split("@", 2)
    expected = {
      "pair_key" => pair_key, "vfx_id" => vfx_id, "sfx_id" => sfx_id,
      "vfx_gate_record_path" => vfx_gate_path, "vfx_gate_record_sha256" => vfx_gate_digest,
      "sfx_gate_record_path" => sfx_gate_path, "sfx_gate_record_sha256" => sfx_gate_digest,
      "vfx_output_path" => vfx_output_path, "vfx_output_sha256" => vfx_output_digest,
      "sfx_output_path" => sfx_output_path, "sfx_output_sha256" => sfx_output_digest
    }
    expected.each { |field, value| error("#{label}: pair proof #{field} mismatch") unless proof[field] == value }
    error("#{label}: child gate/output records must remain separate") if
      vfx_gate_path == sfx_gate_path || vfx_output_path == sfx_output_path ||
      leading_locator(vfx_entry[:provenance], "record") == leading_locator(sfx_entry[:provenance], "record")
    vfx_gate_rows = parse_tsv(
      vfx_evidence["gate_record"], "#{label} VFX gate projection", GATE_RECORD_HEADER, 7,
      commit: commit, fresh_clone: fresh_clone, payload_context: payload_context
    )
    sfx_gate_rows = parse_tsv(
      sfx_evidence["gate_record"], "#{label} audio gate projection", GATE_RECORD_HEADER, 7,
      commit: commit, fresh_clone: fresh_clone, payload_context: payload_context
    )
    vfx_g7 = GATE_RECORD_HEADER.zip(vfx_gate_rows[6] || []).to_h
    sfx_g7 = GATE_RECORD_HEADER.zip(sfx_gate_rows[6] || []).to_h
    vfx_g5 = GATE_RECORD_HEADER.zip(vfx_gate_rows[4] || []).to_h
    sfx_g5 = GATE_RECORD_HEADER.zip(sfx_gate_rows[4] || []).to_h
    error("#{label}: both children must have completed Gate 7") unless
      completion_decision_allowed?(vfx_g7["decision"], "VFX", "G7") &&
      completion_decision_allowed?(sfx_g7["decision"], "AUDIO", "G7")
    error("#{label}: child builds and pair-proof build must be identical") unless
      canonical_build_id?(proof["build_id"]) && proof["build_id"] == vfx_g5["build_id"] && proof["build_id"] == sfx_g5["build_id"]
    owners = (canonical_ledger_owners(vfx_entry[:creator]) || []) + (canonical_ledger_owners(sfx_entry[:creator]) || [])
    error("#{label}: pair-proof reviewer is malformed or an owner") unless
      canonical_identity?(proof["reviewer_id"]) && proof["reviewer_non_owner"] == "YES" && !owners.include?(proof["reviewer_id"])
    sync_error = canonical_integer(proof["sync_error_ms"])
    error("#{label}: synchronized proof must measure at most 33 ms error") unless sync_error && sync_error <= 33
    error("#{label}: pair-proof timestamp is not RFC 3339") unless valid_rfc3339?(proof["decided_at"])
    evidence_path = "review/pairs/#{pair_key}/EVIDENCE_MANIFEST.sha256"
    error("#{label}: pair evidence path/hash is noncanonical") unless
      proof["evidence_manifest_path"] == evidence_path && proof["evidence_manifest_sha256"]&.match?(HEX64)
    capture_has_audio = false
    capture_digest = nil
    measurement = {}
    if proof["evidence_manifest_sha256"]&.match?(HEX64)
      pair_entries = validate_manifest(
        evidence_path, proof["evidence_manifest_sha256"], "#{label} evidence", [], commit, fresh_clone, payload_context
      )
      validate_manifest_member_roots(payload_context, evidence_path, ["review/pairs/#{pair_key}/"], "#{label} evidence")
      if control_owned
        control_owned << evidence_path
        control_owned.merge(manifest_owned_paths(payload_context, evidence_path))
      end
      error("#{label}: pair evidence must contain exact sync capture/report roles") unless
        pair_entries.map { |entry| entry[:role] }.sort == %w[pair.sync_capture pair.sync_report]
      capture_path = "review/pairs/#{pair_key}/SYNC_CAPTURE.mp4"
      report_path = "review/pairs/#{pair_key}/SYNC_MEASUREMENT.tsv"
      capture_entry = pair_entries.find { |entry| entry[:role] == "pair.sync_capture" }
      report_entry = pair_entries.find { |entry| entry[:role] == "pair.sync_report" }
      expected_capture_id = "pair_sync.#{pair_key}"
      error("#{label}: sync capture role/path/capture/build is noncanonical") unless
        capture_entry && capture_entry[:path] == capture_path && capture_entry[:capture] == expected_capture_id &&
        capture_entry[:build] == proof["build_id"]
      error("#{label}: sync report role/path/capture/build is noncanonical") unless
        report_entry && report_entry[:path] == report_path && report_entry[:capture] == "-" &&
        report_entry[:build] == proof["build_id"]
      if capture_entry
        capture_digest = capture_entry[:digest]
        capture_material = materialized_commit_file(
          capture_path, commit, "#{label} synchronized MP4", fresh_clone: fresh_clone
        )
        probe = capture_material && probe_mp4(capture_material[:bytes], "#{label} synchronized MP4")
        capture_has_audio = !!(probe && probe[:audio])
        error("#{label}: synchronized MP4 must contain decodable audio") unless probe && probe[:audio]
      end
      if report_entry
        measurement_rows = parse_tsv(
          "#{report_path}@#{report_entry[:digest]}", "#{label} sync measurement",
          PAIR_SYNC_MEASUREMENT_HEADER, 1, commit: commit, fresh_clone: fresh_clone,
          payload_context: payload_context
        )
        measurement = PAIR_SYNC_MEASUREMENT_HEADER.zip(measurement_rows.first || []).to_h
        error("#{label}: sync measurement does not bind exact capture/build/value") unless
          measurement["pair_key"] == pair_key && measurement["capture_path"] == capture_path &&
          capture_entry && measurement["capture_sha256"] == capture_entry[:digest] &&
          measurement["build_id"] == proof["build_id"] && measurement["sync_error_ms"] == proof["sync_error_ms"]
        error("#{label}: sync measurement timestamp is not RFC 3339") unless valid_rfc3339?(measurement["measured_at"])
      end
      begin
        proof_time = Time.iso8601(proof["decided_at"])
        g7_times = [Time.iso8601(vfx_g7["decided_at"]), Time.iso8601(sfx_g7["decided_at"])]
        error("#{label}: shared pair proof must be decided at or after both child Gate-7 decisions") unless
          proof_time >= g7_times.max
        if report_entry && valid_rfc3339?(measurement["measured_at"])
          measurement_time = Time.iso8601(measurement["measured_at"])
          error("#{label}: pair proof cannot precede its synchronized measurement") unless proof_time >= measurement_time
        end
      rescue ArgumentError, TypeError
        error("#{label}: pair/measurement/Gate-7 timestamps must be RFC 3339")
      end
    end
    validate_shared_lifecycle_branch(
      "move_pair",
      {
        "pair_key" => pair_key, "capture_has_audio" => capture_has_audio,
        "children" => [
          {
            "asset_id" => sfx_id, "status" => sfx_entry[:status],
            "gates" => sfx_gate_rows.map { |gate_row| gate_row[4] },
            "gate_record_sha256" => sfx_gate_digest, "output_sha256" => sfx_output_digest,
            "build_id" => sfx_g5["build_id"]
          },
          {
            "asset_id" => vfx_id, "status" => vfx_entry[:status],
            "gates" => vfx_gate_rows.map { |gate_row| gate_row[4] },
            "gate_record_sha256" => vfx_gate_digest, "output_sha256" => vfx_output_digest,
            "build_id" => vfx_g5["build_id"]
          }
        ],
        "proof" => {
          "pair_key" => proof["pair_key"], "build_id" => proof["build_id"],
          "sync_error_ms" => proof["sync_error_ms"], "capture_sha256" => capture_digest,
          "decided_at" => proof["decided_at"]
        },
        "measurement" => measurement
      },
      "shared production move-pair lifecycle"
    )
  end
end

def validate_current_postapproval_production(local_ledger_body, local_inventory_body, pair_keys, historical_registry_rows:,
                                             historical_ledger_entries:,
                                             historical_inventory_body:,
                                             historical_owned_paths:, historical_benchmark_owned_paths:,
                                             historical_context:, approval_control_target:, generated_transition:)
  local_entries = parse_ledger_entries(local_ledger_body, "current post-approval ledger")
  active_local = local_entries.select { |entry| entry[:status] != "planned" }
  historical_by_id = historical_registry_rows.each_with_object({}) do |fields, rows|
    row = WHITELIST_REGISTRY_HEADER.zip(fields).to_h
    rows[row["production_id"]] = row
  end
  historical_ledger_by_id = historical_ledger_entries.each_with_object({}) do |entry, rows|
    rows[entry[:id]] = entry
  end
  historical_exact = lambda do |entry|
    historical_ledger_by_id[entry[:id]] == entry
  end
  full_ledger_history_exact = local_entries == historical_ledger_entries
  full_inventory_history_exact = local_inventory_body == historical_inventory_body
  historical_exact_ids = active_local.select { |entry| historical_exact.call(entry) }.map { |entry| entry[:id] }.to_set
  current_by_id = local_entries.each_with_object({}) { |entry, rows| rows[entry[:id]] = entry }
  missing_historical_ids = historical_by_id.keys.reject { |production_id| current_by_id.key?(production_id) }
  downgraded_historical_ids = historical_by_id.keys.select { |production_id| current_by_id[production_id]&.dig(:status) == "planned" }
  error("current ledger deleted historically approved production IDs: #{missing_historical_ids.sort.join(', ')}") unless missing_historical_ids.empty?
  error("current ledger downgraded historically approved production IDs to planned: #{downgraded_historical_ids.sort.join(', ')}") unless
    downgraded_historical_ids.empty?
  transitioned_historical_ids = historical_by_id.keys.to_set - historical_exact_ids
  transitioned_owner_paths = transitioned_historical_ids.each_with_object(Set.new) do |production_id, paths|
    paths.merge(historical_owned_paths.fetch(production_id, Set.new))
  end
  historical_control_paths = historical_benchmark_owned_paths - transitioned_owner_paths
  historical_paths = historical_exact_ids.each_with_object(Set.new) do |production_id, paths|
    paths.merge(historical_owned_paths.fetch(production_id, Set.new))
  end
  historical_paths.merge(historical_control_paths)
  current_root_paths = %w[assets-src review].each_with_object(Set.new) do |root_name, paths|
    root = ROOT.join(root_name)
    next unless root.exist?
    Dir.glob(root.join("**", "*").to_s, File::FNM_DOTMATCH).each do |absolute|
      paths << Pathname.new(absolute).relative_path_from(ROOT).to_s if File.file?(absolute) || File.symlink?(absolute)
    end
  end
  new_active = active_local.reject { |entry| historical_exact_ids.include?(entry[:id]) }
  new_root_paths = current_root_paths - historical_paths

  slug = same_repo_slug
  unless slug
    error("post-approval production requires one canonical public GitHub origin")
    return
  end
  status_out, status_error, status_status = git_capture("status", "--porcelain=v1", "-z", "--untracked-files=all")
  error("post-approval production validation requires a clean worktree/index: #{status_error.lines.first.to_s.strip}") unless
    status_status.success? && status_out.empty?
  head_out, head_error, head_status = git_capture("rev-parse", "HEAD")
  local_head = head_out.strip
  unless head_status.success? && local_head.match?(HEX40)
    error("cannot resolve current post-approval HEAD: #{head_error.lines.first.to_s.strip}")
    return
  end
  remote_out, remote_error, remote_status = public_git_capture(
    slug, "ls-remote", "--symref", "https://github.com/#{slug}.git", "HEAD"
  )
  remote_head = remote_out.lines.map do |line|
    oid, ref = line.strip.split("\t", 2)
    oid if ref == "HEAD" && oid&.match?(HEX40)
  end.compact.first
  error("post-approval current HEAD must byte-equal credential-free public default HEAD: #{remote_error.lines.first.to_s.strip}") unless
    remote_status.success? && remote_head == local_head
  return unless remote_head == local_head

  clone = prepare_fresh_public_payload_clone(slug, local_head)
  return unless clone
  if approval_control_target&.match?(HEX40)
    _lineage_out, _lineage_err, lineage_status = git_capture(
      "merge-base", "--is-ancestor", approval_control_target, local_head, root: clone
    )
    error("current public production HEAD does not descend from the signed approval control target") unless lineage_status.success?
  else
    error("post-approval production lacks a resolved signed approval control target")
  end

  retained_historical_control_paths = Set.new
  historical_paths.each do |path|
    if historical_control_paths.include?(path)
      _exists_out, _exists_error, exists_status = git_capture(
        "cat-file", "-e", "#{local_head}:#{path}", root: clone
      )
      next unless exists_status.success?
      retained_historical_control_paths << path
    end
    expected_digest = historical_context[:manifest_digests][path] || historical_context[:entries].dig(path, :digest)
    unless expected_digest&.match?(HEX64)
      error("historical approved path lacks a signed payload digest: #{path}")
      next
    end
    material = materialized_commit_file(
      path, local_head, "current historical approved path", fresh_clone: clone, allow_lfs: true
    )
    error("current public HEAD changed historical approved bytes: #{path}") unless
      material && material[:digest] == expected_digest
  end
  if full_ledger_history_exact && full_inventory_history_exact && new_active.empty? && new_root_paths.empty?
    error("current post-approval ledger contains active rows not present in signed history") unless
      active_local.all? { |entry| historical_exact_ids.include?(entry[:id]) }
    validate_gate1_attempt_history_universe(local_head, clone, historical_owned_paths)
    validate_authoring_receipt_universe(
      commit: local_head, fresh_clone: clone, payload_context: historical_context,
      tree_entries: commit_tree_entries(local_head, clone),
      label: "current unchanged post-approval authoring receipts",
      inherited_contexts: [historical_context]
    )
    return
  end

  payload_path = "review/production/PAYLOAD_MANIFEST.sha256"
  payload_material = materialized_commit_file(
    payload_path, local_head, "post-approval production payload manifest", fresh_clone: clone, allow_lfs: false
  )
  return unless payload_material
  context = new_manifest_context
  validate_manifest(payload_path, payload_material[:digest], "post-approval production payload", [], local_head, clone, context)
  validate_sole_payload_workflow(context, "PENDING", "post-approval production payload")
  production_root_closure = context[:closure].dup
  %w[docs/ASSET_LEDGER.md docs/ASSET_INVENTORY.md].each do |control_path|
    error("post-approval production payload must directly own #{control_path}") unless
      context[:member_owner][control_path] == payload_path
  end
  committed_ledger = materialized_commit_file(
    "docs/ASSET_LEDGER.md", local_head, "post-approval production ledger", fresh_clone: clone, allow_lfs: false
  )
  error("mutable worktree ledger differs from current public post-approval HEAD") unless
    committed_ledger && committed_ledger[:bytes] == local_ledger_body
  committed_inventory = materialized_commit_file(
    "docs/ASSET_INVENTORY.md", local_head, "post-approval production inventory", fresh_clone: clone, allow_lfs: false
  )
  payload_entries = committed_ledger ? parse_ledger_entries(committed_ledger[:bytes], "public post-approval ledger") : []
  validate_ledger_scaffold(payload_entries, committed_inventory ? committed_inventory[:bytes] : "", "public post-approval ledger")
  payload_by_id = payload_entries.each_with_object({}) { |entry, index| index[entry[:id]] = entry }
  owned_paths = Hash.new { |hash, key| hash[key] = Set.new }
  historical_exact_ids.each do |production_id|
    owned_paths[production_id].merge(historical_owned_paths.fetch(production_id, Set.new))
  end
  if generated_transition[:populated]
    error("generated-child transition commit must equal current credential-free public default HEAD") unless
      generated_transition[:commit] == local_head
    error("generated-child transition registry must be a direct current production payload member") unless
      context[:member_owner][generated_transition[:registry_path]] == payload_path
    generated_transition[:source_paths].each do |path|
      error("generated-child source revision is outside the current production payload graph: #{path}") unless
        production_root_closure.include?(path)
    end
    generated_transition[:control_paths].each do |path|
      error("generated-child transition control/evidence path is outside the current production payload graph: #{path}") unless
        production_root_closure.include?(path)
    end
    generated_transition[:child_owned_paths].each do |child_id, paths|
      paths.each do |path|
        error("generated-child owned path is outside the current production payload graph: #{path}") unless
          production_root_closure.include?(path)
      end
      owned_paths[child_id].merge(paths)
    end
  end

  payload_entries.select { |entry| %w[source converted review approved].include?(entry[:status]) }.each do |entry|
    production_id = entry[:id]
    next if historical_exact_ids.include?(production_id)
    label = "post-approval #{production_id}"
    profile_tier = expected_profile_tier(production_id)
    unless profile_tier
      error("#{label}: no canonical profile/tier")
      next
    end
    profile, tier = profile_tier
    error("#{label}: profile/tier mismatch") unless entry[:profile_tier] == "#{profile} / #{tier}"
    provenance_binding = leading_locator(entry[:provenance], "record")
    source_binding = leading_locator(entry[:source], "source")
    output_binding = leading_locator(entry[:output], "output")
    gate_binding = leading_locator(entry[:evidence], "gate_record")
    expected_source_path = "assets-src/#{production_id.split('.', 2).first}/#{production_id}/SOURCE_MANIFEST.sha256"
    expected_output_path = "review/#{production_id}/g5/OUTPUT_MANIFEST.sha256"
    expected_provenance_path = "review/#{production_id}/g1/PROVENANCE.md"
    expected_gate_path = "review/#{production_id}/g1/GATE_RECORD.tsv"
    source_path, source_digest = source_binding.to_s.split("@", 2)
    output_path, output_digest = output_binding.to_s.split("@", 2)
    provenance_path, provenance_digest = provenance_binding.to_s.split("@", 2)
    gate_path, gate_digest = gate_binding.to_s.split("@", 2)
    error("#{label}: canonical provenance/source/gate locator missing") unless
      provenance_path == expected_provenance_path && provenance_digest&.match?(HEX64) &&
      source_path == expected_source_path && source_digest&.match?(HEX64) &&
      gate_path == expected_gate_path && gate_digest&.match?(HEX64)
    [provenance_path, source_path, gate_path].each do |bound_path|
      error("#{label}: binding is outside the root production payload graph: #{bound_path}") unless
        production_root_closure.include?(bound_path)
    end
    has_output = %w[converted review approved].include?(entry[:status])
    if has_output
      error("#{label}: canonical output locator missing") unless output_path == expected_output_path && output_digest&.match?(HEX64)
      error("#{label}: output manifest is outside the root production payload graph") unless
        production_root_closure.include?(output_path)
    else
      error("#{label}: source state output must be output:NONE") unless output_binding == "NONE"
      output_path = "NONE"
      output_digest = "NONE"
    end
    next unless source_digest&.match?(HEX64) && provenance_digest&.match?(HEX64) && gate_digest&.match?(HEX64)

    validate_manifest(source_path, source_digest, "#{label} source manifest", [], local_head, clone, context)
    validate_manifest_member_roots(
      context, source_path, ["assets-src/#{production_id.split('.', 2).first}/#{production_id}/"],
      "#{label} source manifest"
    )
    if has_output && output_digest&.match?(HEX64)
      validate_manifest(output_path, output_digest, "#{label} output manifest", [], local_head, clone, context)
      validate_manifest_member_roots(
        context, output_path, ["review/#{production_id}/g5/"], "#{label} output manifest"
      )
    end
    row = {
      "production_id" => production_id, "subset_sha256" => FULL_PRODUCTION_SUBSET_SHA256,
      "source_manifest_path" => source_path, "source_manifest_sha256" => source_digest,
      "output_manifest_path" => output_path, "output_manifest_sha256" => output_digest
    }
    provenance = validate_provenance_record(
      provenance_binding, row, label, commit: local_head, fresh_clone: clone,
      payload_context: context, record_context: context, allow_none_subset: true
    )
    owners = canonical_ledger_owners(entry[:creator])
    error("#{label}: creator/rightsholder ledger identity malformed") unless owners
    if owners
      error("#{label}: provenance creator/rightsholder mismatch") unless
        provenance["creator_id"] == owners[0] && provenance["rights_holder_id"] == owners[1]
    end
    gates = parse_ledger_gate_vector(entry[:gates], label)
    build_id = if has_output
                 gate_rows = parse_tsv(
                   gate_binding, "#{label} gate projection", GATE_RECORD_HEADER, 7,
                   commit: local_head, fresh_clone: clone, payload_context: context
                 )
                 gate5 = GATE_RECORD_HEADER.zip(gate_rows[4] || []).to_h
                 gate5["build_id"]
               else
                 "-"
               end
    validate_gate_record(
      gate_binding, "#{label} gate record", scope: production_id, profile: profile, tier: tier,
      source_digest: source_digest, output_digest: output_digest, build_id: build_id,
      expected_vector: gates, commit: local_head, fresh_clone: clone, payload_context: context,
      require_complete: entry[:status] == "approved", owned_paths: owned_paths[production_id],
      owner_ids: owners || []
    )
    validate_ledger_gate_lifecycle(entry, gates, has_output, label)
    validate_ledger_provenance_projection(entry, provenance, label)
    owned_paths[production_id].merge([provenance_path, source_path, gate_path])
    owned_paths[production_id].merge(manifest_owned_paths(context, source_path))
    if has_output
      owned_paths[production_id] << output_path
      owned_paths[production_id].merge(manifest_owned_paths(context, output_path))
    end
  end

  validate_concept_entries(
    payload_entries, owned_paths, commit: local_head, fresh_clone: clone, payload_context: context
  )
  validated_pair_control_paths = Set.new
  validate_move_pair_atomicity(
    payload_entries.reject { |entry| historical_exact_ids.include?(entry[:id]) }, pair_keys,
    commit: local_head, fresh_clone: clone,
    payload_context: context, payload_path: payload_path, control_owned: validated_pair_control_paths
  )
  control_owned = Set.new([payload_path])
  control_owned.merge(retained_historical_control_paths)
  control_owned.merge(validated_pair_control_paths)
  control_owned.merge(generated_transition[:control_paths]) if generated_transition[:populated]
  validate_gate1_attempt_history_universe(local_head, clone, owned_paths)
  tree_entries = commit_tree_entries(local_head, clone)
  validate_authoring_receipt_universe(
    commit: local_head, fresh_clone: clone, payload_context: context, tree_entries: tree_entries,
    label: "current post-approval authoring receipts", inherited_contexts: [historical_context]
  )
  scan_payload_production_tree(tree_entries, payload_by_id, owned_paths, control_owned)
  scan_production_roots(
    payload_by_id, owned_paths, {}, "APPROVED", benchmark_owned_paths: control_owned
  )
end

def validate_registry_owner_paths(row, basis, production_id, allow_none_output: true)
  prefix = production_id.split(".", 2).first
  expected = {
    "authorization_path" => "review/#{production_id}/g1/AUTHORIZATION.md",
    "gate_record_path" => "review/#{production_id}/g1/GATE_RECORD.tsv",
    "provenance_path" => "review/#{production_id}/g1/PROVENANCE.md",
    "source_manifest_path" => "assets-src/#{prefix}/#{production_id}/SOURCE_MANIFEST.sha256"
  }
  expected.each do |field, path|
    error("#{basis}: #{field} must equal canonical owner path #{path}") unless row[field] == path
  end
  expected_output = "review/#{production_id}/g5/OUTPUT_MANIFEST.sha256"
  unless allow_none_output && row["output_manifest_path"] == "NONE"
    error("#{basis}: output_manifest_path must equal canonical owner path #{expected_output}") unless
      row["output_manifest_path"] == expected_output
  end
end

def leading_locator(cell, prefix)
  first = cell.to_s.split("; ", 2).first
  first.start_with?("#{prefix}:") ? first.delete_prefix("#{prefix}:") : nil
end

def exact_locator_tokens(cell)
  cell.to_s.split("; ").each_with_object({}) do |token, locators|
    prefix, value = token.split(":", 2)
    return {} unless prefix&.match?(/\A[a-z_]+\z/) && value && !locators.key?(prefix)
    locators[prefix] = value
  end
end

def canonical_identity?(value)
  return false unless value&.match?(/\A[A-Za-z0-9][A-Za-z0-9._@+-]{2,127}\z/)

  normalized = value.downcase
  return false if GENERIC_MACHINE_COMPONENTS.include?(normalized)

  components = normalized.split(/[._@+-]+/)
  !generic_machine_component?(normalized) && components.none? { |component| generic_machine_component?(component) }
end

def remote_protection_fields(value)
  match = value.to_s.match(/\ACONFIRMED:([A-Za-z0-9][A-Za-z0-9._-]{2,63})@([^@]+)@(https:\/\/[^\s]+)\z/)
  return nil unless match && canonical_identity?(match[1]) && valid_rfc3339?(match[2])

  match
end

def canonical_rights_token?(value, allow_all_rights_reserved: false)
  if allow_all_rights_reserved
    OUTPUT_LICENSE_TOKENS.include?(value)
  else
    RIGHTS_BASIS_KINDS.key?(value)
  end
end

def output_license_compatible?(rights_basis, output_license)
  OUTPUT_LICENSES_BY_BASIS.fetch(rights_basis, Set.new).include?(output_license)
end

def generated_source_basis_valid?(manifest_role, input_basis)
  manifest_role != "source.generated" ||
    %w[generated-provider-terms generated-self-owned].include?(input_basis)
end

def approval_lifecycle_pins_ready?
  PRODUCTION_LIFECYCLE_HARNESS_IMPLEMENTED &&
    PRODUCTION_LIFECYCLE_HARNESS_SHA256.match?(HEX64) &&
    PRODUCTION_LIFECYCLE_HARNESS_SHA256 != SEMANTIC_LIFECYCLE_SNAPSHOT_SHA256 &&
    PINNED_ARES_148_BINARY_SHA256.match?(HEX64)
end

def lifecycle_fixture_env
  {
    "PATH" => "/usr/bin:/bin",
    "LANG" => "C.UTF-8",
    "LC_ALL" => "C.UTF-8",
    "PYTHONDONTWRITEBYTECODE" => "1",
    "PYTHONNOUSERSITE" => "1"
  }
end

def lifecycle_ruby_env
  lifecycle_fixture_env.merge(
    "RUBYOPT" => nil, "RUBYLIB" => nil, "GEM_HOME" => nil, "GEM_PATH" => nil,
    "BUNDLE_GEMFILE" => nil, "BUNDLE_PATH" => nil
  )
end

def production_lifecycle_harness_layout
  case_paths = PRODUCTION_LIFECYCLE_BRANCHES.to_h do |branch|
    [branch, "test/fixtures/asset_lifecycle_production/#{branch}/CASE.json"]
  end
  paths = ([PRODUCTION_LIFECYCLE_KERNEL_PATH, PRODUCTION_LIFECYCLE_HARNESS_RUNNER_PATH] + case_paths.values).sort
  roles = paths.to_h do |path|
    branch = case_paths.key(path)
    role = if path == PRODUCTION_LIFECYCLE_KERNEL_PATH
             "role:production_harness.kernel"
           elsif path == PRODUCTION_LIFECYCLE_HARNESS_RUNNER_PATH
             "role:production_harness.runner"
           else
             "role:production_harness.case.#{branch}"
           end
    [path, role]
  end
  [case_paths, paths, roles]
end

def parse_production_lifecycle_harness_manifest(raw, label)
  unless raw.end_with?("\n".b) && !raw.end_with?("\n\n".b) && !raw.include?("\r".b) &&
         raw.dup.force_encoding(Encoding::UTF_8).valid_encoding?
    error("#{label} manifest encoding/line endings are noncanonical")
    return []
  end
  _case_paths, expected_paths, expected_roles = production_lifecycle_harness_layout
  lines = raw.split("\n".b, -1).tap(&:pop)
  error("#{label} manifest member count mismatch") unless lines.length == expected_paths.length
  rows = lines.each_with_index.map do |line, index|
    fields = line.split("\t".b, -1).map { |field| field.dup.force_encoding(Encoding::UTF_8) }
    unless fields.length == 6
      error("#{label} manifest row #{index + 1} must have six TAB fields")
      next
    end
    path, byte_count, digest, build, capture, role = fields
    unless safe_repo_path?(path) && byte_count.match?(/\A(?:0|[1-9][0-9]*)\z/) && digest.match?(HEX64) &&
           build == "build:-" && capture == "capture:-"
      error("#{label} manifest row #{index + 1} has an unsafe/noncanonical identity")
      next
    end
    error("#{label} manifest role mismatch for #{path}") unless role == expected_roles[path]
    { path: path, byte_count: byte_count.to_i, digest: digest, role: role }
  end.compact
  error("#{label} manifest path order/set mismatch") unless rows.map { |row| row[:path] } == expected_paths
  rows
end

def exact_production_harness_receipt(manifest_digest, kernel_digest)
  {
    "schema" => "n64game-production-lifecycle-harness-v1",
    "authority" => "PRODUCTION_SHARED_KERNEL_BRANCH_COVERAGE",
    "result" => "PASS",
    "manifest_sha256" => manifest_digest,
    "kernel_sha256" => kernel_digest,
    "branch_ids" => PRODUCTION_LIFECYCLE_BRANCHES,
    "negative_case_ids" => %w[
      public_concept.no_concept public_concept.active_row public_concept.nonpending_aggregate
      public_concept.false_authority public_concept.malformed_authority public_concept.malformed_ref
      public_concept.advanced_id
      populated.aggregate_count
      populated.split_core populated.optional_without_core populated.zero_active_rows
      populated.malformed_pending_pair populated.rollup_mask_mismatch populated.evidence_incomplete
      populated.rollup_digest_crossbind populated.rollup_build_crossbind populated.rollup_gate_vector
      populated.evidence_build_crossbind populated.pending_repair_only populated.active_build_pending
      approved.inherited_completion approved.rollup_non_rom_g1 approved.rollup_static_state_g1
      approved.pending_build
      repair.out_of_range_basis repair.non_string_token
      generated_child.noncanonical_tuple generated_child.extra_row
      move_pair.non_hash_child move_pair.missing_asset_id
      h2.non_hash_pass release.failed_workflow
    ],
    "live_adapter_coverage" => "EXCLUDED_BY_DESIGN",
    "live_only_adapters" => %w[
      github_api signed_git_tags git_lfs_materialization advertised_ref_fresh_clone
      benchmark_control_transaction ffprobe_media_decode ares_execution rom_rebuild
    ]
  }
end

def run_production_lifecycle_harness(root, manifest_path, manifest_digest, kernel_digest, label)
  runner = Pathname.new(root).join(PRODUCTION_LIFECYCLE_HARNESS_RUNNER_PATH)
  manifest = Pathname.new(root).join(manifest_path)
  unless runner.file? && !runner.symlink? && File.executable?(runner)
    error("#{label} runner is missing, symlinked, or non-executable")
    return
  end
  output, runner_error, status = Open3.capture3(
    lifecycle_ruby_env, "/usr/bin/ruby", "--disable-gems", runner.to_s,
    "--manifest", manifest.to_s, chdir: root.to_s, unsetenv_others: true
  )
  unless status.success?
    error("#{label} runner failed: #{runner_error.lines.first.to_s.strip}")
    return
  end
  receipt = JSON.parse(output)
  error("#{label} receipt is not the exact shared-kernel branch/death result") unless
    receipt == exact_production_harness_receipt(manifest_digest, kernel_digest)
rescue JSON::ParserError => exception
  error("#{label} runner emitted invalid JSON: #{exception.message}")
rescue SystemCallError => exception
  error("#{label} runner could not execute: #{exception.message}")
end

def verify_local_production_lifecycle_harness_pin
  label = "local production lifecycle harness"
  unless PRODUCTION_LIFECYCLE_HARNESS_IMPLEMENTED && PRODUCTION_LIFECYCLE_HARNESS_SHA256.match?(HEX64)
    error("#{label} remains unimplemented/unpinned")
    return
  end
  manifest_path = PRODUCTION_LIFECYCLE_HARNESS_MANIFEST_PATH
  unless regular_without_symlink?(manifest_path)
    error("#{label} manifest is missing, non-regular, or symlinked")
    return
  end
  raw = File.binread(ROOT.join(manifest_path))
  manifest_digest = Digest::SHA256.hexdigest(raw)
  unless manifest_digest == PRODUCTION_LIFECYCLE_HARNESS_SHA256
    error("#{label} manifest digest differs from the production pin")
    return
  end
  rows = parse_production_lifecycle_harness_manifest(raw, label)
  rows.each do |row|
    unless regular_without_symlink?(row[:path])
      error("#{label} member is missing, non-regular, or symlinked: #{row[:path]}")
      next
    end
    bytes = File.binread(ROOT.join(row[:path]))
    error("#{label} member byte count/digest mismatch: #{row[:path]}") unless
      bytes.bytesize == row[:byte_count] && Digest::SHA256.hexdigest(bytes) == row[:digest]
  end
  case_paths, _expected_paths, _roles = production_lifecycle_harness_layout
  fixture_root = ROOT.join("test/fixtures/asset_lifecycle_production")
  expected_fixture_files = ([manifest_path] + case_paths.values).sort
  observed_fixture_files = Dir.glob(fixture_root.join("**", "*").to_s, File::FNM_DOTMATCH).each_with_object([]) do |path, files|
    pathname = Pathname.new(path)
    files << pathname.relative_path_from(ROOT).to_s if File.file?(pathname) || File.symlink?(pathname)
  end.sort
  error("#{label} fixture root contains missing, extra, or symlinked files") unless
    observed_fixture_files == expected_fixture_files
  return unless rows.length == production_lifecycle_harness_layout[1].length &&
                rows.all? { |row| regular_without_symlink?(row[:path]) }

  kernel_row = rows.find { |row| row[:path] == PRODUCTION_LIFECYCLE_KERNEL_PATH }
  run_production_lifecycle_harness(
    ROOT, manifest_path, manifest_digest, kernel_row && kernel_row[:digest], label
  ) if kernel_row
end

def verify_local_lifecycle_semantic_snapshot_pin
  label = "local lifecycle semantic-snapshot suite"
  initial_error_count = ERRORS.length
  unless SEMANTIC_LIFECYCLE_SNAPSHOT_SHA256.match?(HEX64)
    error("#{label} pin is not one lowercase SHA-256")
    return
  end

  manifest = ROOT.join(SEMANTIC_LIFECYCLE_SNAPSHOT_MANIFEST_PATH)
  runner = ROOT.join(SEMANTIC_LIFECYCLE_SNAPSHOT_RUNNER_PATH)
  unless regular_without_symlink?(SEMANTIC_LIFECYCLE_SNAPSHOT_MANIFEST_PATH)
    error("#{label} manifest is missing, non-regular, or symlinked")
    return
  end
  observed_digest = Digest::SHA256.file(manifest).hexdigest
  unless observed_digest == SEMANTIC_LIFECYCLE_SNAPSHOT_SHA256
    error("#{label} manifest SHA-256 is #{observed_digest}, expected #{SEMANTIC_LIFECYCLE_SNAPSHOT_SHA256}")
    return
  end
  raw = File.binread(manifest)
  unless raw.end_with?("\n".b) && !raw.end_with?("\n\n".b) && !raw.include?("\r".b) &&
         raw.dup.force_encoding(Encoding::UTF_8).valid_encoding?
    error("#{label} manifest encoding/line endings are noncanonical")
    return
  end
  lines = raw.split("\n".b, -1).tap(&:pop)
  case_paths = SEMANTIC_LIFECYCLE_SNAPSHOT_CASES.to_h do |case_name|
    [case_name, "test/fixtures/asset_contract/#{case_name}/CASE.json"]
  end
  expected_paths = ([SEMANTIC_LIFECYCLE_SNAPSHOT_RUNNER_PATH] + case_paths.values).sort
  expected_roles = expected_paths.to_h do |path|
    case_name = case_paths.key(path)
    [path, case_name ? "role:semantic_snapshot.#{case_name}" : "role:semantic_snapshot.runner"]
  end
  observed_paths = []
  lines.each_with_index do |line, index|
    fields = line.split("\t".b, -1).map { |field| field.dup.force_encoding(Encoding::UTF_8) }
    unless fields.length == 6
      error("#{label} manifest row #{index + 1} must have six TAB fields")
      next
    end
    member_path, byte_count, digest, build, capture, role = fields
    unless safe_repo_path?(member_path) && byte_count.match?(/\A(?:0|[1-9][0-9]*)\z/) &&
           digest.match?(HEX64) && build == "build:-" && capture == "capture:-"
      error("#{label} manifest row #{index + 1} has an unsafe/noncanonical identity")
      next
    end
    observed_paths << member_path
    error("#{label} manifest role mismatch for #{member_path}") unless role == expected_roles[member_path]
    unless regular_without_symlink?(member_path)
      error("#{label} member is missing, non-regular, or symlinked: #{member_path}")
      next
    end
    member = ROOT.join(member_path)
    error("#{label} member count mismatch: #{member_path}") unless member.size == byte_count.to_i
    error("#{label} member digest mismatch: #{member_path}") unless Digest::SHA256.file(member).hexdigest == digest
  end
  error("#{label} members are not the exact raw-byte path order") unless observed_paths == expected_paths

  fixture_root = ROOT.join("test/fixtures/asset_contract")
  observed_fixture_files = Dir.glob(fixture_root.join("**", "*").to_s, File::FNM_DOTMATCH).each_with_object([]) do |absolute, paths|
    next if %w[. ..].include?(File.basename(absolute))
    next unless File.file?(absolute) || File.symlink?(absolute)

    paths << Pathname.new(absolute).relative_path_from(ROOT).to_s
  end.sort
  expected_fixture_files = ([SEMANTIC_LIFECYCLE_SNAPSHOT_MANIFEST_PATH] + case_paths.values).sort
  error("#{label} fixture root contains missing, extra, or symlinked files") unless
    observed_fixture_files == expected_fixture_files
  unless ERRORS.length == initial_error_count && observed_paths == expected_paths &&
         expected_paths.all? { |path| regular_without_symlink?(path) }
    return
  end
  unless File.executable?(runner)
    error("#{label} runner is not executable")
    return
  end

  output, runner_error, status = Open3.capture3(
    lifecycle_fixture_env, "/usr/bin/python3", "-I", runner.to_s,
    "--json", "--fixture-manifest", manifest.to_s,
    chdir: ROOT.to_s, unsetenv_others: true
  )
  unless status.success?
    error("#{label} runner failed: #{runner_error.lines.first.to_s.strip}")
    return
  end
  receipt = JSON.parse(output)
  expected_receipt = {
    "schema" => "n64game-asset-lifecycle-semantic-snapshots-v1",
    "authority" => "NON_APPROVAL_SEMANTIC_SNAPSHOT",
    "result" => "PASS",
    "manifest_sha256" => SEMANTIC_LIFECYCLE_SNAPSHOT_SHA256,
    "cases" => SEMANTIC_LIFECYCLE_SNAPSHOT_CASES,
    "topology" => "parallel_nonchronological_scenarios",
    "cross_bindings" => ["approved->repair", "approved->release"]
  }
  error("#{label} receipt is not the exact semantic-snapshot result tuple") unless receipt == expected_receipt
rescue JSON::ParserError => e
  error("#{label} runner emitted invalid JSON: #{e.message}")
rescue SystemCallError => e
  error("#{label} could not execute: #{e.message}")
end

def canonical_ledger_owners(cell)
  match = cell.to_s.match(/\Acreator:([A-Za-z0-9][A-Za-z0-9._@+-]{2,127}); rights_holder:([A-Za-z0-9][A-Za-z0-9._@+-]{2,127})(?:; |\z)/)
  return nil unless match && canonical_identity?(match[1]) && canonical_identity?(match[2])

  [match[1], match[2]]
end

def validate_ledger_provenance_projection(entry, record, label)
  rights = exact_locator_tokens(entry[:rights])
  transforms = exact_locator_tokens(entry[:transforms])
  license = exact_locator_tokens(entry[:license])
  error("#{label}: ledger rights cell must be exact rights_basis/rights_evidence machine bindings") unless
    rights.keys.sort == %w[rights_basis rights_evidence] &&
    rights["rights_basis"] == record["rights_basis"] && rights["rights_evidence"] == record["rights_evidence"]
  error("#{label}: ledger transformations cell must project exact provenance digest") unless
    transforms == { "transformations_sha256" => record["transformations_sha256"] }
  error("#{label}: ledger output-license cell must project exact provenance token") unless
    license == { "output_license" => record["output_license"] }
end

def validate_subset_export_allowlist(authorization_record, provenance_record, row, source_manifest_path,
                                     output_manifest_path, complete_package:, commit:, fresh_clone:,
                                     payload_context:, owned_paths:, label:)
  binding = authorization_record["subset_allowlist"]
  error("#{label}: authorization/provenance subset allowlist bindings differ") unless
    binding && provenance_record["subset_allowlist"] == binding
  return unless binding

  path, _digest = binding.split("@", 2)
  expected_path = "review/#{row['production_id']}/g1/SUBSET_EXPORT_ALLOWLIST.tsv"
  error("#{label}: subset export allowlist path is noncanonical") unless path == expected_path
  source_paths = manifest_owned_paths(payload_context, source_manifest_path).to_a
  output_paths = output_manifest_path == "NONE" ? [] : manifest_owned_paths(payload_context, output_manifest_path).to_a
  expected_entries = source_paths.map { |member| ["SOURCE", member] } + output_paths.map { |member| ["OUTPUT", member] }
  expected_entries.sort_by! { |stage, member| [stage == "SOURCE" ? 0 : 1, member] }
  rows = parse_tsv(
    binding, "#{label} subset export allowlist", SUBSET_ALLOWLIST_HEADER, expected_entries.length,
    commit: commit, fresh_clone: fresh_clone, payload_context: payload_context
  )
  error("#{label}: subset export allowlist must be a direct PAYLOAD_MANIFEST member") unless
    payload_context[:member_owner][path] == "review/benchmark/PAYLOAD_MANIFEST.sha256"
  actual_order = rows.map { |fields| [fields[2], fields[3]] }
  error("#{label}: subset export rows must be exact SOURCE-then-OUTPUT/path order") unless actual_order == expected_entries
  error("#{label}: subset export rows are duplicate") unless actual_order.uniq.length == actual_order.length
  rights_evidence_path = provenance_record["rights_evidence"].to_s.split("@", 2).first
  prefix = row["production_id"].split(".", 2).first
  transformations_path = "assets-src/#{prefix}/#{row['production_id']}/TRANSFORMATIONS.md"
  expected_partial_selectors = PARTIAL_SUBSET_SELECTOR_POLICY[row["production_id"]]
  observed_partial_selectors = Set.new
  rows.each do |fields|
    record = SUBSET_ALLOWLIST_HEADER.zip(fields).to_h
    entry = payload_context[:entries][record["member_path"]]
    error("#{label}: subset export production/subset binding mismatch") unless
      record["production_id"] == row["production_id"] && record["subset_sha256"] == row["subset_sha256"]
    error("#{label}: subset export stage is invalid") unless %w[SOURCE OUTPUT].include?(record["stage"])
    error("#{label}: subset export member digest/role mismatch") unless
      entry && record["member_sha256"] == entry[:digest] && record["manifest_role"] == entry[:role]
    selectors = record["export_selectors_csv"].to_s.split(",", -1)
    error("#{label}: export selector list must be nonempty, sorted, and unique") unless
      !selectors.empty? && selectors.none?(&:empty?) && selectors == selectors.sort && selectors.uniq == selectors
    typed = selectors.all? do |selector|
      selector == "ALL" || selector.match?(/\A(?:COLLECTION|CLIP|STATE|SECTOR|CUE|ASSET|METADATA|OUTPUT):[a-z0-9][a-z0-9._\/-]{0,95}\z/)
    end
    error("#{label}: subset export selector list is malformed/placeholder") unless typed

    expected_special = if record["stage"] == "OUTPUT"
                         ["OUTPUT:runtime"]
                       elsif record["member_path"] == rights_evidence_path
                         ["METADATA:rights"]
                       elsif entry && entry[:role] == "rights.support"
                         ["METADATA:rights_support"]
                       elsif entry && entry[:role] == "generation.record"
                         ["METADATA:generation"]
                       elsif record["member_path"] == transformations_path
                         ["METADATA:transformations"]
                       end
    if expected_special
      error("#{label}: special member selector projection mismatch for #{record['member_path']}") unless selectors == expected_special
    elsif complete_package
      error("#{label}: complete-package content source rows must use selector ALL") unless selectors == ["ALL"]
    else
      if expected_partial_selectors.nil?
        error("#{label}: no frozen partial selector policy for #{row['production_id']}")
      else
        extra = selectors - expected_partial_selectors
        error("#{label}: partial selector vocabulary widened for #{record['member_path']}: #{extra.join(',')}") unless extra.empty?
        observed_partial_selectors.merge(selectors)
      end
    end
  end
  if complete_package
    content_rows = rows.reject do |fields|
      stage, path = fields[2], fields[3]
      entry = payload_context[:entries][path]
      stage == "OUTPUT" || path == rights_evidence_path || path == transformations_path ||
        (entry && %w[rights.support generation.record].include?(entry[:role]))
    end
    error("#{label}: complete package has no content source member") if content_rows.empty?
  else
    error("#{label}: partial selector union differs from frozen production policy") unless
      expected_partial_selectors && observed_partial_selectors.to_a.sort == expected_partial_selectors
  end
  owned_paths << path if owned_paths
end

def aggregate_path_hash(path_value, digest_value, label, expected_path: nil)
  return nil if path_value == "PENDING" && digest_value == "PENDING"
  if path_value == "PENDING" || digest_value == "PENDING"
    error("#{label} path/hash must be jointly PENDING or jointly populated")
    return nil
  end
  error("#{label} path must equal #{expected_path}") if expected_path && path_value != expected_path
  unless safe_repo_path?(path_value) && digest_value&.match?(HEX64)
    error("#{label} must use safe path plus 64-lowercase-hex digest")
    return nil
  end
  "#{path_value}@#{digest_value}"
end

def parse_ledger_gate_vector(cell, label)
  parts = cell.to_s.split("; ")
  unless parts.length == 7
    error("#{label}: ledger gate vector must contain exactly seven ordered entries")
    return []
  end
  parts.map.with_index do |part, index|
    match = part.match(/\AG(\d)=([A-Za-z0-9_]+)\z/)
    error("#{label}: malformed ledger gate token #{part.inspect}") unless match && match[1].to_i == index + 1 && ALL_GATE_DECISIONS.include?(match[2])
    match ? match[2] : "INVALID"
  end
end

def scan_production_roots(ledger_by_id, owned_paths, active_states, decision, benchmark_owned_paths: Set.new)
  roots = %w[assets-src review]
  roots.each do |root_name|
    root = ROOT.join(root_name)
    next unless root.exist?
    Dir.glob(root.join("**", "*").to_s, File::FNM_DOTMATCH).sort.each do |absolute|
      next if [".", ".."].include?(File.basename(absolute))
      relative = Pathname.new(absolute).relative_path_from(ROOT).to_s
      if File.symlink?(absolute)
        error("production root contains forbidden symlink: #{relative}")
        next
      end
      next unless File.file?(absolute)
      production_id = nil
      review_gate = nil
      if relative.start_with?("review/generated/")
        generated_owners = owned_paths.select { |_owner_id, paths| paths.include?(relative) }.keys
        error("generated special-namespace file lacks an exact control or child owner: #{relative}") unless
          benchmark_owned_paths.include?(relative) || generated_owners.length == 1
        next
      elsif relative.start_with?("review/benchmark/", "review/production/", "review/pairs/")
        error("preapproval benchmark file is outside every populated aggregate manifest/record binding: #{relative}") unless
          benchmark_owned_paths.include?(relative)
        next
      elsif relative =~ %r{\Aassets-src/([^/]+)/([^/]+)/}
        category = Regexp.last_match(1)
        production_id = Regexp.last_match(2)
        error("production source category/ID prefix mismatch: #{relative}") unless production_id.split(".", 2).first == category
      elsif relative =~ %r{\Areview/([^/]+)/g([1-7])/}
        production_id = Regexp.last_match(1)
        review_gate = Regexp.last_match(2).to_i
      else
        error("orphan file outside canonical production owner layout: #{relative}")
        next
      end
      entry = ledger_by_id[production_id]
      unless entry
        error("production file has no explicit ledger owner: #{relative}")
        next
      end
      error("production file is owned by forbidden alias/evidence ID: #{relative}") if production_id.start_with?("present.", "ev.")
      error("concept production file may exist only under Gate-1 review root: #{relative}") if
        entry[:status] == "concept" && review_gate && review_gate != 1
      unless owned_paths.fetch(production_id, Set.new).include?(relative)
        error("production file is absent from its owner's source/evidence manifest: #{relative}")
      end
      if %w[source converted review approved].include?(entry[:status]) && decision != "APPROVED" &&
         (!active_states.key?(production_id) || active_states[production_id] == "INACTIVE")
        error("advanced prebenchmark production file lacks active exact authorization: #{relative}")
      end
    end
  end
end

def commit_tree_entries(commit, fresh_clone)
  output, tree_error, status = git_capture("ls-tree", "-r", "-z", commit, root: fresh_clone)
  unless status.success?
    error("cannot enumerate reviewed payload tree in fresh public clone: #{tree_error.lines.first.to_s.strip}")
    return []
  end
  output.split("\0").reject(&:empty?).map do |record|
    metadata, path = record.split("\t", 2)
    mode, type, oid = metadata.to_s.split(" ", 3)
    unless path && mode&.match?(/\A[0-9]{6}\z/) && %w[blob commit].include?(type) && oid&.match?(HEX40)
      error("reviewed payload tree contains an unparsable entry")
      next
    end
    { mode: mode, type: type, oid: oid, path: path }
  end.compact
end

def scan_payload_production_tree(tree_entries, payload_ledger_by_id, owned_paths, benchmark_owned_paths)
  tree_entries.each do |tree_entry|
    relative = tree_entry[:path]
    relevant = relative.start_with?("assets-src/", "review/", "build/")
    next unless relevant
    unless safe_repo_path?(relative)
      error("reviewed payload production path is unsafe: #{relative.inspect}")
      next
    end
    unless tree_entry[:type] == "blob" && %w[100644 100755].include?(tree_entry[:mode])
      error("reviewed payload production path is symlinked, non-blob, or submodule: #{relative}")
      next
    end

    if relative.start_with?("build/")
      error("reviewed payload must not commit generated build paths: #{relative}")
      next
    elsif relative.start_with?("review/generated/")
      generated_owners = owned_paths.select { |_owner_id, paths| paths.include?(relative) }.keys
      error("reviewed payload generated file lacks an exact control or child owner: #{relative}") unless
        benchmark_owned_paths.include?(relative) || generated_owners.length == 1
      next
    elsif relative.start_with?("review/benchmark/", "review/production/", "review/pairs/")
      error("reviewed payload benchmark file lacks an exact aggregate/rollup/evidence owner: #{relative}") unless
        benchmark_owned_paths.include?(relative)
      next
    end

    production_id = nil
    if relative =~ %r{\Aassets-src/([^/]+)/([^/]+)/}
      category = Regexp.last_match(1)
      production_id = Regexp.last_match(2)
      error("reviewed payload source category/ID prefix mismatch: #{relative}") unless production_id.split(".", 2).first == category
    elsif relative =~ %r{\Areview/([^/]+)/g([1-7])/}
      production_id = Regexp.last_match(1)
    else
      error("reviewed payload has orphan file outside canonical production owner layout: #{relative}")
      next
    end

    entry = payload_ledger_by_id[production_id]
    unless entry
      error("reviewed payload production file has no payload-ledger owner: #{relative}")
      next
    end
    error("reviewed payload production file is owned by forbidden alias/evidence ID: #{relative}") if production_id.start_with?("present.", "ev.")
    unless owned_paths.fetch(production_id, Set.new).include?(relative)
      error("reviewed payload production file is absent from its owner's source/output/evidence manifest: #{relative}")
    end
  end
end

def canonical_integer(value)
  value.to_s.match?(/\A(?:0|[1-9][0-9]*)\z/) ? value.to_i : nil
end

def metric_value_valid?(evidence_id, metric, value, unit)
  integer = canonical_integer(value)
  case metric
  when "width_px"
    unit == "px" && integer == (evidence_id.end_with?("enlarged") ? 1280 : 320)
  when "height_px"
    unit == "px" && integer == (evidence_id.end_with?("enlarged") ? 960 : 240)
  when "media_type" then unit == "mime" && value == "image/png"
  when "color_format" then unit == "format" && value == "RGBA16"
  when "framebuffer_count" then unit == "count" && integer == 3
  when "capture_count" then unit == "count" && integer == 6
  when /\Acapture\./ then unit == "bool" && value == "PRESENT"
  when "resampler" then unit == "algorithm" && value == "nearest-neighbor"
  when "scale_factor" then unit == "ratio" && integer == 4
  when "game_light_views", "neutral_views", "sheet_count", "clip_count", "contact_frames", "route_views", "reverse_views", "ceiling_views", "state_count", "native_gallery_count"
    unit == "count" && integer && integer.positive?
  when "locked_camera", "collision_overlay", "camera_overlay", "grade_compare"
    unit == "bool" && value == "YES"
  when "purposeful_props" then unit == "count" && integer && integer >= 5
  when "controller_icon_count" then unit == "count" && integer == 12
  when /\A(?:hit|support|braid)_sync_error_ms\z/ then unit == "ms" && integer && integer <= 33
  when "duration_ms" then unit == "ms" && integer && integer >= 60_000
  when "placeholder_frames" then unit == "frames" && integer == 0
  when "sustained_sub30_windows" then unit == "windows" && integer == 0
  when "fps_min" then unit == "fps" && integer && integer >= 30
  when "frame_time_p95_us" then unit == "us" && integer && integer <= 33_333
  when "free_heap_min_bytes" then unit == "bytes" && integer && integer >= 524_288
  when "display_batches_peak" then unit == "count" && integer && integer.positive? && integer <= 32
  when "particles_peak" then unit == "count" && integer && integer.positive? && integer <= 128
  when "scene_working_set_bytes"
    unit == "bytes" && integer && integer.positive? && integer <= 1_126_400
  when "texture_working_set_bytes", "scene_textures_bytes"
    unit == "bytes" && integer && integer.positive? && integer <= 344_064
  when "scene_geometry_display_bytes", "scene_skeleton_animation_bytes", "scene_collision_nav_state_bytes", "scene_vfx_bytes"
    unit == "bytes" && integer && integer.positive? && integer <= 1_126_400
  when "unexplained_converter_warnings" then unit == "count" && integer == 0
  when "baseline_heap_bytes", "post_reload_heap_bytes" then unit == "bytes" && integer && integer.positive?
  when "heap_delta_bytes" then unit == "bytes" && integer == 0
  when "resource_delta_count" then unit == "count" && integer == 0
  when "whitelist_vectors" then unit == "count" && integer == BENCHMARK_WHITELIST_COUNT
  when "integrated_rollups" then unit == "count" && integer == BENCHMARK_ROLLUP_COUNT
  when "gate_decisions_complete" then unit == "count" && integer == BENCHMARK_GATE_DECISION_COUNT
  when "rubric_categories" then unit == "count" && integer == 9
  when "reviewer_count" then unit == "count" && integer == 3
  when "protected_frames_committed" then unit == "count" && integer == 0
  else false
  end
end

def exact_gate_evidence_role_paths(registry_rows, identity)
  paths = {}
  registry_rows.each_with_index do |fields, index|
    row = WHITELIST_REGISTRY_HEADER.zip(fields).to_h
    paths[format("gate.wb%03d", index + 1)] = row["gate_record_path"]
  end
  ROLLUP_SPECS.each do |path_field, _digest_field, _expected_path, scope, _profile, _tier|
    paths[scope] = identity[path_field]
  end
  paths
end

def png_dimensions(bytes, label = "PNG evidence")
  unless bytes.bytesize >= 24 && bytes.start_with?("\x89PNG\r\n\x1A\n".b) && bytes.byteslice(12, 4) == "IHDR"
    error("#{label} lacks a canonical PNG signature/IHDR")
    return nil
  end
  dimensions = bytes.byteslice(16, 8).unpack("N2")
  width, height = dimensions
  unless width.positive? && height.positive? && width <= 8192 && height <= 8192 && width * height <= 32_000_000
    error("#{label} PNG dimensions are unsafe or nonpositive")
    return nil
  end
  return nil unless pinned_tool_available?("magick", ["-version"], PINNED_MAGICK_VERSION, "ImageMagick")
  Dir.mktmpdir("n64game-png-decode-") do |dir|
    path = File.join(dir, "evidence.png")
    File.binwrite(path, bytes)
    decoded, decode_error, status = Open3.capture3(
      "magick", path, "-alpha", "on", "-depth", "8", "rgba:-"
    )
    unless status.success? && decoded.bytesize == width * height * 4
      error("#{label} fails pinned ImageMagick full-pixel decode: #{decode_error.lines.first.to_s.strip}")
      return nil
    end
  end
  dimensions
end

def exact_role_entry(entries, role, label)
  matches = entries.select { |entry| entry[:role] == role }
  error("#{label}: expected exactly one #{role} member") unless matches.length == 1
  matches.first
end

def parse_benchmark_report(entries, role, expected_path, header, label, commit:, fresh_clone:, payload_context:)
  entry = exact_role_entry(entries, role, label)
  error("#{label}: #{role} path is noncanonical") unless
    entry && entry[:path] == expected_path && entry[:capture] == "-"
  rows = if entry
           parse_tsv(
             "#{entry[:path]}@#{entry[:digest]}", label, header, 1,
             commit: commit, fresh_clone: fresh_clone, payload_context: payload_context
           )
         else
           []
         end
  [header.zip(rows.first || []).to_h, entry]
end

def exact_capture_bindings(entries, prefix)
  entries.select { |entry| entry[:role].start_with?("#{prefix}.") && !entry[:role].end_with?(".report") }
         .sort_by { |entry| entry[:role] }
         .map { |entry| "#{entry[:role]}=#{entry[:path]}@#{entry[:digest]}" }.join(",")
end

def png_rgb_sha256(bytes, label)
  return nil unless pinned_tool_available?("magick", ["-version"], PINNED_MAGICK_VERSION, "ImageMagick")
  Dir.mktmpdir("n64game-png-rgb-") do |dir|
    path = File.join(dir, "capture.png")
    File.binwrite(path, bytes)
    rgb, decode_error, status = Open3.capture3(
      "magick", path, "-alpha", "off", "-depth", "8", "rgb:-"
    )
    unless status.success? && rgb.bytesize == 320 * 240 * 3
      error("#{label}: cannot decode exact 320x240 RGB24 pixels: #{decode_error.lines.first.to_s.strip}")
      return nil
    end
    Digest::SHA256.hexdigest(rgb)
  end
end

def validate_native_frame_bindings(report, native_entries, decoded_frames, commit:, fresh_clone:)
  entries = native_entries.select { |entry| entry[:role].match?(/\Anative\.(?!report\z)/) }
                          .sort_by { |entry| entry[:role] }
  fields = report["capture_bindings_csv"].to_s.split(",", -1)
  error("native capture report must bind exactly six ordered PNG/frame/RGB tuples") unless
    fields.length == CAPTURE_NAMES.length && entries.length == CAPTURE_NAMES.length
  used_frames = Set.new
  canonical = entries.zip(fields).map do |entry, field|
    next "INVALID" unless entry && field
    match = field.match(
      /\A(#{Regexp.escape(entry[:role])})=(#{Regexp.escape(entry[:path])})@(#{entry[:digest]})#frame=(0|[1-9][0-9]*)#rgb=([0-9a-f]{64})\z/
    )
    unless match
      error("native capture report has malformed/noncanonical frame binding for #{entry[:role]}")
      next "INVALID"
    end
    frame_index = match[4].to_i
    error("native capture report reuses one representative-capture frame") if used_frames.include?(frame_index)
    used_frames << frame_index
    decoded = decoded_frames[frame_index]
    material = materialized_commit_file(
      entry[:path], commit, "native frame-bound PNG", fresh_clone: fresh_clone, allow_lfs: true
    )
    png_digest = material && png_rgb_sha256(material[:bytes], "native frame-bound PNG #{entry[:role]}")
    error("native PNG #{entry[:role]} is not the exact decoded representative-capture RGB frame") unless
      decoded && decoded[:rgb_sha256] == match[5] && png_digest == match[5]
    "#{entry[:role]}=#{entry[:path]}@#{entry[:digest]}#frame=#{frame_index}#rgb=#{match[5]}"
  end.join(",")
  error("native capture frame bindings are not canonical byte-sorted tuples") unless
    report["capture_bindings_csv"] == canonical
end

def validate_analyzer_fields(record, label)
  error("#{label}: analyzer identity/version differs from the pinned canonical producer") unless
    record["analyzer_id"] == REPORT_ANALYZER_ID && record["analyzer_version"] == REPORT_ANALYZER_VERSION
  error("#{label}: analyzed_at is not strict RFC 3339") unless valid_rfc3339?(record["analyzed_at"])
end

def verify_approval_lifecycle_fixture_suite(commit:, fresh_clone:, payload_context:, owned_paths: nil)
  label = "production-validator approval-lifecycle harness"
  unless PRODUCTION_LIFECYCLE_HARNESS_IMPLEMENTED && PRODUCTION_LIFECYCLE_HARNESS_SHA256.match?(HEX64)
    error("#{label} remains unimplemented/unpinned; semantic snapshot fixtures are not approval evidence")
    return
  end
  unless commit&.match?(HEX40) && fresh_clone && payload_context
    error("#{label} requires a reviewed commit, fresh public clone, and payload ownership context")
    return
  end
  manifest_path = PRODUCTION_LIFECYCLE_HARNESS_MANIFEST_PATH
  manifest_material = materialized_commit_file(
    manifest_path, commit, "#{label} manifest", fresh_clone: fresh_clone, allow_lfs: false
  )
  return unless manifest_material
  unless manifest_material[:kind] == :git && manifest_material[:mode] == "100644"
    error("#{label} manifest must be an ordinary Git 100644 blob")
    return
  end
  unless manifest_material[:digest] == PRODUCTION_LIFECYCLE_HARNESS_SHA256
    error("#{label} manifest digest differs from the production pin")
    return
  end
  rows = parse_production_lifecycle_harness_manifest(manifest_material[:bytes], label)
  expected_payload_root = "review/benchmark/PAYLOAD_MANIFEST.sha256"
  error("#{label} manifest must be a direct root payload member") unless
    payload_context[:member_owner][manifest_path] == expected_payload_root
  error("#{label} production validator must be a direct root payload member") unless
    payload_context[:member_owner]["scripts/validate-asset-contract"] == expected_payload_root
  error("#{label} public authority helper must be a direct root payload member") unless
    payload_context[:member_owner]["lib/n64game/public_commit_authority.rb"] == expected_payload_root
  required_paths = [
    manifest_path, "scripts/validate-asset-contract", "lib/n64game/public_commit_authority.rb",
    *rows.map { |row| row[:path] }
  ]
  required_paths.each do |path|
    error("#{label} path is outside the reviewed payload closure: #{path}") unless
      payload_context[:closure].include?(path)
  end
  reviewed_harness_bytes = { manifest_path => manifest_material[:bytes] }
  rows.each do |row|
    material = materialized_commit_file(
      row[:path], commit, "#{label} member #{row[:path]}", fresh_clone: fresh_clone, allow_lfs: false
    )
    error("#{label} member must be ordinary Git with matching byte count/digest: #{row[:path]}") unless
      material && material[:kind] == :git && material[:bytes].bytesize == row[:byte_count] &&
      material[:digest] == row[:digest]
    reviewed_harness_bytes[row[:path]] = material[:bytes] if
      material && material[:kind] == :git && material[:bytes].bytesize == row[:byte_count] &&
      material[:digest] == row[:digest]
  end
  reviewed_modes = ([manifest_path] + rows.map { |row| row[:path] }).to_h do |path|
    mode_output, _mode_error, mode_status = git_capture("ls-tree", commit, "--", path, root: fresh_clone)
    mode = mode_output[/\A(\d{6})\s+blob\s+[0-9a-f]+\t/, 1] if mode_status.success?
    [path, mode]
  end
  expected_modes = reviewed_modes.keys.to_h do |path|
    [path, path == PRODUCTION_LIFECYCLE_HARNESS_RUNNER_PATH ? "100755" : "100644"]
  end
  error("#{label} reviewed harness file modes differ from the exact ordinary-Git contract") unless
    reviewed_modes == expected_modes
  case_paths, _expected_paths, _roles = production_lifecycle_harness_layout
  expected_fixture_files = ([manifest_path] + case_paths.values).sort
  observed_fixture_files = commit_tree_entries(commit, fresh_clone).map { |entry| entry[:path] }.select do |path|
    path.start_with?("test/fixtures/asset_lifecycle_production/")
  end.sort
  error("#{label} reviewed fixture root contains missing or extra files") unless
    observed_fixture_files == expected_fixture_files
  owned_paths << manifest_path if owned_paths
  owned_paths&.merge(rows.map { |row| row[:path] })
  kernel_row = rows.find { |row| row[:path] == PRODUCTION_LIFECYCLE_KERNEL_PATH }
  return unless kernel_row && rows.length == production_lifecycle_harness_layout[1].length
  return unless reviewed_harness_bytes.keys.sort == ([manifest_path] + rows.map { |row| row[:path] }).sort &&
                reviewed_modes == expected_modes

  # The credential-free clone deliberately uses --no-checkout. Materialize only
  # the exact ordinary-Git bytes already retrieved and hash-checked above into a
  # new empty root; never execute a working-tree file or synthesize live adapters.
  Dir.mktmpdir("n64game-reviewed-lifecycle-") do |harness_root|
    reviewed_harness_bytes.each do |relative, bytes|
      target = Pathname.new(harness_root).join(relative)
      FileUtils.mkdir_p(target.dirname)
      File.binwrite(target, bytes)
      File.chmod(relative == PRODUCTION_LIFECYCLE_HARNESS_RUNNER_PATH ? 0o755 : 0o644, target)
    end
    run_production_lifecycle_harness(
      harness_root, manifest_path, manifest_material[:digest], kernel_row[:digest], label
    )
  end
end

def require_exact_report_fields(record, expected, label)
  expected.each do |field, value|
    error("#{label}: recomputed #{field} mismatch") unless record[field] == value.to_s
  end
end

def verify_ares_wrapper_execution(ares, ares_entry, execution_entry, capture_entry, frame_entry,
                                  capture_bytes, frame_bytes, execution_bytes,
                                  commit:, fresh_clone:, local_rom_path:)
  return unless local_rom_path

  error("APPROVED Ares evidence is disabled until Gate 3 pins the audited Ares 148 binary SHA-256") unless
    PINNED_ARES_148_BINARY_SHA256.match?(HEX64)
  ares_binary_path = ENV["N64GAME_ARES_BINARY"].to_s
  binary = Pathname.new(ares_binary_path)
  error("approved Ares proof requires N64GAME_ARES_BINARY to name one regular executable non-symlink") unless
    binary.absolute? && binary.file? && !binary.symlink? && File.executable?(binary)
  return unless binary.absolute? && binary.file? && !binary.symlink? && File.executable?(binary)

  binary_digest = Digest::SHA256.file(binary).hexdigest
  error("installed Ares binary differs from the Gate-3 pin") unless binary_digest == PINNED_ARES_148_BINARY_SHA256
  error("installed Ares binary differs from the wrapper-produced run record") unless binary_digest == ares["ares_binary_sha256"]
  wrapper = Pathname.new(fresh_clone).join(ares["wrapper_path"])
  error("approved Ares wrapper is not one regular executable file in the reviewed public clone") unless
    wrapper.file? && !wrapper.symlink? && File.executable?(wrapper)
  return unless wrapper.file? && !wrapper.symlink? && File.executable?(wrapper)

  rom = Pathname.new(local_rom_path)
  error("approved Ares wrapper verification requires the exact local ROM as a regular non-symlink") unless
    rom.file? && !rom.symlink?
  return unless rom.file? && !rom.symlink?

  Dir.mktmpdir("n64game-ares-wrapper-verify-") do |dir|
    capture_file = File.join(dir, "capture.mp4")
    frame_file = File.join(dir, "FRAME_AUDIT.tsv")
    execution_file = File.join(dir, "ARES_EXECUTION_EVENTS.tsv")
    run_file = File.join(dir, "ARES_RUN.tsv")
    File.binwrite(capture_file, capture_bytes)
    File.binwrite(frame_file, frame_bytes)
    File.binwrite(execution_file, execution_bytes)
    run_material = materialized_commit_file(
      ares_entry[:path], commit, "Ares wrapper-produced run record", fresh_clone: fresh_clone, allow_lfs: false
    )
    File.binwrite(run_file, run_material ? run_material[:bytes] : "")
    output, wrapper_error, status = Open3.capture3(
      wrapper.to_s, "--verify-evidence", "--ares-binary", binary.to_s, "--rom", rom.to_s,
      "--capture", capture_file, "--frame-audit", frame_file, "--execution-log", execution_file,
      "--run-record", run_file
    )
    unless status.success?
      error("Ares wrapper could not reproduce/verify its causal evidence tuple: #{wrapper_error.lines.first.to_s.strip}")
      next
    end
    receipt = JSON.parse(output)
    expected = {
      "schema" => "n64game-ares-wrapper-receipt-v1", "result" => "VERIFIED",
      "rom_sha256" => ares["rom_sha256"], "capture_sha256" => capture_entry[:digest],
      "frame_audit_sha256" => frame_entry[:digest], "run_record_sha256" => ares_entry[:digest],
      "execution_log_sha256" => execution_entry[:digest],
      "ares_binary_sha256" => ares["ares_binary_sha256"], "wrapper_sha256" => ares["wrapper_sha256"]
    }
    error("Ares wrapper receipt does not exactly bind the reproduced run/capture/telemetry tuple") unless receipt == expected
  rescue JSON::ParserError => e
    error("Ares wrapper verification did not emit one canonical JSON receipt: #{e.message}")
  end
end

def validate_capture_telemetry_bundle(entries, evidence_root, build_id:, expected_rom_sha256:, owner_ids:,
                                      commit:, fresh_clone:, payload_context:, owned_paths:, local_rom_path:)
  label = "ev.benchmark.capture_60s"
  capture_entry = exact_role_entry(entries, "capture.representative", label)
  ares_entry = exact_role_entry(entries, "ares.run_record", label)
  execution_entry = exact_role_entry(entries, "ares.execution_log", label)
  frame_entry = exact_role_entry(entries, "capture.frame_audit", label)
  analysis_entry = exact_role_entry(entries, "capture.analysis", label)
  expected_paths = {
    ares_entry => "#{evidence_root}/ARES_RUN.tsv",
    execution_entry => "#{evidence_root}/ARES_EXECUTION_EVENTS.tsv",
    frame_entry => "#{evidence_root}/FRAME_AUDIT.tsv",
    analysis_entry => "#{evidence_root}/CAPTURE_ANALYSIS.tsv",
    capture_entry => "#{evidence_root}/REPRESENTATIVE_60S.mp4"
  }
  expected_paths.each do |entry, path|
    error("#{label}: evidence member path is noncanonical; expected #{path}") unless entry && entry[:path] == path
  end
  return nil unless [capture_entry, ares_entry, execution_entry, frame_entry, analysis_entry].all?

  ares_rows = parse_tsv(
    "#{ares_entry[:path]}@#{ares_entry[:digest]}", "Ares wrapper-produced run record", ARES_RUN_HEADER, 1,
    commit: commit, fresh_clone: fresh_clone, payload_context: payload_context
  )
  frame_rows = parse_variable_tsv(
    "#{frame_entry[:path]}@#{frame_entry[:digest]}", "Ares frame audit", FRAME_AUDIT_HEADER,
    minimum_rows: 1800, commit: commit, fresh_clone: fresh_clone, payload_context: payload_context
  )
  execution_rows = parse_tsv(
    "#{execution_entry[:path]}@#{execution_entry[:digest]}", "Ares wrapper execution event log",
    ARES_EXECUTION_EVENT_HEADER, ARES_EXECUTION_EVENTS.length,
    commit: commit, fresh_clone: fresh_clone, payload_context: payload_context
  )
  analysis_rows = parse_tsv(
    "#{analysis_entry[:path]}@#{analysis_entry[:digest]}", "capture analysis report", CAPTURE_ANALYSIS_HEADER, 1,
    commit: commit, fresh_clone: fresh_clone, payload_context: payload_context
  )
  ares = ARES_RUN_HEADER.zip(ares_rows.first || []).to_h
  analysis = CAPTURE_ANALYSIS_HEADER.zip(analysis_rows.first || []).to_h
  capture_material = materialized_commit_file(
    capture_entry[:path], commit, "representative Ares capture", fresh_clone: fresh_clone, allow_lfs: true
  )
  frame_material = materialized_commit_file(
    frame_entry[:path], commit, "Ares frame audit bytes", fresh_clone: fresh_clone, allow_lfs: false
  )
  execution_material = materialized_commit_file(
    execution_entry[:path], commit, "Ares execution event bytes", fresh_clone: fresh_clone, allow_lfs: false
  )
  return nil unless ares_rows.length == 1 && analysis_rows.length == 1 &&
                    execution_rows.length == ARES_EXECUTION_EVENTS.length && capture_material && frame_material && execution_material

  decoded_frames = decode_video_framehash(capture_material[:bytes], "representative Ares capture")
  capture_probe = probe_mp4(capture_material[:bytes], "representative Ares capture")
  error("#{label}: representative capture must be native 320x240") unless
    capture_probe && capture_probe[:width] == 320 && capture_probe[:height] == 240
  frame_hashes = frame_rows.map { |fields| FRAME_AUDIT_HEADER.zip(fields).to_h }
  error("#{label}: frame-audit row count differs from the fully decoded MP4") unless frame_hashes.length == decoded_frames.length
  frame_hashes.zip(decoded_frames).each_with_index do |(row, decoded), index|
    next unless decoded
    exact = canonical_integer(row["frame_index"]) == decoded[:index] &&
      canonical_integer(row["frame_start_us"]) == decoded[:start_us] &&
      canonical_integer(row["frame_time_us"]) == decoded[:frame_time_us] &&
      row["video_rgb_sha256"] == decoded[:rgb_sha256]
    error("#{label}: frame-audit row #{index} is not causally bound to decoded capture pixels/timing") unless exact
  end
  telemetry = begin
    derive_telemetry_metrics(frame_hashes)
  rescue ArgumentError => e
    error("#{label}: telemetry derivation failed: #{e.message}")
    nil
  end
  return nil unless telemetry

  run_id = "ares-#{Digest::SHA256.hexdigest("#{ares['rom_sha256']}:#{capture_entry[:digest]}")[0, 16]}"
  expected_invocation = "scripts/run-ares --homebrew-mode --expected-rom-sha256=#{ares['rom_sha256']} --capture-id=representative_60s --frame-audit=#{frame_entry[:path]} --execution-log=#{execution_entry[:path]}"
  argv_sha256 = Digest::SHA256.hexdigest(expected_invocation)
  event_records = execution_rows.map { |fields| ARES_EXECUTION_EVENT_HEADER.zip(fields).to_h }
  error("#{label}: wrapper event sequence is not exact") unless
    event_records.map { |record| record["event"] } == ARES_EXECUTION_EVENTS &&
    event_records.map { |record| record["sequence"] } == (0...ARES_EXECUTION_EVENTS.length).map(&:to_s)
  monotonic = event_records.map { |record| canonical_integer(record["monotonic_ns"]) }
  error("#{label}: wrapper event clock is malformed or non-increasing") unless
    monotonic.all? && monotonic.each_cons(2).all? { |left, right| right > left }
  child_pids = event_records.map { |record| canonical_integer(record["child_pid"]) }
  error("#{label}: wrapper event log does not bind one positive child PID") unless
    child_pids.all? { |value| value && value.positive? } && child_pids.uniq.length == 1
  event_records.each do |event_record|
    common_event = event_record["run_id"] == run_id && event_record["argv_sha256"] == argv_sha256 &&
      event_record["rom_sha256"] == ares["rom_sha256"] &&
      event_record["capture_sha256"] == capture_entry[:digest] &&
      event_record["frame_audit_sha256"] == frame_entry[:digest]
    error("#{label}: wrapper event #{event_record['event']} does not bind exact run argv/ROM/capture/audit bytes") unless common_event
    expected_exit = %w[CHILD_EXIT WRAPPER_FINISH].include?(event_record["event"]) ? "0" : "-"
    error("#{label}: wrapper event #{event_record['event']} exit-code projection mismatch") unless
      event_record["exit_code"] == expected_exit
    if event_record["event"] == "BOOT_READY"
      error("#{label}: BOOT_READY lacks a substantive boot-handshake hash") unless
        event_record["boot_handshake_sha256"]&.match?(HEX64)
    else
      error("#{label}: only BOOT_READY may carry the boot-handshake hash") unless
        event_record["boot_handshake_sha256"] == "-"
    end
  end
  wrapper_binding_valid = ares["wrapper_path"] == "scripts/run-ares" && ares["wrapper_sha256"]&.match?(HEX64)
  error("#{label}: wrapper path/hash is noncanonical") unless wrapper_binding_valid
  wrapper_material = if wrapper_binding_valid
                       validate_path_hash(
                         "#{ares['wrapper_path']}@#{ares['wrapper_sha256']}", "Ares evidence wrapper",
                         commit: commit, fresh_clone: fresh_clone, allow_lfs: false
                       )
                     end
  error("#{label}: wrapper is outside the reviewed payload graph") if
    wrapper_material && !payload_context[:closure].include?(wrapper_material[:path])
  owned_paths << ares["wrapper_path"] if owned_paths && wrapper_material
  expected_run = {
    "run_id" => run_id, "build_id" => build_id,
    "ares_version" => "148", "ares_revision" => ARES_148_REVISION,
    "ares_mode" => "Homebrew_Mode", "framebuffer_count" => "3", "framebuffer_format" => "RGBA16",
    "wrapper_path" => "scripts/run-ares", "wrapper_version" => "n64game-ares-wrapper-v1",
    "invocation" => expected_invocation, "capture_path" => capture_entry[:path],
    "capture_sha256" => capture_entry[:digest], "frame_audit_path" => frame_entry[:path],
    "frame_audit_sha256" => frame_entry[:digest], "boot_result" => "BOOT_AND_RUN_PASS",
    "exit_code" => "0", "run_duration_ms" => telemetry["duration_ms"].to_s,
    "execution_log_path" => execution_entry[:path], "execution_log_sha256" => execution_entry[:digest]
  }
  require_exact_report_fields(ares, expected_run, "Ares wrapper-produced run record")
  error("Ares run ROM SHA-256 is malformed") unless ares["rom_sha256"]&.match?(HEX64)
  error("Ares run ROM differs from the approved local/public/rebuilt ROM") if
    expected_rom_sha256 && ares["rom_sha256"] != expected_rom_sha256
  error("Ares run binary SHA-256 is malformed") unless ares["ares_binary_sha256"]&.match?(HEX64)
  error("Ares run binary differs from the Gate-3 audited pin") if
    PINNED_ARES_148_BINARY_SHA256.match?(HEX64) && ares["ares_binary_sha256"] != PINNED_ARES_148_BINARY_SHA256
  error("Ares run operator is malformed/placeholder") unless canonical_identity?(ares["operator_id"])
  error("Ares run operator must be independent of asset owners") if owner_ids.include?(ares["operator_id"])
  error("Ares run timestamp is not strict RFC 3339") unless valid_rfc3339?(ares["recorded_at"])
  error("Ares frame audit run IDs differ from the exact run") unless frame_hashes.all? { |row| row["run_id"] == run_id }

  expected_analysis = {
    "schema" => "n64game-capture-analysis-v1", "evidence_id" => label,
    "run_id" => run_id, "build_id" => build_id, "rom_sha256" => ares["rom_sha256"],
    "ares_run_path" => ares_entry[:path], "ares_run_sha256" => ares_entry[:digest],
    "frame_audit_path" => frame_entry[:path], "frame_audit_sha256" => frame_entry[:digest],
    "capture_path" => capture_entry[:path], "capture_sha256" => capture_entry[:digest],
    "decoded_frame_count" => decoded_frames.length, "first_pts_us" => decoded_frames.first&.dig(:start_us),
    "last_pts_us" => decoded_frames.last&.dig(:start_us), "duration_ms" => telemetry["duration_ms"],
    "fps_window_us" => telemetry["fps_window_us"], "full_window_count" => telemetry["full_window_count"],
    "fps_min" => telemetry["fps_min"], "sustained_sub30_windows" => telemetry["sustained_sub30_windows"],
    "placeholder_frames" => telemetry["placeholder_frames"]
  }
  require_exact_report_fields(analysis, expected_analysis, "capture analysis report")
  validate_analyzer_fields(analysis, "capture analysis report")
  verify_ares_wrapper_execution(
    ares, ares_entry, execution_entry, capture_entry, frame_entry, capture_material[:bytes],
    frame_material[:bytes], execution_material[:bytes],
    commit: commit, fresh_clone: fresh_clone, local_rom_path: local_rom_path
  ) if expected_rom_sha256
  {
    telemetry: telemetry, ares: ares, ares_entry: ares_entry, execution_entry: execution_entry, frame_entry: frame_entry,
    capture_entry: capture_entry, analysis_entry: analysis_entry, decoded_frames: decoded_frames
  }
end

def validate_benchmark_evidence(registry_rows, control_rows, commit:, fresh_clone:, payload_context:, build_id:, require_pass: true,
                                owned_paths: nil, gate_role_paths: nil, expected_rom_sha256: nil,
                                owner_ids: Set.new, local_rom_path: nil)
  refs = Set.new
  png_bytes_by_role = {}
  video_probe_by_path = {}
  computed_metrics = Hash.new { |hash, key| hash[key] = {} }
  benchmark_reports = {}
  evidence_entries_by_id = {}
  telemetry = nil
  ares_binding = nil
  verify_approval_lifecycle_fixture_suite(
    commit: commit, fresh_clone: fresh_clone, payload_context: payload_context, owned_paths: owned_paths
  ) if expected_rom_sha256
  registry_rows.each_with_index do |fields, index|
    row = EVIDENCE_REGISTRY_HEADER.zip(fields).to_h
    evidence_id = EVIDENCE_SPECS.keys[index]
    spec = EVIDENCE_SPECS[evidence_id]
    evidence_slug = evidence_id.delete_prefix("ev.benchmark.")
    evidence_root = "review/benchmark/evidence/#{evidence_slug}"
    error("benchmark evidence registry row #{index + 1} ID/order mismatch") unless row["evidence_id"] == evidence_id
    error("#{evidence_id}: canonical manifest path mismatch") unless
      row["manifest_path"] == "#{evidence_root}/EVIDENCE_MANIFEST.sha256"
    error("#{evidence_id}: canonical measurement-record path mismatch") unless
      row["record_path"] == "#{evidence_root}/MEASUREMENTS.tsv"
    error("#{evidence_id}: evidence control projection mismatch") unless control_rows[index][2] == "#{row['manifest_path']}@#{row['manifest_sha256']}"
    error("#{evidence_id}: result must be PASS") if require_pass && control_rows[index][3] != "PASS"
    error("#{evidence_id}: build ID mismatch") unless row["build_id"] == build_id
    error("#{evidence_id}: member_count is not canonical/exact") unless canonical_integer(row["member_count"]) == spec[:roles].length
    error("#{evidence_id}: exact required role set mismatch") unless row["required_roles_csv"].split(",") == spec[:roles]
    expected_captures = spec[:captures].empty? ? "NONE" : spec[:captures].join(",")
    error("#{evidence_id}: exact capture-ID set mismatch") unless row["required_capture_ids_csv"] == expected_captures
    unless payload_context[:closure].include?(row["manifest_path"])
      error("#{evidence_id}: subordinate manifest is not payload-owned")
      next
    end
    entries = validate_manifest(
      row["manifest_path"], row["manifest_sha256"], "#{evidence_id} manifest", [], commit,
      fresh_clone, payload_context
    )
    evidence_entries_by_id[evidence_id] = entries
    validate_manifest_member_roots(
      payload_context, row["manifest_path"], ["#{evidence_root}/"], "#{evidence_id} manifest"
    ) unless evidence_id == "ev.benchmark.gates"
    owned_paths << row["manifest_path"] if owned_paths
    owned_paths << row["record_path"] if owned_paths
    owned_paths&.merge(manifest_owned_paths(payload_context, row["manifest_path"]))
    error("#{evidence_id}: manifest member count mismatch") unless entries.length == spec[:roles].length
    error("#{evidence_id}: manifest role set mismatch") unless entries.map { |entry| entry[:role] }.sort == spec[:roles]
    error("#{evidence_id}: manifest capture-ID set mismatch") unless entries.map { |entry| entry[:capture] }.reject { |capture| capture == "-" }.sort == spec[:captures]
    role_capture_map = EVIDENCE_ROLE_CAPTURES.fetch(evidence_id)
    error("#{evidence_id}: internal role/capture schema does not exactly cover required roles") unless
      role_capture_map.keys.sort == spec[:roles]
    entries.each do |entry|
      error("#{evidence_id}: every benchmark member must bind clean-build ID") unless entry[:build] == build_id
      error("#{evidence_id}: role #{entry[:role]} has wrong exact capture identity") unless
        entry[:capture] == role_capture_map[entry[:role]]
      external_gate_member = evidence_id == "ev.benchmark.gates" &&
                             entry[:role].match?(/\A(?:gate\.wb\d{3}|rollup\.(?:player|quarrune|sector|presentation))\z/)
      error("#{evidence_id}: evidence member escapes canonical evidence namespace: #{entry[:path]}") unless
        entry[:path].start_with?("#{evidence_root}/") || external_gate_member
      if external_gate_member
        expected_gate_path = gate_role_paths && gate_role_paths[entry[:role]]
        error("#{evidence_id}: external gate role/path is not the exact registry binding: #{entry[:role]}") unless
          expected_gate_path && entry[:path] == expected_gate_path
      end
      next if entry[:role] == "evidence_record"
      extension = File.extname(entry[:path]).downcase
      expected_extensions = case evidence_id
                            when "ev.benchmark.native", "ev.benchmark.enlarged"
                              entry[:role].end_with?(".report") ? [".tsv"] : [".png"]
                            when "ev.benchmark.environment.corner", "ev.benchmark.ui"
                              [".png"]
                            when "ev.benchmark.turntable.player", "ev.benchmark.turntable.quarrune", "ev.benchmark.animation.player", "ev.benchmark.animation.quarrune"
                              entry[:role].end_with?("sheet") ? [".png"] : [".mp4"]
                            when "ev.benchmark.vfx_audio" then [".mp4"]
                            when "ev.benchmark.capture_60s"
                              entry[:role] == "capture.representative" ? [".mp4"] : [".tsv"]
                            when "ev.benchmark.performance", "ev.benchmark.unload_reload", "ev.benchmark.gates" then [".tsv"]
                            when "ev.benchmark.authorship" then %w[.tsv .md]
                            else []
                            end
      error("#{evidence_id}: role #{entry[:role]} uses invalid media/report type #{extension}") unless expected_extensions.include?(extension)
      material = materialized_commit_file(entry[:path], commit, "#{evidence_id} member", fresh_clone: fresh_clone)
      if material && extension == ".png"
        error("#{evidence_id}: PNG role contains non-PNG bytes") unless png_dimensions(material[:bytes])
        png_bytes_by_role[entry[:role]] = material[:bytes]
      elsif material && extension == ".mp4"
        probe = probe_mp4(material[:bytes], "#{evidence_id} #{entry[:role]}")
        video_probe_by_path[entry[:path]] = probe if probe
        if %w[ev.benchmark.vfx_audio ev.benchmark.capture_60s].include?(evidence_id) && probe
          error("#{evidence_id}: audible presentation MP4 lacks a decodable audio stream") unless probe[:audio]
        end
        if evidence_id == "ev.benchmark.capture_60s" && probe
          error("ev.benchmark.capture_60s: ffprobe duration is below 60,000 ms") unless probe[:duration_ms] >= 60_000
        end
      end
    end
    record_entry = entries.find { |entry| entry[:path] == row["record_path"] }
    error("#{evidence_id}: measurement record is not a manifest member") unless record_entry
    error("#{evidence_id}: measurement record digest mismatch") unless record_entry && record_entry[:digest] == row["record_sha256"]
    error("#{evidence_id}: measurement record must be exact evidence_record role with no capture and current build") unless
      record_entry && record_entry[:role] == "evidence_record" && record_entry[:capture] == "-" &&
      record_entry[:build] == build_id
    case evidence_id
    when "ev.benchmark.native"
      report, report_entry = parse_benchmark_report(
        entries, "native.report", "#{evidence_root}/NATIVE_REPORT.tsv", NATIVE_REPORT_HEADER,
        "native capture report", commit: commit, fresh_clone: fresh_clone, payload_context: payload_context
      )
      expected = {
        "schema" => "n64game-native-report-v1", "evidence_id" => evidence_id,
        "build_id" => build_id,
        "capture_count" => 6, "width_px" => 320, "height_px" => 240,
        "media_type" => "image/png", "color_format" => "RGBA16", "framebuffer_count" => 3
      }
      require_exact_report_fields(report, expected, "native capture report")
      validate_analyzer_fields(report, "native capture report")
      benchmark_reports[evidence_id] = [report, report_entry]
      CAPTURE_NAMES.each { |name| computed_metrics[evidence_id]["capture.#{name}"] = ["PRESENT", "bool"] }
      computed_metrics[evidence_id].merge!(
        "capture_count" => ["6", "count"], "color_format" => ["RGBA16", "format"],
        "framebuffer_count" => ["3", "count"], "height_px" => ["240", "px"],
        "media_type" => ["image/png", "mime"], "width_px" => ["320", "px"]
      )
    when "ev.benchmark.enlarged"
      report, report_entry = parse_benchmark_report(
        entries, "enlarged.report", "#{evidence_root}/ENLARGED_REPORT.tsv", ENLARGED_REPORT_HEADER,
        "enlarged capture report", commit: commit, fresh_clone: fresh_clone, payload_context: payload_context
      )
      native_report = benchmark_reports.dig("ev.benchmark.native", 0) || {}
      expected = {
        "schema" => "n64game-enlarged-report-v1", "evidence_id" => evidence_id,
        "native_bindings_csv" => native_report["capture_bindings_csv"],
        "enlarged_bindings_csv" => exact_capture_bindings(entries, "enlarged"),
        "capture_count" => 6, "width_px" => 1280, "height_px" => 960,
        "media_type" => "image/png", "scale_factor" => 4, "resampler" => "nearest-neighbor"
      }
      require_exact_report_fields(report, expected, "enlarged capture report")
      validate_analyzer_fields(report, "enlarged capture report")
      benchmark_reports[evidence_id] = [report, report_entry]
      CAPTURE_NAMES.each { |name| computed_metrics[evidence_id]["capture.#{name}"] = ["PRESENT", "bool"] }
      computed_metrics[evidence_id].merge!(
        "capture_count" => ["6", "count"], "height_px" => ["960", "px"],
        "media_type" => ["image/png", "mime"], "resampler" => ["nearest-neighbor", "algorithm"],
        "scale_factor" => ["4", "ratio"], "width_px" => ["1280", "px"]
      )
    when "ev.benchmark.capture_60s"
      ares_binding = validate_capture_telemetry_bundle(
        entries, evidence_root, build_id: build_id, expected_rom_sha256: expected_rom_sha256,
        owner_ids: owner_ids, commit: commit, fresh_clone: fresh_clone, payload_context: payload_context,
        owned_paths: owned_paths, local_rom_path: local_rom_path
      )
      if ares_binding
        telemetry = ares_binding[:telemetry]
        computed_metrics[evidence_id].merge!(
          "duration_ms" => [telemetry["duration_ms"].to_s, "ms"],
          "placeholder_frames" => [telemetry["placeholder_frames"].to_s, "frames"],
          "sustained_sub30_windows" => [telemetry["sustained_sub30_windows"].to_s, "windows"]
        )
      end
    when "ev.benchmark.performance"
      report, report_entry = parse_benchmark_report(
        entries, "performance.report", "#{evidence_root}/PERFORMANCE_REPORT.tsv", PERFORMANCE_REPORT_HEADER,
        "performance report", commit: commit, fresh_clone: fresh_clone, payload_context: payload_context
      )
      if telemetry && ares_binding
        expected = {
          "schema" => "n64game-performance-report-v1", "evidence_id" => evidence_id,
          "run_id" => telemetry["run_id"], "build_id" => build_id,
          "rom_sha256" => ares_binding[:ares]["rom_sha256"],
          "ares_run_path" => ares_binding[:ares_entry][:path],
          "ares_run_sha256" => ares_binding[:ares_entry][:digest],
          "frame_audit_path" => ares_binding[:frame_entry][:path],
          "frame_audit_sha256" => ares_binding[:frame_entry][:digest]
        }
        PERFORMANCE_REPORT_HEADER[9...-3].each { |field| expected[field] = telemetry[field] }
        require_exact_report_fields(report, expected, "performance report")
        validate_analyzer_fields(report, "performance report")
        units = {
          "fps_min" => "fps", "frame_time_p95_us" => "us", "free_heap_min_bytes" => "bytes",
          "display_batches_peak" => "count", "particles_peak" => "count",
          "scene_collision_nav_state_bytes" => "bytes", "scene_geometry_display_bytes" => "bytes",
          "scene_skeleton_animation_bytes" => "bytes", "scene_textures_bytes" => "bytes",
          "scene_vfx_bytes" => "bytes", "scene_working_set_bytes" => "bytes",
          "texture_working_set_bytes" => "bytes", "unexplained_converter_warnings" => "count"
        }
        units.each { |field, unit| computed_metrics[evidence_id][field] = [telemetry[field].to_s, unit] }
      else
        error("performance report cannot be verified without the preceding decoded Ares telemetry bundle")
      end
      benchmark_reports[evidence_id] = [report, report_entry]
    when "ev.benchmark.unload_reload"
      report, report_entry = parse_benchmark_report(
        entries, "unload.report", "#{evidence_root}/UNLOAD_REPORT.tsv", UNLOAD_REPORT_HEADER,
        "unload/reload report", commit: commit, fresh_clone: fresh_clone, payload_context: payload_context
      )
      if telemetry && ares_binding
        expected = {
          "schema" => "n64game-unload-report-v1", "evidence_id" => evidence_id,
          "run_id" => telemetry["run_id"], "build_id" => build_id,
          "ares_run_path" => ares_binding[:ares_entry][:path],
          "ares_run_sha256" => ares_binding[:ares_entry][:digest],
          "frame_audit_path" => ares_binding[:frame_entry][:path],
          "frame_audit_sha256" => ares_binding[:frame_entry][:digest]
        }
        UNLOAD_REPORT_HEADER[8...-3].each { |field| expected[field] = telemetry[field] }
        require_exact_report_fields(report, expected, "unload/reload report")
        validate_analyzer_fields(report, "unload/reload report")
        computed_metrics[evidence_id].merge!(
          "baseline_heap_bytes" => [telemetry["baseline_heap_bytes"].to_s, "bytes"],
          "heap_delta_bytes" => [telemetry["heap_delta_bytes"].to_s, "bytes"],
          "post_reload_heap_bytes" => [telemetry["post_reload_heap_bytes"].to_s, "bytes"],
          "resource_delta_count" => [telemetry["resource_delta_count"].to_s, "count"]
        )
      else
        error("unload/reload report cannot be verified without the preceding decoded Ares telemetry bundle")
      end
      benchmark_reports[evidence_id] = [report, report_entry]
    end
    measurement_rows = parse_tsv(
      "#{row['record_path']}@#{row['record_sha256']}", "#{evidence_id} measurement record",
      MEASUREMENT_HEADER, spec[:metrics].length, commit: commit, fresh_clone: fresh_clone,
      payload_context: payload_context
    )
    metrics = measurement_rows.map { |measurement| measurement[1] }
    error("#{evidence_id}: metric set/order mismatch") unless metrics == spec[:metrics]
    entry_by_path = entries.to_h { |entry| [entry[:path], entry] }
    measurement_rows.each do |measurement|
      metric_row = MEASUREMENT_HEADER.zip(measurement).to_h
      error("#{evidence_id}: measurement evidence ID mismatch") unless metric_row["evidence_id"] == evidence_id
      error("#{evidence_id}##{metric_row['metric']}: invalid measured value/unit") unless
        metric_value_valid?(evidence_id, metric_row["metric"], metric_row["value"], metric_row["unit"])
      if %w[
        ev.benchmark.native ev.benchmark.enlarged ev.benchmark.capture_60s
        ev.benchmark.performance ev.benchmark.unload_reload
      ].include?(evidence_id)
        expected_claim = computed_metrics[evidence_id][metric_row["metric"]]
        error("#{evidence_id}##{metric_row['metric']}: claim is not backed by a recomputed canonical report") unless expected_claim
        error("#{evidence_id}##{metric_row['metric']}: value/unit differs from recomputed report bytes") unless
          expected_claim == [metric_row["value"], metric_row["unit"]]
      end
      member = entry_by_path[metric_row["member_path"]]
      error("#{evidence_id}##{metric_row['metric']}: referenced member is not in subordinate manifest") unless member
      if member
        error("#{evidence_id}##{metric_row['metric']}: referenced digest mismatch") unless member[:digest] == metric_row["member_sha256"]
        error("#{evidence_id}##{metric_row['metric']}: referenced build/capture mismatch") unless
          metric_row["build_id"] == build_id && metric_row["capture_id"] == member[:capture]
        expected_metric_role = EVIDENCE_METRIC_ROLES.fetch(evidence_id)[metric_row["metric"]]
        error("#{evidence_id}##{metric_row['metric']}: measurement references wrong semantic role") unless
          expected_metric_role && member[:role] == expected_metric_role
        if metric_row["metric"] == "duration_ms" && video_probe_by_path[member[:path]]
          observed_duration = video_probe_by_path[member[:path]][:duration_ms]
          reported_duration = canonical_integer(metric_row["value"])
          error("#{evidence_id}#duration_ms: TSV duration differs from pinned ffprobe observation") unless
            reported_duration && (observed_duration - reported_duration).abs <= 50
        end
      end
      if metric_row["metric"].start_with?("capture.")
        capture_name = metric_row["metric"].delete_prefix("capture.")
        expected_role = evidence_id.end_with?("enlarged") ? "enlarged.#{capture_name}" : "native.#{capture_name}"
        error("#{evidence_id}##{metric_row['metric']}: named capture points to wrong role") unless member && member[:role] == expected_role
      end
      refs << "#{evidence_id}##{metric_row['metric']}"
    end
    if evidence_id == "ev.benchmark.performance"
      values = measurement_rows.to_h { |measurement| [measurement[1], canonical_integer(measurement[2])] }
      category_metrics = %w[
        scene_textures_bytes scene_geometry_display_bytes scene_skeleton_animation_bytes
        scene_collision_nav_state_bytes scene_vfx_bytes
      ]
      category_values = category_metrics.map { |metric| values[metric] }
      error("ev.benchmark.performance: five measured scene categories must sum exactly to scene working set") unless
        category_values.all? && category_values.sum == values["scene_working_set_bytes"]
      error("ev.benchmark.performance: texture working set must equal measured scene texture category") unless
        values["texture_working_set_bytes"] == values["scene_textures_bytes"]
    end
    if %w[ev.benchmark.native ev.benchmark.enlarged].include?(evidence_id)
      expected_dimensions = evidence_id.end_with?("enlarged") ? [1280, 960] : [320, 240]
      entries.select { |entry| entry[:role].match?(/\A(?:native|enlarged)\.(?!report\z)/) }.each do |entry|
        material = materialized_commit_file(entry[:path], commit, "#{evidence_id} PNG", fresh_clone: fresh_clone)
        error("#{evidence_id}: capture is not an exact #{expected_dimensions.join('x')} PNG: #{entry[:path]}") unless
          material && png_dimensions(material[:bytes]) == expected_dimensions
      end
    end
  end
  if ares_binding && benchmark_reports["ev.benchmark.native"]
    native_report, = benchmark_reports["ev.benchmark.native"]
    require_exact_report_fields(
      native_report,
      {
        "run_id" => ares_binding[:telemetry]["run_id"],
        "ares_run_path" => ares_binding[:ares_entry][:path],
        "ares_run_sha256" => ares_binding[:ares_entry][:digest]
      },
      "native capture report"
    )
    validate_native_frame_bindings(
      native_report, evidence_entries_by_id.fetch("ev.benchmark.native", []), ares_binding[:decoded_frames],
      commit: commit, fresh_clone: fresh_clone
    )
    begin
      recorded_at = Time.iso8601(ares_binding[:ares]["recorded_at"])
      reports_for_chronology = benchmark_reports.values.map(&:first)
      capture_analysis_entry = ares_binding[:analysis_entry]
      capture_analysis_rows = parse_tsv(
        "#{capture_analysis_entry[:path]}@#{capture_analysis_entry[:digest]}",
        "capture analysis chronology", CAPTURE_ANALYSIS_HEADER, 1,
        commit: commit, fresh_clone: fresh_clone, payload_context: payload_context
      )
      reports_for_chronology << CAPTURE_ANALYSIS_HEADER.zip(capture_analysis_rows.first || []).to_h
      reports_for_chronology.each do |report|
        analyzed_at = Time.iso8601(report["analyzed_at"])
        error("benchmark report analysis timestamp precedes the causally bound Ares run") if analyzed_at < recorded_at
      end
    rescue ArgumentError, TypeError
      error("benchmark report/Ares chronology cannot be parsed as strict RFC 3339")
    end
  else
    error("native capture report cannot be causally bound without the decoded Ares capture bundle")
  end
  CAPTURE_NAMES.each do |capture_name|
    native_bytes = png_bytes_by_role["native.#{capture_name}"]
    enlarged_bytes = png_bytes_by_role["enlarged.#{capture_name}"]
    unless native_bytes && enlarged_bytes
      error("native/enlarged pixel-pair is missing for #{capture_name}")
      next
    end
    exact_nearest_neighbor_4x?(native_bytes, enlarged_bytes, "native/enlarged #{capture_name}")
  end
  refs
end

def parse_evidence_references(cell, label, valid_refs, allowed_ids: nil)
  references_text, observation = cell.to_s.split(" :: ", 2)
  unless references_text && observation && !observation.strip.empty?
    error("#{label}: evidence cell must contain exact refs :: nonempty observation")
    return []
  end
  references = references_text.split(",")
  error("#{label}: evidence references must be sorted and unique") unless references == references.sort.uniq
  references.each do |reference|
    valid = valid_refs.include?(reference) || reference == "ev.benchmark.approval#signature"
    error("#{label}: unresolved exact evidence reference #{reference.inspect}") unless valid
    if allowed_ids
      evidence_id = reference.split("#", 2).first
      error("#{label}: evidence ID #{evidence_id} is not allowed for this decision") unless allowed_ids.include?(evidence_id)
    end
  end
  references
end

def manifest_owned_paths(context, manifest_path, seen = Set.new)
  return Set.new if seen.include?(manifest_path)
  seen << manifest_path
  paths = Set.new
  context[:manifests].fetch(manifest_path, []).each do |entry|
    paths << entry[:path]
    if context[:manifests].key?(entry[:path])
      paths.merge(manifest_owned_paths(context, entry[:path], seen))
    end
  end
  paths
end

def validate_manifest_member_roots(context, manifest_path, allowed_roots, label)
  manifest_owned_paths(context, manifest_path).each do |path|
    next if allowed_roots.any? { |root| path.start_with?(root) }

    error("#{label} member is outside canonical owner roots #{allowed_roots.join(',')}: #{path}")
  end
end

def gate_attempt_history_edge_append_only?(parent_rows, child_rows)
  return true if parent_rows.nil?
  return false if child_rows.nil? || parent_rows.length > child_rows.length

  child_rows.first(parent_rows.length) == parent_rows
end

def gate_attempt_history_rows_at(path, commit, fresh_clone, label, cache)
  return cache[commit] if cache.key?(commit)

  tree_out, tree_error, tree_status = git_capture("ls-tree", commit, "--", path, root: fresh_clone)
  unless tree_status.success?
    error("#{label}: cannot inspect attempt-history tree state at #{commit}: #{tree_error.lines.first.to_s.strip}")
    return cache[commit] = nil
  end
  return cache[commit] = nil if tree_out.empty?

  mode, type, oid_and_path = tree_out.lines.first.to_s.split(/\s+/, 3)
  oid, actual_path = oid_and_path.to_s.split("\t", 2)
  unless %w[100644 100755].include?(mode) && type == "blob" && oid&.match?(HEX40) && actual_path.to_s.chomp == path
    error("#{label}: attempt-history tree entry is not one exact regular Git blob at #{commit}")
    return cache[commit] = []
  end
  blob, blob_error, blob_status = git_capture("cat-file", "blob", oid, root: fresh_clone)
  unless blob_status.success?
    error("#{label}: cannot read attempt-history blob at #{commit}: #{blob_error.lines.first.to_s.strip}")
    return cache[commit] = []
  end
  digest = Digest::SHA256.hexdigest(blob.b)
  cache[commit] = parse_variable_tsv(
    "#{path}@#{digest}", "#{label} at #{commit}", GATE_ATTEMPT_HISTORY_HEADER,
    minimum_rows: 1, commit: commit, fresh_clone: fresh_clone
  )
end

def gate_attempt_commit_graph(commit, fresh_clone, label)
  cache = (@gate_attempt_commit_graph_cache ||= {})
  key = [Pathname.new(fresh_clone).expand_path.to_s, commit]
  return cache[key] if cache.key?(key)

  graph_out, graph_error, graph_status = git_capture("rev-list", "--parents", commit, root: fresh_clone)
  unless graph_status.success?
    error("#{label}: cannot enumerate the complete public commit graph: #{graph_error.lines.first.to_s.strip}")
    return nil
  end
  graph = {}
  graph_out.each_line do |line|
    child, *parents = line.split
    unless child&.match?(HEX40) && parents.all? { |parent| parent.match?(HEX40) } && !graph.key?(child)
      error("#{label}: complete public commit graph is malformed or contains duplicate commits")
      return nil
    end
    graph[child] = parents
  end
  unless graph.key?(commit) && graph.values.flatten.all? { |parent| graph.key?(parent) }
    error("#{label}: public commit graph is incomplete or shallow")
    return nil
  end
  cache[key] = graph
end

def gate_attempt_path_states(path, graph, fresh_clone, label)
  commits = graph.keys
  queries = commits.map { |candidate| "#{candidate}:#{path}" }
  states_out, states_error, states_status = git_capture(
    "cat-file", "--batch-check=%(objectname) %(objecttype)",
    root: fresh_clone, stdin_data: queries.join("\n") + "\n"
  )
  unless states_status.success?
    error("#{label}: cannot resolve attempt-history state across the complete commit graph: #{states_error.lines.first.to_s.strip}")
    return nil
  end
  lines = states_out.lines.map(&:chomp)
  unless lines.length == commits.length
    error("#{label}: attempt-history batch state count differs from the complete commit graph")
    return nil
  end

  commits.zip(lines).each_with_object({}) do |(candidate, line), states|
    if line == "#{candidate}:#{path} missing"
      states[candidate] = nil
    elsif (match = line.match(/\A([0-9a-f]{40}) blob\z/))
      states[candidate] = match[1]
    else
      error("#{label}: attempt-history state is not a blob or an exact missing path at #{candidate}")
      states[candidate] = :invalid
    end
  end
end

def validate_gate1_attempt_history_retention(production_id, path, current_manifest_owns:, commit:, fresh_clone:)
  label = "#{production_id} Gate-1 attempt history retention"
  unless commit&.match?(HEX40) && fresh_clone
    error("#{label}: requires an exact current public commit and credential-free fresh clone")
    return
  end

  graph = gate_attempt_commit_graph(commit, fresh_clone, label)
  return unless graph
  states = gate_attempt_path_states(path, graph, fresh_clone, label)
  return unless states

  row_cache = {}
  current_state = states[commit]
  gate_attempt_history_rows_at(path, commit, fresh_clone, label, row_cache) if current_state.is_a?(String)
  history_exists = states.values.any? { |state| state.is_a?(String) }
  if history_exists && !current_manifest_owns
    error("#{label}: current Gate-1 evidence manifest dropped the canonical attempt-history member")
  end

  graph.each do |child_commit, parents|
    child_state = states[child_commit]
    parents.each do |parent_commit|
      parent_state = states[parent_commit]
      next if child_state == parent_state
      next if parent_state.nil? && child_state.is_a?(String)

      parent_rows = if parent_state.is_a?(String)
                      gate_attempt_history_rows_at(path, parent_commit, fresh_clone, label, row_cache)
                    end
      child_rows = if child_state.is_a?(String)
                     gate_attempt_history_rows_at(path, child_commit, fresh_clone, label, row_cache)
                   end
      next if gate_attempt_history_edge_append_only?(parent_rows, child_rows)

      if parent_rows && child_rows.nil?
        error("#{label}: canonical history was deleted at #{child_commit} from parent #{parent_commit}")
      else
        error("#{label}: rows were removed, reordered, or rewritten at #{child_commit} from parent #{parent_commit}")
      end
    end
  end
end

def gate1_attempt_history_paths_in_graph(commit, fresh_clone)
  label = "Gate-1 attempt-history universe"
  unless commit&.match?(HEX40) && fresh_clone
    error("#{label}: requires an exact current public commit and credential-free fresh clone")
    return []
  end
  output, history_error, history_status = git_capture(
    "log", "-m", commit, "--format=", "--name-only", "-z", "--no-renames", root: fresh_clone
  )
  unless history_status.success?
    error("#{label}: cannot enumerate every reachable changed path: #{history_error.lines.first.to_s.strip}")
    return []
  end

  paths = []
  output.b.split("\0").reject(&:empty?).each do |raw_path|
    path = raw_path.dup.force_encoding(Encoding::UTF_8)
    unless path.valid_encoding?
      error("#{label}: reachable history contains an invalid UTF-8 pathname")
      next
    end
    match = path.match(%r{\Areview/([^/]+)/g1/attempts/ATTEMPT_HISTORY\.tsv\z})
    next unless match
    production_id = match[1]
    error("#{label}: historical path has no canonical production profile/tier: #{path}") unless
      expected_profile_tier(production_id)
    paths << [production_id, path]
  end
  paths.uniq.sort_by { |production_id, path| [production_id, path] }
end

def validate_gate1_attempt_history_universe(commit, fresh_clone, owned_paths_by_id)
  gate1_attempt_history_paths_in_graph(commit, fresh_clone).each do |production_id, path|
    _exists_out, _exists_error, exists_status = git_capture(
      "cat-file", "-e", "#{commit}:#{path}", root: fresh_clone
    )
    current_owner_paths = owned_paths_by_id.fetch(production_id, Set.new)
    validate_gate1_attempt_history_retention(
      production_id, path,
      current_manifest_owns: exists_status.success? && current_owner_paths.include?(path),
      commit: commit, fresh_clone: fresh_clone
    )
  end
end

def validate_gate1_attempt_history(production_id, evidence_manifest_path, owner_ids, commit:, fresh_clone:,
                                   payload_context:, owned_paths:)
  entries = payload_context[:manifests].fetch(evidence_manifest_path, [])
  attempts = entries.select { |entry| entry[:role] == "gate.attempt_history" }
  error("#{production_id}: Gate-1 evidence may contain at most one attempt-history member") unless attempts.length <= 1
  expected_history_path = "review/#{production_id}/g1/attempts/ATTEMPT_HISTORY.tsv"
  history = attempts.first
  rows = []
  if history
    error("#{production_id}: Gate-1 attempt history path/capture/build is noncanonical") unless
      history[:path] == expected_history_path && history[:capture] == "-" && history[:build] == "-"
    rows = parse_variable_tsv(
      "#{history[:path]}@#{history[:digest]}", "#{production_id} Gate-1 attempt history",
      GATE_ATTEMPT_HISTORY_HEADER, minimum_rows: 1, commit: commit, fresh_clone: fresh_clone,
      payload_context: payload_context
    )
  end
  validate_gate1_attempt_history_retention(
    production_id, expected_history_path,
    current_manifest_owns: attempts.length == 1 && history[:path] == expected_history_path,
    commit: commit, fresh_clone: fresh_clone
  )
  return unless history

  owned_paths << history[:path]
  previous_row_sha = "NONE"
  previous_commit = nil
  previous_decided_at = nil
  prefix = production_id.split(".", 2).first
  rows.each_with_index do |fields, index|
    row = GATE_ATTEMPT_HISTORY_HEADER.zip(fields).to_h
    number = index + 1
    attempt_id = format("G1-%04d", number)
    attempt_root = format("review/%s/g1/attempts/%04d", production_id, number)
    expected = {
      "production_id" => production_id, "attempt_number" => number.to_s, "attempt_id" => attempt_id,
      "source_manifest_path" => "assets-src/#{prefix}/#{production_id}/SOURCE_MANIFEST.sha256",
      "evidence_manifest_path" => "#{attempt_root}/EVIDENCE_MANIFEST.sha256",
      "review_record_path" => "#{attempt_root}/REVIEW.md", "reviewer_non_owner" => "YES",
      "previous_row_sha256" => previous_row_sha
    }
    require_exact_report_fields(row, expected, "#{production_id} #{attempt_id} history row")
    error("#{production_id} #{attempt_id}: commit/hash fields are malformed") unless
      row["attempt_commit"]&.match?(HEX40) &&
      %w[source_manifest_sha256 evidence_manifest_sha256 review_record_sha256].all? { |key| row[key]&.match?(HEX64) }
    error("#{production_id} #{attempt_id}: reviewer is malformed/placeholder") unless canonical_identity?(row["reviewer_id"])
    error("#{production_id} #{attempt_id}: reviewer is not independent") if owner_ids.include?(row["reviewer_id"])
    error("#{production_id} #{attempt_id}: decided_at is not strict RFC 3339") unless valid_rfc3339?(row["decided_at"])
    begin
      decided_at = Time.iso8601(row["decided_at"])
      error("#{production_id} #{attempt_id}: attempt timestamps are not strictly increasing") if
        previous_decided_at && decided_at <= previous_decided_at
      previous_decided_at = decided_at
    rescue ArgumentError
      # Strict syntax failure is already recorded above.
    end
    error("#{production_id} #{attempt_id}: disposition must be exact REJECT or REVISE") unless
      %w[REJECT REVISE].include?(row["disposition"])
    error("#{production_id} #{attempt_id}: rejection requires sorted unique canonical defect IDs") unless
      canonical_defect_ids?(row["defect_ids"])

    attempt_commit = row["attempt_commit"]
    if attempt_commit&.match?(HEX40) && commit&.match?(HEX40)
      _ancestor_out, _ancestor_error, ancestor_status = git_capture(
        "merge-base", "--is-ancestor", attempt_commit, commit, root: fresh_clone
      )
      error("#{production_id} #{attempt_id}: attempt commit must be a strict public ancestor of the current reviewed commit") unless
        ancestor_status.success? && attempt_commit != commit
      if previous_commit
        _forward_out, _forward_error, forward_status = git_capture(
          "merge-base", "--is-ancestor", previous_commit, attempt_commit, root: fresh_clone
        )
        error("#{production_id} #{attempt_id}: attempt commits are not a strict forward history") unless
          forward_status.success? && previous_commit != attempt_commit
      end
    else
      error("#{production_id} #{attempt_id}: attempt history requires an exact current public commit")
    end

    if attempt_commit&.match?(HEX40)
      historical_context = new_manifest_context
      validate_manifest(
        row["source_manifest_path"], row["source_manifest_sha256"], "#{production_id} #{attempt_id} source",
        [], attempt_commit, fresh_clone, historical_context
      )
      validate_manifest_member_roots(
        historical_context, row["source_manifest_path"], ["assets-src/#{prefix}/#{production_id}/"],
        "#{production_id} #{attempt_id} source"
      )
      validate_manifest(
        row["evidence_manifest_path"], row["evidence_manifest_sha256"], "#{production_id} #{attempt_id} evidence",
        [], attempt_commit, fresh_clone, historical_context
      )
      validate_manifest_member_roots(
        historical_context, row["evidence_manifest_path"], ["#{attempt_root}/"],
        "#{production_id} #{attempt_id} evidence"
      )
      review_entry = historical_context[:entries][row["review_record_path"]]
      error("#{production_id} #{attempt_id}: review record is not owned by its historical evidence manifest") unless
        review_entry && review_entry[:digest] == row["review_record_sha256"] &&
        review_entry[:role] == "gate.attempt_review" && review_entry[:capture] == "-" && review_entry[:build] == "-" &&
        historical_context[:member_owner][row["review_record_path"]] == row["evidence_manifest_path"]
      review = parse_machine_record(
        "#{row['review_record_path']}@#{row['review_record_sha256']}", "#{production_id} #{attempt_id} rejection review",
        GATE_ATTEMPT_REVIEW_KEYS, commit: attempt_commit, fresh_clone: fresh_clone
      )
      expected_review = {
        "schema" => "n64game-g1-attempt-review-v1", "production_id" => production_id,
        "attempt_id" => attempt_id, "gate" => "G1", "decision" => "fail",
        "reviewer_id" => row["reviewer_id"], "reviewer_non_owner" => "YES",
        "source_manifest_sha256" => row["source_manifest_sha256"], "output_manifest_sha256" => "NONE",
        "evidence_manifest" => "#{row['evidence_manifest_path']}@#{row['evidence_manifest_sha256']}",
        "build_id" => "-", "decided_at" => row["decided_at"], "defect_ids" => row["defect_ids"],
        "disposition" => row["disposition"]
      }
      require_exact_report_fields(review, expected_review, "#{production_id} #{attempt_id} rejection review")
      error("#{production_id} #{attempt_id}: rejection rationale is missing/placeholder") unless
        review["rationale"] && review["rationale"] != "PENDING" && review["rationale"].length.between?(20, 1000)
    end
    previous_row_sha = gate_attempt_row_sha256(fields)
    previous_commit = attempt_commit
  end
end

def validate_concept_entries(entries, owned_paths_by_id, commit: nil, fresh_clone: nil, payload_context: nil)
  concept_context = payload_context || new_manifest_context
  entries.select { |entry| entry[:status] == "concept" }.each do |entry|
    production_id = entry[:id]
    profile_tier = expected_profile_tier(production_id)
    unless profile_tier
      error("#{production_id}: concept row has no canonical production profile/tier")
      next
    end
    error("#{production_id}: concept profile/tier mismatch") unless entry[:profile_tier] == profile_tier.join(" / ")
    prefix = production_id.split(".", 2).first
    provenance_path = "review/#{production_id}/g1/PROVENANCE.md"
    source_manifest_path = "assets-src/#{prefix}/#{production_id}/SOURCE_MANIFEST.sha256"
    evidence_manifest_path = "review/#{production_id}/g1/EVIDENCE_MANIFEST.sha256"
    review_path = "review/#{production_id}/g1/REVIEW.md"
    provenance_binding = leading_locator(entry[:provenance], "record")
    source_binding = leading_locator(entry[:source], "source")
    evidence_locators = exact_locator_tokens(entry[:evidence])
    error("#{production_id}: concept provenance must bind canonical g1 PROVENANCE.md") unless
      provenance_binding&.start_with?("#{provenance_path}@")
    error("#{production_id}: concept source must bind canonical SOURCE_MANIFEST.sha256") unless
      source_binding&.start_with?("#{source_manifest_path}@")
    error("#{production_id}: concept evidence must be exact concept_evidence/review locator pair") unless
      evidence_locators.keys.sort == %w[concept_evidence review] &&
      evidence_locators["concept_evidence"]&.start_with?("#{evidence_manifest_path}@") &&
      evidence_locators["review"]&.start_with?("#{review_path}@")
    error("#{production_id}: concept output must be exact output:NONE") unless entry[:output] == "output:NONE"
    owner_ids = canonical_ledger_owners(entry[:creator])
    error("#{production_id}: concept creator/rights-holder machine binding missing/placeholder") unless owner_ids
    error("#{production_id}: concept gate vector must be seven literal PENDING decisions") unless
      parse_ledger_gate_vector(entry[:gates], "#{production_id} concept") == Array.new(7, "PENDING")

    bindings = [provenance_binding, source_binding, evidence_locators["concept_evidence"], evidence_locators["review"]].compact
    if payload_context
      bindings.each do |binding|
        path = binding.split("@", 2).first
        error("#{production_id}: concept binding is outside reviewed payload graph: #{path}") unless payload_context[:closure].include?(path)
      end
    end
    concept_subset_digest = Digest::SHA256.hexdigest("CONCEPT_ONLY")
    provenance_record = if provenance_binding
                          validate_provenance_record(
                            provenance_binding,
                            {
                              "production_id" => production_id, "subset_sha256" => concept_subset_digest,
                              "source_manifest_path" => source_manifest_path,
                              "source_manifest_sha256" => source_binding.to_s.split("@", 2)[1],
                              "output_manifest_path" => "NONE", "output_manifest_sha256" => "NONE"
                            },
                            "#{production_id} concept", commit: commit, fresh_clone: fresh_clone,
                            payload_context: payload_context, record_context: concept_context,
                            allow_none_subset: true
                          )
                        else
                          {}
                        end
    if owner_ids
      error("#{production_id}: concept provenance creator/rightsholder differs from ledger") unless
        provenance_record["creator_id"] == owner_ids[0] && provenance_record["rights_holder_id"] == owner_ids[1]
    end
    validate_ledger_provenance_projection(entry, provenance_record, "#{production_id} concept") unless provenance_record.empty?
    if source_binding
      source_path, source_digest = source_binding.split("@", 2)
      validate_manifest(
        source_path, source_digest, "#{production_id} concept source", [], commit, fresh_clone, concept_context
      )
      validate_manifest_member_roots(
        concept_context, source_path, ["assets-src/#{prefix}/#{production_id}/"],
        "#{production_id} concept source"
      )
      rights_path = provenance_record["rights_evidence"].to_s.split("@", 2).first
      error("#{production_id}: concept rights evidence is not source-manifest-owned") unless
        manifest_owned_paths(concept_context, source_path).include?(rights_path)
    end
    if evidence_locators["concept_evidence"]
      evidence_path, evidence_digest = evidence_locators["concept_evidence"].split("@", 2)
      validate_manifest(
        evidence_path, evidence_digest, "#{production_id} Gate-1 concept evidence", [], commit, fresh_clone, concept_context
      )
      validate_manifest_member_roots(
        concept_context, evidence_path, ["review/#{production_id}/g1/"],
        "#{production_id} Gate-1 concept evidence"
      )
      review_entry = concept_context[:entries][review_path]
      error("#{production_id}: canonical g1 REVIEW.md must be a direct concept-evidence-manifest member") unless
        concept_context[:member_owner][review_path] == evidence_manifest_path
      error("#{production_id}: canonical g1 REVIEW.md must use exact concept.review role") unless
        review_entry && review_entry[:role] == "concept.review"
    end
    if evidence_locators["review"]
      concept_review = parse_machine_record(
        evidence_locators["review"], "#{production_id} Gate-1 concept review",
        CONCEPT_REVIEW_RECORD_KEYS, commit: commit, fresh_clone: fresh_clone,
        payload_context: payload_context, record_context: concept_context
      )
      expected_review = {
        "schema" => "n64game-concept-review-v1", "production_id" => production_id,
        "stage" => "G1_CONCEPT", "creator_id" => owner_ids && owner_ids[0],
        "source_manifest" => source_binding,
        "evidence_manifest" => evidence_locators["concept_evidence"], "status" => "IN_PROGRESS"
      }
      expected_review.each do |key, value|
        error("#{production_id}: concept review #{key} mismatch") unless concept_review[key] == value
      end
      error("#{production_id}: concept review updated_at is not RFC 3339") unless valid_rfc3339?(concept_review["updated_at"])
      error("#{production_id}: concept review rationale is missing") unless
        concept_review["rationale"] && concept_review["rationale"] != "PENDING" && concept_review["rationale"].length.between?(12, 500)
    end

    validate_gate1_attempt_history(
      production_id, evidence_manifest_path, owner_ids || [], commit: commit, fresh_clone: fresh_clone,
      payload_context: concept_context, owned_paths: owned_paths_by_id[production_id]
    ) if evidence_locators["concept_evidence"]

    owned_paths_by_id[production_id].merge([provenance_path, source_manifest_path, evidence_manifest_path, review_path])
    owned_paths_by_id[production_id].merge(manifest_owned_paths(concept_context, source_manifest_path))
    owned_paths_by_id[production_id].merge(manifest_owned_paths(concept_context, evidence_manifest_path))

    concept_owned_paths = owned_paths_by_id[production_id]
    concept_owned_paths.each do |path|
      basename = File.basename(path)
      forbidden_basenames = %w[
        AUTHORIZATION.md GATE_RECORD.tsv SUBSET_EXPORT_ALLOWLIST.tsv AUTHORING_STACK_RECEIPT.txt
        OUTPUT_MANIFEST.sha256
      ]
      forbidden_path = forbidden_basenames.any? { |candidate| basename.casecmp?(candidate) } ||
        path.match?(%r{/g[2-7]/}) ||
        path.start_with?("build/", "review/benchmark/", "review/production/", "review/pairs/", "review/generated/")
      error("#{production_id}: concept ownership includes forbidden authority/Gate-2+/output path: #{path}") if
        forbidden_path
      role = concept_context[:entries].dig(path, :role).to_s
      forbidden_role = role.match?(
        /\A(?:authorization|gate\.record|subset\.export_allowlist|authoring\.stack_receipt|output(?:\.|\z)|converted(?:\.|\z)|conversion(?:\.|\z))/
      )
      error("#{production_id}: concept ownership includes forbidden authority/output role #{role.inspect}: #{path}") if
        forbidden_role
    end
  end
  concept_context
end

def verified_prior_approval_baseline(baseline_identity, slug, whitelist_ids, expected_subset_hashes)
  tag_ref = baseline_identity["Prior approved attestation ref"]
  unless tag_ref&.match?(%r{\Arefs/tags/n64game-visual-benchmark/[0-9a-f]{12}\z}) && slug
    error("prior approval baseline ref/origin is malformed")
    return nil
  end
  tag_type, _tag_type_error, tag_type_status = git_capture("cat-file", "-t", tag_ref)
  tag_oid_out, _tag_oid_error, tag_oid_status = git_capture("rev-parse", tag_ref)
  target_out, _target_error, target_status = git_capture("rev-parse", "#{tag_ref}^{commit}")
  tag_oid = tag_oid_out.strip if tag_oid_status.success?
  tag_target = target_out.strip if target_status.success?
  unless tag_type_status.success? && tag_type.strip == "tag" && tag_oid&.match?(HEX40) && tag_target&.match?(HEX40)
    error("prior approval baseline must resolve to one local annotated tag and commit target")
    return nil
  end
  error("prior approval tag object ID differs from recorded baseline identity") unless
    tag_oid == baseline_identity["Prior approved attestation tag object ID"]
  error("prior approval control commit differs from recorded baseline identity") unless
    tag_target == baseline_identity["Prior approved control Git commit"]

  remote_out, remote_error, remote_status = public_git_capture(
    slug, "ls-remote", "--tags", "https://github.com/#{slug}.git", tag_ref, "#{tag_ref}^{}"
  )
  remote_refs = remote_out.lines.to_h { |line| oid, ref = line.strip.split("\t", 2); [ref, oid] }
  unless remote_status.success? && remote_refs[tag_ref] == tag_oid && remote_refs["#{tag_ref}^{}"] == tag_target
    error("prior approval baseline public tag object/target differs from local: #{remote_error.lines.first.to_s.strip}")
    return nil
  end

  tag_object, tag_object_error, tag_object_status = git_capture("cat-file", "tag", tag_ref)
  signature_marker = "-----BEGIN SSH SIGNATURE-----\n"
  marker_offset = tag_object.index(signature_marker)
  signed_prefix = marker_offset ? tag_object[0...marker_offset] : ""
  signature_block = marker_offset ? tag_object[marker_offset..] : ""
  exact_signature = signature_block.match?(/\A-----BEGIN SSH SIGNATURE-----\n(?:[^\r\n]*\n)*-----END SSH SIGNATURE-----\n\z/)
  unless tag_object_status.success? && marker_offset && exact_signature
    error("prior approval baseline tag lacks one exact SSH signature: #{tag_object_error.lines.first.to_s.strip}")
    return nil
  end
  return nil unless verify_pinned_ssh_signature(signed_prefix, signature_block)

  attested_text = signed_prefix.split("\n\n", 2)[1].to_s
  attested_lines = attested_text.lines(chomp: true)
  payload_commit = attested_lines[1].to_s.delete_prefix("payload_commit=")
  payload_digest = attested_lines[2].to_s.delete_prefix("payload_manifest_sha256=")
  expected_text = [
    "schema=n64game-benchmark-attestation-v1", "payload_commit=#{payload_commit}",
    "payload_manifest_sha256=#{payload_digest}", "control_path=docs/VISUAL_BENCHMARK_APPROVAL.md",
    "decision=APPROVED"
  ].join("\n") + "\n"
  unless attested_text == expected_text && payload_commit.match?(HEX40) && payload_digest.match?(HEX64) &&
         tag_ref.end_with?(payload_commit[0, 12])
    error("prior approval baseline attestation message/payload binding is malformed")
    return nil
  end
  error("prior approval payload commit differs from recorded baseline identity") unless
    payload_commit == baseline_identity["Prior approved payload Git commit"]
  error("prior approval payload-manifest digest differs from recorded baseline identity") unless
    payload_digest == baseline_identity["Prior approved payload-manifest SHA-256"]
  _ancestor_out, _ancestor_error, ancestor_status = git_capture("merge-base", "--is-ancestor", payload_commit, tag_target)
  unless ancestor_status.success?
    error("prior approval payload is not an ancestor of its signed control tag target")
    return nil
  end
  fresh_clone = prepare_fresh_public_clone(slug, payload_commit, tag_ref)
  return nil unless fresh_clone
  fresh_tag_oid, _fresh_oid_error, fresh_oid_status = git_capture("rev-parse", tag_ref, root: fresh_clone)
  fresh_target, _fresh_target_error, fresh_target_status = git_capture("rev-parse", "#{tag_ref}^{commit}", root: fresh_clone)
  fresh_tag_object, _fresh_object_error, fresh_object_status = git_capture("cat-file", "tag", tag_ref, root: fresh_clone)
  unless fresh_oid_status.success? && fresh_tag_oid.strip == tag_oid && fresh_target_status.success? &&
         fresh_target.strip == tag_target && fresh_object_status.success? && fresh_tag_object == tag_object
    error("prior approval baseline is not byte-identical/reachable in fresh public clone")
    return nil
  end

  control_bytes, control_error, control_status = git_capture(
    "show", "#{tag_target}:docs/VISUAL_BENCHMARK_APPROVAL.md", root: fresh_clone
  )
  unless control_status.success?
    error("prior approval tag target lacks control: #{control_error.lines.first.to_s.strip}")
    return nil
  end
  control_header = benchmark_control_header(control_bytes, "prior approval baseline control")
  unless control_header && control_header[:schema_version] == "4" &&
         control_header[:decision] == "APPROVED" && control_header[:production_lock] == "UNLOCKED"
    error("prior approval baseline control is not Schema-Version 4 APPROVED/UNLOCKED")
    return nil
  end
  identity_section = between(control_bytes, "## 1. Approval identity", "## 2. Exact pre-approval production whitelist")
  prior_identity_pairs = identity_section.lines.each_with_object([]) do |line, pairs|
    next unless line.start_with?("|")
    cells = table_cells(line)
    next unless cells.length == 3 && !%w[Field ---].include?(cells[0])
    pairs << [cells[0], strip_code(cells[2])]
  end
  unless prior_identity_pairs.map(&:first) == REQUIRED_IDENTITY_FIELDS
    error("prior approval control identity field set/order/uniqueness mismatch")
    return nil
  end
  prior_identity = prior_identity_pairs.to_h
  unless prior_identity["Approval attestation ref"] == tag_ref &&
         prior_identity["Attestation signer fingerprint"] == PINNED_SSH_FINGERPRINT &&
         prior_identity["Reviewed payload Git commit"] == payload_commit &&
         prior_identity["Payload manifest path"] == "review/benchmark/PAYLOAD_MANIFEST.sha256" &&
         prior_identity["Payload manifest SHA-256"] == payload_digest
    error("prior approval control identity differs from signed baseline message")
  end
  error("prior approved control must itself have no earlier active baseline") unless
    PRIOR_BASELINE_FIELDS.all? { |field| prior_identity[field] == "NONE" }

  payload_context = new_manifest_context
  validate_manifest(
    "review/benchmark/PAYLOAD_MANIFEST.sha256", payload_digest, "prior approval payload",
    [], payload_commit, fresh_clone, payload_context
  )
  registry_path = prior_identity["Whitelist/gate registry path"]
  registry_digest = prior_identity["Whitelist/gate registry SHA-256"]
  unless registry_path == "review/benchmark/WHITELIST_GATE_REGISTRY.tsv" && registry_digest&.match?(HEX64)
    error("prior approval control whitelist registry identity is malformed")
    return nil
  end
  error("prior approval whitelist registry digest differs from recorded baseline identity") unless
    registry_digest == baseline_identity["Prior approved whitelist/gate-registry SHA-256"]
  prior_registry_rows = parse_tsv(
    "#{registry_path}@#{registry_digest}", "prior approval whitelist registry",
    WHITELIST_REGISTRY_HEADER, BENCHMARK_WHITELIST_COUNT, commit: payload_commit, fresh_clone: fresh_clone,
    payload_context: payload_context
  )
  prior_ledger_material = materialized_commit_file(
    "docs/ASSET_LEDGER.md", payload_commit, "prior approval payload ledger",
    fresh_clone: fresh_clone, allow_lfs: false
  )
  prior_ledger_entries = prior_ledger_material ?
    parse_ledger_entries(prior_ledger_material[:bytes], "prior approval payload ledger") : []
  prior_ledger_by_id = prior_ledger_entries.each_with_object({}) { |entry, rows| rows[entry[:id]] = entry }
  auth_section = between(
    control_bytes, "### 2.1 Exact authorization and current-hash bindings",
    "## 3. Exact benchmark evidence set"
  )
  prior_auth_lines = auth_section.lines.grep(/^\| WB-\d{3} \|/)
  prior_auth_rows = prior_auth_lines.map { |line| table_cells(line).map { |cell| strip_code(cell) } }
  error("prior approval control must contain exactly #{BENCHMARK_WHITELIST_COUNT} authorization rows") unless
    prior_auth_rows.length == BENCHMARK_WHITELIST_COUNT
  prior_gate_rows = []
  prior_subset_allowlists = []
  prior_registry_rows.each_with_index do |fields, index|
    row = WHITELIST_REGISTRY_HEADER.zip(fields).to_h
    basis = format("WB-%03d", index + 1)
    production_id = whitelist_ids[index]
    control = prior_auth_rows[index]
    error("prior approval #{basis}: registry order/ID/subset mismatch") unless
      row["basis"] == basis && row["production_id"] == production_id &&
      row["subset_sha256"] == expected_subset_hashes[production_id]
    projection = [
      basis, production_id, "#{row['authorization_path']}@#{row['authorization_sha256']}",
      "#{row['gate_record_path']}@#{row['gate_record_sha256']}",
      "#{row['provenance_path']}@#{row['provenance_sha256']}",
      "#{row['source_manifest_path']}@#{row['source_manifest_sha256']}",
      "#{row['output_manifest_path']}@#{row['output_manifest_sha256']}", row["state"]
    ]
    error("prior approval #{basis}: control/registry projection mismatch") unless projection == control
    profile, = expected_profile_tier(production_id)
    baseline_gates_complete = (1..7).all? do |gate_number|
      completion_decision_allowed?(row["g#{gate_number}"], profile, "G#{gate_number}")
    end
    error("prior approval #{basis}: baseline row is not final AUTHORIZED/completed") unless
      row["state"] == "AUTHORIZED" && row["repair_ids"] == "NONE" && baseline_gates_complete
    gate_rows = parse_tsv(
      "#{row['gate_record_path']}@#{row['gate_record_sha256']}", "prior approval #{basis} gate record",
      GATE_RECORD_HEADER, 7, commit: payload_commit, fresh_clone: fresh_clone, payload_context: payload_context
    )
    prior_gate_rows << gate_rows
    prior_provenance = parse_machine_record(
      "#{row['provenance_path']}@#{row['provenance_sha256']}", "prior approval #{basis} provenance",
      PROVENANCE_RECORD_KEYS, commit: payload_commit, fresh_clone: fresh_clone,
      payload_context: payload_context, record_context: payload_context
    )
    prior_subset_allowlists << prior_provenance["subset_allowlist"]
  end
  {
    tag_ref: tag_ref, payload_commit: payload_commit, payload_digest: payload_digest,
    tag_oid: tag_oid, control_commit: tag_target, fresh_clone: fresh_clone,
    control: control_bytes, authorization_lines: prior_auth_lines,
    authorization_rows: prior_auth_rows, registry_rows: prior_registry_rows,
    gate_rows: prior_gate_rows, subset_allowlists: prior_subset_allowlists,
    ledger_by_id: prior_ledger_by_id
  }
end

def quiet_public_approval_candidate(clone, tag_ref)
  tag_type, _type_error, type_status = git_capture("cat-file", "-t", tag_ref, root: clone)
  return nil unless type_status.success? && tag_type.strip == "tag"
  target_out, _target_error, target_status = git_capture("rev-parse", "#{tag_ref}^{commit}", root: clone)
  tag_object, _object_error, object_status = git_capture("cat-file", "tag", tag_ref, root: clone)
  return nil unless target_status.success? && object_status.success?
  target = target_out.strip
  marker = "-----BEGIN SSH SIGNATURE-----\n"
  marker_offset = tag_object.index(marker)
  return nil unless marker_offset
  signed_prefix = tag_object[0...marker_offset]
  signature = tag_object[marker_offset..]
  return nil unless signature.match?(/\A-----BEGIN SSH SIGNATURE-----\n(?:[^\r\n]*\n)*-----END SSH SIGNATURE-----\n\z/)
  return nil unless verify_pinned_ssh_signature(signed_prefix, signature, report: false)
  attested_text = signed_prefix.split("\n\n", 2)[1].to_s
  lines = attested_text.lines(chomp: true)
  return nil unless lines.length == 5 && lines[0] == "schema=n64game-benchmark-attestation-v1" &&
                    lines[3] == "control_path=docs/VISUAL_BENCHMARK_APPROVAL.md" && lines[4] == "decision=APPROVED"
  payload_commit = lines[1].delete_prefix("payload_commit=")
  payload_digest = lines[2].delete_prefix("payload_manifest_sha256=")
  expected_text = [
    lines[0], "payload_commit=#{payload_commit}", "payload_manifest_sha256=#{payload_digest}",
    lines[3], lines[4]
  ].join("\n") + "\n"
  return nil unless attested_text == expected_text && payload_commit.match?(HEX40) && payload_digest.match?(HEX64) &&
                    tag_ref.end_with?(payload_commit[0, 12])
  _ancestor_out, _ancestor_error, ancestor_status = git_capture(
    "merge-base", "--is-ancestor", payload_commit, target, root: clone
  )
  return nil unless ancestor_status.success?
  control, _control_error, control_status = git_capture(
    "show", "#{target}:docs/VISUAL_BENCHMARK_APPROVAL.md", root: clone
  )
  return nil unless control_status.success?
  control_header = benchmark_control_header(control, "public approval candidate control", report: false)
  return nil unless control_header && control_header[:schema_version] == "4" &&
                    control_header[:decision] == "APPROVED" && control_header[:production_lock] == "UNLOCKED"
  identity_start_marker = "## 1. Approval identity"
  identity_end_marker = "## 2. Exact pre-approval production whitelist"
  identity_start = control.index(identity_start_marker)
  identity_end = identity_start && control.index(identity_end_marker, identity_start + identity_start_marker.length)
  return nil unless identity_start && identity_end
  identity_section = control[(identity_start + identity_start_marker.length)...identity_end]
  prior_identity_pairs = identity_section.lines.each_with_object([]) do |line, pairs|
    next unless line.start_with?("|")
    cells = table_cells(line)
    next unless cells.length == 3 && !%w[Field ---].include?(cells[0])
    pairs << [cells[0], strip_code(cells[2])]
  end
  return nil unless prior_identity_pairs.map(&:first) == REQUIRED_IDENTITY_FIELDS
  prior_identity = prior_identity_pairs.to_h
  return nil unless prior_identity["Approval attestation ref"] == tag_ref &&
                    prior_identity["Attestation signer fingerprint"] == PINNED_SSH_FINGERPRINT &&
                    prior_identity["Reviewed payload Git commit"] == payload_commit &&
                    prior_identity["Payload manifest SHA-256"] == payload_digest
  { ref: tag_ref, target: target }
end

def enforce_latest_public_approval_baseline(baseline, slug)
  clone = baseline[:fresh_clone]
  selected_ref = baseline[:tag_ref]
  remote_head_out, remote_head_error, remote_head_status = public_git_capture(
    slug, "ls-remote", "--symref", "https://github.com/#{slug}.git", "HEAD"
  )
  current_head = remote_head_out.lines.map do |line|
    oid, ref = line.strip.split("\t", 2)
    oid if ref == "HEAD" && oid&.match?(HEX40)
  end.compact.first
  unless clone && remote_head_status.success? && current_head
    error("cannot establish credential-free current public HEAD for prior-approval anti-rollback: #{remote_head_error.lines.first.to_s.strip}")
    return
  end
  public_url = "https://github.com/#{slug}.git"
  _fetch_out, fetch_error, fetch_status = public_git_capture(
    slug, "fetch", "--force", public_url,
    "+refs/tags/n64game-visual-benchmark/*:refs/tags/n64game-visual-benchmark/*",
    root: clone
  )
  unless fetch_status.success?
    error("cannot enumerate public approval tags for anti-rollback: #{fetch_error.lines.first.to_s.strip}")
    return
  end
  _head_exists_out, _head_exists_error, head_exists_status = git_capture(
    "cat-file", "-e", "#{current_head}^{commit}", root: clone
  )
  unless head_exists_status.success?
    _head_fetch_out, head_fetch_error, head_fetch_status = public_git_capture(
      slug, "fetch", "--force", public_url, current_head, root: clone
    )
    unless head_fetch_status.success?
      error("current HEAD is not public/reachable for prior-approval anti-rollback: #{head_fetch_error.lines.first.to_s.strip}")
      return
    end
  end
  refs_out, refs_error, refs_status = git_capture(
    "for-each-ref", "--format=%(refname)", "refs/tags/n64game-visual-benchmark/", root: clone
  )
  unless refs_status.success?
    error("cannot list public approval tags for anti-rollback: #{refs_error.lines.first.to_s.strip}")
    return
  end
  candidates = refs_out.lines.map(&:strip).map do |tag_ref|
    candidate = quiet_public_approval_candidate(clone, tag_ref)
    next unless candidate
    _reachable_out, _reachable_error, reachable_status = git_capture(
      "merge-base", "--is-ancestor", candidate[:target], current_head, root: clone
    )
    reachable_status.success? ? candidate : nil
  end.compact
  maxima = candidates.reject do |candidate|
    candidates.any? do |other|
      next false if other[:ref] == candidate[:ref] || other[:target] == candidate[:target]
      _dominance_out, _dominance_error, dominance_status = git_capture(
        "merge-base", "--is-ancestor", candidate[:target], other[:target], root: clone
      )
      dominance_status.success?
    end
  end
  unless maxima.length == 1 && maxima.first[:ref] == selected_ref
    error("selected prior approval is not the unique latest pinned-key public approval ancestor; maxima=#{maxima.map { |item| item[:ref] }.sort.join(',')}")
  end
end

art = read("docs/ART_BIBLE.md")
inventory = read("docs/ASSET_INVENTORY.md")
ledger = read("docs/ASSET_LEDGER.md")
reviews = read("docs/ASSET_REVIEW_TEMPLATES.md")
benchmark = read("docs/VISUAL_BENCHMARK_APPROVAL.md")
toolchain = read("docs/TOOLCHAIN.md")
data_schemas = read("docs/DATA_SCHEMAS.md")
benchmark_header = benchmark_control_header(benchmark, "visual benchmark control")

tracked_out, tracked_error, tracked_status = git_capture("ls-files", "-z")
head_tree_out, head_tree_error, head_tree_status = git_capture(
  "ls-tree", "-r", "--name-only", "-z", "HEAD^{tree}", env: { "GIT_NO_REPLACE_OBJECTS" => "1" }
)
if tracked_status.success? && head_tree_status.success?
  (tracked_out.split("\0") + head_tree_out.split("\0")).reject(&:empty?).uniq.each do |path|
    error("current index or HEAD tree contains forbidden ROM binary: #{path}") if
      ROM_EXTENSIONS.include?(File.extname(path).downcase)
  end
else
  errors = []
  errors << "index: #{tracked_error.lines.first.to_s.strip}" unless tracked_status.success?
  errors << "HEAD tree: #{head_tree_error.lines.first.to_s.strip}" unless head_tree_status.success?
  error("cannot enumerate current index and HEAD tree for forbidden ROM binaries: #{errors.join('; ')}")
end

[
  "### 8.1 Scale chart",
  "### 8.2 Native scale and gameplay-camera examples",
  "### Display transform and color-grade contract",
  "## 10. Composition and gameplay-camera readability",
  "## 15. Objective rejection and rebuild criteria",
  "## 16. Seven art gates",
  "## 17. Visual benchmark definition"
].each do |heading|
  error("ART_BIBLE missing required contract heading: #{heading}") unless art.include?(heading)
end
error("ART_BIBLE does not lock native 320x240 review") unless art.include?("320×240")
error("ART_BIBLE omits the two documented H2 polish passes") unless art.include?("two documented polish passes for hero assets")

profile_section = between(
  inventory,
  "### 1.2 Canonical production IDs, review profiles, and polish tiers",
  "## 2. Inventory totals"
)
expected_profiles = %w[
  RIGGED_MODEL
  STATIC_MODEL_ENV
  UI_FONT_IMAGE
  VFX
  AUDIO
  ANIMATION
  DATA_SPATIAL
  STORYBOARD
  GENERATED_CHILD
]
expected_profiles.each do |profile|
  error("inventory profile matrix omits #{profile}") unless profile_section.include?("`#{profile}`")
end
expected_tiers = %w[H2 M7 S7 C7 D7 A0 E0]
exact_set(
  "inventory review tiers",
  profile_section.scan(/`(H2|M7|S7|C7|D7|A0|E0)`/).flatten.uniq,
  expected_tiers
)

inventory_production_ids = canonical_inventory_production_ids(inventory)
inventory_counts = inventory_production_ids.each_with_object(Hash.new(0)) { |production_id, counts| counts[production_id] += 1 }
inventory_duplicates = inventory_counts.select { |_production_id, count| count != 1 }.keys.sort
error("inventory canonical production IDs are not exactly-once: #{inventory_duplicates.join(', ')}") unless inventory_duplicates.empty?
error("inventory canonical production-ID count changed; got #{inventory_production_ids.length}") unless
  inventory_production_ids.length == INVENTORY_PRODUCTION_ID_COUNT
inventory_id_set_digest = Digest::SHA256.hexdigest(inventory_production_ids.sort.join("\n") + "\n")
error("inventory canonical production-ID set differs from the frozen Gate-2 registry") unless
  inventory_id_set_digest == INVENTORY_PRODUCTION_ID_SET_SHA256
inventory_production_ids.each do |production_id|
  error("inventory production ID has no deterministic profile/tier: #{production_id}") unless expected_profile_tier(production_id)
end

equivalent_section = between(
  reviews,
  "### Review-profile applicability and strict equivalents",
  "### Severity and disposition"
)
equivalent_codes = equivalent_section.scan(/^\| `([A-Z_]+_EQ)` \|/).flatten
exact_set(
  "review substitute codes",
  equivalent_codes,
  %w[STATIC_STATE_EQ NON_ROM_DELIVERY_EQ INHERITED_CHILD_EQ]
)
if reviews.match?(/\bN\/A\b/) && !reviews.include?("Bare `N/A`")
  error("review contract appears to permit a bare N/A")
end

ui_section = between(
  inventory,
  "## 9. UI, fonts, icons, portraits, and presentation",
  "## 10. Battle move VFX and paired audio events"
)
ui_ids = ui_section.scan(/^\| `((?:ui|font)\.[^`]+)` \|/).flatten
error("UI inventory must contain exactly 37 unique production IDs; got #{ui_ids.length}") unless ui_ids.length == 37
error("UI inventory IDs are not unique") unless ui_ids.uniq.length == ui_ids.length
error("UI inventory must contain exactly 35 ui.* IDs") unless ui_ids.count { |id| id.start_with?("ui.") } == 35
error("UI inventory must contain exactly two font.* IDs") unless ui_ids.count { |id| id.start_with?("font.") } == 2

controller_line = ui_section.lines.find { |line| line.start_with?("| `ui.icons.controller` |") }
if controller_line
  controller_cells = table_cells(controller_line)
  icon_clause = controller_cells[1].to_s.split(";", 2).first
  expected_controller_icons = ["Stick", "D-pad", "A", "B", "L", "R", "Z", "C-Up", "C-Down", "C-Left", "C-Right", "Start"]
  actual_controller_icons = icon_clause.scan(/Stick|D-pad|C-Up|C-Down|C-Left|C-Right|Start|\b[ABLRZ]\b/)
  error("controller atlas icon order/set must be exact 12") unless actual_controller_icons == expected_controller_icons
  error("controller atlas budget cell does not say exactly 12 icons") unless controller_cells[2].to_s.include?("exactly 12 icons")
  error("controller atlas omits L+C-Up/C-Down pitch and bare C-Down Relay semantics") unless
    controller_cells[1].to_s.include?("L + C-Up/C-Down") && controller_cells[1].to_s.include?("bare C-Down remains Relay")
else
  error("UI inventory lacks ui.icons.controller")
end

ui_evidence_section = between(
  inventory,
  "### 16.1 Exact 37-package UI evidence map",
  "## 17. Converted ROM BOM and bundle rollup"
)
ui_evidence_rows = ui_evidence_section.scan(
  /^\| `((?:ui|font)\.[^`]+)` \| `(ev\.ui\.[^`]+)` \|/
)
error("UI evidence map must contain exactly 37 rows; got #{ui_evidence_rows.length}") unless ui_evidence_rows.length == 37
exact_set("UI evidence subjects", ui_evidence_rows.map(&:first), ui_ids)
ui_evidence_rows.each do |production_id, evidence_id|
  evidence_subject = production_id.sub(/\Aui\./, "")
  expected_id = "ev.ui.#{evidence_subject}.native"
  error("#{production_id}: expected UI evidence ID #{expected_id}, got #{evidence_id}") unless evidence_id == expected_id
end
controller_evidence_line = ui_evidence_section.lines.find { |line| line.start_with?("| `ui.icons.controller` |") }
unless controller_evidence_line&.include?("all exact 12 prompt icons") &&
       controller_evidence_line&.include?("L + C-Up/C-Down") &&
       controller_evidence_line&.include?("bare C-Down Relay")
  error("controller UI evidence does not lock all 12 icons and both chord/bare-button semantics")
end
error("ART_BIBLE does not lock the exact 12-icon controller atlas") unless
  art.include?("exactly 12 distinct authored icons") && art.include?("L + C-Up") && art.include?("bare `C-Down`")
