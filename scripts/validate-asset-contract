ERRORS = []

def error(message)
  ERRORS << message
end

def validate_shared_lifecycle_branch(branch, payload, label)
  N64Game::AssetLifecycleContract.validate!(branch, payload)
  true
rescue N64Game::AssetLifecycleContract::Violation => violation
  violation.issues.each { |issue| error("#{label}: #{issue}") }
  false
end

def read(relative)
  path = ROOT.join(relative)
  unless path.file?
    error("missing required file: #{relative}")
    return ""
  end
  path.read
end

def between(text, start_marker, end_marker)
  start_index = text.index(start_marker)
  unless start_index
    error("missing section marker: #{start_marker}")
    return ""
  end

  body_start = start_index + start_marker.length
  end_index = text.index(end_marker, body_start)
  unless end_index
    error("missing section end marker after #{start_marker}: #{end_marker}")
    return ""
  end
  text[body_start...end_index]
end

def benchmark_control_header(text, label, report: true)
  issues = []
  lines = text.lines(chomp: true)
  expected_fixed = {
    0 => "# N64GAME Visual Benchmark Approval",
    1 => "",
    3 => "",
    5 => "",
    7 => "",
    9 => ""
  }
  expected_fixed.each do |index, expected|
    issues << "line #{index + 1} must be #{expected.inspect}" unless lines[index] == expected
  end

  field_patterns = {
    status: [2, /\AStatus: ([^\r\n]+)\z/],
    schema_version: [4, /\ASchema-Version: (\d+)\z/],
    production_lock: [6, /\AProduction-Lock: ([A-Z_]+)\z/],
    decision: [8, /\ADecision: ([A-Z_]+)\z/]
  }
  values = {}
  field_patterns.each do |field, (index, pattern)|
    match = lines[index].to_s.match(pattern)
    issues << "line #{index + 1} has malformed or missing #{field}" unless match
    values[field] = match && match[1]
  end

  occurrences = field_patterns.keys.to_h { |field| [field, []] }
  fence = nil
  lines.each_with_index do |line, index|
    if fence
      fence = nil if line.match?(/\A#{Regexp.escape(fence[:character])}{#{fence[:length]},}\s*\z/)
      next
    end
    if (fence_match = line.match(/\A(`{3,}|~{3,})/))
      fence = { character: fence_match[1][0], length: fence_match[1].length }
      next
    end
    field_patterns.each do |field, (_expected_index, pattern)|
      occurrences[field] << index if line.match?(pattern)
    end
  end
  issues << "contains an unterminated Markdown fence" if fence
  field_patterns.each do |field, (expected_index, _pattern)|
    issues << "#{field} must occur exactly once outside fences at line #{expected_index + 1}" unless
      occurrences[field] == [expected_index]
  end

  issues.each { |issue| error("#{label}: #{issue}") } if report
  issues.empty? ? values : nil
end

def exact_set(label, actual, expected)
  actual_counts = actual.each_with_object(Hash.new(0)) { |value, counts| counts[value] += 1 }
  duplicates = actual_counts.select { |_value, count| count != 1 }
  error("#{label} has duplicate rows: #{duplicates.keys.sort.join(', ')}") unless duplicates.empty?

  actual_set = actual_counts.keys.sort
  expected_set = expected.sort
  return if actual_set == expected_set

  missing = expected_set - actual_set
  extra = actual_set - expected_set
  error("#{label} set mismatch; missing=#{missing.join(', ')} extra=#{extra.join(', ')}")
end

