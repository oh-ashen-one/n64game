ledger_rows = ledger_entries.map { |entry| [entry[:id], entry[:status]] }
explicit_move_rows = ledger_rows.map(&:first).grep(/\A(?:vfx|sfx)\.move\./)
explicit_vfx_suffixes = explicit_move_rows.grep(/\Avfx\.move\./).map { |id| id.sub(/\Avfx\.move\./, "") }
explicit_sfx_suffixes = explicit_move_rows.grep(/\Asfx\.move\./).map { |id| id.sub(/\Asfx\.move\./, "") }
exact_set("explicit move-child ledger pairing", explicit_vfx_suffixes, explicit_sfx_suffixes)
unknown_move_rows = (explicit_vfx_suffixes | explicit_sfx_suffixes) - move_pairs.map(&:first)
error("ledger contains move children absent from the canonical pair registry: #{unknown_move_rows.sort.join(', ')}") unless unknown_move_rows.empty?

alias_section = between(
  inventory,
  "Presentation rows are delivery/assembly aliases",
  "The 15 `ASSET_CAMERA_SHOT_*` values"
)
alias_rows = alias_section.scan(/^\| (present\.[^| ]+) \| ([^|]+) \|/).map do |alias_id, targets|
  [alias_id.strip.delete("`"), targets.strip]
end
expected_aliases = %w[
  present.studio_mark
  present.game_mark
  present.loading_backdrop
  present.loading_indicator
  present.cutscene_slate
  present.world_route
  present.sim_dissolve
