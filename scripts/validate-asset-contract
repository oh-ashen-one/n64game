  actual_targets = target.scan(/`([^`]+)`/).flatten
  error("#{alias_id}: alias_of owner mapping/order mismatch") unless actual_targets == expected_alias_mappings.fetch(alias_id, [])
end
error("ledger assigns an owning row to a present.* alias") if ledger.match?(/^\| `present\.[^`]+` \|/)
error("ledger lacks the canonical cutscene-slate owner") unless ledger.match?(/^\| `ui\.screen\.cutscene_slate` \|/)
