  "visual benchmark complete/partial selector-policy partition",
  COMPLETE_SUBSET_IDS.to_a + PARTIAL_SUBSET_SELECTOR_POLICY.keys,
  whitelist_ids
)
error("visual benchmark whitelist order changed") unless whitelist_ids == expected_subset_hashes.keys
error("supporting battle actor model/animation pairs must remain exact WB-047..WB-052 suffix rows") unless
  whitelist_ids.last(BENCHMARK_SUPPORTING_PAIRS.length) == BENCHMARK_SUPPORTING_PAIRS
hero_echo_rows = PARTIAL_SUBSET_SELECTOR_POLICY.select do |production_id, selectors|
  production_id.start_with?("echo.") && selectors.include?("ASSET:hero_model")
end.keys
error("Quarrune must remain the only preapproval hero Echoform model") unless hero_echo_rows == ["echo.quarrune"]
BENCHMARK_SUPPORTING_ACTORS.each do |actor|
  model_id = "echo.#{actor}"
  animation_id = "anm.echo.#{actor}"
  error("#{model_id}: supporting subset must remain distance-model/texture/rig/blob-shadow only") unless
    PARTIAL_SUBSET_SELECTOR_POLICY[model_id] == %w[ASSET:blob_shadow ASSET:distance_model ASSET:rig ASSET:texture]
  error("#{animation_id}: supporting subset must remain exact idle_a/reposition/hit only") unless
    PARTIAL_SUBSET_SELECTOR_POLICY[animation_id] == %w[CLIP:hit CLIP:idle_a CLIP:reposition]
  error("#{model_id}: supporting model subset must retain RIGGED_MODEL/H2 review depth") unless
    expected_profile_tier(model_id) == %w[RIGGED_MODEL H2]
  error("#{animation_id}: supporting animation subset must retain ANIMATION/M7 review depth") unless
    expected_profile_tier(animation_id) == %w[ANIMATION M7]
end
whitelist_rows.each do |cells|
  production_id = strip_code(cells[0])
  actual_subset_digest = Digest::SHA256.hexdigest(cells[1].to_s.strip)
  error("#{production_id}: exact preapproval subset widened/changed") unless actual_subset_digest == expected_subset_hashes[production_id]
end
