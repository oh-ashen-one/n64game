  "present.studio_mark" => ["ui.screen.studio_mark"],
  "present.game_mark" => ["ui.screen.title_mark"],
  "present.loading_backdrop" => ["ui.screen.loading"],
  "present.loading_indicator" => ["vfx.transition.loading_relay", "anm.ui.loading_relay"],
