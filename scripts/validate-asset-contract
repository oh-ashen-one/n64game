whitelist_section = between(
  benchmark,
  "## 2. Exact pre-approval production whitelist",
  "## 3. Exact benchmark evidence set"
)
whitelist_rows = whitelist_section.lines.grep(/^\| `[^`]+` \|/).map { |line| table_cells(line) }
whitelist_ids = whitelist_rows.map { |cells| strip_code(cells[0]) }
complete_package_ids = COMPLETE_SUBSET_IDS
exact_set("visual benchmark whitelist", whitelist_ids, expected_whitelist)
error("visual benchmark whitelist constant/count drifted") unless
  expected_whitelist.length == BENCHMARK_WHITELIST_COUNT && whitelist_ids.length == BENCHMARK_WHITELIST_COUNT
error("complete and partial subset-policy IDs overlap") unless (COMPLETE_SUBSET_IDS & PARTIAL_SUBSET_SELECTOR_POLICY.keys.to_set).empty?
