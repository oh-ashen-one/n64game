exact_set("visual benchmark evidence IDs", benchmark_evidence_ids, expected_benchmark_evidence)
benchmark_evidence_control_rows = benchmark_evidence_section.lines.grep(/^\| `ev\.benchmark\./).map do |line|
  table_cells(line).map { |cell| strip_code(cell) }
end
if decision != "APPROVED"
  approval_evidence_row = benchmark_evidence_control_rows.last
  error("nonapproved benchmark approval evidence row must retain exact PENDING external-attestation scaffold") unless
    approval_evidence_row && approval_evidence_row[0] == "ev.benchmark.approval" &&
    approval_evidence_row[1] == APPROVAL_EVIDENCE_DESCRIPTION &&
    approval_evidence_row[2] == "PENDING external tag ref/signature; never a payload member" &&
    approval_evidence_row[3] == "PENDING"

  benchmark_evidence_control_rows.first(14).each do |cells|
    pending_pair = cells[2] == "PENDING" && cells[3] == "PENDING"
    populated_pass = cells[2].to_s.match?(/\A[A-Za-z0-9][A-Za-z0-9._\/-]*@[0-9a-f]{64}\z/) && cells[3] == "PASS"
    error("#{cells[0]}: nonapproved evidence must be exact PENDING/PENDING or populated-binding/PASS") unless
      pending_pair || populated_pass
  end

  nonapproved_objective = between(benchmark, "## 4. Objective acceptance", "## 5. Visual-authorship rubric")
  objective_claims = nonapproved_objective.lines.grep(/^\| [^|-]/).map do |line|
    table_cells(line).map { |cell| strip_code(cell) }
  end.reject { |cells| cells[0] == "Criterion" }
  error("nonapproved objective rows must keep Actual/evidence and Decision jointly PENDING") unless
    objective_claims.length == 13 && objective_claims.all? { |cells| cells[2] == "PENDING" && cells[3] == "PENDING" }

  nonapproved_rubric = between(benchmark, "## 5. Visual-authorship rubric", "## 6. Independent reviewer record")
  rubric_claims = nonapproved_rubric.lines.grep(/^\| [^|-]/).map do |line|
    table_cells(line).map { |cell| strip_code(cell) }
  end.reject { |cells| cells[0] == "Category" }
  error("nonapproved authorship rows must keep evidence and Decision jointly PENDING") unless
    rubric_claims.length == 9 && rubric_claims.all? { |cells| cells[2] == "PENDING" && cells[3] == "PENDING" }

  nonapproved_reviewers = between(benchmark, "## 6. Independent reviewer record", "## 7. Final decision")
  reviewer_claims = nonapproved_reviewers.lines.grep(/^\| (?:Art|Technical|Gameplay) \/ /).map do |line|
    table_cells(line).map { |cell| strip_code(cell) }
  end
  error("nonapproved independent-reviewer rows must keep every result field PENDING") unless
    reviewer_claims.length == 3 && reviewer_claims.all? { |cells| cells[1..].all? { |cell| cell == "PENDING" } }
end
if decision != "APPROVED" && benchmark_evidence_control_rows.first(14).any? { |cells| cells[2] != "PENDING" || cells[3] != "PENDING" }
  error("nonapproved benchmark evidence claims require the full populated payload/evidence registry") unless
    preapproval_payload_binding && preapproval_evidence_registry_binding && preapproval_evidence_registry_rows.length == 14
end
if decision != "APPROVED" && preapproval_evidence_registry_rows.length == 14
  validate_benchmark_evidence(
    preapproval_evidence_registry_rows, benchmark_evidence_control_rows.first(14),
    commit: preapproval_commit, fresh_clone: preapproval_fresh_clone,
    payload_context: preapproval_payload_context,
    build_id: pre_identity["Clean-build ID"], require_pass: true,
    owned_paths: preapproval_benchmark_owned_paths,
    gate_role_paths: exact_gate_evidence_role_paths(registry_rows, pre_identity),
    owner_ids: preapproval_asset_owner_ids
  )
end
if decision != "APPROVED" && preapproval_payload_binding && preapproval_commit && preapproval_fresh_clone
  expected_rollup_owner = if preapproval_evidence_registry_binding
                            "review/benchmark/evidence/gates/EVIDENCE_MANIFEST.sha256"
                          else
                            pre_identity["Payload manifest path"]
                          end
  preapproval_rollup_bindings.each do |binding, path_field, scope, _profile, _tier|
    next unless binding
    error("preapproval #{scope} rollup has the wrong sole manifest owner for its aggregate state") unless
      preapproval_payload_context[:member_owner][pre_identity[path_field]] == expected_rollup_owner
  end
end
if decision != "APPROVED" && preapproval_commit && preapproval_fresh_clone
  validate_gate1_attempt_history_universe(
    preapproval_commit, preapproval_fresh_clone, owned_paths_by_id
  )
  validate_authoring_receipt_universe(
    commit: preapproval_commit, fresh_clone: preapproval_fresh_clone,
    payload_context: preapproval_payload_context, tree_entries: preapproval_tree_entries,
    label: "preapproval authoring receipts"
  )
  scan_payload_production_tree(
    preapproval_tree_entries, preapproval_ledger_by_id, owned_paths_by_id,
    preapproval_benchmark_owned_paths
  )
end
scan_production_roots(
  ledger_by_id, owned_paths_by_id, active_state_by_id, decision,
  benchmark_owned_paths: preapproval_benchmark_owned_paths
) unless decision == "APPROVED" || preapproval_aggregate_populated

