  reviews.include?("exactly 12 distinct icons") && reviews.include?("L + C-Up") && reviews.include?("bare `C-Down`")

move_section = between(
  inventory,
  "## 10. Battle move VFX and paired audio events",
  "## 11. Common, environment, transition, and story VFX"
)
move_pairs = move_section.scan(
  /^\| `vfx\.move\.([^`]+)` \| `sfx\.move\.([^`]+)` \|/
)
error("move presentation registry must contain exactly 32 rows; got #{move_pairs.length}") unless move_pairs.length == 32
move_pairs.each do |vfx_suffix, audio_suffix|
  error("move pair suffix mismatch: #{vfx_suffix} / #{audio_suffix}") unless vfx_suffix == audio_suffix
end
exact_set("move presentation pair keys", move_pairs.map(&:first), move_pairs.map(&:first).uniq)

