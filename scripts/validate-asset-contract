{
  "generated-child transition registry" => GENERATED_CHILD_TRANSITION_HEADER,
  "move-pair sync proof" => PAIR_SYNC_HEADER,
  "move-pair sync measurement" => PAIR_SYNC_MEASUREMENT_HEADER
}.each do |label, header|
  error("ASSET_LEDGER omits exact #{label} header") unless ledger.include?(header.join("\\t"))
end
error("ASSET_LEDGER omits exact generated-child provenance key schema") unless
  ledger.include?(GENERATED_CHILD_PROVENANCE_KEYS.map { |key| "`#{key}`" }.join(", "))
error("aggregate identity pair constant must retain exact eight canonical pairs") unless
  AGGREGATE_PAIR_FIELDS.length == 8 && AGGREGATE_PAIR_FIELDS.flatten.uniq.length == 16
AGGREGATE_PAIR_FIELDS.flatten.each do |field|
  error("VISUAL_BENCHMARK_APPROVAL omits aggregate identity field #{field}") unless benchmark.include?("| #{field} |")
end

cross_document_guards = {
  "ART_BIBLE" => [
    "Schema-Version 4 makes repair history mechanical",
    "unique ancestry-maximal pinned-key-valid public approval-tag target",
    "Pre-approval progression is a derived validator state",
    "one shared manifest ownership context",
    "exact role `concept.review`",
    "`HEAD^{tree}` must equal `A^{tree}`",
    "only `APPROVED` compares it to local/fresh/public ROM identities",
    "every `.z64`, `.n64`, or `.v64` tree entry is forbidden",
    "Pinned ImageMagick `7.1.2-13`",
    "Pinned `ffprobe 8.1.2`"
  ],
  "ASSET_INVENTORY" => [
    "Schema-Version 4 prevents a repair state from inventing history",
    "unique ancestry-maximal pinned-key-valid public approval ancestor",
    "exact eight current aggregate pairs",
    "one shared commit-bound manifest context",
    "local/fresh/public ROM equality is approval-only"
  ],
  "ASSET_LEDGER" => [
    "Schema-Version 4 `REVIEW_REQUIRED`/`BLOCKED`",
    "unique ancestry-maximal pinned-key-valid public approval target",
    "exact eight current aggregate pairs",
