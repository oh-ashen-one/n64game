document_bodies = {
  "ART_BIBLE" => art, "ASSET_INVENTORY" => inventory, "ASSET_LEDGER" => ledger,
  "ASSET_REVIEW_TEMPLATES" => reviews, "TOOLCHAIN" => toolchain,
  "VISUAL_BENCHMARK_APPROVAL" => benchmark
}
cross_document_guards.each do |label, tokens|
  tokens.each do |token|
    error("#{label} omits cross-document contract token: #{token}") unless document_bodies.fetch(label).include?(token)
  end
end
unless benchmark.include?("PAYLOAD_MANIFEST.sha256") &&
       benchmark.include?("tag and control are excluded") &&
       benchmark.include?("signed annotated origin tag") &&
       benchmark.include?("cannot infer remote-host protection") &&
       benchmark.include?("BENCHMARK_EVIDENCE_REGISTRY.tsv") &&
       benchmark.include?("ignored/untracked local ROM") &&
       benchmark.include?("schema=n64game-benchmark-attestation-v1") &&
       benchmark.include?("no direct or transitive self-hash")
  error("benchmark omits non-circular payload/control/tag contract")
end

identity_section = between(benchmark, "## 1. Approval identity", "## 2. Exact pre-approval production whitelist")
identity_pairs = identity_section.lines.each_with_object([]) do |line, pairs|
  next unless line.start_with?("|")
  cells = table_cells(line)
  next unless cells.length == 3 && !%w[Field ---].include?(cells[0])
  pairs << [cells[0], strip_code(cells[2])]
end
error("benchmark approval identity field set/order/uniqueness mismatch") unless
  identity_pairs.map(&:first) == REQUIRED_IDENTITY_FIELDS
identity = identity_pairs.to_h
exact_set("benchmark approval identity fields", identity.keys, REQUIRED_IDENTITY_FIELDS)

production_lock = benchmark_header && benchmark_header[:production_lock]
decision = benchmark_header && benchmark_header[:decision]
control_status = benchmark_header && benchmark_header[:status]
unless %w[PENDING REVIEW_REQUIRED BLOCKED APPROVED].include?(decision)
  error("invalid visual benchmark Decision: #{decision.inspect}")
end
expected_lock = decision == "APPROVED" ? "UNLOCKED" : "LOCKED"
error("visual benchmark lock/decision mismatch: #{production_lock.inspect}/#{decision.inspect}") unless production_lock == expected_lock
expected_control_status = decision == "APPROVED" ? "Gate 4 approved control record" : "Gate 4 control record"
error("visual benchmark status/decision mismatch: #{control_status.inspect}/#{decision.inspect}") unless
  control_status == expected_control_status
prior_baseline_values = PRIOR_BASELINE_FIELDS.to_h { |field| [field, identity[field]] }
prior_baseline_ref = prior_baseline_values["Prior approved attestation ref"]
if %w[PENDING APPROVED].include?(decision)
  error("#{decision}: all prior approved baseline fields must be NONE") unless
    prior_baseline_values.values.all? { |value| value == "NONE" }
elsif %w[REVIEW_REQUIRED BLOCKED].include?(decision)
  baseline_shapes_valid = prior_baseline_ref&.match?(%r{\Arefs/tags/n64game-visual-benchmark/[0-9a-f]{12}\z}) &&
                          prior_baseline_values.values.none? { |value| %w[NONE PENDING].include?(value) } &&
                          prior_baseline_values.values_at(
                            "Prior approved attestation tag object ID", "Prior approved control Git commit",
                            "Prior approved payload Git commit"
                          ).all? { |value| value&.match?(HEX40) } &&
                          prior_baseline_values.values_at(
                            "Prior approved payload-manifest SHA-256", "Prior approved whitelist/gate-registry SHA-256"
                          ).all? { |value| value&.match?(HEX64) }
  error("#{decision}: all six prior approved baseline fields must be exact and jointly populated") unless baseline_shapes_valid
end
if decision != "APPROVED"
  stale_fields = [
    "Local ROM path", "ROM byte count", "ROM SHA-256", "ROM header SHA-256",
    "Public build workflow run ID", "Public ROM release tag", "Public ROM release asset URL",
    "Approval attestation ref", "Attestation signer fingerprint", "Remote tag-protection release check",
    "Decision timestamp/timezone"
  ]
  stale_fields.each do |field|
    error("#{decision}: current approval-only identity field #{field} must be PENDING; archive prior approval separately") unless identity[field] == "PENDING"
  end
  error("#{decision}: final production decision field mismatch") unless final_values_early["Production decision"] == decision
  %w[
    Approving\ payload\ commit\ /\ clean-build\ ID\ /\ ROM\ SHA-256\ tuple
    Payload-manifest\ SHA-256
    Whitelist/gate-registry\ SHA-256
    Benchmark-evidence-registry\ SHA-256
    Public\ release\ tag\ /\ asset\ URL
    Approval\ attestation\ ref\ /\ signer\ fingerprint
    Decision\ owner\ /\ RFC\ 3339\ timestamp
  ].each do |field|
    error("#{decision}: stale final approval field #{field} must be PENDING") unless final_values_early[field] == "PENDING"
  end
end
if decision != "APPROVED"
  advanced_rows = ledger_rows.select do |_production_id, status|
    %w[source converted review approved].include?(status)
  end
  illegal_rows = advanced_rows.reject { |production_id, _status| expected_whitelist.include?(production_id) }
  unless illegal_rows.empty?
    error("pre-approval ledger advances non-whitelisted production IDs: #{illegal_rows.map(&:first).sort.join(', ')}")
  end
end
approved_registry_rows = []
approved_payload_ledger_entries = []
approved_payload_inventory_text = ""
approved_owned_paths = Hash.new { |hash, key| hash[key] = Set.new }
approved_benchmark_owned_paths = Set.new
approved_payload_context = new_manifest_context
approved_control_target = nil
if decision == "APPROVED"
  error("APPROVED is fail-closed until the production-validator lifecycle harness is implemented, committed, and pinned") unless
    approval_lifecycle_pins_ready?
  error("APPROVED is fail-closed until Gate 3 pins the audited Ares 148 platform-binary SHA-256") unless
    PINNED_ARES_148_BINARY_SHA256.match?(HEX64)
  approval_body = between(benchmark, "## 1. Approval identity", "## 2. Exact pre-approval production whitelist") +
                  between(benchmark, "## 4. Objective acceptance", "## 7. Final decision")
  error("approved visual benchmark still contains PENDING fields") if approval_body.include?("`PENDING`")

  payload_commit = identity["Reviewed payload Git commit"]
  build_id = identity["Clean-build ID"]
  rom_path = identity["Local ROM path"]
  rom_size = canonical_integer(identity["ROM byte count"])
  rom_digest = identity["ROM SHA-256"]
  rom_header_digest = identity["ROM header SHA-256"]
  payload_path = identity["Payload manifest path"]
  payload_digest = identity["Payload manifest SHA-256"]
  error("approved payload commit must be exactly 40 lowercase hex") unless payload_commit&.match?(HEX40)
  _commit_out, _commit_err, commit_status = git_capture("cat-file", "-e", "#{payload_commit}^{commit}") if payload_commit&.match?(HEX40)
  error("approved payload commit does not resolve") unless payload_commit&.match?(HEX40) && commit_status&.success?
  error("approved build ID is malformed") unless canonical_build_id?(build_id)
  error("approved ROM digest/header digest malformed") unless rom_digest&.match?(HEX64) && rom_header_digest&.match?(HEX64)
  error("approved ROM byte count must be positive and below 16 MiB") unless rom_size&.positive? && rom_size < 16 * 1024 * 1024
  error("approved Ares target mismatch") unless identity["Ares target"] == "Ares 148 / Homebrew Mode"
  tag_ref = identity["Approval attestation ref"]
  signer = identity["Attestation signer fingerprint"]
  expected_tag_ref = payload_commit&.match?(HEX40) ? "refs/tags/n64game-visual-benchmark/#{payload_commit[0, 12]}" : nil
  error("approved attestation ref must derive from payload prefix") unless tag_ref == expected_tag_ref
  error("approved signer fingerprint must equal Gate-2-pinned ED25519 key") unless signer == PINNED_SSH_FINGERPRINT
  slug = same_repo_slug
  error("origin must be one canonical github.com owner/repository URL") unless slug

  local_tag_oid = nil
  local_tag_target = nil
  fresh_clone = nil
  if expected_tag_ref && slug
    tag_type, _tag_type_err, tag_type_status = git_capture("cat-file", "-t", tag_ref)
    error("approval attestation must be an annotated tag") unless tag_type_status.success? && tag_type.strip == "tag"
    tag_oid_out, _tag_oid_err, tag_oid_status = git_capture("rev-parse", tag_ref)
    target_out, _target_err, target_status = git_capture("rev-parse", "#{tag_ref}^{commit}")
    local_tag_oid = tag_oid_out.strip if tag_oid_status.success?
    local_tag_target = target_out.strip if target_status.success?
    approved_control_target = local_tag_target
    error("local approval tag object/target cannot be resolved") unless local_tag_oid&.match?(HEX40) && local_tag_target&.match?(HEX40)
    _ancestor_out, _ancestor_err, ancestor_status = git_capture("merge-base", "--is-ancestor", payload_commit, local_tag_target.to_s)
    error("reviewed payload commit is not an ancestor of approval tag target") unless ancestor_status.success?
    remote_out, _remote_err, remote_status = public_git_capture(
      slug, "ls-remote", "--tags", "https://github.com/#{slug}.git", tag_ref, "#{tag_ref}^{}"
    )
    remote_refs = remote_out.lines.to_h { |line| oid, ref = line.strip.split("\t", 2); [ref, oid] }
    error("public origin approval tag object ID differs from local") unless remote_status.success? && remote_refs[tag_ref] == local_tag_oid
    error("public origin approval tag peeled target differs from local") unless remote_status.success? && remote_refs["#{tag_ref}^{}"] == local_tag_target
    fresh_clone = prepare_fresh_public_clone(slug, payload_commit, tag_ref)
    if fresh_clone
      fresh_tag_oid, _a, fresh_tag_status = git_capture("rev-parse", tag_ref, root: fresh_clone)
      fresh_target, _b, fresh_target_status = git_capture("rev-parse", "#{tag_ref}^{commit}", root: fresh_clone)
      error("fresh public clone tag object differs") unless fresh_tag_status.success? && fresh_tag_oid.strip == local_tag_oid
      error("fresh public clone tag target differs") unless fresh_target_status.success? && fresh_target.strip == local_tag_target
      _fresh_ancestor_out, _fresh_ancestor_err, fresh_ancestor_status = git_capture("merge-base", "--is-ancestor", payload_commit, local_tag_target.to_s, root: fresh_clone)
      error("payload ancestry is not reproducible in fresh public clone") unless fresh_ancestor_status.success?
    end

    tag_object, _tag_object_err, tag_object_status = git_capture("cat-file", "tag", tag_ref)
    signature_marker = "-----BEGIN SSH SIGNATURE-----\n"
    marker_offset = tag_object.index(signature_marker)
    signed_prefix = marker_offset ? tag_object[0...marker_offset] : ""
    signature_block = marker_offset ? tag_object[marker_offset..] : ""
    exact_signature = signature_block.match?(/\A-----BEGIN SSH SIGNATURE-----\n(?:[^\r\n]*\n)*-----END SSH SIGNATURE-----\n\z/)
    error("approval attestation must contain exactly one complete LF-only SSH signature block") unless tag_object_status.success? && marker_offset && exact_signature
    verify_pinned_ssh_signature(signed_prefix, signature_block) if tag_object_status.success? && marker_offset && exact_signature
    attested_text = signed_prefix.split("\n\n", 2)[1].to_s
    expected_attested_text = [
      "schema=n64game-benchmark-attestation-v1", "payload_commit=#{payload_commit}",
      "payload_manifest_sha256=#{payload_digest}", "control_path=docs/VISUAL_BENCHMARK_APPROVAL.md",
      "decision=APPROVED"
    ].join("\n") + "\n"
    error("approval attestation message must be exactly five canonical lines plus one final LF") unless attested_text == expected_attested_text
    tagged_control, _tagged_control_err, tagged_control_status = git_capture("show", "#{local_tag_target}:docs/VISUAL_BENCHMARK_APPROVAL.md")
    error("approval tag target does not contain this exact populated control") unless tagged_control_status.success? && tagged_control == benchmark
    if fresh_clone
      fresh_tag_object, _fresh_tag_err, fresh_tag_object_status = git_capture("cat-file", "tag", tag_ref, root: fresh_clone)
      error("fresh public clone tag object bytes differ") unless fresh_tag_object_status.success? && fresh_tag_object == tag_object
    end
  end

  payload_context = new_manifest_context
  approved_payload_context = payload_context
  error("approved payload-manifest path/digest malformed") unless payload_path == "review/benchmark/PAYLOAD_MANIFEST.sha256" && payload_digest&.match?(HEX64)
  if payload_path == "review/benchmark/PAYLOAD_MANIFEST.sha256" && payload_digest&.match?(HEX64) && payload_commit&.match?(HEX40) && fresh_clone
    validate_manifest(payload_path, payload_digest, "benchmark payload", [], payload_commit, fresh_clone, payload_context)
  end
  error("payload manifest must exclude approval control") if payload_context[:closure].include?("docs/VISUAL_BENCHMARK_APPROVAL.md")
  error("payload manifest must exclude local ROM") if payload_context[:closure].include?(rom_path)
  payload_tree_entries = fresh_clone ? commit_tree_entries(payload_commit, fresh_clone) : []
  payload_tree_entries.each do |tree_entry|
    if ROM_EXTENSIONS.include?(File.extname(tree_entry[:path]).downcase)
      error("reviewed payload Git tree contains forbidden ROM entry: #{tree_entry[:path]}")
    end
  end
  payload_ledger_path = "docs/ASSET_LEDGER.md"
  error("payload manifest must own the reviewed ASSET_LEDGER bytes") unless payload_context[:closure].include?(payload_ledger_path)
  error("payload manifest must own the reviewed ASSET_INVENTORY bytes") unless payload_context[:closure].include?("docs/ASSET_INVENTORY.md")
  payload_ledger_material = if fresh_clone
                              materialized_commit_file(
                                payload_ledger_path, payload_commit, "reviewed payload ASSET_LEDGER",
                                fresh_clone: fresh_clone, allow_lfs: false
                              )
                            end
  payload_ledger_text = payload_ledger_material ? payload_ledger_material[:bytes].dup.force_encoding(Encoding::UTF_8) : ""
  error("reviewed payload ASSET_LEDGER must be valid UTF-8") unless payload_ledger_text.valid_encoding?
  payload_ledger_entries = parse_ledger_entries(payload_ledger_text, "reviewed payload ledger")
  approved_payload_ledger_entries = payload_ledger_entries
  payload_inventory_material = if fresh_clone
                                 materialized_commit_file(
                                   "docs/ASSET_INVENTORY.md", payload_commit, "reviewed payload ASSET_INVENTORY",
                                   fresh_clone: fresh_clone, allow_lfs: false
                                 )
                               end
  payload_inventory_text = payload_inventory_material ? payload_inventory_material[:bytes].dup.force_encoding(Encoding::UTF_8) : ""
  approved_payload_inventory_text = payload_inventory_text
  error("reviewed payload ASSET_INVENTORY must be valid UTF-8") unless payload_inventory_text.valid_encoding?
  validate_ledger_scaffold(payload_ledger_entries, payload_inventory_text, "reviewed payload ledger")
  payload_ledger_by_id = payload_ledger_entries.each_with_object({}) { |entry, index| index[entry[:id]] = entry }
  approved_owned_paths = Hash.new { |hash, key| hash[key] = Set.new }
  validate_concept_entries(
    payload_ledger_entries, approved_owned_paths, commit: payload_commit,
    fresh_clone: fresh_clone, payload_context: payload_context
  )

  registry_path = identity["Whitelist/gate registry path"]
  registry_digest = identity["Whitelist/gate registry SHA-256"]
  error("approved whitelist registry identity malformed") unless registry_path == "review/benchmark/WHITELIST_GATE_REGISTRY.tsv" && registry_digest&.match?(HEX64)
  approved_registry_rows = if fresh_clone && registry_digest&.match?(HEX64)
                             parse_tsv("#{registry_path}@#{registry_digest}", "approved whitelist registry", WHITELIST_REGISTRY_HEADER, BENCHMARK_WHITELIST_COUNT,
                                       commit: payload_commit, fresh_clone: fresh_clone, payload_context: payload_context)
                           else
                             []
                           end
  approved_benchmark_owned_paths = Set.new([
    payload_path, registry_path, identity["ROM build recipe path"]
  ])
  asset_owner_ids = Set.new
  approved_gate_paths = []
  approved_registry_rows.each_with_index do |fields, index|
    row = WHITELIST_REGISTRY_HEADER.zip(fields).to_h
    basis = format("WB-%03d", index + 1)
    production_id = whitelist_ids[index]
    control = authorization_rows[index]
    error("#{basis}: approved registry order/ID/subset mismatch") unless row["basis"] == basis && row["production_id"] == production_id && row["subset_sha256"] == expected_subset_hashes[production_id]
    projection = [
      basis, production_id, "#{row['authorization_path']}@#{row['authorization_sha256']}",
      "#{row['gate_record_path']}@#{row['gate_record_sha256']}", "#{row['provenance_path']}@#{row['provenance_sha256']}",
      "#{row['source_manifest_path']}@#{row['source_manifest_sha256']}",
      "#{row['output_manifest_path']}@#{row['output_manifest_sha256']}", row["state"]
    ]
    error("#{basis}: approved control projection mismatch") unless projection == control
    error("#{basis}: APPROVED requires AUTHORIZED/NONE repair/build match") unless row["state"] == "AUTHORIZED" && row["repair_ids"] == "NONE" && row["build_id"] == build_id
    validate_registry_owner_paths(row, basis, production_id, allow_none_output: false)
    gates = (1..7).map { |gate| row["g#{gate}"] }
    profile, tier = expected_profile_tier(production_id)
    error("#{basis}: APPROVED requires seven legal completion decisions") unless
      gates.each_with_index.all? { |gate_decision, gate_index| completion_decision_allowed?(gate_decision, profile, "G#{gate_index + 1}") }
    authorization_record = validate_authorization_record(
      "#{row['authorization_path']}@#{row['authorization_sha256']}", row, basis,
      commit: payload_commit, fresh_clone: fresh_clone, payload_context: payload_context,
      record_context: payload_context
    )
    provenance_record = validate_provenance_record(
      "#{row['provenance_path']}@#{row['provenance_sha256']}", row, basis,
      commit: payload_commit, fresh_clone: fresh_clone, payload_context: payload_context,
      record_context: payload_context
    )
    validate_manifest(row["source_manifest_path"], row["source_manifest_sha256"], "#{basis} source manifest", [], payload_commit, fresh_clone, payload_context)
    validate_manifest_member_roots(
      payload_context, row["source_manifest_path"],
      ["assets-src/#{production_id.split('.', 2).first}/#{production_id}/"], "#{basis} source manifest"
    )
    validate_manifest(row["output_manifest_path"], row["output_manifest_sha256"], "#{basis} output manifest", [], payload_commit, fresh_clone, payload_context)
    validate_manifest_member_roots(
      payload_context, row["output_manifest_path"],
      ["review/#{production_id}/g5/"], "#{basis} output manifest"
    )
    validate_subset_export_allowlist(
      authorization_record, provenance_record, row, row["source_manifest_path"], row["output_manifest_path"],
      complete_package: complete_package_ids.include?(production_id), commit: payload_commit,
      fresh_clone: fresh_clone, payload_context: payload_context,
      owned_paths: approved_owned_paths[production_id], label: basis
    )
    error("#{basis}: source/output manifests must be payload-owned") unless payload_context[:closure].include?(row["source_manifest_path"]) && payload_context[:closure].include?(row["output_manifest_path"])
    validate_gate_record(
      "#{row['gate_record_path']}@#{row['gate_record_sha256']}", "#{basis} gate record",
      scope: production_id, profile: profile, tier: tier, source_digest: row["source_manifest_sha256"],
      output_digest: row["output_manifest_sha256"], build_id: build_id, expected_vector: gates,
      commit: payload_commit, fresh_clone: fresh_clone, payload_context: payload_context,
      require_complete: true, owned_paths: approved_owned_paths[production_id],
      owner_ids: [provenance_record["creator_id"], provenance_record["rights_holder_id"]].compact
    )
    approved_gate_paths << row["gate_record_path"]
    approved_owned_paths[production_id].merge([
      row["authorization_path"], row["provenance_path"], row["gate_record_path"],
      row["source_manifest_path"], row["output_manifest_path"]
    ])
    approved_owned_paths[production_id].merge(manifest_owned_paths(payload_context, row["source_manifest_path"]))
    approved_owned_paths[production_id].merge(manifest_owned_paths(payload_context, row["output_manifest_path"]))
    entry = payload_ledger_by_id[production_id]
    unless entry && entry[:status] == "approved"
      error("#{basis}: active approved binding lacks one advanced explicit reviewed-payload ledger row")
      next
    end
    validate_ledger_gate_lifecycle(entry, gates, true, basis)
    error("#{basis}: ledger profile/tier mismatch") unless entry[:profile_tier] == "#{profile} / #{tier}"
    error("#{basis}: ledger authorization provenance mismatch") unless leading_locator(entry[:provenance], "record") == "#{row['provenance_path']}@#{row['provenance_sha256']}"
    error("#{basis}: ledger source/output/gate locators mismatch") unless
      leading_locator(entry[:source], "source") == "#{row['source_manifest_path']}@#{row['source_manifest_sha256']}" &&
      leading_locator(entry[:output], "output") == "#{row['output_manifest_path']}@#{row['output_manifest_sha256']}" &&
      leading_locator(entry[:evidence], "gate_record") == "#{row['gate_record_path']}@#{row['gate_record_sha256']}"
    error("#{basis}: ledger gate-vector projection mismatch") unless parse_ledger_gate_vector(entry[:gates], basis) == gates
    owner_ids = canonical_ledger_owners(entry[:creator])
    error("#{basis}: creator/rights-holder machine binding missing/placeholder") unless owner_ids
    if owner_ids
      asset_owner_ids.merge(owner_ids)
      error("#{basis}: approved provenance creator/rightsholder differs from payload ledger") unless
        provenance_record["creator_id"] == owner_ids[0] && provenance_record["rights_holder_id"] == owner_ids[1]
      error("#{basis}: approved authorizer must not be an asset owner") if
        owner_ids.include?(authorization_record["authorizer_id"])
    end
    validate_ledger_provenance_projection(entry, provenance_record, basis)
    rights_path = provenance_record["rights_evidence"].to_s.split("@", 2).first
    error("#{basis}: approved rights evidence is not source-manifest-owned") unless
      manifest_owned_paths(payload_context, row["source_manifest_path"]).include?(rights_path)
  end
  error("approved external registry must contain all #{BENCHMARK_WHITELIST_COUNT} valid rows") unless
    approved_registry_rows.length == BENCHMARK_WHITELIST_COUNT
  validate_move_pair_atomicity(
    payload_ledger_entries, move_pairs.map(&:first), commit: payload_commit, fresh_clone: fresh_clone,
    payload_context: payload_context, payload_path: payload_path,
    control_owned: approved_benchmark_owned_paths
  ) if fresh_clone

  rollup_specs = ROLLUP_SPECS
  rollup_paths = []
  approved_kernel_rollups = []
  rollup_specs.each do |path_field, digest_field, expected_path, scope, profile, tier|
    path = identity[path_field]
    digest = identity[digest_field]
    rollup_paths << path
    error("#{scope} gate-record path must equal canonical benchmark owner path") unless path == expected_path
    decisions = if path && digest
                  validate_gate_record(
                    "#{path}@#{digest}", "#{scope} gate record", scope: scope, profile: profile, tier: tier,
                    source_digest: registry_digest, output_digest: registry_digest, build_id: build_id,
                    expected_vector: nil, commit: payload_commit, fresh_clone: fresh_clone,
                    payload_context: payload_context, require_complete: true, owned_paths: approved_benchmark_owned_paths,
                    owner_ids: asset_owner_ids.to_a
                  )
                else
                  []
                end
    approved_kernel_rollups << {
      "scope" => scope, "build_id" => build_id, "gates" => Array(decisions),
      "gate_record_sha256" => digest
    }
  end

  approved_kernel_registry = approved_registry_rows.map do |fields|
    row = WHITELIST_REGISTRY_HEADER.zip(fields).to_h
    row.merge("gates" => (1..7).map { |gate| row["g#{gate}"] })
  end
  approved_defect_counts = identity["Open critical/high/medium defects"].to_s.split(" / ").map do |value|
    canonical_integer(value)
  end
  approved_artifact_name = payload_commit&.match?(HEX40) ? "n64game-#{payload_commit}.z64" : nil
  validate_shared_lifecycle_branch(
    "approved",
    {
      "decision" => decision, "lock" => production_lock, "status" => control_status,
      "defects" => {
        "critical" => approved_defect_counts[0], "high" => approved_defect_counts[1],
        "medium" => approved_defect_counts[2]
      },
      "build_id" => build_id, "registry_rows" => approved_kernel_registry,
      "rollups" => approved_kernel_rollups,
      "identity" => {
        "payload_commit" => payload_commit, "repository" => slug,
        "payload_manifest_sha256" => payload_digest, "registry_sha256" => registry_digest,
        "rom_sha256" => rom_digest, "rom_size_bytes" => rom_size,
        "approval_ref" => tag_ref, "release_tag" => identity["Public ROM release tag"],
        "artifact_name" => approved_artifact_name,
        "release_asset_url" => identity["Public ROM release asset URL"],
        "workflow_path" => identity["Public build workflow file"]
      }
    },
    "shared production approved lifecycle"
  )

  evidence_registry_path = identity["Benchmark evidence registry path"]
  evidence_registry_digest = identity["Benchmark evidence registry SHA-256"]
  error("approved benchmark-evidence registry identity malformed") unless
    evidence_registry_path == "review/benchmark/BENCHMARK_EVIDENCE_REGISTRY.tsv" && evidence_registry_digest&.match?(HEX64)
  evidence_registry_rows = if fresh_clone && evidence_registry_digest&.match?(HEX64)
                             parse_tsv("#{evidence_registry_path}@#{evidence_registry_digest}", "benchmark evidence registry", EVIDENCE_REGISTRY_HEADER, 14,
                                       commit: payload_commit, fresh_clone: fresh_clone, payload_context: payload_context)
                           else
                             []
                           end
  approved_benchmark_owned_paths << evidence_registry_path if evidence_registry_path
  evidence_rows = benchmark_evidence_section.lines.grep(/^\| `ev\.benchmark\./).map { |line| table_cells(line).map { |cell| strip_code(cell) } }
  error("approved benchmark requires all 15 evidence results PASS") unless evidence_rows.length == 15 && evidence_rows.all? { |cells| cells[3] == "PASS" }
  approval_evidence_row = evidence_rows.last
  expected_approval_evidence =
    "tag:#{tag_ref}; payload:#{payload_commit}@#{payload_digest}; signer:#{signer}; protection:#{identity['Remote tag-protection release check']}"
  error("approved ev.benchmark.approval row must exactly project the verified external attestation tuple") unless
    approval_evidence_row == [
      "ev.benchmark.approval", APPROVAL_EVIDENCE_DESCRIPTION, expected_approval_evidence, "PASS"
    ]
  valid_evidence_refs = validate_benchmark_evidence(
    evidence_registry_rows, evidence_rows.first(14), commit: payload_commit, fresh_clone: fresh_clone,
    payload_context: payload_context, build_id: build_id,
    owned_paths: approved_benchmark_owned_paths,
    gate_role_paths: exact_gate_evidence_role_paths(approved_registry_rows, identity),
    expected_rom_sha256: rom_digest, owner_ids: asset_owner_ids,
    local_rom_path: rom_path && ROOT.join(rom_path).to_s
  ) if evidence_registry_rows.length == 14 && fresh_clone
  valid_evidence_refs ||= Set.new
  validate_gate1_attempt_history_universe(payload_commit, fresh_clone, approved_owned_paths) if fresh_clone
  validate_authoring_receipt_universe(
    commit: payload_commit, fresh_clone: fresh_clone, payload_context: payload_context,
    tree_entries: payload_tree_entries, label: "approved authoring receipts"
  ) if fresh_clone
  scan_payload_production_tree(
    payload_tree_entries, payload_ledger_by_id, approved_owned_paths,
    approved_benchmark_owned_paths
  )
  gates_registry_row = evidence_registry_rows.find { |fields| fields[0] == "ev.benchmark.gates" }
  if gates_registry_row
    gate_manifest_path = gates_registry_row[1]
    gate_entries = payload_context[:manifests][gate_manifest_path] || []
    expected_gate_role_paths = {}
    approved_gate_paths.each_with_index { |path, index| expected_gate_role_paths[format("gate.wb%03d", index + 1)] = path }
    %w[player quarrune sector presentation].zip(rollup_paths).each { |name, path| expected_gate_role_paths["rollup.#{name}"] = path }
    expected_gate_role_paths.each do |role, path|
      error("ev.benchmark.gates: role #{role} does not bind exact gate record path") unless gate_entries.any? { |entry| entry[:role] == role && entry[:path] == path }
    end
  end

  objective_requirements = {
    "Output" => %w[ev.benchmark.native#color_format ev.benchmark.native#framebuffer_count ev.benchmark.native#height_px ev.benchmark.native#media_type ev.benchmark.native#width_px],
    "Frame rate" => %w[ev.benchmark.capture_60s#sustained_sub30_windows ev.benchmark.performance#fps_min ev.benchmark.performance#frame_time_p95_us],
    "Peak free heap" => %w[ev.benchmark.performance#free_heap_min_bytes],
    "Scene/action arena" => %w[
      ev.benchmark.performance#scene_collision_nav_state_bytes
      ev.benchmark.performance#scene_geometry_display_bytes
      ev.benchmark.performance#scene_skeleton_animation_bytes
      ev.benchmark.performance#scene_textures_bytes
      ev.benchmark.performance#scene_vfx_bytes
      ev.benchmark.performance#scene_working_set_bytes
    ],
    "Runtime texture working set" => %w[
      ev.benchmark.performance#scene_textures_bytes
      ev.benchmark.performance#texture_working_set_bytes
    ],
    "Unload/reload" => %w[ev.benchmark.unload_reload#heap_delta_bytes ev.benchmark.unload_reload#resource_delta_count],
    "Conversion" => %w[ev.benchmark.performance#unexplained_converter_warnings],
    "Evidence graph" => %w[ev.benchmark.gates#gate_decisions_complete],
    "Approval attestation" => %w[ev.benchmark.approval#signature],
    "Native readability" => %w[ev.benchmark.native#capture_count ev.benchmark.ui#native_gallery_count],
    "Completeness" => %w[ev.benchmark.environment.corner#purposeful_props ev.benchmark.ui#state_count],
    "Rights/provenance" => %w[ev.benchmark.gates#whitelist_vectors],
    "Open defects" => %w[ev.benchmark.gates#gate_decisions_complete]
  }
  objective_section = between(benchmark, "## 4. Objective acceptance", "## 5. Visual-authorship rubric")
  objective_rows = objective_section.lines.grep(/^\| [^|-]/).map { |line| table_cells(line).map { |cell| strip_code(cell) } }.reject { |cells| cells[0] == "Criterion" }
  error("objective criterion set/order mismatch") unless objective_rows.map(&:first) == objective_requirements.keys
  objective_rows.each do |cells|
    criterion = cells[0]
    error("#{criterion}: objective decision must be PASS") unless cells[3] == "PASS"
    references = parse_evidence_references(cells[2], "objective #{criterion}", valid_evidence_refs)
    error("#{criterion}: missing required exact metric references") unless (objective_requirements.fetch(criterion, []) - references).empty?
  end

  rubric_requirements = {
    "Silhouette and originality" => %w[ev.benchmark.turntable.player#sheet_count ev.benchmark.turntable.quarrune#sheet_count],
    "Environment density and recent activity" => %w[ev.benchmark.environment.corner#purposeful_props ev.benchmark.environment.corner#reverse_views],
    "Topology/material/texture craft" => %w[ev.benchmark.turntable.player#neutral_views ev.benchmark.turntable.quarrune#neutral_views],
    "Lighting/fog/display grade" => %w[ev.benchmark.environment.corner#grade_compare ev.benchmark.native#capture_count],
    "Animation/deformation/personality" => %w[ev.benchmark.animation.player#clip_count ev.benchmark.animation.quarrune#clip_count],
    "VFX/audio synchronization" => %w[ev.benchmark.vfx_audio#braid_sync_error_ms ev.benchmark.vfx_audio#hit_sync_error_ms],
    "UI/loading presentation" => %w[ev.benchmark.ui#controller_icon_count ev.benchmark.ui#state_count],
    "Camera staging/native readability" => %w[ev.benchmark.environment.corner#camera_overlay ev.benchmark.native#capture_count],
    "Cross-discipline cohesion" => %w[ev.benchmark.capture_60s#duration_ms ev.benchmark.native#capture_count ev.benchmark.ui#native_gallery_count]
  }
  rubric_decisions = rubric_section.lines.grep(/^\| [^|-]/).map { |line| table_cells(line).map { |cell| strip_code(cell) } }.reject { |cells| cells[0] == "Category" }
  error("authorship category set/order mismatch") unless rubric_decisions.map(&:first) == rubric_requirements.keys
  rubric_decisions.each do |cells|
    category = cells[0]
    error("#{category}: rubric decision must be PASS") unless cells[3] == "PASS"
    allowed_ids = rubric_requirements.fetch(category, []).map { |ref| ref.split("#", 2).first }.uniq
    references = parse_evidence_references(cells[2], "rubric #{category}", valid_evidence_refs, allowed_ids: allowed_ids)
    error("#{category}: missing required exact metric references") unless (rubric_requirements.fetch(category, []) - references).empty?
  end

  reviewer_rows = reviewer_section.lines.grep(/^\| (?:Art|Technical|Gameplay) \/ /).map { |line| table_cells(line).map { |cell| strip_code(cell) } }
  expected_reviewer_roles = [
    "Art / visual authorship", "Technical / conversion-performance", "Gameplay / native readability"
  ]
  error("approved reviewer role set/order mismatch") unless reviewer_rows.map(&:first) == expected_reviewer_roles
  reviewer_ids = reviewer_rows.map { |cells| cells[1] }
  error("approved reviewer identities must be three canonical nonplaceholder pairwise-distinct IDs") unless
    reviewer_ids.length == 3 && reviewer_ids.all? { |value| canonical_identity?(value) } && reviewer_ids.uniq.length == 3
  reviewer_rows.each do |cells|
    error("approved reviewer must confirm non-owner YES") unless cells[2] == "YES"
    error("approved reviewer identity conflicts with an asset creator") if asset_owner_ids.include?(cells[1])
    error("approved reviewer timestamp must be RFC 3339") unless valid_rfc3339?(cells[3])
    error("approved reviewer must sign payload manifest digest") unless cells[4] == payload_digest
    error("approved reviewer decision must be PASS") unless cells[5] == "PASS"
    error("approved reviewer rationale must be nonempty and non-PENDING") if cells[6].to_s.empty? || cells[6] == "PENDING"
  end
  error("approved defect tuple must be 0 / 0 / 0") unless identity["Open critical/high/medium defects"] == "0 / 0 / 0"
  error("approved decision timestamp must be RFC 3339") unless valid_rfc3339?(identity["Decision timestamp/timezone"])

  protection = remote_protection_fields(identity["Remote tag-protection release check"])
  error("remote tag-protection release check is malformed or uses a placeholder operator") unless protection
  if protection && slug
    protection_uri = URI(protection[3]) rescue nil
    error("remote protection evidence must be an HTTPS URL under the same github.com repository") unless
      protection_uri.is_a?(URI::HTTPS) && protection_uri.host == "github.com" && protection_uri.path.start_with?("/#{slug}/")
  end

  error("approved local ROM path must be ignored build/*.z64 regular non-symlink") unless
    rom_path&.start_with?("build/") && rom_path.end_with?(".z64") && regular_without_symlink?(rom_path)
  local_rom_identity = nil
  if rom_path && regular_without_symlink?(rom_path)
    local_bytes = File.binread(ROOT.join(rom_path))
    local_rom_identity = rom_identity(local_bytes, "local ROM")
    error("local ROM size/SHA/header mismatch") unless local_rom_identity == { digest: rom_digest, size: rom_size, header_digest: rom_header_digest }
    _ignored_out, _ignored_err, ignored_status = git_capture("check-ignore", "-q", "--", rom_path)
    error("local ROM path is not ignored") unless ignored_status.success?
    _tracked_out, _tracked_err, tracked_status = git_capture("ls-files", "--error-unmatch", "--", rom_path)
    error("local ROM must be untracked") if tracked_status.success?
    _tree_rom_out, _tree_rom_err, tree_rom_status = git_capture("cat-file", "-e", "#{payload_commit}:#{rom_path}")
    error("ROM bytes/pointer must not exist in reviewed payload Git tree") if tree_rom_status.success?
  end

  recipe_path = identity["ROM build recipe path"]
  recipe_digest = identity["ROM build recipe SHA-256"]
  error("ROM build recipe identity malformed") unless recipe_path == "review/benchmark/ROM_BUILD_RECIPE.tsv" && recipe_digest&.match?(HEX64)
  recipe_rows = if fresh_clone && recipe_digest&.match?(HEX64)
                  parse_tsv("#{recipe_path}@#{recipe_digest}", "ROM build recipe", ROM_RECIPE_HEADER, 1,
                            commit: payload_commit, fresh_clone: fresh_clone, payload_context: payload_context)
                else
                  []
                end
  recipe = ROM_RECIPE_HEADER.zip(recipe_rows.first || []).to_h
  if recipe_rows.length == 1
    error("ROM recipe build/path/size/header mismatch") unless recipe["build_id"] == build_id && recipe["output_path"] == rom_path &&
      canonical_integer(recipe["rom_size_bytes"]) == rom_size && recipe["rom_header_sha256"] == rom_header_digest
    error("ROM recipe make target malformed") unless recipe["make_target"].match?(BUILD_ID)
  end

  workflow_path = identity["Public build workflow file"]
  workflow_run_id = identity["Public build workflow run ID"]
  error("public workflow path/run ID malformed") unless workflow_path&.match?(WORKFLOW_PATH) && canonical_integer(workflow_run_id)&.positive?
  if workflow_path&.match?(WORKFLOW_PATH) && fresh_clone
    error("public workflow must be a direct PAYLOAD_MANIFEST member") unless
      payload_context[:member_owner][workflow_path] == payload_path
    materialized_commit_file(workflow_path, payload_commit, "public build workflow", fresh_clone: fresh_clone, allow_lfs: false)
  end
  validate_sole_payload_workflow(payload_context, workflow_path, "approved benchmark payload")

  release_tag = identity["Public ROM release tag"]
  release_url = identity["Public ROM release asset URL"]
  expected_release_tag = payload_commit&.match?(HEX40) ? "n64game-benchmark-#{payload_commit}" : nil
  asset_name = payload_commit&.match?(HEX40) ? "n64game-#{payload_commit}.z64" : nil
  expected_release_url = slug && expected_release_tag ? "https://github.com/#{slug}/releases/download/#{expected_release_tag}/#{asset_name}" : nil
  error("public release tag/asset URL must derive exactly from payload commit and same repository") unless release_tag == expected_release_tag && release_url == expected_release_url
  if slug && release_tag == expected_release_tag
    release_ref = "refs/tags/#{release_tag}"
    release_remote_out, release_remote_err, release_remote_status = public_git_capture(
      slug, "ls-remote", "--tags", "https://github.com/#{slug}.git", release_ref, "#{release_ref}^{}"
    )
    release_remote_refs = release_remote_out.lines.to_h do |line|
      oid, ref = line.strip.split("\t", 2)
      [ref, oid]
    end
    public_release_target = release_remote_refs["#{release_ref}^{}"] || release_remote_refs[release_ref]
    error("public ROM release tag does not peel/resolve to exact payload commit: #{release_remote_err.lines.first.to_s.strip}") unless
      release_remote_status.success? && public_release_target == payload_commit
    if fresh_clone
      _release_fetch_out, release_fetch_err, release_fetch_status = public_git_capture(
        slug, "fetch", "--force", "https://github.com/#{slug}.git", "+#{release_ref}:#{release_ref}", root: fresh_clone
      )
      error("fresh public clone cannot fetch exact ROM release tag: #{release_fetch_err.lines.first.to_s.strip}") unless release_fetch_status.success?
      release_target_out, _release_target_err, release_target_status = git_capture(
        "rev-parse", "#{release_ref}^{commit}", root: fresh_clone
      )
      error("fresh public clone ROM release tag target differs from payload commit") unless
        release_target_status.success? && release_target_out.strip == payload_commit
    end
  end
  workflow_json = nil
  release_json = nil
  if slug && canonical_integer(workflow_run_id)&.positive?
    workflow_json = http_json("https://api.github.com/repos/#{slug}/actions/runs/#{workflow_run_id}", "public workflow run")
    if workflow_json
      error("public workflow run does not bind successful payload build") unless workflow_json["head_sha"] == payload_commit && workflow_json["conclusion"] == "success" && workflow_json["path"] == workflow_path
    end
  end
  if slug && release_tag == expected_release_tag
    release_json = http_json("https://api.github.com/repos/#{slug}/releases/tags/#{release_tag}", "public ROM release")
    if release_json
      error("public release identity/state mismatch") unless release_json["tag_name"] == release_tag && !release_json["draft"]
      asset = Array(release_json["assets"]).find { |candidate| candidate["name"] == asset_name }
      error("public release lacks exact derived ROM asset") unless asset
      if asset
        error("public release asset URL/size mismatch") unless asset["browser_download_url"] == release_url && asset["size"] == rom_size
        error("public release API digest mismatch") if asset["digest"] && asset["digest"] != "sha256:#{rom_digest}"
      end
    end
  end
  validate_shared_lifecycle_branch(
    "release",
    {
      "identity" => {
        "payload_commit" => payload_commit, "repository" => slug,
        "payload_manifest_sha256" => payload_digest, "registry_sha256" => registry_digest,
        "rom_sha256" => rom_digest, "rom_size_bytes" => rom_size,
        "approval_ref" => tag_ref, "release_tag" => release_tag,
        "artifact_name" => asset_name, "release_asset_url" => release_url,
        "workflow_path" => workflow_path
      },
      "workflow_json" => workflow_json, "release_json" => release_json
    },
    "shared production release lifecycle"
  )
  remote_rom_identity = download_identity(release_url, "public ROM release asset") if release_url == expected_release_url
  error("public ROM bytes differ from local identity") if remote_rom_identity && remote_rom_identity != local_rom_identity

  if fresh_clone && recipe_rows.length == 1 && recipe["make_target"]&.match?(BUILD_ID)
    _checkout_out, checkout_err, checkout_status = public_git_capture(slug, "checkout", "--detach", payload_commit, root: fresh_clone)
    error("fresh public clone checkout failed: #{checkout_err.lines.first.to_s.strip}") unless checkout_status.success?
    build_env = {
      "PATH" => ENV.fetch("PATH", "/usr/bin:/bin"), "LANG" => "C.UTF-8", "LC_ALL" => "C.UTF-8",
      "GIT_TERMINAL_PROMPT" => "0", "GIT_CONFIG_GLOBAL" => "/dev/null", "GIT_CONFIG_NOSYSTEM" => "1"
    }
    _make_out, make_err, make_status = Open3.capture3(
      build_env, "make", recipe["make_target"], chdir: fresh_clone, unsetenv_others: true
    )
    error("fresh public clone ROM build failed: #{make_err.lines.first.to_s.strip}") unless make_status.success?
    if make_status.success? && regular_without_symlink?(rom_path, root: fresh_clone)
      built_bytes = File.binread(Pathname.new(fresh_clone).join(rom_path))
      built_identity = rom_identity(built_bytes, "fresh public-clone ROM")
      error("fresh public clone ROM bytes differ from local/public identity") unless built_identity == local_rom_identity
    else
      error("fresh public clone build did not create exact regular ROM output")
    end
  end

  final_values = final_values_early
  error("final production decision mismatch") unless final_values["Production decision"] == "APPROVED"
  error("approved final return field must be NONE") unless final_values["Exact return gate and defect IDs if not approved"] == "NONE"
  error("final payload tuple does not match identity") unless final_values["Approving payload commit / clean-build ID / ROM SHA-256 tuple"].to_s == "#{payload_commit} / #{build_id} / #{rom_digest}"
  error("final payload-manifest digest mismatch") unless final_values["Payload-manifest SHA-256"] == payload_digest
  error("final whitelist registry digest mismatch") unless final_values["Whitelist/gate-registry SHA-256"] == registry_digest
  error("final evidence registry digest mismatch") unless final_values["Benchmark-evidence-registry SHA-256"] == evidence_registry_digest
  error("final public release tuple mismatch") unless final_values["Public release tag / asset URL"] == "#{release_tag} / #{release_url}"
  error("final attestation tuple mismatch") unless final_values["Approval attestation ref / signer fingerprint"].to_s == "#{tag_ref} / #{signer}"
  decision_owner_time = final_values["Decision owner / RFC 3339 timestamp"].to_s
  decision_owner, decision_time = decision_owner_time.split(" / ", 2)
  error("final decision owner/time is missing, placeholder, malformed, or mismatched") unless
    canonical_identity?(decision_owner) && decision_time == identity["Decision timestamp/timezone"] &&
    valid_rfc3339?(decision_time)
end

validate_current_postapproval_production(
  ledger, inventory, move_pairs.map(&:first), historical_registry_rows: approved_registry_rows,
  historical_ledger_entries: approved_payload_ledger_entries,
  historical_inventory_body: approved_payload_inventory_text,
  historical_owned_paths: approved_owned_paths,
  historical_benchmark_owned_paths: approved_benchmark_owned_paths,
  historical_context: approved_payload_context, approval_control_target: approved_control_target,
  generated_transition: generated_transition
) if decision == "APPROVED"

[art, inventory, ledger, reviews, benchmark].each_with_index do |body, index|
  label = %w[ART_BIBLE ASSET_INVENTORY ASSET_LEDGER ASSET_REVIEW_TEMPLATES VISUAL_BENCHMARK_APPROVAL][index]
  error("#{label} omits immutable SHA-256 evidence-manifest rules") unless
    body.include?("EVIDENCE_MANIFEST.sha256") && body.include?("SHA-256")
end
error("inventory does not require reproducible runtime-generating sources with verified actual bytes") unless
  inventory.include?("Every runtime-generating source") && inventory.include?("ordinary reviewed Git blob") &&
  inventory.include?("credential-free fresh public clone") && inventory.include?("actual bytes materialize")
error("ledger provenance contract omits input rights") unless ledger.include?("Input rights / license evidence")
error("ledger provenance contract omits material transformations") unless ledger.include?("Transformations / material human edits")
error("ledger provenance contract omits output rights") unless ledger.include?("Output license")
error("art contract permits committed generated-build products or omits Gate-5 review snapshots") unless
  art.include?("no `build/` byte may be a public payload member") &&
  art.include?("immutable converted-output review snapshots")
error("inventory omits the ignored-build/review-snapshot separation") unless
  inventory.include?("generated runtime tree is ignored `build/generated/assets/` and is never committed") &&
  inventory.include?("Gate-5 review snapshots live under `review/<production-id>/g5/`")
error("ledger omits the ignored-build/review-snapshot separation") unless
  ledger.include?("Ignored `build/` products are reproducibly regenerated") &&
  ledger.include?("never committed, never a payload member")
error("Gate-5 template permits a committed build product") unless
  reviews.include?("never a committed build product")

# These local-only semantic snapshots harden schema/type/cross-binding behavior,
# but they never enter a benchmark payload and are never approval evidence.
# The separately pinned production-validator lifecycle harness exercises the
# shared live kernel; it still excludes and cannot replace the live adapters.
verify_local_lifecycle_semantic_snapshot_pin
verify_local_production_lifecycle_harness_pin if PRODUCTION_LIFECYCLE_HARNESS_IMPLEMENTED

# This runs on every validation so an unexercised production-unlock branch cannot
# silently become reachable; --self-test-hardening additionally prints its count.
run_hardening_self_test(data_schemas, verbose: ARGV.include?("--self-test-hardening"))

if ERRORS.empty?
  puts "Gate 2 asset-production contract validation passed."
  puts "Inventory locks 37 UI subjects (including the exact 12-icon controller atlas), 32 paired move presentations, 8 exact non-owning alias mappings, and 15 concept-status camera children."
  puts "Visual benchmark locks #{whitelist_ids.length} exact production exceptions with #{BENCHMARK_WHITELIST_COUNT} WB bindings and #{benchmark_evidence_ids.length} evidence records behind #{production_lock}/#{decision}; local manifest/control/signed-origin-tag checks fail closed, while remote-host tag protection remains an external release check."
  exit 0
end

warn "Gate 2 asset-production contract validation failed with #{ERRORS.length} error(s):"
ERRORS.each { |message| warn "- #{message}" }
exit 1
