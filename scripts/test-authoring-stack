#!/bin/sh
set -eu

if [ -L "$0" ]; then
  /bin/echo "authoring test entrypoint must not be invoked through a symlink" >&2
  exit 1
fi
SCRIPT_DIR="$(CDPATH= cd -- "$(/usr/bin/dirname -- "$0")" && /bin/pwd -P)"
ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && /bin/pwd -P)"
CDPATH= cd -- "$ROOT"
exec /usr/bin/python3 -I -B -m unittest discover -s test/authoring -p 'test_*.py' -v
